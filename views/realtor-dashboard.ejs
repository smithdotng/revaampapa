// Filter properties
function filterProperties() {
    const type = $('#propertyTypeFilter').val();
    const status = $('#propertyStatusFilter').val();
    const tier = $('#propertyTierFilter').val();
    const search = $('#propertySearch').val().toLowerCase();
    
    $('.property-card').each(function() {
        const card = $(this);
        const cardType = card.data('type');
        const cardStatus = card.data('status');
        const cardTier = card.data('tier');
        const title = card.find('h5 a').text().toLowerCase();
        
        let show = true;
        if (type && cardType !== type) show = false;
        if (status && cardStatus !== status) show = false;
        if (tier && cardTier !== tier) show = false;
        if (search && !title.includes(search)) show = false;
        
        card.toggle(show);
    });
}

// Delete property
function deleteProperty(id) {
    $('#deleteForm').attr('action', `/properties/${id}?_method=DELETE`);
    $('#deleteModal').modal('show');
}

// Mark property as completed
function markAsCompleted(id) {
    if (confirm('Mark this property as sold/rented? This will record the transaction.')) {
        $.post(`/properties/${id}/complete`, function(response) {
            if (response.success) {
                alert('Property marked as completed!');
                location.reload();
            }
        }).fail(function(xhr) {
            alert('Error: ' + (xhr.responseJSON?.error || 'Unknown error'));
        });
    }
}

// Upgrade tier
function upgradeTier(propertyId) {
    $.get(`/properties/${propertyId}/upgrade-options`, function(data) {
        let html = `
            <p>Select a tier to upgrade your property:</p>
            <div class="row">
        `;
        
        data.tiers.forEach(tier => {
            if (tier.name !== data.currentTier) {
                html += `
                    <div class="col-md-6">
                        <div class="card mb-3 ${tier.name === 'premium' ? 'border-warning' : 'border-info'}">
                            <div class="card-body">
                                <h5 class="card-title">
                                    ${tier.name === 'premium' ? '<i class="fas fa-crown text-warning"></i>' : '<i class="fas fa-star text-info"></i>'} 
                                    ${tier.name.charAt(0).toUpperCase() + tier.name.slice(1)}
                                </h5>
                                <p class="card-text">
                                    Upgrade Fee: <strong>₦${tier.upgradeFee.toLocaleString()}</strong><br>
                                    Your Commission: <strong>${tier.commissionSplit.promoter}%</strong>
                                </p>
                                <button class="btn btn-sm btn-${tier.name === 'premium' ? 'warning' : 'info'}" 
                                        onclick="processUpgrade('${propertyId}', '${tier.name}')">
                                    Upgrade to ${tier.name}
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            }
        });
        
        html += '</div>';
        $('#upgradeModalBody').html(html);
        $('#upgradeModal').modal('show');
    });
}

// Process upgrade
function processUpgrade(propertyId, newTier) {
    if (confirm(`Upgrade to ${newTier} tier? You will be redirected to payment.`)) {
        $.post(`/properties/${propertyId}/upgrade`, { newTier: newTier }, function(response) {
            if (response.paymentUrl) {
                window.location.href = response.paymentUrl;
            }
        }).fail(function(xhr) {
            alert('Error: ' + (xhr.responseJSON?.error || 'Unknown error'));
        });
    }
}

// Reply to inquiry
function replyToInquiry(id) {
    window.location.href = `/inquiries/${id}`;
}

// View inquiry details
function viewInquiry(id) {
    window.location.href = `/inquiries/${id}`;
}

// Initialize on page load
$(document).ready(function() {
    // Load data for active tabs
    loadInquiries();
    loadTransactions();
    loadEarnings();
    loadAnalytics();
    
    // Search on input
    $('#propertySearch').on('keyup', function(e) {
        if (e.key === 'Enter') {
            filterProperties();
        }
    });
    
    // Handle tab changes
    $('a[data-toggle="tab"]').on('shown.bs.tab', function(e) {
        const target = $(e.target).attr('href');
        
        if (target === '#inquiries') {
            loadInquiries();
        } else if (target === '#transactions') {
            loadTransactions();
        } else if (target === '#earnings') {
            loadEarnings();
        } else if (target === '#analytics') {
            loadAnalytics();
        }
    });
});
</script>

