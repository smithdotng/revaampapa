<!-- JavaScript -->
<script>
// Load inquiries
function loadInquiries() {
    $.get('/api/inquiries', function(data) {
        let html = '';
        if (data.length > 0) {
            data.forEach(inquiry => {
                html += `
                    <div class="inquiry-item p-3 border-bottom">
                        <div class="d-flex justify-content-between">
                            <h6>${inquiry.name}</h6>
                            <small class="text-muted">${new Date(inquiry.createdAt).toLocaleDateString()}</small>
                        </div>
                        <p>${inquiry.message}</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="badge badge-primary">${inquiry.propertyTitle}</span>
                                ${!inquiry.read ? '<span class="badge badge-warning">New</span>' : ''}
                            </div>
                            <button class="btn btn-sm btn-outline-primary" onclick="replyToInquiry('${inquiry._id}')">
                                <i class="fas fa-reply"></i> Reply
                            </button>
                        </div>
                    </div>
                `;
            });
        } else {
            html = '<p class="text-center py-4">No inquiries yet</p>';
        }
        $('#inquiriesList').html(html);
        $('#inquiryCount').text(data.filter(i => !i.read).length);
    });
}

// Load transactions
function loadTransactions() {
    $.get('/api/transactions', function(data) {
        let html = '';
        if (data.length > 0) {
            data.forEach(transaction => {
                html += `
                    <tr>
                        <td>${new Date(transaction.transactionDate).toLocaleDateString()}</td>
                        <td>${transaction.property?.title || 'N/A'}</td>
                        <td>${transaction.transactionType}</td>
                        <td>₦${transaction.amount.toLocaleString()}</td>
                        <td>₦${transaction.agencyFee.toLocaleString()}</td>
                        <td>₦${(transaction.commissionSplit?.promoter?.amount || 0).toLocaleString()}</td>
                        <td><span class="badge badge-success">Completed</span></td>
                        <td>
                            <a href="/transactions/${transaction._id}" class="btn btn-sm btn-info">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                `;
            });
        } else {
            html = '<tr><td colspan="8" class="text-center py-3">No transactions yet</td></tr>';
        }
        $('#transactionsList').html(html);
    });
}

// Load earnings data
function loadEarnings() {
    $.get('/api/earnings', function(data) {
        $('#totalEarned').text(data.totalEarned.toLocaleString());
        $('#monthlyEarned').text(data.monthlyEarned.toLocaleString());
        $('#pendingFees').text(data.pendingFees.toLocaleString());
        
        // Create earnings chart
        if (data.chartData) {
            createEarningsChart(data.chartData);
        }
    });
}

// Load analytics
function loadAnalytics() {
    $.get('/api/analytics', function(data) {
        $('#avgViewsPerProperty').text(data.avgViewsPerProperty);
        $('#inquiryConversion').text(data.inquiryConversion + '%');
        $('#avgDaysOnMarket').text(data.avgDaysOnMarket);
        $('#totalValue').text('₦' + data.totalValue.toLocaleString());
        
        // Create views chart
        createViewsChart(data.viewsOverTime);
        
        // Create tier chart
        createTierChart(data.tierDistribution);
        
        // Create property type chart
        createPropertyTypeChart(data.propertyTypeDistribution);
        
        // Load top properties
        let topHtml = '';
        data.topProperties.forEach(prop => {
            const performance = ((prop.inquiries / prop.views) * 100).toFixed(1);
            topHtml += `
                <tr>
                    <td>${prop.title.substring(0, 30)}...</td>
                    <td><span class="badge badge-${prop.tier === 'premium' ? 'warning' : (prop.tier === 'standard' ? 'info' : 'secondary')}">${prop.tier}</span></td>
                    <td>${prop.views}</td>
                    <td>${prop.inquiries}</td>
                    <td>${prop.favorites}</td>
                    <td>
                        <div class="progress">
                            <div class="progress-bar bg-success" style="width: ${performance}%">
                                ${performance}%
                            </div>
                        </div>
                    </td>
                </tr>
            `;
        });
        $('#topPropertiesList').html(topHtml);
    });
}

// Create earnings chart
