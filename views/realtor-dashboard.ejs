<%- include('partials/header') %>

<% 
// Ensure stats object exists with default values
if (typeof stats === 'undefined') { 
    var stats = { 
        totalProperties: 0, 
        totalViews: 0, 
        totalFavorites: 0, 
        totalInquiries: 0,
        pendingFees: 0,
        activeTiers: {
            free: 0,
            standard: 0,
            premium: 0
        }
    }; 
} 

// Ensure properties exists
if (typeof properties === 'undefined') { 
    var properties = []; 
} 

// Ensure recentInquiries exists
if (typeof recentInquiries === 'undefined') { 
    var recentInquiries = []; 
} 

// Ensure pendingListingFees exists
if (typeof pendingListingFees === 'undefined') { 
    var pendingListingFees = []; 
}

// Helper function to get tier badge HTML
function getTierBadge(tier) {
    if (tier === 'premium') {
        return '<span class="badge badge-warning"><i class="fas fa-crown"></i> Premium</span>';
    } else if (tier === 'standard') {
        return '<span class="badge badge-info"><i class="fas fa-star"></i> Featured</span>';
    } else {
        return '<span class="badge badge-secondary">Free</span>';
    }
}

// Helper function to get status badge class
function getStatusBadgeClass(status) {
    switch(status) {
        case 'available': return 'success';
        case 'pending': return 'warning';
        case 'sold': return 'secondary';
        case 'rented': return 'info';
        default: return 'primary';
    }
}

// Helper function to format price in millions
function formatPriceInMillions(price) {
    return '₦' + (price / 1000000).toFixed(1) + 'M';
}

// Debug log
console.log('Properties count:', properties ? properties.length : 0);
%>

<!-- Page Top -->
<section>
    <div class="w-100 pt-180 pb-110 black-layer opc45 position-relative">
        <div class="fixed-bg" style="background-image: url(/assets/images/pg-tp-bg.jpg);"></div>
        <div class="container">
            <div class="pg-tp-wrp text-center w-100">
                <h1 class="mb-0">Realtor Dashboard</h1>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/" title="Home">Home</a></li>
                    <li class="breadcrumb-item active">Dashboard</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<!-- Dashboard Section -->
<section>
    <div class="w-100 gray-bg position-relative">
        <div class="container">
            <div class="row">
                <!-- Sidebar -->
                <div class="col-md-3">
                    <div class="dashboard-sidebar">
                        <div class="realtor-profile text-center">
                            <div class="profile-image-wrapper">
                                <img src="<%= user.profileImage ? '/uploads/profiles/' + user.profileImage : '/assets/images/default-avatar.jpg' %>" 
                                     alt="<%= user.name %>" 
                                     class="rounded-circle img-fluid profile-image">
                                <button class="change-photo-btn" onclick="document.getElementById('profileImageInput').click();">
                                    <i class="fas fa-camera"></i>
                                </button>
                                <form id="profileImageForm" action="/dashboard/update-profile-image" method="POST" enctype="multipart/form-data" style="display: none;">
                                    <input type="file" id="profileImageInput" name="profileImage" accept="image/*" onchange="this.form.submit();">
                                </form>
                            </div>
                            <h4 class="mt-3"><%= user.name %></h4>
                            <p class="text-muted">
                                <i class="fas fa-building"></i> <%= user.realtorProfile?.company || 'Independent Realtor' %>
                            </p>
                            <% if (user.realtorProfile?.verified) { %>
                                <span class="badge badge-success p-2">
                                    <i class="fas fa-check-circle"></i> Verified Realtor
                                </span>
                            <% } else { %>
                                <span class="badge badge-warning p-2">
                                    <i class="fas fa-clock"></i> Pending Verification
                                </span>
                            <% } %>
                            <p class="mt-3">
                                <i class="fas fa-calendar-alt"></i> Member since <%= new Date(user.createdAt).toLocaleDateString() %>
                            </p>
                        </div>
                        
                        <div class="sidebar-menu">
                            <ul class="nav nav-pills flex-column">
                                <li class="nav-item">
                                    <a class="nav-link active" href="#dashboard" data-toggle="tab">
                                        <i class="fas fa-tachometer-alt"></i> Dashboard
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#properties" data-toggle="tab">
                                        <i class="fas fa-building"></i> My Properties
                                        <span class="badge badge-primary float-right"><%= properties ? properties.length : 0 %></span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#add-property" data-toggle="tab">
                                        <i class="fas fa-plus-circle"></i> Add New Property
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#inquiries" data-toggle="tab">
                                        <i class="fas fa-envelope"></i> Inquiries
                                        <span class="badge badge-danger float-right" id="inquiryCount">0</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#transactions" data-toggle="tab">
                                        <i class="fas fa-credit-card"></i> Transactions
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#earnings" data-toggle="tab">
                                        <i class="fas fa-money-bill-wave"></i> Earnings
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#analytics" data-toggle="tab">
                                        <i class="fas fa-chart-line"></i> Analytics
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="#settings" data-toggle="tab">
                                        <i class="fas fa-cog"></i> Settings
                                    </a>
                                </li>
                            </ul>
                        </div>
                        
                        <div class="sidebar-footer mt-4">
                            <a href="/logout" class="btn btn-outline-danger btn-block">
                                <i class="fas fa-sign-out-alt"></i> Logout
                            </a>
                        </div>
                    </div>
                </div>
                
                <!-- Main Content -->
                <div class="col-md-9">
                    <div class="dashboard-content">
                        <div class="tab-content">
                            <!-- Dashboard Tab -->
                            <div class="tab-pane active" id="dashboard">
                                <div class="content-header">
                                    <h2>Welcome back, <%= user.name %>!</h2>
                                    <p>Here's what's happening with your properties today.</p>
                                </div>
                                
                                <!-- Stats Cards -->
                                <div class="row">
                                    <div class="col-md-3">
                                        <div class="stat-card">
                                            <div class="stat-icon">
                                                <i class="fas fa-building"></i>
                                            </div>
                                            <div class="stat-details">
                                                <h3><%= stats.totalProperties %></h3>
                                                <p>Total Properties</p>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-3">
                                        <div class="stat-card">
                                            <div class="stat-icon">
                                                <i class="fas fa-eye"></i>
                                            </div>
                                            <div class="stat-details">
                                                <h3><%= stats.totalViews %></h3>
                                                <p>Total Views</p>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-3">
                                        <div class="stat-card">
                                            <div class="stat-icon">
                                                <i class="fas fa-heart"></i>
                                            </div>
                                            <div class="stat-details">
                                                <h3><%= stats.totalFavorites %></h3>
                                                <p>Favorites</p>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-3">
                                        <div class="stat-card">
                                            <div class="stat-icon">
                                                <i class="fas fa-envelope"></i>
                                            </div>
                                            <div class="stat-details">
                                                <h3><%= stats.totalInquiries %></h3>
                                                <p>Inquiries</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Tier Stats -->
                                <div class="row mt-3">
                                    <div class="col-md-4">
                                        <div class="tier-stats-card free">
                                            <h6>Free Listings</h6>
                                            <h3><%= stats.activeTiers.free %></h3>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="tier-stats-card standard">
                                            <h6>Featured Listings</h6>
                                            <h3><%= stats.activeTiers.standard %></h3>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="tier-stats-card premium">
                                            <h6>Premium Listings</h6>
                                            <h3><%= stats.activeTiers.premium %></h3>
                                        </div>
                                    </div>
                                </div>

                                <!-- Pending Fees Alert -->
                                <% if (stats.pendingFees > 0) { %>
                                    <div class="alert alert-warning mt-3">
                                        <i class="fas fa-exclamation-triangle"></i>
                                        You have <strong>₦<%= stats.pendingFees.toLocaleString() %></strong> in pending listing fees. 
                                        <a href="#properties" class="alert-link" onclick="$('#properties-tab').tab('show')">Complete payment</a> to activate your listings.
                                    </div>
                                <% } %>
                                
                                <!-- Recent Properties -->
                                <div class="card mt-4">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <h5 class="mb-0">Recent Properties</h5>
                                        <a href="#properties" class="btn btn-sm btn-primary" onclick="$('#properties-tab').tab('show')">View All</a>
                                    </div>
                                    <div class="card-body">
                                        <div class="table-responsive">
                                            <table class="table table-hover">
                                                <thead>
                                                    <tr>
                                                        <th>Property</th>
                                                        <th>Type</th>
                                                        <th>Tier</th>
                                                        <th>Price</th>
                                                        <th>Status</th>
                                                        <th>Views</th>
                                                        <th>Actions</th>
                                                     </thead>
                                                <tbody>
                                                    <% if (properties && properties.length > 0) { %>
                                                        <% properties.slice(0, 5).forEach(property => { %>
                                                            <tr>
                                                                <td>
                                                                    <img src="<%= property.images && property.images[0] ? property.images[0].url : '/assets/images/default-property.jpg' %>" 
                                                                         alt="<%= property.title %>" 
                                                                         style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px;">
                                                                    <span class="ml-2"><%= property.title.substring(0, 30) %>...</span>
                                                                </td>
                                                                <td><%= property.propertyType %></td>
                                                                <td>
                                                                    <%- getTierBadge(property.listingTier) %>
                                                                </td>
                                                                <td>₦<%= property.price.toLocaleString() %></td>
                                                                <td>
                                                                    <span class="badge badge-<%= getStatusBadgeClass(property.status) %>">
                                                                        <%= property.status %>
                                                                    </span>
                                                                </td>
                                                                <td><%= property.views || 0 %></td>
                                                                <td>
                                                                    <a href="/properties/<%= property.slug %>" class="btn btn-sm btn-info" title="View">
                                                                        <i class="fas fa-eye"></i>
                                                                    </a>
                                                                    <a href="/properties/<%= property._id %>/edit" class="btn btn-sm btn-warning" title="Edit">
                                                                        <i class="fas fa-edit"></i>
                                                                    </a>
                                                                    <button class="btn btn-sm btn-danger" onclick="deleteProperty('<%= property._id %>')" title="Delete">
                                                                        <i class="fas fa-trash"></i>
                                                                    </button>
                                                                </td>
                                                            </tr>
                                                        <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="7" class="text-center">No properties found. <a href="#add-property">Add your first property</a></td>
                                                        </tr>
                                                    <% } %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Recent Inquiries -->
                                <div class="card mt-4">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <h5 class="mb-0">Recent Inquiries</h5>
                                        <a href="#inquiries" class="btn btn-sm btn-primary" onclick="$('#inquiries-tab').tab('show')">View All</a>
                                    </div>
                                    <div class="card-body">
                                        <div class="inquiry-list">
                                            <% if (recentInquiries && recentInquiries.length > 0) { %>
                                                <% recentInquiries.forEach(inquiry => { %>
                                                    <div class="inquiry-item d-flex align-items-start p-3 border-bottom">
                                                        <div class="inquiry-avatar mr-3">
                                                            <div class="avatar-circle">
                                                                <%= inquiry.name.charAt(0).toUpperCase() %>
                                                            </div>
                                                        </div>
                                                        <div class="inquiry-content flex-grow-1">
                                                            <div class="d-flex justify-content-between">
                                                                <h6 class="mb-1"><%= inquiry.name %></h6>
                                                                <small class="text-muted"><%= new Date(inquiry.createdAt).toLocaleDateString() %></small>
                                                            </div>
                                                            <p class="mb-1"><%= inquiry.message.substring(0, 100) %>...</p>
                                                            <small class="text-muted">
                                                                <i class="fas fa-phone"></i> <%= inquiry.phone %> | 
                                                                <i class="fas fa-envelope"></i> <%= inquiry.email %>
                                                            </small>
                                                            <div class="mt-2">
                                                                <span class="badge badge-primary"><%= inquiry.propertyTitle %></span>
                                                                <% if (!inquiry.read) { %>
                                                                    <span class="badge badge-warning">New</span>
                                                                <% } %>
                                                            </div>
                                                        </div>
                                                        <div class="inquiry-actions">
                                                            <button class="btn btn-sm btn-outline-primary" onclick="viewInquiry('<%= inquiry._id %>')">
                                                                <i class="fas fa-reply"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                <% }); %>
                                            <% } else { %>
                                                <p class="text-center py-4">No inquiries yet</p>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Properties Tab -->
                            <div class="tab-pane" id="properties">
                                <div class="content-header d-flex justify-content-between align-items-center">
                                    <h2>My Properties</h2>
                                    <a href="#add-property" class="thm-btn" onclick="$('#add-property-tab').tab('show')">
                                        <i class="fas fa-plus"></i> Add New Property
                                    </a>
                                </div>
                                
                                <!-- Filter Bar -->
                                <div class="filter-bar bg-white p-3 rounded mb-4">
                                    <div class="row">
                                        <div class="col-md-2">
                                            <select class="form-control" id="propertyTypeFilter">
                                                <option value="">All Types</option>
                                                <option value="shortlet">Shortlet</option>
                                                <option value="land">Land</option>
                                                <option value="building">Building</option>
                                                <option value="shop">Shop</option>
                                                <option value="business_complex">Business Complex</option>
                                            </select>
                                        </div>
                                        <div class="col-md-2">
                                            <select class="form-control" id="propertyStatusFilter">
                                                <option value="">All Status</option>
                                                <option value="available">Available</option>
                                                <option value="pending">Pending</option>
                                                <option value="sold">Sold</option>
                                                <option value="rented">Rented</option>
                                            </select>
                                        </div>
                                        <div class="col-md-2">
                                            <select class="form-control" id="propertyTierFilter">
                                                <option value="">All Tiers</option>
                                                <option value="free">Free</option>
                                                <option value="standard">Featured</option>
                                                <option value="premium">Premium</option>
                                            </select>
                                        </div>
                                        <div class="col-md-4">
                                            <input type="text" class="form-control" id="propertySearch" placeholder="Search properties...">
                                        </div>
                                        <div class="col-md-2">
                                            <button class="btn btn-primary btn-block" onclick="filterProperties()">
                                                <i class="fas fa-filter"></i> Filter
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Pending Fees Section -->
                                <% if (pendingListingFees && pendingListingFees.length > 0) { %>
                                    <div class="pending-fees-section mb-4">
                                        <h5>Pending Listing Fees</h5>
                                        <div class="row">
                                            <% pendingListingFees.forEach(fee => { %>
                                                <div class="col-md-6">
                                                    <div class="card mb-3 border-warning">
                                                        <div class="card-body">
                                                            <div class="d-flex justify-content-between">
                                                                <h6><%= fee.property.title.substring(0, 40) %>...</h6>
                                                                <span class="badge badge-warning">Pending</span>
                                                            </div>
                                                            <p class="mb-1">Tier: <strong><%= fee.tier %></strong></p>
                                                            <p class="mb-1">Fee: <strong>₦<%= fee.feeAmount.toLocaleString() %></strong></p>
                                                            <p class="mb-2">Your commission: <strong><%= fee.commissionSplit.promoter %>%</strong></p>
                                                            <a href="/properties/pay-listing-fee/<%= fee.property._id %>?tier=<%= fee.tier %>" class="btn btn-sm btn-warning">
                                                                <i class="fas fa-credit-card"></i> Pay Now
                                                            </a>
                                                        </div>
                                                    </div>
                                                </div>
                                            <% }); %>
                                        </div>
                                    </div>
                                <% } %>
                                
                                <!-- Properties Grid -->
                                <div class="properties-grid">
                                    <div class="row" id="propertiesContainer">
                                        <% if (properties && properties.length > 0) { %>
                                            <% properties.forEach(property => { %>
                                                <div class="col-md-6 col-lg-4 property-card mb-4" 
                                                     data-type="<%= property.propertyType %>" 
                                                     data-status="<%= property.status %>"
                                                     data-tier="<%= property.listingTier || 'free' %>">
                                                    <div class="list-post-box v2 brd-rd5 overflow-hidden position-relative w-100">
                                                        <div class="list-post-img overflow-hidden position-relative w-100" style="height: 180px;">
                                                            <img class="img-fluid w-100" style="height: 100%; object-fit: cover;" src="<%= property.images && property.images[0] ? property.images[0].url : '/assets/images/default-property.jpg' %>" 
                                                                 alt="<%= property.title %>">
                                                            <span class="list-post-cat2 position-absolute">
                                                                <a class="rounded-pill" href="javascript:void(0);"><%= property.propertyType %></a>
                                                            </span>
                                                            <% if (property.listingTier === 'premium') { %>
                                                                <span class="premium-badge position-absolute">
                                                                    <i class="fas fa-crown"></i> Premium
                                                                </span>
                                                            <% } else if (property.listingTier === 'standard') { %>
                                                                <span class="featured-badge position-absolute">
                                                                    <i class="fas fa-star"></i> Featured
                                                                </span>
                                                            <% } %>
                                                        </div>
                                                        
                                                        <div class="list-post-info w-100 p-3">
                                                            <div class="list-post-inner w-100">
                                                                <div class="list-post-info-top d-flex flex-wrap justify-content-between mb-2">
                                                                    <span class="list-post-date small text-muted">
                                                                        <i class="thm-clr far fa-clock"></i>
                                                                        <%= new Date(property.createdAt).toLocaleDateString() %>
                                                                    </span>
                                                                    <span class="list-post-rate">
                                                                        <span class="badge badge-<%= property.status === 'available' ? 'success' : (property.status === 'pending' ? 'warning' : 'secondary') %>">
                                                                            <%= property.status %>
                                                                        </span>
                                                                    </span>
                                                                </div>
                                                                
                                                                <h5 class="mb-2">
                                                                    <a href="/properties/<%= property.slug %>" title="">
                                                                        <%= property.title.length > 40 ? property.title.substring(0, 40) + '...' : property.title %>
                                                                    </a>
                                                                </h5>
                                                                
                                                                <div class="list-post-author-stats d-flex flex-wrap justify-content-between align-items-center mb-2">
                                                                    <div class="list-post-author d-inline-flex align-items-center">
                                                                        <span class="small text-muted"><%= property.transactionType %></span>
                                                                    </div>
                                                                    <span class="text-success font-weight-bold">₦<%= (property.price/1000000).toFixed(1) %>M</span>
                                                                </div>
                                                            </div>
                                                            
                                                            <ul class="list-post-meta mb-2 list-unstyled small">
                                                                <li class="active d-inline-block mr-3">
                                                                    <i class="thm-clr fas fa-map-marker-alt"></i>
                                                                    <span><%= property.location.city %>, <%= property.location.state %></span>
                                                                </li>
                                                                <% if (property.features && property.features.bedrooms) { %>
                                                                    <li class="d-inline-block">
                                                                        <i class="thm-clr fas fa-bed"></i>
                                                                        <span><%= property.features.bedrooms %> Beds</span>
                                                                    </li>
                                                                <% } %>
                                                            </ul>
                                                            
                                                            <div class="property-actions mt-2">
                                                                <a href="/properties/<%= property._id %>/edit" class="btn btn-sm btn-warning">
                                                                    <i class="fas fa-edit"></i> Edit
                                                                </a>
                                                                <button class="btn btn-sm btn-danger" onclick="deleteProperty('<%= property._id %>')">
                                                                    <i class="fas fa-trash"></i> Delete
                                                                </button>
                                                                <% if (property.status === 'available') { %>
                                                                    <button class="btn btn-sm btn-success" onclick="markAsCompleted('<%= property._id %>')">
                                                                        <i class="fas fa-check"></i> Mark <%= property.transactionType === 'sale' ? 'Sold' : 'Rented' %>
                                                                    </button>
                                                                <% } %>
                                                                <% if (property.listingTier === 'free') { %>
                                                                    <button class="btn btn-sm btn-info" onclick="upgradeTier('<%= property._id %>')">
                                                                        <i class="fas fa-arrow-up"></i> Upgrade
                                                                    </button>
                                                                <% } %>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            <% }); %>
                                        <% } else { %>
                                            <div class="col-12 text-center py-5">
                                                <i class="fas fa-building fa-4x text-muted mb-3"></i>
                                                <h4>No properties yet</h4>
                                                <p>Start by adding your first property listing</p>
                                                <a href="#add-property" class="thm-btn" onclick="$('#add-property-tab').tab('show')">
                                                    <i class="fas fa-plus"></i> Add Property
                                                </a>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                                
                                <!-- Pagination -->
                                <% if (totalPages > 1) { %>
                                    <div class="pagination-wrap text-center mt-4">
                                        <ul class="pagination justify-content-center">
                                            <% for (let i = 1; i <= totalPages; i++) { %>
                                                <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                                    <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                                                </li>
                                            <% } %>
                                        </ul>
                                    </div>
                                <% } %>
                            </div>
                            
                            <!-- Add Property Tab -->
                            <div class="tab-pane" id="add-property">
                                <div class="content-header">
                                    <h2>Add New Property</h2>
                                    <p>Fill in the details below to list your property</p>
                                </div>
                                
                                <%- include('partials/property-form', { property: null, listingTiers: listingTiers }) %>
                            </div>
                            
                            <!-- Inquiries Tab -->
                            <div class="tab-pane" id="inquiries">
                                <div class="content-header">
                                    <h2>Property Inquiries</h2>
                                    <p>Manage messages from potential buyers and tenants</p>
                                </div>
                                
                                <div class="inbox-container">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="inbox-sidebar bg-white rounded p-3">
                                                <div class="inbox-search mb-3">
                                                    <input type="text" class="form-control" placeholder="Search inquiries...">
                                                </div>
                                                <div class="inbox-filters mb-3">
                                                    <h6>Filter by</h6>
                                                    <select class="form-control mb-2" id="inquiryPropertyFilter">
                                                        <option value="">All Properties</option>
                                                        <% if (properties && properties.length > 0) { %>
