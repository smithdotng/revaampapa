<!DOCTYPE html>
<html lang="en-US">

<head>
    <title><%= title %></title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="author" content="RevaampAP" />
    <meta name="description" content="Promoter Dashboard - Track your earnings, manage promotions, referrals, and grow your business" />

    <!-- switzer font css -->
    <link rel="stylesheet" href="/fonts/css/switzer.css" type="text/css" media="all">
    <!-- font awesome css -->
    <link rel="stylesheet" href="/fonts/css/font-awesome.min.css" type="text/css" media="all">
    <!-- bootstrap grid css -->
    <link rel="stylesheet" href="/css/plugins/bootstrap-grid.css" type="text/css" media="all">
    <!-- swiper css -->
    <link rel="stylesheet" href="/css/plugins/swiper.min.css" type="text/css" media="all">
    <!-- magnific popup -->
    <link rel="stylesheet" href="/css/plugins/magnific-popup.css" type="text/css" media="all">
    <!-- plax css -->
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <!-- custom css -->
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- Favicon -->
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>

<body>

    <!-- wrapper -->
    <div id="smooth-wrapper" class="mil-wrapper">

        <!-- preloader -->
        <div class="mil-preloader">
            <div class="mil-load"></div>
            <p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p>
        </div>
        <!-- preloader end -->

        <!-- scroll progress -->
        <div class="mil-progress-track">
            <div class="mil-progress"></div>
        </div>
        <!-- scroll progress end -->

        <!-- back to top -->
        <div class="progress-wrap active-progress"></div>

        <!-- top panel -->
        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo">
                    <img src="/img/logo.png" alt="RevaampAP" width="83" height="32">
                </a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/properties">Properties</a></li>
                        <li class="mil-active"><a href="/promoter/dashboard">Dashboard</a></li>
                        <li><a href="/promoter/earnings">Earnings</a></li>
                        <li><a href="/promoter/analytics">Analytics</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <div class="dropdown" style="position: relative;">
                        <a href="#" class="mil-btn mil-sm dropdown-toggle" data-bs-toggle="dropdown" style="display: flex; align-items: center; gap: 8px;">
                            <i class="fa fa-user-circle" style="font-size: 18px;"></i> 
                            <span><%= user.name %></span>
                            <i class="fa fa-chevron-down" style="font-size: 12px;"></i>
                        </a>
                        <ul class="dropdown-menu" style="position: absolute; right: 0; top: 100%; min-width: 220px; background: white; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.15); padding: 10px 0; margin-top: 10px; z-index: 1000;">
                            <li><a href="/promoter/dashboard"><i class="fa fa-tachometer"></i> Dashboard</a></li>
                            <li><a href="/promoter/earnings"><i class="fa fa-money"></i> Earnings</a></li>
                            <li><a href="/promoter/analytics"><i class="fa fa-chart-line"></i> Analytics</a></li>
                            <li><a href="/promoter/settings"><i class="fa fa-cog"></i> Settings</a></li>
                            <li><hr></li>
                            <li><a href="/logout"><i class="fa fa-sign-out-alt"></i> Logout</a></li>
                        </ul>
                    </div>
                    <div class="mil-menu-btn">
                        <span></span>
                    </div>
                </div>
            </div>
        </div>
        <!-- top panel end -->

        <!-- content -->
        <div id="smooth-content">

            <!-- banner -->
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-text-m mil-mb-20 mil-up">Welcome back, <%= user.name %>!</div>
                                <h1 class="mil-mb-60 mil-up">Promoter Dashboard</h1>
                                <ul class="mil-breadcrumbs mil-pub-info mil-center mil-up">
                                    <li><a href="/">Home</a></li>
                                    <li><a href="/promoter/dashboard">Dashboard</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- banner end -->

            <!-- Stats Cards -->
            <div class="mil-blog-list mil-p-0-80">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <div class="mil-icon-box mil-mb-15">
                                    <i class="fa fa-eye" style="font-size: 40px; color: #03A6A6;"></i>
                                </div>
                                <h4 class="mil-mb-15"><span class="mil-pricing-table-price"><%= stats.totalClicks || 0 %></span></h4>
                                <p class="mil-text-s mil-soft">Total Clicks</p>
                            </div>
                        </div>
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <div class="mil-icon-box mil-mb-15">
                                    <i class="fa fa-users" style="font-size: 40px; color: #03A6A6;"></i>
                                </div>
                                <h4 class="mil-mb-15"><span class="mil-pricing-table-price"><%= stats.totalInterests || 0 %></span></h4>
                                <p class="mil-text-s mil-soft">Buyer Interests</p>
                            </div>
                        </div>
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <div class="mil-icon-box mil-mb-15">
                                    <i class="fa fa-shopping-cart" style="font-size: 40px; color: #03A6A6;"></i>
                                </div>
                                <h4 class="mil-mb-15"><span class="mil-pricing-table-price"><%= stats.totalTransactions || 0 %></span></h4>
                                <p class="mil-text-s mil-soft">Successful Sales</p>
                            </div>
                        </div>
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <div class="mil-icon-box mil-mb-15">
                                    <i class="fa fa-money" style="font-size: 40px; color: #03A6A6;"></i>
                                </div>
                                <h4 class="mil-mb-15">₦<span class="mil-pricing-table-price"><%= (stats.totalEarnings || 0).toLocaleString() %></span></h4>
                                <p class="mil-text-s mil-soft">Total Earnings</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Stats Cards End -->

            <!-- Commission Structure Banner -->
            <div class="mil-cta mil-up">
                <div class="container">
                    <div class="mil-out-frame mil-p-80-80" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                        <div class="row justify-content-between align-items-center">
                            <div class="col-xl-12 mil-text-center">
                                <h2 class="mil-light mil-mb-30 mil-up">Your Commission Structure</h2>
                                <p class="mil-text-m mil-dark-soft mil-up">Earn up to 90% commission when you bring a buyer! 10% administrative fee applies.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Commission Structure Banner End -->

            <!-- All Properties Section - Promotable Properties -->
            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="mil-text-center">
                        <h2 class="mil-mb-30 mil-up">Properties Available for Promotion</h2>
                        <p class="mil-text-m mil-soft mil-mb-60 mil-up">Click "Promote" on any property to get your unique referral link. When someone clicks and expresses interest, you earn commission!</p>
                    </div>
                    <div class="row" id="propertiesGrid">
                        <% if (typeof properties !== 'undefined' && properties && properties.length > 0) { %>
                            <% properties.forEach(function(property) { %>
                                <div class="col-xl-4 col-md-6 mil-mb-30">
                                    <div class="mil-price-card mil-up" style="height: 100%;">
                                        <div class="property-image" style="position: relative; overflow: hidden; border-radius: 15px; margin-bottom: 20px;">
                                            <% if(property.images && property.images.length > 0) { %>
                                                <img src="<%= property.images[0].url %>" alt="<%= property.title %>" style="width: 100%; height: 220px; object-fit: cover;">
                                            <% } else { %>
                                                <img src="/img/property-placeholder.jpg" alt="<%= property.title %>" style="width: 100%; height: 220px; object-fit: cover;">
                                            <% } %>
                                            <div class="property-badges" style="position: absolute; top: 10px; left: 10px;">
                                                <span class="mil-badge" style="background: #28a745; color: white; padding: 4px 10px; border-radius: 5px; font-size: 11px;">✓ Verified</span>
                                            </div>
                                        </div>
                                        <div class="property-content">
                                            <div class="mil-flex-between mil-mb-10">
                                                <h5 class="property-price" style="color: #03A6A6;">₦<%= property.price ? property.price.toLocaleString() : '0' %></h5>
                                                <span class="mil-text-xs mil-soft"><%= property.transactionType === 'sale' ? 'For Sale' : 'For Rent' %></span>
                                            </div>
                                            <h4 class="property-title mil-mb-10"><%= property.title %></h4>
                                            <p class="mil-text-s mil-soft mil-mb-15"><i class="fa fa-map-marker"></i> <%= property.location ? property.location.city + ', ' + property.location.state : 'Location TBD' %></p>
                                            <div class="property-features mil-flex-between mil-mb-20">
                                                <div class="feature-item"><i class="fa fa-bed"></i> <span><%= property.features && property.features.bedrooms ? property.features.bedrooms : '0' %> beds</span></div>
                                                <div class="feature-item"><i class="fa fa-bath"></i> <span><%= property.features && property.features.bathrooms ? property.features.bathrooms : '0' %> baths</span></div>
                                                <div class="feature-item"><i class="fa fa-car"></i> <span><%= property.features && property.features.parkingSpaces ? property.features.parkingSpaces : '0' %> parking</span></div>
                                            </div>
                                            <div class="property-footer">
                                                <button class="mil-btn mil-sm mil-accent promote-btn" data-property-id="<%= property._id %>" data-property-title="<%= property.title %>">
                                                    <i class="fa fa-bullhorn"></i> Promote & Get Link
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="col-xl-12">
                                <div class="mil-price-card mil-up mil-text-center" style="padding: 60px 20px;">
                                    <i class="fa fa-building-o" style="font-size: 60px; opacity: 0.3; margin-bottom: 20px;"></i>
                                    <h3 class="mil-mb-15">No Properties Available</h3>
                                    <p class="mil-text-m mil-soft mil-mb-30">Check back soon for new properties to promote!</p>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
            <!-- All Properties End -->

            <!-- Your Active Promotions Section -->
            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="mil-text-center">
                        <h2 class="mil-mb-30 mil-up">Your Active Promotions</h2>
                        <p class="mil-text-m mil-soft mil-mb-60 mil-up">Track your referral links and buyer interests</p>
                    </div>
                    <div class="row">
                        <div class="col-xl-12">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <div id="promotionsList">
                                    <div class="text-center py-5">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">Loading...</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Active Promotions End -->

            <!-- Buyer Interest Submissions Section -->
            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="mil-text-center">
                        <h2 class="mil-mb-30 mil-up">Recent Buyer Interests</h2>
                        <p class="mil-text-m mil-soft mil-mb-60 mil-up">Buyers who expressed interest through your links</p>
                    </div>
                    <div class="row">
                        <div class="col-xl-12">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <div class="mil-table-responsive">
                                    <table class="mil-table" style="width: 100%; border-collapse: collapse;">
                                        <thead>
                                            <tr style="border-bottom: 1px solid #eee;">
                                                <th style="padding: 12px; text-align: left;">Property</th>
                                                <th style="padding: 12px; text-align: left;">Buyer Name</th>
                                                <th style="padding: 12px; text-align: left;">Contact</th>
                                                <th style="padding: 12px; text-align: left;">Date</th>
                                                <th style="padding: 12px; text-align: left;">Status</th>
                                             </tr>
                                        </thead>
                                        <tbody id="interestsTableBody">
                                            <tr>
                                                <td colspan="5" class="text-center py-4">Loading interests...</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Buyer Interests End -->

            <!-- Your Referral Link Section -->
            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-price-card mil-up mil-mb-30 mil-featured" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                <div class="mil-text-center">
                                    <i class="fa fa-link" style="font-size: 50px; color: white; margin-bottom: 20px;"></i>
                                    <h3 class="mil-light mil-mb-15">Your Unique Referral Link</h3>
                                    <p class="mil-dark-soft mil-mb-30">Share this link to invite others to join as promoters, business partners, or sub-aggregators!</p>
                                    <div class="mil-referral-box" style="background: rgba(255,255,255,0.2); border-radius: 10px; padding: 15px; margin-bottom: 20px;">
                                        <code style="color: white; word-break: break-all;" id="referralLink">
                                            <%= typeof baseUrl !== 'undefined' ? baseUrl : 'http://localhost:3000' %>/promoter/register?ref=<%= user._id %>
                                        </code>
                                    </div>
                                    <button class="mil-btn mil-md mil-light" onclick="copyReferralLink()">
                                        <i class="fa fa-copy"></i> Copy Link
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Referral Link End -->

            <!-- Quick Actions -->
            <div class="mil-cta mil-up">
                <div class="container">
                    <div class="mil-out-frame mil-p-80-80" style="background: #f8f9fa;">
                        <div class="row justify-content-between align-items-center">
                            <div class="col-xl-12 mil-text-center">
                                <h2 class="mil-mb-30 mil-up">Quick Actions</h2>
                                <div class="mil-buttons-frame mil-up">
                                    <a href="/promoter/submit-property" class="mil-btn mil-sm">Submit Property</a>
                                    <a href="/promoter/submit-buyer" class="mil-btn mil-sm mil-light">Submit Buyer</a>
                                    <a href="/promoter/onboard-hotel" class="mil-btn mil-sm mil-light">Onboard Hotel</a>
                                    <a href="/promoter/earnings" class="mil-btn mil-sm mil-light">View Earnings</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Quick Actions End -->

            <!-- Tips Section -->
            <div class="mil-cta mil-up">
                <div class="container">
                    <div class="mil-out-frame mil-p-80-80" style="background: #f8f9fa;">
                        <div class="row justify-content-between align-items-center">
                            <div class="col-xl-12">
                                <h2 class="mil-mb-30 mil-up">Pro Tips for Maximizing Your Earnings</h2>
                                <div class="row">
                                    <div class="col-md-4 mil-mb-30">
                                        <div class="mil-text-center">
                                            <i class="fa fa-share-alt" style="font-size: 40px; color: #03A6A6; margin-bottom: 15px;"></i>
                                            <h5 class="mil-mb-15">Share on Multiple Platforms</h5>
                                            <p class="mil-text-s mil-soft">Share your property links on WhatsApp, Instagram, Facebook, Twitter, and LinkedIn</p>
                                        </div>
                                    </div>
                                    <div class="col-md-4 mil-mb-30">
                                        <div class="mil-text-center">
                                            <i class="fa fa-users" style="font-size: 40px; color: #03A6A6; margin-bottom: 15px;"></i>
                                            <h5 class="mil-mb-15">Build Your Referral Network</h5>
                                            <p class="mil-text-s mil-soft">Refer other promoters, business partners, and sub-aggregators for residual income</p>
                                        </div>
                                    </div>
                                    <div class="col-md-4 mil-mb-30">
                                        <div class="mil-text-center">
                                            <i class="fa fa-hotel" style="font-size: 40px; color: #03A6A6; margin-bottom: 15px;"></i>
                                            <h5 class="mil-mb-15">Onboard Hotels</h5>
                                            <p class="mil-text-s mil-soft">Partner with hotels to earn 30% commission on every booking</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Tips Section End -->

            <!-- footer -->
            <footer class="mil-p-80-0">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-3">
                            <a href="/" class="mil-footer-logo mil-mb-60">
                                <img src="/img/logo-2.png" alt="RevaampAP" width="28" height="32">
                            </a>
                        </div>
                        <div class="col-xl-3 mil-mb-60">
                            <h6 class="mil-mb-60">Quick Links</h6>
                            <ul class="mil-footer-list">
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/">Home</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/properties">Properties</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/promoter/dashboard">Dashboard</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/promoter/earnings">Earnings</a></li>
                            </ul>
                        </div>
                        <div class="col-xl-3 mil-mb-60">
                            <h6 class="mil-mb-60">Support</h6>
                            <ul class="mil-footer-list">
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/contact">Contact Us</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/faq">FAQ</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/how-it-works">How It Works</a></li>
                            </ul>
                        </div>
                        <div class="col-xl-3 mil-mb-80">
                            <h6 class="mil-mb-60">Newsletter</h6>
                            <p class="mil-text-xs mil-soft mil-mb-15">Get tips and updates for promoters</p>
                            <form class="mil-subscripe-form-footer" id="footerNewsletterForm">
                                <input class="mil-input" type="email" placeholder="Email">
                                <button type="submit"><i class="far fa-envelope-open mil-dark"></i></button>
                            </form>
                        </div>
                    </div>
                    <div class="mil-footer-bottom">
                        <div class="row">
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-soft">© 2024 RevaampAP. All rights reserved.</p>
                            </div>
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-text-right mil-sm-text-left mil-soft">Promoter Dashboard</p>
                            </div>
                        </div>
                    </div>
                </div>
            </footer>
            <!-- footer end -->

        </div>
        <!-- content end -->
    </div>
    <!-- wrapper end -->

    <!-- jquery js -->
    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/plugins/swiper.min.js"></script>
    <script src="/js/plugins/gsap.min.js"></script>
    <script src="/js/plugins/ScrollSmoother.min.js"></script>
    <script src="/js/plugins/ScrollTrigger.min.js"></script>
    <script src="/js/plugins/ScrollTo.min.js"></script>
    <script src="/js/plugins/magnific-popup.js"></script>
    <script src="/js/main.js"></script>

    <script>
        // Copy referral link
        function copyReferralLink() {
            const linkText = document.getElementById('referralLink').innerText;
            navigator.clipboard.writeText(linkText).then(function() {
                alert('Referral link copied to clipboard!');
            }, function() {
                alert('Failed to copy link. Please copy manually.');
            });
        }

        // Load promotions
        async function loadPromotions() {
            try {
                const response = await fetch('/promoter/api/promotions');
                const data = await response.json();
                const container = document.getElementById('promotionsList');
                
                if (data.success && data.promotions && data.promotions.length > 0) {
                    container.innerHTML = `
                        <div class="mil-table-responsive">
                            <table class="mil-table" style="width: 100%; border-collapse: collapse;">
                                <thead>
                                    <tr style="border-bottom: 1px solid #eee;">
                                        <th style="padding: 12px; text-align: left;">Property</th>
                                        <th style="padding: 12px; text-align: left;">Referral Link</th>
                                        <th style="padding: 12px; text-align: left;">Clicks</th>
                                        <th style="padding: 12px; text-align: left;">Interests</th>
                                        <th style="padding: 12px; text-align: left;">Created</th>
                                        <th style="padding: 12px; text-align: left;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${data.promotions.map(promo => `
                                        <tr style="border-bottom: 1px solid #f0f0f0;">
                                            <td style="padding: 12px;">${promo.property?.title || 'N/A'}</td>
                                            <td style="padding: 12px;">
                                                <code style="font-size: 11px; word-break: break-all;">${promo.referralLink}</code>
                                                <button class="mil-btn mil-xs" onclick="copyToClipboard('${promo.referralLink}')"><i class="fa fa-copy"></i></button>
                                            </td>
                                            <td style="padding: 12px;">${promo.clicks || 0}</td>
                                            <td style="padding: 12px;">${promo.inquiries || 0}</td>
                                            <td style="padding: 12px;">${new Date(promo.createdAt).toLocaleDateString()}</td>
                                            <td style="padding: 12px;">
                                                <button class="mil-btn mil-xs mil-accent" onclick="shareProperty('${promo.referralLink}', '${promo.property?.title}')">
                                                    <i class="fa fa-share-alt"></i> Share
                                                </button>
                                            </td>
                                        </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>
                    `;
                } else {
                    container.innerHTML = '<div class="text-center py-4"><p>No active promotions yet. Click "Promote" on any property to get started!</p></div>';
                }
            } catch (error) {
                console.error('Error loading promotions:', error);
                document.getElementById('promotionsList').innerHTML = '<div class="text-center py-4"><p>Error loading promotions. Please refresh.</p></div>';
            }
        }

        // Load buyer interests
        async function loadInterests() {
            try {
                const response = await fetch('/promoter/api/interests');
                const data = await response.json();
                const tbody = document.getElementById('interestsTableBody');
                
                if (data.success && data.interests && data.interests.length > 0) {
                    tbody.innerHTML = data.interests.map(interest => `
                        <tr style="border-bottom: 1px solid #f0f0f0;">
                            <td style="padding: 12px;">${interest.propertyTitle || 'N/A'}</td>
                            <td style="padding: 12px;">${interest.name}</td>
                            <td style="padding: 12px;">${interest.email}<br><small>${interest.phone || ''}</small></td>
                            <td style="padding: 12px;">${new Date(interest.createdAt).toLocaleDateString()}</td>
                            <td style="padding: 12px;">
                                ${interest.status === 'new' ? 
                                    '<span style="background: #28a745; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">New</span>' : 
                                    '<span style="background: #17a2b8; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Contacted</span>'
                                }
                            </td>
                        </tr>
                    `).join('');
                } else {
                    tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4">No buyer interests yet. Share your property links to get leads!</td></tr>';
                }
            } catch (error) {
                console.error('Error loading interests:', error);
                document.getElementById('interestsTableBody').innerHTML = '<tr><td colspan="5" class="text-center py-4">Error loading interests. Please refresh.</td></tr>';
            }
        }

        // Copy to clipboard
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(function() {
                alert('Link copied to clipboard!');
            });
        }

        // Share property
        function shareProperty(link, title) {
            if (navigator.share) {
                navigator.share({
                    title: title,
                    text: 'Check out this property on RevaampAP!',
                    url: link
                }).catch(console.error);
            } else {
                copyToClipboard(link);
                alert('Link copied! Share it on your social media.');
            }
        }

        // Create promotion for property
        async function createPromotion(propertyId, propertyTitle) {
            const btn = event.target.closest('.promote-btn');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Creating...';
            btn.disabled = true;
            
            try {
                const response = await fetch(`/promoter/api/promotion/${propertyId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                
                if (data.success) {
                    alert(`Promotion created for "${propertyTitle}"!\n\nShare this link: ${data.promotion.referralLink}\n\nWhen someone clicks and expresses interest, you'll earn commission!`);
                    loadPromotions(); // Refresh promotions list
                } else {
                    alert(data.message || 'Error creating promotion. Please try again.');
                }
            } catch (error) {
                console.error('Error creating promotion:', error);
                alert('Error creating promotion. Please try again.');
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        }

        // Attach promote button handlers
        document.querySelectorAll('.promote-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                const propertyId = this.getAttribute('data-property-id');
                const propertyTitle = this.getAttribute('data-property-title');
                createPromotion(propertyId, propertyTitle);
            });
        });

        // Newsletter subscription
        function initNewsletter() {
            const newsletterForm = document.getElementById('footerNewsletterForm');
            if (newsletterForm) {
                newsletterForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const email = newsletterForm.querySelector('input[type="email"]').value;
                    try {
                        const response = await fetch('/api/subscribe', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ email })
                        });
                        const data = await response.json();
                        alert(data.success ? 'Successfully subscribed!' : 'Error subscribing. Please try again.');
                        if (data.success) newsletterForm.reset();
                    } catch (error) {
                        console.error('Newsletter error:', error);
                        alert('Error subscribing. Please try again.');
                    }
                });
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            loadPromotions();
            loadInterests();
            initNewsletter();
        });
    </script>

    <style>
        .dropdown-menu { display: none; }
        .dropdown:hover .dropdown-menu,
        .dropdown .dropdown-menu.show { display: block; }
        .dropdown-menu li a:hover { background: #f8f9fa; padding-left: 25px; }
        .mil-table-responsive { overflow-x: auto; }
        .mil-table { width: 100%; }
        .mil-xs { padding: 4px 8px; font-size: 11px; }
        .mil-flex-between { display: flex; justify-content: space-between; align-items: center; }
        .mil-mb-10 { margin-bottom: 10px; }
        .mil-mb-20 { margin-bottom: 20px; }
        .promote-btn { cursor: pointer; transition: all 0.3s ease; }
        .promote-btn:hover { transform: translateY(-2px); }
        .property-card { transition: transform 0.3s ease; }
        .property-card:hover { transform: translateY(-5px); }
        @media (max-width: 768px) {
            .mil-table th, .mil-table td { padding: 8px; font-size: 12px; }
        }
    </style>
</body>
</html>