<!-- Start Property Search Area -->
<div class="find-degree ptb-100">
    <div class="container">
        <div class="d-row">
            <div class="d-col-1">
                <div class="content-1" data-aos="fade-up" data-aos-delay="100">
                    <h4>Find Your Perfect Property</h4>
                    <p>Search through thousands of verified properties across Nigeria</p>
                    
                    <div class="search-key">
                        <label for="searchLocation">Location</label>
                        <select class="form-select" id="searchLocation">
                            <option value="">All Locations</option>
                            <option value="Lagos">Lagos</option>
                            <option value="Abuja">Abuja</option>
                            <option value="Rivers">Port Harcourt</option>
                            <option value="Ogun">Ogun State</option>
                            <option value="Oyo">Ibadan</option>
                            <option value="Kano">Kano</option>
                        </select>

                        <label for="searchType" class="mt-3">Property Type</label>
                        <select class="form-select" id="searchType">
                            <option value="">All Types</option>
                            <option value="land">Land</option>
                            <option value="building">Building/House</option>
                            <option value="shortlet">Shortlet Apartment</option>
                            <option value="shop">Shop/Commercial</option>
                            <option value="business_complex">Business Complex</option>
                        </select>

                        <label for="searchPrice" class="mt-3">Price Range</label>
                        <select class="form-select" id="searchPrice">
                            <option value="">Any Price</option>
                            <option value="0-50k">Under ₦50 Million</option>
                            <option value="50k-100k">₦50M - ₦100M</option>
                            <option value="100k+">₦100M+</option>
                        </select>
                    </div>
                    
                    <div class="selector-box-2 mt-4">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="transactionType" id="saleRadio" value="sale" checked>
                            <label class="form-check-label" for="saleRadio">For Sale</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="transactionType" id="rentRadio" value="rent">
                            <label class="form-check-label" for="rentRadio">For Rent</label>
                        </div>
                    </div>
                    
                    <div class="selector-btns mt-4">
                        <a class="default-btn" href="#" onclick="searchProperties(); return false;">Search Properties</a>
                        <a class="default-btn black" href="/properties">View All</a>
                    </div>
                </div>
            </div>
            <div class="d-col-2">
                <div class="content-image" style="background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);">
                    <div class="content" data-aos="fade-down" data-aos-delay="100">
                        <h5>For Property Owners</h5>
                        <h3>List Your Property</h3>
                        <h4>Get Verified & Reach More Buyers</h4>
                        <p class="mt-3">Verification Fee: <strong>₦20,000 only</strong></p>
                        <a class="btn btn-light mt-3" href="/register">List Now</a>
                    </div>
                </div>
            </div>
            <div class="d-col-3">
                <div class="content-2" data-aos="fade-up" data-aos-delay="100">
                    <h4>I am a</h4>
                    <ul class="nav nav-tabs" id="myTab" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="promoter-tab" data-bs-toggle="tab" data-bs-target="#promoter-tab-pane" type="button" role="tab">Promoter</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="buyer-tab" data-bs-toggle="tab" data-bs-target="#buyer-tab-pane" type="button" role="tab">Buyer/Investor</button>
                        </li>
                    </ul>
                    <div class="tab-content" id="myTabContent">
                        <div class="tab-pane fade show active" id="promoter-tab-pane" role="tabpanel">
                            <ul>
                                <li><a href="/promoter/register">Earn 70% Commission</a></li>
                                <li><a href="/promoter/register">Share Properties on Social Media</a></li>
                                <li><a href="/promoter/register">Get Your Unique Referral Link</a></li>
                                <li><a href="/promoter/register">Weekly Payouts</a></li>
                                <li><a href="/promoter/register">No Investment Required</a></li>
                            </ul>
                        </div>
                        <div class="tab-pane fade" id="buyer-tab-pane" role="tabpanel">
                            <ul>
                                <li><a href="/properties">Find Verified Properties</a></li>
                                <li><a href="/properties">Connect with Promoters</a></li>
                                <li><a href="/properties">Schedule Viewings</a></li>
                                <li><a href="/properties">Get the Best Deals</a></li>
                                <li><a href="/properties">Secure Transactions</a></li>
                            </ul>
                        </div>
                    </div>
                    <a class="default-btn black mt-4" href="/how-it-works">Learn More</a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- End Property Search Area -->