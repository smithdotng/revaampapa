<!-- Header Start -->
<header class="main-header-two clearfix">
    <div class="main-header-two__top clearfix">
        <div class="container">
            <div class="main-header-two__top-inner clearfix">
                <div class="main-header-two__top-left">
                    <ul class="list-unstyled main-header-two__top-address">
                        <li>
                            <div class="icon">
                                <span class="icon-pin"></span>
                            </div>
                            <div class="text">
                                <p>Abuja, Nigeria</p>
                            </div>
                        </li>
                        <li>
                            <div class="icon">
                                <span class="icon-email"></span>
                            </div>
                            <div class="text">
                                <p><a href="mailto:info@revaampap.com">info@revaampap.com</a></p>
                            </div>
                        </li>
                        <li>
                            <div class="icon">
                                <span class="icon-telephone"></span>
                            </div>
                            <div class="text">
                                <p><a href="tel:+2348000000000">+234 800 000 0000</a></p>
                            </div>
                        </li>
                    </ul>
                </div>
                <div class="main-header-two__top-right">
                    <div class="main-header-two__top-right-social">
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-facebook"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-linkedin"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <nav class="main-menu main-menu-two clearfix">
        <div class="main-menu-two__wrapper clearfix">
            <div class="container clearfix">
                <div class="main-menu-two__wrapper-left">
                    <div class="main-menu-two__wrapper-logo">
                        <a href="/"><img src="/assets/images/resources/logo-2.png" alt="RevaampAP"></a>
                    </div>
                    <div class="main-menu-two__wrapper-main-menu">
                        <a href="#" class="mobile-nav__toggler"><i class="fa fa-bars"></i></a>
                        <ul class="main-menu__list">
                            <li class="<%= typeof currentPath !== 'undefined' && currentPath === '/' ? 'current' : '' %>"><a href="/">Home</a></li>
                            <li><a href="/properties">Properties</a></li>
                            <li class="dropdown">
                                <a href="#">For Owners</a>
                                <ul>
                                    <li><a href="/register">List Your Property</a></li>
                                    <li><a href="/how-it-works#verification">Verification Process</a></li>
                                    <li><a href="/how-it-works#fees">Pricing & Fees</a></li>
                                </ul>
                            </li>
                            <li class="dropdown">
                                <a href="#">For Promoters</a>
                                <ul>
                                    <li><a href="/promoter/register">Become a Promoter</a></li>
                                    <li><a href="/how-it-works#promoter">How It Works</a></li>
                                    <li><a href="/how-it-works#commission">Commission Structure</a></li>
                                </ul>
                            </li>
                            <li><a href="/about">About</a></li>
                            <li><a href="/contact">Contact</a></li>
                        </ul>
                    </div>
                </div>
                <div class="main-menu-two__wrapper-right">
                    <div class="auth-buttons">
                        <% if (typeof user !== 'undefined' && user) { %>
                            <div class="dropdown user-dropdown">
                                <a href="#" class="dropdown-toggle user-btn" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle"></i>
                                    <span><%= user.name %></span>
                                    <i class="fas fa-chevron-down"></i>
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a href="/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                                    <li><a href="/dashboard/settings"><i class="fas fa-cog"></i> Settings</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                                </ul>
                            </div>
                        <% } else { %>
                            <a href="/login" class="thm-btn login-btn">
                                <i class="fas fa-sign-in-alt"></i> Login
                            </a>
                            <a href="/register" class="thm-btn list-btn">
                                <i class="fas fa-plus-circle"></i> List Property
                            </a>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </nav>
</header>
<!-- Header End -->

<!-- Sticky Header -->
<div class="stricky-header stricked-menu main-menu main-menu-two">
    <div class="sticky-header__content"></div>
</div>
<!-- Sticky Header End -->