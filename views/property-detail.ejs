<%- include('partials/header') %>

<%
// Helper function to format price
function formatPrice(price) {
    if (!price || price === 0) return 'Contact for pricing';
    if (price >= 1000000000) {
        return '₦' + (price / 1000000000).toFixed(1) + 'B';
    }
    if (price >= 1000000) {
        return '₦' + (price / 1000000).toFixed(1) + 'M';
    }
    return '₦' + price.toLocaleString();
}

// Helper function to format date
function formatDate(date) {
    if (!date) return 'N/A';
    return new Date(date).toLocaleDateString('en-NG', {
        year: 'numeric',
        month: 'short',
        day: 'numeric'
    });
}

// Helper function to get status badge class
function getStatusBadge(status) {
    switch(status) {
        case 'available': return 'success';
        case 'pending': return 'warning';
        case 'sold': return 'secondary';
        case 'rented': return 'info';
        case 'unavailable': return 'danger';
        default: return 'primary';
    }
}

// Helper function to get property type display
function getPropertyType(type) {
    switch(type) {
        case 'shortlet': return 'Shortlet';
        case 'land': return 'Land';
        case 'building': return 'Building';
        case 'shop': return 'Shop';
        case 'business_complex': return 'Business Complex';
        default: return type;
    }
}

// Helper function to get transaction type badge
function getTransactionTypeBadge(type) {
    switch(type) {
        case 'sale': return 'success';
        case 'rent': return 'info';
        case 'lease': return 'warning';
        default: return 'primary';
    }
}

// Override meta tags for this property
title = property.title + ' - Found Properties';
metaDescription = property.description ? property.description.replace(/<[^>]*>/g, '').substring(0, 160) : '';
ogTitle = property.title;
ogDescription = property.description ? property.description.replace(/<[^>]*>/g, '').substring(0, 160) : '';
ogImage = property.images && property.images[0] ? property.images[0].url : '/assets/images/og-default.jpg';
ogType = 'article';
%>

<!-- Page Top -->
<section>
    <div class="w-100 pt-180 pb-110 black-layer opc45 position-relative">
        <div class="fixed-bg" style="background-image: url(/assets/images/pg-tp-bg.jpg);"></div>
        <div class="container">
            <div class="pg-tp-wrp text-center w-100">
                <h1 class="mb-0"><%= property.title %></h1>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/" title="Home">Home</a></li>
                    <li class="breadcrumb-item"><a href="/properties" title="Properties">Properties</a></li>
                    <li class="breadcrumb-item active">Property Details</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<!-- Property Detail Section -->
<section>
    <div class="w-100 pt-80 pb-80 gray-bg position-relative">
        <div class="container">
            <div class="row">
                <!-- Main Content -->
                <div class="col-lg-8">
                    <!-- Property Gallery -->
                    <div class="property-gallery mb-4">
                        <div class="main-image mb-3">
                            <img id="mainGalleryImage" class="img-fluid w-100 rounded" 
                                 src="<%= property.images && property.images[0] ? property.images[0].url : '/assets/images/default-property.jpg' %>" 
                                 alt="<%= property.title %>" style="height: 400px; object-fit: cover;">
                        </div>
                        <% if (property.images && property.images.length > 1) { %>
                            <div class="gallery-thumbs">
                                <div class="row">
                                    <% property.images.forEach((image, index) => { %>
                                        <div class="col-3 mb-2">
                                            <img src="<%= image.url %>" 
                                                 alt="Thumbnail" 
                                                 class="img-fluid rounded cursor-pointer" 
                                                 style="height: 80px; width: 100%; object-fit: cover;"
                                                 onclick="changeMainImage('<%= image.url %>')">
                                        </div>
                                    <% }); %>
                                </div>
                            </div>
                        <% } %>
                    </div>

                    <!-- Property Header -->
                    <div class="property-header mb-4">
                        <div class="d-flex justify-content-between align-items-start flex-wrap">
                            <div>
                                <h2><%= property.title %></h2>
                                <p class="text-muted mb-2">
                                    <i class="fas fa-map-marker-alt thm-clr"></i> 
                                    <%= property.location.address ? property.location.address + ', ' : '' %>
                                    <%= property.location.city %>, <%= property.location.state %>
                                </p>
                            </div>
                            <div class="property-actions mt-2 mt-md-0">
                                <button class="btn btn-outline-danger mr-2" onclick="toggleFavorite('<%= property._id %>')">
                                    <i class="far fa-heart"></i> Save
                                </button>
                                <button class="btn btn-outline-primary" onclick="shareProperty()">
                                    <i class="fas fa-share-alt"></i> Share
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Property Badges -->
                    <div class="property-badges mb-4">
                        <span class="badge badge-primary p-2 mr-2"><%= getPropertyType(property.propertyType) %></span>
                        <span class="badge badge-<%= getTransactionTypeBadge(property.transactionType) %> p-2 mr-2">
                            For <%= property.transactionType %>
                        </span>
                        <span class="badge badge-<%= getStatusBadge(property.status) %> p-2">
                            <%= property.status.charAt(0).toUpperCase() + property.status.slice(1) %>
                        </span>
                        <% if (property.featured) { %>
                            <span class="badge badge-warning p-2 ml-2"><i class="fas fa-star"></i> Featured</span>
                        <% } %>
                    </div>

                    <!-- Price -->
                    <div class="property-price p-4 bg-light rounded mb-4">
                        <h3 class="mb-0 text-success"><%= formatPrice(property.price) %></h3>
                        <% if (property.transactionType === 'rent') { %>
                            <p class="mb-0 text-muted">per year</p>
                        <% } else if (property.transactionType === 'lease') { %>
                            <p class="mb-0 text-muted">lease term</p>
                        <% } %>
                        <% if (property.priceNegotiable) { %>
                            <span class="badge badge-success mt-2"><i class="fas fa-handshake"></i> Price Negotiable</span>
                        <% } %>
                    </div>

                    <!-- Key Features -->
                    <div class="property-features mb-4">
                        <h4><i class="fas fa-list thm-clr"></i> Key Features</h4>
                        <div class="row mt-3">
                            <% if (property.features.bedrooms) { %>
                                <div class="col-6 col-md-3 mb-3">
                                    <div class="feature-item text-center p-3 border rounded">
                                        <i class="fas fa-bed fa-2x thm-clr mb-2"></i>
                                        <p class="mb-0"><strong><%= property.features.bedrooms %></strong></p>
                                        <small>Bedrooms</small>
                                    </div>
                                </div>
                            <% } %>
                            <% if (property.features.bathrooms) { %>
                                <div class="col-6 col-md-3 mb-3">
                                    <div class="feature-item text-center p-3 border rounded">
                                        <i class="fas fa-bath fa-2x thm-clr mb-2"></i>
                                        <p class="mb-0"><strong><%= property.features.bathrooms %></strong></p>
                                        <small>Bathrooms</small>
                                    </div>
                                </div>
                            <% } %>
                            <% if (property.features.toilets) { %>
                                <div class="col-6 col-md-3 mb-3">
                                    <div class="feature-item text-center p-3 border rounded">
                                        <i class="fas fa-toilet fa-2x thm-clr mb-2"></i>
                                        <p class="mb-0"><strong><%= property.features.toilets %></strong></p>
                                        <small>Toilets</small>
                                    </div>
                                </div>
                            <% } %>
                            <% if (property.features.parkingSpaces) { %>
                                <div class="col-6 col-md-3 mb-3">
                                    <div class="feature-item text-center p-3 border rounded">
                                        <i class="fas fa-car fa-2x thm-clr mb-2"></i>
                                        <p class="mb-0"><strong><%= property.features.parkingSpaces %></strong></p>
                                        <small>Parking Spaces</small>
                                    </div>
                                </div>
                            <% } %>
                            <% if (property.features.floorArea) { %>
                                <div class="col-6 col-md-3 mb-3">
                                    <div class="feature-item text-center p-3 border rounded">
                                        <i class="fas fa-vector-square fa-2x thm-clr mb-2"></i>
                                        <p class="mb-0"><strong><%= property.features.floorArea %></strong></p>
                                        <small>sqm (Floor)</small>
                                    </div>
                                </div>
                            <% } %>
                            <% if (property.features.landArea) { %>
                                <div class="col-6 col-md-3 mb-3">
                                    <div class="feature-item text-center p-3 border rounded">
                                        <i class="fas fa-map fa-2x thm-clr mb-2"></i>
                                        <p class="mb-0"><strong><%= property.features.landArea %></strong></p>
                                        <small>sqm (Land)</small>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Amenities -->
                    <% if (property.features.furnished || property.features.serviced || property.features.security || 
                          property.features.powerSupply || property.features.borehole) { %>
                        <div class="property-amenities mb-4">
                            <h4><i class="fas fa-concierge-bell thm-clr"></i> Amenities</h4>
                            <div class="row mt-3">
                                <% if (property.features.furnished) { %>
                                    <div class="col-6 col-md-4 mb-2">
                                        <i class="fas fa-check-circle text-success"></i> Furnished
                                    </div>
                                <% } %>
                                <% if (property.features.serviced) { %>
                                    <div class="col-6 col-md-4 mb-2">
                                        <i class="fas fa-check-circle text-success"></i> Serviced
                                    </div>
                                <% } %>
                                <% if (property.features.security) { %>
                                    <div class="col-6 col-md-4 mb-2">
                                        <i class="fas fa-check-circle text-success"></i> 24/7 Security
                                    </div>
                                <% } %>
                                <% if (property.features.powerSupply) { %>
                                    <div class="col-6 col-md-4 mb-2">
                                        <i class="fas fa-check-circle text-success"></i> Power Supply
                                    </div>
                                <% } %>
                                <% if (property.features.borehole) { %>
                                    <div class="col-6 col-md-4 mb-2">
                                        <i class="fas fa-check-circle text-success"></i> Borehole
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% } %>

                    <!-- Description - Rendered as Rich Text (HTML) -->
                    <div class="property-description mb-4">
                        <h4><i class="fas fa-file-alt thm-clr"></i> Description</h4>
                        <div class="property-description-content">
                            <%- property.description %>
                        </div>
                    </div>

                    <!-- Shortlet Details -->
                    <% if (property.propertyType === 'shortlet' && property.shortletDetails) { %>
                        <div class="shortlet-details mb-4">
                            <h4><i class="fas fa-home thm-clr"></i> Shortlet Information</h4>
                            <div class="row mt-3">
                                <div class="col-md-6">
                                    <table class="table table-borderless">
                                        <tr>
                                            <th width="40%">Minimum Stay:</th>
                                            <td><%= property.shortletDetails.minimumStay %> nights</td>
                                        </tr>
                                        <tr>
                                            <th>Maximum Stay:</th>
                                            <td><%= property.shortletDetails.maximumStay %> nights</td>
                                        </tr>
                                        <tr>
                                            <th>Check-in:</th>
                                            <td><%= property.shortletDetails.checkInTime %></td>
                                        </tr>
                                        <tr>
                                            <th>Check-out:</th>
                                            <td><%= property.shortletDetails.checkOutTime %></td>
                                        </tr>
                                        <tr>
                                            <th>Max Guests:</th>
                                            <td><%= property.shortletDetails.maxGuests %></td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-md-6">
                                    <% if (property.shortletDetails.amenities && property.shortletDetails.amenities.length > 0) { %>
                                        <h6>Amenities:</h6>
                                        <ul>
                                            <% property.shortletDetails.amenities.forEach(function(amenity) { %>
                                                <li><i class="fas fa-check text-success"></i> <%= amenity %></li>
                                            <% }); %>
                                        </ul>
                                    <% } %>
                                    <% if (property.shortletDetails.houseRules && property.shortletDetails.houseRules.length > 0) { %>
                                        <h6>House Rules:</h6>
                                        <ul>
                                            <% property.shortletDetails.houseRules.forEach(function(rule) { %>
                                                <li><i class="fas fa-info-circle text-info"></i> <%= rule %></li>
                                            <% }); %>
                                        </ul>
                                    <% } %>
                                </div>
                            </div>
                            <div class="alert alert-info mt-3">
                                <strong>Cancellation Policy:</strong> <%= property.shortletDetails.cancellationPolicy %><br>
                                <% if (property.shortletDetails.cleaningFee > 0) { %>
                                    <strong>Cleaning Fee:</strong> <%= formatPrice(property.shortletDetails.cleaningFee) %><br>
                                <% } %>
                                <% if (property.shortletDetails.securityDeposit > 0) { %>
                                    <strong>Security Deposit:</strong> <%= formatPrice(property.shortletDetails.securityDeposit) %>
                                <% } %>
                            </div>
                        </div>
                    <% } %>

                    <!-- Similar Properties -->
                    <% if (similarProperties && similarProperties.length > 0) { %>
                        <div class="similar-properties mt-5">
                            <h3 class="mb-4">Similar Properties</h3>
                            <div class="row">
                                <% similarProperties.forEach(function(prop) { %>
                                    <div class="col-md-4 mb-4">
                                        <div class="property-card">
                                            <a href="/properties/<%= prop.slug %>">
                                                <img src="<%= prop.images && prop.images[0] ? prop.images[0].url : '/assets/images/default-property.jpg' %>" 
                                                     alt="<%= prop.title %>" 
                                                     class="img-fluid w-100" 
                                                     style="height: 150px; object-fit: cover; border-radius: 10px 10px 0 0;">
                                            </a>
                                            <div class="p-3 bg-white" style="border-radius: 0 0 10px 10px;">
                                                <h6 class="mb-1"><a href="/properties/<%= prop.slug %>"><%= prop.title.substring(0, 35) %>...</a></h6>
                                                <p class="mb-0 text-muted"><%= prop.location.city %>, <%= prop.location.state %></p>
                                                <p class="mb-0 text-success font-weight-bold"><%= formatPrice(prop.price) %></p>
                                            </div>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    <% } %>
                </div>

                <!-- Sidebar -->
                <div class="col-lg-4">
                    <!-- Realtor Info Card -->
                    <div class="realtor-card p-4 bg-white rounded mb-4">
                        <h5>Listed By</h5>
                        <div class="d-flex align-items-center mb-3">
                            <img src="<%= property.owner && property.owner.profileImage ? '/uploads/profiles/' + property.owner.profileImage : '/assets/images/default-avatar.jpg' %>" 
                                 alt="<%= property.owner ? property.owner.name : 'Found Properties' %>" 
                                 class="rounded-circle mr-3" 
                                 style="width: 60px; height: 60px; object-fit: cover;">
                            <div>
                                <h6 class="mb-1"><%= property.owner ? property.owner.name : 'Found Properties' %></h6>
                                <% if (property.owner && property.owner.realtorProfile && property.owner.realtorProfile.verified) { %>
                                    <p class="mb-0 text-success"><i class="fas fa-check-circle"></i> Verified Realtor</p>
                                <% } else if (property.owner) { %>
                                    <p class="mb-0 text-muted"><i class="fas fa-clock"></i> Pending Verification</p>
                                <% } %>
                            </div>
                        </div>
                        <% if (property.owner && property.owner.realtorProfile && property.owner.realtorProfile.company) { %>
                            <p class="mb-2"><i class="fas fa-building"></i> <%= property.owner.realtorProfile.company %></p>
                        <% } %>
                        <% if (property.owner && property.owner.phone) { %>
                            <p class="mb-2"><i class="fas fa-phone"></i> <a href="tel:<%= property.owner.phone %>"><%= property.owner.phone %></a></p>
                        <% } %>
                        <% if (property.owner && property.owner.email) { %>
                            <p class="mb-2"><i class="fas fa-envelope"></i> <a href="mailto:<%= property.owner.email %>"><%= property.owner.email %></a></p>
                        <% } %>
                    </div>

                    <!-- Inquiry Form -->
                    <div class="inquiry-card p-4 bg-white rounded mb-4">
                        <h5>Interested in this property?</h5>
                        <form action="/inquiries/property" method="POST">
                            <input type="hidden" name="propertyId" value="<%= property._id %>">
                            <div class="form-group">
                                <input type="text" class="form-control" name="name" placeholder="Your Full Name" required>
                            </div>
                            <div class="form-group">
                                <input type="email" class="form-control" name="email" placeholder="Your Email" required>
                            </div>
                            <div class="form-group">
                                <input type="tel" class="form-control" name="phone" placeholder="Your Phone Number" required>
                            </div>
                            <div class="form-group">
                                <textarea class="form-control" name="message" rows="4" placeholder="I'm interested in this property. Please contact me..."></textarea>
                            </div>
                            <button type="submit" class="thm-btn btn-block">Send Inquiry</button>
                        </form>
                    </div>

                    <!-- Property Stats -->
                    <div class="stats-card p-4 bg-white rounded">
                        <h5>Property Stats</h5>
                        <ul class="list-unstyled mb-0">
                            <li class="d-flex justify-content-between mb-2">
                                <span><i class="fas fa-eye"></i> Views</span>
                                <span class="badge badge-primary"><%= property.views || 0 %></span>
                            </li>
                            <li class="d-flex justify-content-between mb-2">
                                <span><i class="fas fa-calendar-alt"></i> Listed</span>
                                <span><%= formatDate(property.createdAt) %></span>
                            </li>
                            <li class="d-flex justify-content-between mb-2">
                                <span><i class="fas fa-tag"></i> Property ID</span>
                                <span><%= property._id.toString().slice(-6).toUpperCase() %></span>
                            </li>
                            <li class="d-flex justify-content-between">
                                <span><i class="fas fa-hand-holding-usd"></i> Agency Fee</span>
                                <span class="text-success"><%= formatPrice(property.agencyFee) %></span>
                            </li>
                        </ul>
                        <div class="alert alert-info mt-3 mb-0">
                            <i class="fas fa-info-circle"></i> Total agency fees capped at 5%
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Share Modal -->
<div class="modal fade" id="shareModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Share this Property</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <p>Share this property with your network:</p>
                <div class="social-share-buttons text-center mb-3">
                    <button class="btn btn-primary m-1" onclick="shareOnFacebook()">
                        <i class="fab fa-facebook"></i> Facebook
                    </button>
                    <button class="btn btn-info m-1" onclick="shareOnTwitter()">
                        <i class="fab fa-twitter"></i> Twitter
                    </button>
                    <button class="btn btn-success m-1" onclick="shareOnWhatsApp()">
                        <i class="fab fa-whatsapp"></i> WhatsApp
                    </button>
                </div>
                <hr>
                <p>Or copy the link:</p>
                <div class="input-group">
                    <input type="text" class="form-control" id="propertyLink" value="<%= req.protocol + '://' + req.get('host') + '/properties/' + property.slug %>" readonly>
                    <div class="input-group-append">
                        <button class="btn btn-primary" onclick="copyPropertyLink()">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.property-gallery {
    position: relative;
}

.gallery-thumbs img {
    cursor: pointer;
    transition: opacity 0.3s ease;
}

.gallery-thumbs img:hover {
    opacity: 0.8;
}

.cursor-pointer {
    cursor: pointer;
}

.feature-item {
    transition: all 0.3s ease;
}

.feature-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

.realtor-card, .inquiry-card, .stats-card {
    border: 1px solid #f0f0f0;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
}

.inquiry-card .form-control {
    border: 1px solid #e0e0e0;
    border-radius: 5px;
    padding: 10px 15px;
    font-size: 14px;
}

.inquiry-card .form-control:focus {
    border-color: #ff6b6b;
    outline: none;
    box-shadow: 0 0 0 2px rgba(255,107,107,0.1);
}

.property-card {
    transition: all 0.3s ease;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    height: 100%;
}

.property-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.1);
}

.property-card a {
    text-decoration: none;
}

.property-card h6 a {
    color: #333;
}

.property-card h6 a:hover {
    color: #ff6b6b;
}

.social-share-buttons button {
    min-width: 100px;
}

/* Rich Text Styles for Property Description */
.property-description-content {
    font-size: 16px;
    line-height: 1.8;
    color: #555;
}

.property-description-content p {
    margin-bottom: 20px;
}

.property-description-content h2,
.property-description-content h3,
.property-description-content h4 {
    margin: 30px 0 20px;
    color: #333;
    font-weight: 600;
}

.property-description-content h2 {
    font-size: 28px;
}

.property-description-content h3 {
    font-size: 24px;
}

.property-description-content h4 {
    font-size: 20px;
}

.property-description-content img {
    max-width: 100%;
    height: auto;
    border-radius: 10px;
    margin: 20px 0;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

.property-description-content blockquote {
    border-left: 4px solid #ff6b6b;
    padding: 20px;
    background: #f8f9fa;
    font-style: italic;
    margin: 20px 0;
    border-radius: 0 10px 10px 0;
}

.property-description-content ul,
.property-description-content ol {
    margin-bottom: 20px;
    padding-left: 20px;
}

.property-description-content li {
    margin-bottom: 10px;
}

.property-description-content ul li {
    list-style-type: disc;
}

.property-description-content ol li {
    list-style-type: decimal;
}

.property-description-content table {
    width: 100%;
    margin-bottom: 20px;
    border-collapse: collapse;
}

.property-description-content th,
.property-description-content td {
    border: 1px solid #e0e0e0;
    padding: 10px;
    text-align: left;
}

.property-description-content th {
    background: #f8f9fa;
    font-weight: 600;
}

@media (max-width: 768px) {
    .social-share-buttons button {
        width: 100%;
        margin: 5px 0;
    }
    
    .property-description-content {
        font-size: 15px;
    }
    
    .property-description-content h2 {
        font-size: 24px;
    }
    
    .property-description-content h3 {
        font-size: 20px;
    }
    
    .property-description-content h4 {
        font-size: 18px;
    }
}
</style>

<script>
// Gallery image changer
function changeMainImage(src) {
    document.getElementById('mainGalleryImage').src = src;
}

// Toggle favorite
function toggleFavorite(propertyId) {
    <% if (!currentUser) { %>
        window.location.href = '/login?redirect=' + encodeURIComponent(window.location.pathname);
        return;
    <% } %>
    
    $.post('/favorites/toggle', { propertyId: propertyId }, function(data) {
        if (data.favorited) {
            alert('Property added to favorites');
        } else {
            alert('Property removed from favorites');
        }
    }).fail(function() {
        alert('Error toggling favorite');
    });
}

// Share property
function shareProperty() {
    $('#shareModal').modal('show');
}

// Social sharing functions
function shareOnFacebook() {
    var url = encodeURIComponent(window.location.href);
    window.open('https://www.facebook.com/sharer/sharer.php?u=' + url, '_blank', 'width=600,height=400');
}

function shareOnTwitter() {
    var url = encodeURIComponent(window.location.href);
    var text = encodeURIComponent('Check out this property on Found Properties');
    window.open('https://twitter.com/intent/tweet?text=' + text + '&url=' + url, '_blank', 'width=600,height=400');
}

function shareOnWhatsApp() {
    var url = encodeURIComponent(window.location.href);
    var text = encodeURIComponent('Check out this property on Found Properties');
    window.open('https://wa.me/?text=' + text + '%20' + url, '_blank');
}

function copyPropertyLink() {
    var link = document.getElementById('propertyLink');
    link.select();
    document.execCommand('copy');
    alert('Link copied to clipboard!');
}

// Nigerian phone number formatting
document.querySelector('input[name="phone"]')?.addEventListener('input', function(e) {
    var phone = this.value.replace(/\D/g, '');
    if (phone.length > 11 && !this.value.startsWith('+234')) {
        phone = phone.substr(0, 11);
    } else if (this.value.startsWith('+234') && phone.length > 13) {
        phone = phone.substr(0, 13);
    }
    this.value = phone;
});

// Form validation
document.querySelector('.inquiry-card form')?.addEventListener('submit', function(e) {
    var phone = document.querySelector('input[name="phone"]').value;
    var phoneRegex = /^(0|\+234)[7-9][0-1]\d{8}$/;
    
    if (!phoneRegex.test(phone)) {
        e.preventDefault();
        alert('Please enter a valid Nigerian phone number (e.g., 08031234567 or +2348031234567)');
        return;
    }
});
</script>

