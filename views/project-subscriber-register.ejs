                                    <p class="mil-text-m mil-soft">Get expert project management for your construction projects across Africa</p>
                                </div>
                                
                                <form action="/project-subscriber/register" method="POST" enctype="multipart/form-data">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="text" name="name" placeholder="Full name" required>
                                        </div>
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="email" name="email" placeholder="Email address" required>
                                        </div>
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="tel" name="phone" placeholder="Phone number" required>
                                        </div>
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="text" name="countryOfResidence" placeholder="Country of Residence" required>
                                        </div>
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="text" name="passportNumber" placeholder="Passport / ID Number" required>
                                        </div>
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="password" name="password" placeholder="Password (min. 8 characters)" required>
                                        </div>
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-30" type="password" name="confirmPassword" placeholder="Confirm Password" required>
                                        </div>
                                    </div>

                                    <div class="mil-checkbox-frame mil-up mil-mb-30">
                                        <div class="mil-checkbox">
                                            <input type="checkbox" id="terms" name="terms" required>
                                            <label for="terms"></label>
                                        </div>
                                        <p class="mil-text-xs mil-soft">I agree to the <a href="/terms" class="mil-accent">Terms and Conditions</a> and <a href="/privacy" class="mil-accent">Privacy Policy</a></p>
                                    </div>

                                    <div class="mil-up">
                                        <button type="submit" class="mil-btn mil-md mil-fw">Subscribe Now</button>
                                    </div>

                                    <div class="mil-text-center mil-mt-30">
                                        <p class="mil-text-s mil-soft">
                                            Already have an account? <a href="/login" class="mil-accent">Login here</a>
                                        </p>
                                        <p class="mil-text-s mil-soft mil-mt-15">
                                            Want to list your property? <a href="/register" class="mil-accent">Register as Property Owner</a>
                                        </p>
                                        <p class="mil-text-s mil-soft">
                                            Want to earn commissions? <a href="/promoter/register" class="mil-accent">Become a Promoter (Free)</a>
                                        </p>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Registration Form End -->

            <!-- Complete Benefits Section -->
            <div class="mil-features mil-p-80-80">
                <div class="container">
                    <div class="mil-text-center mil-mb-60">
                        <h2 class="mil-mb-30 mil-up">Revaamp Project Management Solution - Complete Benefits</h2>
                        <p class="mil-text-m mil-soft mil-up">Hassle-free solution for developing your dream home or real estate projects across Africa</p>
                    </div>
                    
                    <!-- Core Benefits -->
                    <div class="row">
                        <div class="col-xl-12">
                            <div class="mil-price-card mil-up mil-mb-30">
