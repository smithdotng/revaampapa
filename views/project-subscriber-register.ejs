                                <div class="row">
                                    <div class="col-md-4 mil-mb-30">
                                        <div class="mil-text-center">
                                            <i class="fa fa-user-circle-o" style="font-size: 40px; color: #03A6A6; margin-bottom: 15px;"></i>
                                            <h5 class="mil-mb-10">Pre-qualified Contractors</h5>
                                            <p class="mil-text-s mil-soft">Recommendation of pre-qualified and shortlisted building contractors for your project</p>
                                        </div>
                                    </div>
