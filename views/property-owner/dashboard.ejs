<!DOCTYPE html>
<html lang="en-US">

<head>
    <title><%= title %></title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="author" content="RevaampAP" />

    <!-- switzer font css -->
    <link rel="stylesheet" href="/fonts/css/switzer.css" type="text/css" media="all">
    <!-- font awesome css -->
    <link rel="stylesheet" href="/fonts/css/font-awesome.min.css" type="text/css" media="all">
    <!-- bootstrap grid css -->
    <link rel="stylesheet" href="/css/plugins/bootstrap-grid.css" type="text/css" media="all">
    <!-- swiper css -->
    <link rel="stylesheet" href="/css/plugins/swiper.min.css" type="text/css" media="all">
    <!-- magnific popup -->
    <link rel="stylesheet" href="/css/plugins/magnific-popup.css" type="text/css" media="all">
    <!-- plax css -->
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <!-- custom css -->
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">

    <!-- Favicon -->
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>

<body>

    <!-- wrapper -->
    <div id="smooth-wrapper" class="mil-wrapper">

        <!-- preloader -->
        <div class="mil-preloader">
            <div class="mil-load"></div>
            <p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p>
        </div>
        <!-- preloader end -->

        <!-- scroll progress -->
        <div class="mil-progress-track">
            <div class="mil-progress"></div>
        </div>
        <!-- scroll progress end -->

        <!-- back to top -->
        <div class="progress-wrap active-progress"></div>

        <!-- top panel -->
        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo">
                    <img src="/img/logo.png" alt="RevaampAP" width="83" height="32">
                </a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/properties">Properties</a></li>
                        <li class="mil-active"><a href="/dashboard">Dashboard</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <div class="dropdown" style="position: relative;">
                        <a href="#" class="mil-btn mil-sm dropdown-toggle" data-bs-toggle="dropdown" style="display: flex; align-items: center; gap: 8px;">
                            <i class="fa fa-user-circle" style="font-size: 18px;"></i> 
                            <span><%= user.name %></span>
                            <i class="fa fa-chevron-down" style="font-size: 12px;"></i>
                        </a>
                        <ul class="dropdown-menu" style="position: absolute; right: 0; top: 100%; min-width: 220px; background: white; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.15); padding: 10px 0; margin-top: 10px; z-index: 1000;">
                            <li><a href="/dashboard" style="display: flex; align-items: center; gap: 10px; padding: 12px 20px; color: #333; text-decoration: none; transition: all 0.3s ease;"><i class="fa fa-tachometer" style="width: 20px; color: #03A6A6;"></i> Dashboard</a></li>
                            <li><a href="/property-owner/settings" style="display: flex; align-items: center; gap: 10px; padding: 12px 20px; color: #333; text-decoration: none; transition: all 0.3s ease;"><i class="fa fa-cog" style="width: 20px; color: #03A6A6;"></i> Settings</a></li>
                            <li><a href="/property-owner/earnings" style="display: flex; align-items: center; gap: 10px; padding: 12px 20px; color: #333; text-decoration: none; transition: all 0.3s ease;"><i class="fa fa-money" style="width: 20px; color: #03A6A6;"></i> Earnings</a></li>
                            <li><hr style="margin: 8px 0; border-color: #eee;"></li>
                            <li><a href="/logout" style="display: flex; align-items: center; gap: 10px; padding: 12px 20px; color: #dc3545; text-decoration: none; transition: all 0.3s ease;"><i class="fa fa-sign-out-alt" style="width: 20px;"></i> Logout</a></li>
                        </ul>
                    </div>
                    <div class="mil-menu-btn">
                        <span></span>
                    </div>
                </div>
            </div>
        </div>
        <!-- top panel end -->

        <!-- content -->
        <div id="smooth-content">

            <!-- banner -->
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-text-m mil-mb-20 mil-up">Welcome Back</div>
                                <h1 class="mil-mb-60 mil-up">Property Owner Dashboard</h1>
                                <ul class="mil-breadcrumbs mil-pub-info mil-center mil-up">
                                    <li><a href="/">Home</a></li>
                                    <li><a href="/dashboard">Dashboard</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- banner end -->

            <!-- stats cards -->
            <div class="mil-blog-list mil-p-0-80">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4 class="mil-mb-15"><span class="mil-pricing-table-price"><%= stats.totalProperties %></span></h4>
                                <p class="mil-text-s mil-soft">Total Properties</p>
                                <i class="fa fa-building" style="font-size: 40px; opacity: 0.3; margin-top: 20px;"></i>
                            </div>
                        </div>
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4 class="mil-mb-15"><span class="mil-pricing-table-price"><%= stats.pendingPayment %></span></h4>
                                <p class="mil-text-s mil-soft">Pending Payment</p>
                                <i class="fa fa-clock-o" style="font-size: 40px; opacity: 0.3; margin-top: 20px;"></i>
                            </div>
                        </div>
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4 class="mil-mb-15"><span class="mil-pricing-table-price"><%= stats.underReview %></span></h4>
                                <p class="mil-text-s mil-soft">Under Review</p>
                                <i class="fa fa-search" style="font-size: 40px; opacity: 0.3; margin-top: 20px;"></i>
                            </div>
                        </div>
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4 class="mil-mb-15"><span class="mil-pricing-table-price"><%= stats.verified %></span></h4>
                                <p class="mil-text-s mil-soft">Verified Properties</p>
                                <i class="fa fa-check-circle" style="font-size: 40px; opacity: 0.3; margin-top: 20px;"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- stats cards end -->

            <!-- action buttons -->
            <div class="mil-cta mil-up">
                <div class="container">
                    <div class="mil-out-frame mil-p-80-80" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                        <div class="row justify-content-between align-items-center">
                            <div class="col-xl-8 mil-sm-text-center">
                                <h2 class="mil-light mil-mb-30 mil-up">Ready to List a New Property?</h2>
                                <p class="mil-text-m mil-mb-30 mil-dark-soft mil-up">Get your property verified and reach thousands of potential buyers</p>
                            </div>
                            <div class="col-xl-4 mil-sm-text-center">
                                <div class="mil-buttons-frame mil-up">
                                    <a href="/property-owner/properties/add" class="mil-btn mil-md">Add New Property</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- action buttons end -->

            <!-- properties list -->
            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="mil-text-center">
                        <h2 class="mil-mb-30 mil-up">Your Properties</h2>
                        <p class="mil-text-m mil-soft mil-mb-60 mil-up">Manage all your property listings from one place</p>
                    </div>

                    <div class="row">
                        <% if (properties && properties.length > 0) { %>
                            <% properties.forEach(function(property) { %>
                                <div class="col-xl-4 col-md-6">
                                    <div class="mil-price-card mil-up mil-mb-30">
                                        <div style="position: relative;">
                                            <% if (property.images && property.images[0]) { %>
                                                <img src="<%= property.images[0].url %>" alt="<%= property.title %>" style="width: 100%; height: 200px; object-fit: cover; border-radius: 15px; margin-bottom: 20px;">
                                            <% } else { %>
                                                <div style="width: 100%; height: 200px; background: #f0f0f0; border-radius: 15px; margin-bottom: 20px; display: flex; align-items: center; justify-content: center;">
                                                    <i class="fa fa-building" style="font-size: 50px; color: #ccc;"></i>
                                                </div>
                                            <% } %>
                                            <% if (property.verificationStatus === 'verified') { %>
                                                <span style="position: absolute; top: 10px; right: 10px; background: #28a745; color: white; padding: 5px 10px; border-radius: 5px; font-size: 12px;">Verified</span>
                                            <% } else if (property.verificationStatus === 'pending_payment') { %>
                                                <span style="position: absolute; top: 10px; right: 10px; background: #ffc107; color: #856404; padding: 5px 10px; border-radius: 5px; font-size: 12px;">Payment Pending</span>
                                            <% } else if (property.verificationStatus === 'verification_pending') { %>
                                                <span style="position: absolute; top: 10px; right: 10px; background: #17a2b8; color: white; padding: 5px 10px; border-radius: 5px; font-size: 12px;">Under Review</span>
                                            <% } else if (property.verificationStatus === 'rejected') { %>
                                                <span style="position: absolute; top: 10px; right: 10px; background: #dc3545; color: white; padding: 5px 10px; border-radius: 5px; font-size: 12px;">Rejected</span>
                                            <% } %>
                                        </div>
                                        <h6 class="mil-mb-15"><%= property.title %></h6>
                                        <p class="mil-text-s mil-soft mil-mb-15"><i class="fa fa-map-marker"></i> <%= property.location.city %>, <%= property.location.state %></p>
                                        <h4 class="mil-mb-15">₦<%= property.price.toLocaleString() %></h4>
                                        <div class="mil-mb-30">
                                            <span class="mil-text-xs mil-soft">Views: <%= property.views || 0 %></span>
                                        </div>
                                        <div class="mil-buttons-frame">
                                            <a href="/properties/<%= property.slug %>" class="mil-link mil-accent">View</a>
                                            <a href="/property-owner/properties/<%= property._id %>/edit" class="mil-link mil-accent">Edit</a>
                                            <% if (property.verificationStatus === 'pending_payment') { %>
                                                <a href="/property-owner/properties/pay-verification/<%= property._id %>" class="mil-link mil-accent">Pay Fee</a>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="col-xl-12">
                                <div class="mil-price-card mil-up mil-mb-30 mil-text-center">
                                    <i class="fa fa-building" style="font-size: 60px; opacity: 0.3; margin-bottom: 20px;"></i>
                                    <h4 class="mil-mb-15">No Properties Yet</h4>
                                    <p class="mil-text-m mil-soft mil-mb-30">You haven't listed any properties yet.</p>
                                    <a href="/property-owner/properties/add" class="mil-btn mil-md">List Your First Property</a>
                                </div>
                            </div>
                        <% } %>
                    </div>

                    <% if (properties && properties.length > 0 && totalPages > 1) { %>
                        <div class="mil-pagination mil-up">
                            <div class="mil-pagination-list">
                                <% for (var i = 1; i <= totalPages; i++) { %>
                                    <a href="?page=<%= i %>" class="mil-pagination-item <%= i === currentPage ? 'mil-active' : '' %>"><%= i %></a>
                                <% } %>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
            <!-- properties list end -->

            <!-- recent activity -->
            <div class="mil-cta mil-up">
                <div class="container">
                    <div class="mil-out-frame mil-p-80-80" style="background: #f8f9fa;">
                        <div class="row justify-content-between align-items-center">
                            <div class="col-xl-8 mil-sm-text-center">
                                <h2 class="mil-mb-30 mil-up">Need Help with Your Listings?</h2>
                                <p class="mil-text-m mil-mb-30 mil-soft mil-up">Our support team is here to help you every step of the way</p>
                            </div>
                            <div class="col-xl-4 mil-sm-text-center">
                                <div class="mil-buttons-frame mil-up">
                                    <a href="/contact" class="mil-btn mil-md mil-light">Contact Support</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- recent activity end -->

            <!-- footer -->
            <footer class="mil-p-80-0">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-3">
                            <a href="/" class="mil-footer-logo mil-mb-60">
                                <img src="/img/logo-2.png" alt="RevaampAP" width="28" height="32">
                            </a>
                        </div>
                        <div class="col-xl-3 mil-mb-60">
                            <h6 class="mil-mb-60">Useful Links</h6>
                            <ul class="mil-footer-list">
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/">Home</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/about">About Us</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/contact">Contact Us</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/properties">Properties</a></li>
                            </ul>
                        </div>
                        <div class="col-xl-3 mil-mb-60">
                            <h6 class="mil-mb-60">Help</h6>
                            <ul class="mil-footer-list">
                                <li class="mil-text-m mil-soft mil-mb-15">Abuja, Nigeria</li>
                                <li class="mil-text-m mil-soft mil-mb-15">+234 800 000 0000</li>
                                <li class="mil-text-m mil-soft mil-mb-15">support@revaampap.com</li>
                            </ul>
                        </div>
                        <div class="col-xl-3 mil-mb-80">
                            <h6 class="mil-mb-60">Newsletter</h6>
                            <p class="mil-text-xs mil-soft mil-mb-15">Subscribe to get the latest property updates</p>
                            <form class="mil-subscripe-form-footer" id="footerNewsletterForm">
                                <input class="mil-input" type="email" placeholder="Email">
                                <button type="submit"><i class="far fa-envelope-open mil-dark"></i></button>
                            </form>
                        </div>
                    </div>
                    <div class="mil-footer-bottom">
                        <div class="row">
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-soft">© 2024 RevaampAP. All rights reserved.</p>
                            </div>
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-text-right mil-sm-text-left mil-soft">Property Promotion Platform</p>
                            </div>
                        </div>
                    </div>
                </div>
            </footer>
            <!-- footer end -->

        </div>
        <!-- content end -->
    </div>
    <!-- wrapper end -->

    <!-- jquery js -->
    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/plugins/swiper.min.js"></script>
    <script src="/js/plugins/gsap.min.js"></script>
    <script src="/js/plugins/ScrollSmoother.min.js"></script>
    <script src="/js/plugins/ScrollTrigger.min.js"></script>
    <script src="/js/plugins/ScrollTo.min.js"></script>
    <script src="/js/plugins/magnific-popup.js"></script>
    <script src="/js/main.js"></script>

    <style>
        .dropdown {
            position: relative;
        }
        .dropdown-menu {
            display: none;
            position: absolute;
            right: 0;
            top: 100%;
            min-width: 220px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            padding: 10px 0;
            margin-top: 10px;
            z-index: 1000;
        }
        .dropdown:hover .dropdown-menu,
        .dropdown .dropdown-menu.show {
            display: block;
        }
        .dropdown-menu li a:hover {
            background: #f8f9fa;
            padding-left: 25px;
        }
        .dropdown-menu li a {
            transition: all 0.3s ease;
        }
    </style>

    <script>
        // Initialize dropdown
        document.addEventListener('DOMContentLoaded', function() {
            // Newsletter form
            var footerForm = document.getElementById('footerNewsletterForm');
            if (footerForm) {
                footerForm.addEventListener('submit', function(e) {
                    e.preventDefault();
                    var email = footerForm.querySelector('input[type="email"]').value;
                    fetch('/api/subscribe', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email: email })
                    })
                    .then(response => response.json())
                    .then(data => {
                        alert(data.success ? 'Successfully subscribed!' : 'Error subscribing');
                        if (data.success) footerForm.reset();
                    })
                    .catch(error => console.error('Error:', error));
                });
            }
        });
    </script>
</body>
</html>