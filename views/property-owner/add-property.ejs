<!DOCTYPE html>
<html lang="en-US">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <!-- CSS Files -->
    <link rel="stylesheet" href="/fonts/css/switzer.css" type="text/css" media="all">
    <link rel="stylesheet" href="/fonts/css/font-awesome.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/bootstrap-grid.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/swiper.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/magnific-popup.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">
    
    <!-- TinyMCE Rich Text Editor -->
    <script src="https://cdn.tiny.cloud/1/r7yn90cu0z6obkdeiouqmtq3bvnazgybfvn40efwi6fdzms4/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
    
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>
<body>

    <div id="smooth-wrapper" class="mil-wrapper">
        <div class="mil-preloader"><div class="mil-load"></div><p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p></div>
        <div class="mil-progress-track"><div class="mil-progress"></div></div>
        <div class="progress-wrap active-progress"></div>

        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo"><img src="/img/logo.png" alt="RevaampAPA" width="83" height="32"></a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/properties">Properties</a></li>
                        <li><a href="/about">About</a></li>
                        <li><a href="/contact">Contact</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <div class="dropdown" style="position: relative;">
                        <a href="#" class="mil-btn mil-sm dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="fa fa-user-circle"></i> <%= user.name %> <i class="fa fa-chevron-down"></i>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a href="/property-owner/dashboard"><i class="fa fa-tachometer"></i> Dashboard</a></li>
                            <li><a href="/property-owner/settings"><i class="fa fa-cog"></i> Settings</a></li>
                            <li><hr></li>
                            <li><a href="/logout"><i class="fa fa-sign-out-alt"></i> Logout</a></li>
                        </ul>
                    </div>
                    <div class="mil-menu-btn"><span></span></div>
                </div>
            </div>
        </div>

        <div id="smooth-content">
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-text-m mil-mb-20 mil-up">List Your Property</div>
                                <h1 class="mil-mb-60 mil-up"><%= property ? 'Edit Property' : 'Add New Property' %></h1>
                                <ul class="mil-breadcrumbs mil-center mil-up">
                                    <li><a href="/">Home</a></li>
                                    <li><a href="/property-owner/dashboard">Dashboard</a></li>
                                    <li><a href="#"><%= property ? 'Edit Property' : 'Add Property' %></a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-xl-10">
                            <div class="mil-price-card mil-up">
                                <form action="/property-owner/properties/add" method="POST" enctype="multipart/form-data" id="propertyForm">
                                    <!-- Basic Information -->
                                    <h3 class="mil-mb-30">Property Information</h3>
                                    <div class="row">
                                        <div class="col-md-12">
                                            <label class="mil-text-s mil-soft mil-mb-10">Property Title *</label>
                                            <input class="mil-input mil-mb-15" type="text" name="title" placeholder="e.g., Luxury 5-Bedroom Villa in Banana Island" value="<%= property ? property.title : '' %>" required>
                                        </div>
                                        <div class="col-md-12">
                                            <label class="mil-text-s mil-soft mil-mb-10">Description *</label>
                                            <textarea id="propertyDescription" name="description" rows="10" placeholder="Describe your property in detail..."><%= property ? property.description : '' %></textarea>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="mil-text-s mil-soft mil-mb-10">Property Type *</label>
                                            <select class="mil-input mil-mb-15" name="propertyType" required>
                                                <option value="">Select Property Type</option>
                                                <option value="land" <%= (property && property.propertyType === 'land') ? 'selected' : '' %>>Land</option>
                                                <option value="building" <%= (property && property.propertyType === 'building') ? 'selected' : '' %>>Building/House</option>
                                                <option value="shortlet" <%= (property && property.propertyType === 'shortlet') ? 'selected' : '' %>>Shortlet Apartment</option>
                                                <option value="shop" <%= (property && property.propertyType === 'shop') ? 'selected' : '' %>>Shop/Commercial</option>
                                                <option value="business_complex" <%= (property && property.propertyType === 'business_complex') ? 'selected' : '' %>>Business Complex</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="mil-text-s mil-soft mil-mb-10">Transaction Type *</label>
                                            <select class="mil-input mil-mb-15" name="transactionType" required>
                                                <option value="">Select Transaction Type</option>
                                                <option value="sale" <%= (property && property.transactionType === 'sale') ? 'selected' : '' %>>For Sale</option>
                                                <option value="rent" <%= (property && property.transactionType === 'rent') ? 'selected' : '' %>>For Rent</option>
                                                <option value="lease" <%= (property && property.transactionType === 'lease') ? 'selected' : '' %>>For Lease</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="mil-text-s mil-soft mil-mb-10">Price (₦) *</label>
                                            <input class="mil-input mil-mb-15" type="number" name="price" placeholder="Enter price" value="<%= property ? property.price : '' %>" required>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="mil-text-s mil-soft mil-mb-10">
                                                <input type="checkbox" name="priceNegotiable" <%= (property && property.priceNegotiable) ? 'checked' : '' %>> Price Negotiable
                                            </label>
                                        </div>
                                    </div>

                                    <!-- Location Details -->
                                    <h3 class="mil-mb-30 mil-mt-30">Location Details</h3>
                                    <div class="row">
                                        <div class="col-md-12">
                                            <label class="mil-text-s mil-soft mil-mb-10">Address *</label>
                                            <input class="mil-input mil-mb-15" type="text" name="address" placeholder="Street address" value="<%= (property && property.location) ? property.location.address : '' %>" required>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="mil-text-s mil-soft mil-mb-10">City *</label>
                                            <input class="mil-input mil-mb-15" type="text" name="city" placeholder="City" value="<%= (property && property.location) ? property.location.city : '' %>" required>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="mil-text-s mil-soft mil-mb-10">State *</label>
                                            <select class="mil-input mil-mb-15" name="state" required>
                                                <option value="">Select State</option>
                                                <option value="Lagos" <%= (property && property.location && property.location.state === 'Lagos') ? 'selected' : '' %>>Lagos</option>
                                                <option value="Abuja" <%= (property && property.location && property.location.state === 'Abuja') ? 'selected' : '' %>>Abuja</option>
                                                <option value="Rivers" <%= (property && property.location && property.location.state === 'Rivers') ? 'selected' : '' %>>Rivers</option>
                                                <option value="Ogun" <%= (property && property.location && property.location.state === 'Ogun') ? 'selected' : '' %>>Ogun</option>
                                                <option value="Oyo" <%= (property && property.location && property.location.state === 'Oyo') ? 'selected' : '' %>>Oyo</option>
                                                <option value="Kano" <%= (property && property.location && property.location.state === 'Kano') ? 'selected' : '' %>>Kano</option>
                                                <option value="Imo" <%= (property && property.location && property.location.state === 'Imo') ? 'selected' : '' %>>Imo</option>
                                            </select>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="mil-text-s mil-soft mil-mb-10">LGA</label>
                                            <input class="mil-input mil-mb-15" type="text" name="lga" placeholder="Local Government Area" value="<%= (property && property.location) ? property.location.lga : '' %>">
                                        </div>
                                        <div class="col-md-12">
                                            <label class="mil-text-s mil-soft mil-mb-10">Landmark</label>
                                            <input class="mil-input mil-mb-15" type="text" name="landmark" placeholder="Nearby landmark" value="<%= (property && property.location) ? property.location.landmark : '' %>">
                                        </div>
                                    </div>

                                    <!-- Property Features -->
                                    <h3 class="mil-mb-30 mil-mt-30">Property Features</h3>
                                    <div class="row">
                                        <div class="col-md-3">
                                            <label class="mil-text-s mil-soft mil-mb-10">Bedrooms</label>
                                            <input class="mil-input mil-mb-15" type="number" name="bedrooms" placeholder="Number of bedrooms" value="<%= (property && property.features) ? property.features.bedrooms : '' %>">
                                        </div>
                                        <div class="col-md-3">
                                            <label class="mil-text-s mil-soft mil-mb-10">Bathrooms</label>
                                            <input class="mil-input mil-mb-15" type="number" name="bathrooms" placeholder="Number of bathrooms" value="<%= (property && property.features) ? property.features.bathrooms : '' %>">
                                        </div>
                                        <div class="col-md-3">
                                            <label class="mil-text-s mil-soft mil-mb-10">Toilets</label>
                                            <input class="mil-input mil-mb-15" type="number" name="toilets" placeholder="Number of toilets" value="<%= (property && property.features) ? property.features.toilets : '' %>">
                                        </div>
                                        <div class="col-md-3">
                                            <label class="mil-text-s mil-soft mil-mb-10">Parking Spaces</label>
                                            <input class="mil-input mil-mb-15" type="number" name="parkingSpaces" placeholder="Parking capacity" value="<%= (property && property.features) ? property.features.parkingSpaces : '' %>">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="mil-text-s mil-soft mil-mb-10">Floor Area (sqm)</label>
                                            <input class="mil-input mil-mb-15" type="number" step="0.01" name="floorArea" placeholder="Floor area in square meters" value="<%= (property && property.features) ? property.features.floorArea : '' %>">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="mil-text-s mil-soft mil-mb-10">Land Area (sqm)</label>
                                            <input class="mil-input mil-mb-15" type="number" step="0.01" name="landArea" placeholder="Land area in square meters" value="<%= (property && property.features) ? property.features.landArea : '' %>">
                                        </div>
                                    </div>

                                    <!-- Amenities -->
                                    <h3 class="mil-mb-30 mil-mt-30">Amenities</h3>
                                    <div class="row">
                                        <div class="col-md-3">
                                            <label class="mil-text-s mil-soft mil-mb-10">
                                                <input type="checkbox" name="furnished" <%= (property && property.features && property.features.furnished) ? 'checked' : '' %>> Furnished
                                            </label>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="mil-text-s mil-soft mil-mb-10">
                                                <input type="checkbox" name="serviced" <%= (property && property.features && property.features.serviced) ? 'checked' : '' %>> Serviced
                                            </label>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="mil-text-s mil-soft mil-mb-10">
                                                <input type="checkbox" name="security" <%= (property && property.features && property.features.security) ? 'checked' : '' %>> 24/7 Security
                                            </label>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="mil-text-s mil-soft mil-mb-10">
                                                <input type="checkbox" name="powerSupply" <%= (property && property.features && property.features.powerSupply) ? 'checked' : '' %>> Power Supply
                                            </label>
                                        </div>
                                        <div class="col-md-12">
                                            <label class="mil-text-s mil-soft mil-mb-10">
                                                <input type="checkbox" name="borehole" <%= (property && property.features && property.features.borehole) ? 'checked' : '' %>> Borehole
                                            </label>
                                        </div>
                                    </div>

                                    <!-- Images Upload -->
                                    <h3 class="mil-mb-30 mil-mt-30">Property Images</h3>
                                    <div class="row">
                                        <div class="col-md-12">
                                            <label class="mil-text-s mil-soft mil-mb-10">Upload Images</label>
                                            <input class="mil-input mil-mb-15" type="file" name="images" accept="image/*" multiple>
                                            <p class="mil-text-xs mil-soft">You can select multiple images. First image will be the primary image.</p>
                                        </div>
                                    </div>

                                    <% if (property && property.images && property.images.length > 0) { %>
                                        <div class="row mil-mt-30">
                                            <div class="col-md-12">
                                                <h4>Current Images</h4>
                                                <div class="current-images">
                                                    <% for(var i = 0; i < property.images.length; i++) { %>
                                                        <% var image = property.images[i]; %>
                                                        <div style="display: inline-block; margin: 10px;">
                                                            <img src="<%= image.url %>" alt="Property image" style="width: 100px; height: 100px; object-fit: cover; border-radius: 10px;">
                                                            <br>
                                                            <label>
                                                                <input type="checkbox" name="removeImages" value="<%= image.url %>"> Remove
                                                            </label>
                                                        </div>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>
                                    <% } %>

                                    <!-- Payment Instructions for New Property -->
                                    <% if (!property) { %>
                                        <div class="mil-price-card mil-up mil-mt-30" style="background: #f0f9ff; border-left: 4px solid #03A6A6;">
                                            <div class="mil-text-center">
                                                <i class="fa fa-bank" style="font-size: 40px; color: #03A6A6; margin-bottom: 15px;"></i>
                                                <h4 class="mil-mb-15">Verification Fee Payment</h4>
                                                <p class="mil-text-s mil-soft">After submission, you will need to pay the verification fee of <strong>₦20,000</strong> to:</p>
                                                <div style="background: white; padding: 15px; border-radius: 10px; margin: 15px 0; display: inline-block;">
                                                    <p class="mil-mb-5"><strong>Bank Name:</strong> Fidelity Bank</p>
                                                    <p class="mil-mb-5"><strong>Account Name:</strong> Revacom Ltd</p>
                                                    <p class="mil-mb-5"><strong>Account Number:</strong> 5601419395</p>
                                                </div>
                                                <p class="mil-text-xs mil-soft">Your property will be listed only after payment verification.</p>
                                            </div>
                                        </div>
                                    <% } %>

                                    <div class="mil-mt-30">
                                        <button type="submit" class="mil-btn mil-md"><%= property ? 'Update Property' : 'Submit Property' %></button>
                                        <a href="/property-owner/dashboard" class="mil-btn mil-md mil-light">Cancel</a>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <footer class="mil-p-80-0">
            <div class="container">
                <div class="mil-footer-bottom">
                    <p class="mil-text-s mil-soft">© 2026 RevaampAPA. All rights reserved.</p>
                </div>
            </div>
        </footer>
    </div>

    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/plugins/swiper.min.js"></script>
    <script src="/js/plugins/gsap.min.js"></script>
    <script src="/js/plugins/ScrollSmoother.min.js"></script>
    <script src="/js/plugins/ScrollTrigger.min.js"></script>
    <script src="/js/plugins/ScrollTo.min.js"></script>
    <script src="/js/plugins/magnific-popup.js"></script>
    <script src="/js/main.js"></script>

    <script>
        // Initialize TinyMCE Rich Text Editor
        tinymce.init({
            selector: '#propertyDescription',
            height: 400,
            menubar: true,
            plugins: [
                'advlist', 'autolink', 'lists', 'link', 'image', 'charmap', 'preview',
                'anchor', 'searchreplace', 'visualblocks', 'code', 'fullscreen',
                'insertdatetime', 'media', 'table', 'help', 'wordcount'
            ],
            toolbar: 'undo redo | blocks | ' +
                'bold italic backcolor | alignleft aligncenter ' +
                'alignright alignjustify | bullist numlist outdent indent | ' +
                'removeformat | help',
            content_style: 'body { font-family:Helvetica,Arial,sans-serif; font-size:16px }',
            setup: function(editor) {
                editor.on('change', function() {
                    editor.save();
                });
            }
        });
    </script>

    <style>
        .dropdown-menu { display: none; }
        .dropdown:hover .dropdown-menu { display: block; }
        .mil-input { width: 100%; padding: 12px 15px; border: 1px solid #e0e0e0; border-radius: 8px; }
        .mil-mt-30 { margin-top: 30px; }
        .mil-mb-10 { margin-bottom: 10px; }
        .mil-mb-15 { margin-bottom: 15px; }
        .mil-mb-30 { margin-bottom: 30px; }
        label { display: block; margin-bottom: 5px; font-weight: 500; }
        
        /* TinyMCE container styling */
        .tox-tinymce {
            border-radius: 8px !important;
            border-color: #e0e0e0 !important;
        }
    </style>
</body>
</html>