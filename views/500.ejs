<!DOCTYPE html>
<html lang="en-US">

<head>
    <title>500 - Server Error | RevaampAP</title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Server error on RevaampAP">
    
    <!-- switzer font css -->
    <link rel="stylesheet" href="/fonts/css/switzer.css" type="text/css" media="all">
    <!-- font awesome css -->
    <link rel="stylesheet" href="/fonts/css/font-awesome.min.css" type="text/css" media="all">
    <!-- bootstrap grid css -->
    <link rel="stylesheet" href="/css/plugins/bootstrap-grid.css" type="text/css" media="all">
    <!-- swiper css -->
    <link rel="stylesheet" href="/css/plugins/swiper.min.css" type="text/css" media="all">
    <!-- magnific popup -->
    <link rel="stylesheet" href="/css/plugins/magnific-popup.css" type="text/css" media="all">
    <!-- plax css -->
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <!-- custom css -->
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">

    <!-- Favicon -->
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>

<body>

    <!-- wrapper -->
    <div id="smooth-wrapper" class="mil-wrapper">

        <!-- preloader -->
        <div class="mil-preloader">
            <div class="mil-load"></div>
            <p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p>
        </div>
        <!-- preloader end -->

        <!-- scroll progress -->
        <div class="mil-progress-track">
            <div class="mil-progress"></div>
        </div>
        <!-- scroll progress end -->

        <!-- back to top -->
        <div class="progress-wrap active-progress"></div>

        <!-- top panel -->
        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo">
                    <img src="/img/logo.png" alt="RevaampAP" width="83" height="32">
                </a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/properties">Properties</a></li>
                        <li><a href="/about">About</a></li>
                        <li><a href="/contact">Contact</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <% if (user) { %>
                        <div class="dropdown" style="position: relative;">
                            <a href="#" class="mil-btn mil-sm dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="fa fa-user-circle"></i> <%= user.name %>
                                <i class="fa fa-chevron-down" style="margin-left: 8px; font-size: 12px;"></i>
                            </a>
                            <ul class="dropdown-menu" style="position: absolute; right: 0; top: 100%; min-width: 200px; background: white; border-radius: 10px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); padding: 10px 0;">
                                <li><a href="/dashboard" style="display: block; padding: 10px 20px; color: #333; text-decoration: none;"><i class="fa fa-tachometer"></i> Dashboard</a></li>
                                <li><a href="/dashboard/settings" style="display: block; padding: 10px 20px; color: #333; text-decoration: none;"><i class="fa fa-cog"></i> Settings</a></li>
                                <li><hr style="margin: 5px 0;"></li>
                                <li><a href="/logout" style="display: block; padding: 10px 20px; color: #dc3545; text-decoration: none;"><i class="fa fa-sign-out-alt"></i> Logout</a></li>
                            </ul>
                        </div>
                    <% } else { %>
                        <a href="/login" class="mil-btn mil-sm">Log in</a>
                        <a href="/register" class="mil-btn mil-sm mil-light">List Property</a>
                    <% } %>
                    <div class="mil-menu-btn">
                        <span></span>
                    </div>
                </div>
            </div>
        </div>
        <!-- top panel end -->

        <!-- content -->
        <div id="smooth-content">
            <div class="mil-banner mil-banner-inner mil-dissolve" style="min-height: 70vh; display: flex; align-items: center;">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-error-code" style="font-size: 120px; font-weight: 700; color: #dc3545; margin-bottom: 20px;">500</div>
                                <h1 class="mil-mb-30">Server Error</h1>
                                <p class="mil-text-m mil-soft mil-mb-60">Something went wrong on our end. Please try again later.</p>
                                <div class="mil-buttons-frame">
                                    <a href="/" class="mil-btn mil-md">Back to Home</a>
                                    <a href="/contact" class="mil-btn mil-md mil-light">Contact Support</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- content end -->

        <!-- footer -->
        <footer class="mil-p-80-0">
            <div class="container">
                <div class="mil-footer-bottom">
                    <div class="row">
                        <div class="col-xl-6">
                            <p class="mil-text-s mil-soft">© 2024 RevaampAP. All rights reserved.</p>
                        </div>
                        <div class="col-xl-6">
                            <p class="mil-text-s mil-text-right mil-sm-text-left mil-soft">Property Promotion Platform</p>
                        </div>
                    </div>
                </div>
            </div>
        </footer>
        <!-- footer end -->

    </div>
    <!-- wrapper end -->

    <!-- jquery js -->
    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/plugins/swiper.min.js"></script>
    <script src="/js/plugins/gsap.min.js"></script>
    <script src="/js/plugins/ScrollSmoother.min.js"></script>
    <script src="/js/plugins/ScrollTrigger.min.js"></script>
    <script src="/js/plugins/ScrollTo.min.js"></script>
    <script src="/js/plugins/magnific-popup.js"></script>
    <script src="/js/main.js"></script>

    <style>
        .dropdown-menu {
            display: none;
        }
        .dropdown:hover .dropdown-menu,
        .dropdown .dropdown-menu.show {
            display: block;
        }
    </style>
</body>
</html>