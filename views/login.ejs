<!DOCTYPE html>
<html lang="en-US">

<head>
    <title>Login to RevaampAP | Property Promotion Platform</title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="HandheldFriendly" content="true">
    <meta name="author" content="RevaampAP" />
    <meta name="description" content="Login to your RevaampAP account. Access your dashboard, manage properties, track earnings, and more." />
        <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://revaampapa.com/">
    <meta property="og:title" content="RevaampAPA - Aggregation, Promotions & Agency Platform">
    <meta property="og:description" content="Africa's leading aggregation, promotions and agency platform. Find verified properties, manage projects, and earn up to 90% commission as a promoter. FREE registration!">
    <meta property="og:image" content="https://revaampapa.com/img/og-image.jpg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:site_name" content="RevaampAPA">
    <meta property="og:locale" content="en_NG">
    <meta property="og:image:alt" content="RevaampAPA - Property Aggregation, Promotions & Agency Platform">
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="https://revaampapa.com/">
    <meta name="twitter:title" content="RevaampAPA - Aggregation, Promotions & Agency Platform">
    <meta name="twitter:description" content="Find verified properties, manage projects, and earn up to 90% commission as a promoter. FREE registration!">
    <meta name="twitter:image" content="https://revaampapa.com/img/twitter-card.jpg">
    <meta name="twitter:site" content="@revaampap">
    <meta name="twitter:creator" content="@revaampap">
    
    <!-- Additional OG Tags -->
    <meta property="og:email" content="info@revaampapa.com">
    <meta property="og:phone_number" content="+2348000000000">
    <meta property="og:country_name" content="Nigeria">
    
    <!-- Article Specific (if applicable) -->
    <meta property="article:publisher" content="https://facebook.com/revaampapa">
    <meta property="article:author" content="https://facebook.com/revaampapa">
    <meta property="article:published_time" content="2024-01-01T00:00:00+00:00">
    <meta property="article:modified_time" content="2024-01-01T00:00:00+00:00">
    
    <!-- WhatsApp Preview -->
    <meta property="og:image:type" content="image/jpeg">
    <meta property="og:image:secure_url" content="https://revaampapa.com/img/og-image.jpg">
    
    <!-- LinkedIn Specific -->
    <meta property="linkedin:card" content="summary_large_image">
    
    <!-- Pinterest Specific -->
    <meta name="pinterest:richpins" content="enabled">
    <!-- switzer font css -->
    <link rel="stylesheet" href="/fonts/css/switzer.css" type="text/css" media="all">
    <!-- font awesome css -->
    <link rel="stylesheet" href="/fonts/css/font-awesome.min.css" type="text/css" media="all">
    <!-- bootstrap grid css -->
    <link rel="stylesheet" href="/css/plugins/bootstrap-grid.css" type="text/css" media="all">
    <!-- swiper css -->
    <link rel="stylesheet" href="/css/plugins/swiper.min.css" type="text/css" media="all">
    <!-- magnific popup -->
    <link rel="stylesheet" href="/css/plugins/magnific-popup.css" type="text/css" media="all">
    <!-- plax css -->
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <!-- custom css -->
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">

    <!-- Favicon -->
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>

<body>

    <!-- wrapper -->
    <div id="smooth-wrapper" class="mil-wrapper">

        <!-- preloader -->
        <div class="mil-preloader">
            <div class="mil-load"></div>
            <p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p>
        </div>
        <!-- preloader end -->

        <!-- scroll progress -->
        <div class="mil-progress-track">
            <div class="mil-progress"></div>
        </div>
        <!-- scroll progress end -->

        <!-- back to top -->
        <div class="progress-wrap active-progress"></div>

        <!-- top panel -->
        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo">
                    <img src="/img/logo.png" alt="RevaampAP" width="83" height="32">
                </a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/properties">Properties</a></li>
                        <li class="mil-has-children">
                            <a href="#">For Owners</a>
                            <ul>
                                <li><a href="/register">List Your Property</a></li>
                                <li><a href="/how-it-works#verification">Verification Process</a></li>
                                <li><a href="/how-it-works#fees">Pricing & Fees</a></li>
                            </ul>
                        </li>
                        <li class="mil-has-children">
                            <a href="#">For Promoters</a>
                            <ul>
                                <li><a href="/promoter/register">Become a Promoter</a></li>
                                <li><a href="/how-it-works#promoter">How It Works</a></li>
                                <li><a href="/how-it-works#commission">Commission Structure</a></li>
                            </ul>
                        </li>
                        <li><a href="/about">About</a></li>
                        <li><a href="/contact">Contact</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <a href="/login" class="mil-btn mil-sm mil-light">Log in</a>
                    <a href="/register" class="mil-btn mil-sm">Register</a>
                    <div class="mil-menu-btn">
                        <span></span>
                    </div>
                </div>
            </div>
        </div>
        <!-- top panel end -->

        <!-- Flash Messages -->
        <% if (error && error.length) { %>
            <div class="alert alert-danger alert-dismissible fade show m-3" style="position: fixed; top: 100px; right: 20px; z-index: 9999; background: #f8d7da; color: #721c24; padding: 15px 20px; border-radius: 10px; border-left: 4px solid #dc3545;">
                <i class="fas fa-exclamation-circle"></i> <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" style="float: right; background: none; border: none; font-size: 20px; cursor: pointer;">&times;</button>
            </div>
        <% } %>
        <% if (success && success.length) { %>
            <div class="alert alert-success alert-dismissible fade show m-3" style="position: fixed; top: 100px; right: 20px; z-index: 9999; background: #d4edda; color: #155724; padding: 15px 20px; border-radius: 10px; border-left: 4px solid #28a745;">
                <i class="fas fa-check-circle"></i> <%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" style="float: right; background: none; border: none; font-size: 20px; cursor: pointer;">&times;</button>
            </div>
        <% } %>

        <!-- content -->
        <div id="smooth-content">

            <!-- banner -->
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-text-m mil-mb-20 mil-up">Welcome Back</div>
                                <h1 class="mil-mb-60 mil-up">Login to Your Account</h1>
                                <ul class="mil-breadcrumbs mil-center mil-up">
                                    <li><a href="/">Home</a></li>
                                    <li><a href="/login">Login</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- banner end -->

            <!-- login form -->
            <div class="mil-blog-list mip-p-0-160">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-xl-5">
                            <form action="/login" method="POST">
                                <input class="mil-input mil-up mil-mb-15" type="email" name="email" placeholder="Email address" required>
                                <input class="mil-input mil-up mil-mb-15" type="password" name="password" placeholder="Password" required>

                                <div class="mil-checkbox-frame mil-up mil-mb-30">
                                    <div class="mil-checkbox">
                                        <input type="checkbox" id="remember" name="remember">
                                        <label for="remember"></label>
                                    </div>
                                    <p class="mil-text-xs mil-soft">Remember Me</p>
                                </div>

                                <div class="mil-up mil-mb-30">
                                    <button type="submit" class="mil-btn mil-md mil-fw">Login</button>
                                </div>

                                <p class="mil-text-xs mil-text-center mil-soft mil-mb-30">Or login with:</p>
                                
                                <div class="mil-up mil-mb-15">
                                    <a href="#" class="mil-btn mil-md mil-grey mil-fw mil-mb-30">
                                        <i class="fab fa-google"></i> Sign in with Google
                                    </a>
                                </div>

                                <p class="mil-text-xs mil-text-center mil-soft mil-mt-30">
                                    Don't have an account? <a href="/register" class="mil-accent">Register as Property Owner</a>
                                </p>
                                <p class="mil-text-xs mil-text-center mil-soft">
                                    Want to earn commissions? <a href="/promoter/register" class="mil-accent">Become a Promoter →</a>
                                </p>
                                <p class="mil-text-xs mil-text-center mil-soft mil-mt-15">
                                    <a href="/forgot-password" class="mil-accent">Forgot Password?</a>
                                </p>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- login form end -->
            
            <div class="mil-space-fix"></div>

            <!-- footer -->
            <footer>
                <div class="container">
                    <div class="row">
                        <div class="col-xl-3">
                            <a href="/" class="mil-footer-logo mil-mb-60">
                                <img src="/img/logo-2.png" alt="RevaampAP" width="28" height="32">
                            </a>
                        </div>
                        <div class="col-xl-3 mil-mb-60">
                            <h6 class="mil-mb-60">Useful Links</h6>
                            <ul class="mil-footer-list">
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/">Home</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/about">About Us</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/contact">Contact Us</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/properties">Properties</a></li>
                            </ul>
                        </div>
                        <div class="col-xl-3 mil-mb-60">
                            <h6 class="mil-mb-60">For Owners</h6>
                            <ul class="mil-footer-list">
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/register">List Your Property</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/how-it-works#verification">Verification Process</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/how-it-works#fees">Pricing & Fees</a></li>
                            </ul>
                        </div>
                        <div class="col-xl-3 mil-mb-80">
                            <h6 class="mil-mb-60">For Promoters</h6>
                            <ul class="mil-footer-list">
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/promoter/register">Become a Promoter</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/how-it-works#promoter">How It Works</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/how-it-works#commission">Commission Structure</a></li>
                            </ul>
                        </div>
                    </div>
                    <div class="mil-footer-bottom">
                        <div class="row">
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-soft">© 2026 RevaampAP. All rights reserved.</p>
                            </div>
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-text-right mil-sm-text-left mil-soft">Design & Development by <a href="https://shedfactory.co" target="_blank" style="color: #667eea; text-decoration: none;">Shed Factory</a></p>
                            </div>
                        </div>
                    </div>
                </div>
            </footer>
            <!-- footer end -->

        </div>
        <!-- content end -->
    </div>
    <!-- wrapper end -->

    <!-- jquery js -->
    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/plugins/swiper.min.js"></script>
    <script src="/js/plugins/gsap.min.js"></script>
    <script src="/js/plugins/ScrollSmoother.min.js"></script>
    <script src="/js/plugins/ScrollTrigger.min.js"></script>
    <script src="/js/plugins/ScrollTo.min.js"></script>
    <script src="/js/plugins/magnific-popup.js"></script>
    <script src="/js/main.js"></script>

    <script>
        // Auto-close flash messages
        setTimeout(function() {
            document.querySelectorAll('.alert').forEach(function(alert) {
                alert.style.opacity = '0';
                setTimeout(function() {
                    if (alert.parentNode) alert.remove();
                }, 300);
            });
        }, 5000);
    </script>
</body>
</html>