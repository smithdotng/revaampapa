<!DOCTYPE html>
<html lang="en-US">

<head>
    <title><%= title %></title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <link rel="stylesheet" href="/fonts/css/switzer.css" type="text/css" media="all">
    <link rel="stylesheet" href="/fonts/css/font-awesome.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/bootstrap-grid.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/swiper.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/magnific-popup.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>

<body>
    <div id="smooth-wrapper" class="mil-wrapper">
        <div class="mil-preloader"><div class="mil-load"></div><p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p></div>
        <div class="mil-progress-track"><div class="mil-progress"></div></div>
        <div class="progress-wrap active-progress"></div>

        <!-- Top Panel -->
        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo"><img src="/img/logo.png" alt="RevaampAPA" width="83" height="32"></a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li class="mil-active"><a href="/solicitor/dashboard">Dashboard</a></li>
                        <li><a href="/solicitor/transactions">Transactions</a></li>
                        <li><a href="/solicitor/referrals">Referrals</a></li>
                        <li><a href="/solicitor/kpis">KPIs</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <div class="dropdown" style="position: relative;">
                        <a href="#" class="mil-btn mil-sm dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="fa fa-user-circle"></i> <%= user.name %> <i class="fa fa-chevron-down"></i>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a href="/solicitor/dashboard"><i class="fa fa-tachometer"></i> Dashboard</a></li>
                            <li><a href="/solicitor/settings"><i class="fa fa-cog"></i> Settings</a></li>
                            <li><hr></li>
                            <li><a href="/logout"><i class="fa fa-sign-out-alt"></i> Logout</a></li>
                        </ul>
                    </div>
                    <div class="mil-menu-btn"><span></span></div>
                </div>
            </div>
        </div>

        <div id="smooth-content">
            <!-- Banner -->
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-text-m mil-mb-20">Welcome back, <%= user.name %>!</div>
                                <h1 class="mil-mb-60">REVAAMP Partner Solicitor Dashboard</h1>
                                <ul class="mil-breadcrumbs mil-pub-info mil-center mil-up">
                                    <li><a href="/">Home</a></li>
                                    <li><a href="/solicitor/dashboard">Dashboard</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stats Cards -->
            <div class="mil-blog-list mil-p-0-80">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <i class="fa fa-gavel" style="font-size: 40px; color: #03A6A6; margin-bottom: 15px;"></i>
                                <h4><%= stats.transactionsInitiated %></h4>
                                <p class="mil-text-s mil-soft">Transactions Initiated</p>
                            </div>
                        </div>
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <i class="fa fa-users" style="font-size: 40px; color: #ffc107; margin-bottom: 15px;"></i>
                                <h4><%= stats.promotersOnboarded %></h4>
                                <p class="mil-text-s mil-soft">Promoters Onboarded</p>
                            </div>
                        </div>
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <i class="fa fa-handshake-o" style="font-size: 40px; color: #28a745; margin-bottom: 15px;"></i>
                                <h4><%= stats.cooperativeSocieties || 0 %></h4>
                                <p class="mil-text-s mil-soft">Cooperative Societies</p>
                            </div>
                        </div>
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <i class="fa fa-money" style="font-size: 40px; color: #03A6A6; margin-bottom: 15px;"></i>
                                <h4>₦<%= stats.totalEarnings.toLocaleString() %></h4>
                                <p class="mil-text-s mil-soft">Total Legal Fees</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Status Cards -->
            <div class="mil-blog-list mil-p-0-80">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-6 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4>Account Status</h4>
                                <div class="mil-mt-15">
                                    <% if (user.partnerProfile && user.partnerProfile.isActive) { %>
                                        <span style="background: #28a745; color: white; padding: 5px 15px; border-radius: 20px;">✓ Active</span>
                                        <p class="mil-text-s mil-soft mil-mt-15">Your account is active. You can initiate transactions and onboard promoters.</p>
                                    <% } else { %>
                                        <span style="background: #ffc107; color: #856404; padding: 5px 15px; border-radius: 20px;">⏳ Pending Approval</span>
                                        <p class="mil-text-s mil-soft mil-mt-15">Your application is being reviewed. You'll be notified once approved.</p>
                                    <% } %>
                                </div>
                                <div class="mil-mt-15">
                                    <a href="/solicitor/mandate" class="mil-link mil-accent">View Mandate Letter →</a>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-6 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4>Performance Summary</h4>
                                <div class="mil-mt-15">
                                    <div class="mil-flex-between mil-mb-10">
                                        <span class="mil-text-s mil-soft">Transactions Initiated:</span>
                                        <span class="mil-text-s mil-bold"><%= stats.transactionsInitiated %> / 4 (Quarterly Target)</span>
                                    </div>
                                    <div class="progress-bar" style="background: #e0e0e0; border-radius: 10px; height: 8px;">
                                        <div style="width: <%= Math.min((stats.transactionsInitiated / 4) * 100, 100) %>%; background: #03A6A6; border-radius: 10px; height: 8px;"></div>
                                    </div>
                                    <div class="mil-flex-between mil-mt-10">
                                        <span class="mil-text-s mil-soft">Promoters Onboarded:</span>
                                        <span class="mil-text-s mil-bold"><%= stats.promotersOnboarded %> / 15 (Quarterly Target)</span>
                                    </div>
                                    <div class="progress-bar" style="background: #e0e0e0; border-radius: 10px; height: 8px;">
                                        <div style="width: <%= Math.min((stats.promotersOnboarded / 15) * 100, 100) %>%; background: #03A6A6; border-radius: 10px; height: 8px;"></div>
                                    </div>
                                </div>
                                <div class="mil-mt-15">
                                    <a href="/solicitor/kpis" class="mil-link mil-accent">Update KPIs →</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Earnings Overview -->
            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-8">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4 class="mil-mb-30">Earnings Overview</h4>
                                <canvas id="earningsChart" style="width: 100%; height: 300px;"></canvas>
                            </div>
                        </div>
                        <div class="col-xl-4">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4 class="mil-mb-30">Commission Breakdown</h4>
                                <div class="mil-mb-20">
                                    <div class="mil-flex-between mil-mb-10">
                                        <span class="mil-text-s mil-soft">Your Legal Fees:</span>
                                        <span class="mil-text-s mil-bold">70%</span>
                                    </div>
                                    <div class="progress-bar" style="background: #e0e0e0; border-radius: 10px; height: 10px;">
                                        <div style="width: 70%; background: #28a745; border-radius: 10px; height: 10px;"></div>
                                    </div>
                                </div>
                                <div class="mil-mb-20">
                                    <div class="mil-flex-between mil-mb-10">
                                        <span class="mil-text-s mil-soft">Administrative Fee:</span>
                                        <span class="mil-text-s mil-bold">10%</span>
                                    </div>
                                    <div class="progress-bar" style="background: #e0e0e0; border-radius: 10px; height: 10px;">
                                        <div style="width: 10%; background: #ffc107; border-radius: 10px; height: 10px;"></div>
                                    </div>
                                </div>
                                <div class="mil-mt-30 mil-text-center">
                                    <p class="mil-text-s mil-soft">When you initiate a transaction, you earn <strong class="mil-accent">70% of legal fees</strong> even if other lawyers execute it.</p>
                                    <p class="mil-text-s mil-soft mil-mt-15">Plus <strong class="mil-accent">60% of monthly legal fees</strong> from aggregation projects!</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Transactions -->
            <div class="mil-blog-list mil-p-0-80">
                <div class="container">
                    <div class="mil-text-center">
                        <h2 class="mil-mb-30 mil-up">Recent Transactions</h2>
                        <p class="mil-text-m mil-soft mil-mb-60 mil-up">Your latest legal engagements</p>
                    </div>
                    <div class="row">
                        <div class="col-xl-12">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <% if (transactions && transactions.length > 0) { %>
                                    <div class="mil-table-responsive">
                                        <table class="mil-table" style="width: 100%; border-collapse: collapse;">
                                            <thead>
                                                <tr style="border-bottom: 1px solid #eee;">
                                                    <th style="padding: 12px; text-align: left;">Transaction Type</th>
                                                    <th style="padding: 12px; text-align: left;">Property/Project</th>
                                                    <th style="padding: 12px; text-align: left;">Legal Fee</th>
                                                    <th style="padding: 12px; text-align: left;">Date</th>
                                                    <th style="padding: 12px; text-align: left;">Status</th>
                                                 </tr>
                                            </thead>
                                            <tbody>
                                                <% transactions.forEach(function(transaction) { %>
                                                    <tr style="border-bottom: 1px solid #f0f0f0;">
                                                        <td style="padding: 12px;">
                                                            <% if(transaction.type === 'property_sale') { %>Property Sale
                                                            <% } else if(transaction.type === 'cooperative_setup') { %>Cooperative Setup
                                                            <% } else { %>Legal Advisory<% } %>
                                                         </td>
                                                        <td style="padding: 12px;"><%= transaction.property?.title || 'N/A' %></td>
                                                        <td style="padding: 12px; color: #28a745; font-weight: bold;">₦<%= (transaction.legalFee || 0).toLocaleString() %></td>
                                                        <td style="padding: 12px;"><%= new Date(transaction.createdAt).toLocaleDateString() %></td>
                                                        <td style="padding: 12px;">
                                                            <% if (transaction.status === 'completed') { %>
                                                                <span style="background: #28a745; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Completed</span>
                                                            <% } else { %>
                                                                <span style="background: #ffc107; color: #856404; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Pending</span>
                                                            <% } %>
                                                         </td>
                                                     </tr>
                                                <% }); %>
                                            </tbody>
                                         </table>
                                    </div>
                                    <div class="mil-mt-30 mil-text-center">
                                        <a href="/solicitor/transactions" class="mil-link mil-accent">View All Transactions →</a>
                                    </div>
                                <% } else { %>
                                    <div class="mil-text-center mil-p-40">
                                        <i class="fa fa-gavel" style="font-size: 60px; opacity: 0.3; margin-bottom: 20px;"></i>
                                        <h4 class="mil-mb-15">No Transactions Yet</h4>
                                        <p class="mil-text-m mil-soft mil-mb-30">Start initiating transactions to earn legal fees!</p>
                                        <a href="/solicitor/initiate" class="mil-btn mil-md">Initiate Transaction</a>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- REVAAMP Solutions Section -->
            <div class="mil-cta mil-up">
                <div class="container">
                    <div class="mil-out-frame mil-p-80-80" style="background: linear-gradient(135deg, #2c3e50 0%, #3498db 100%);">
                        <div class="row justify-content-between align-items-center">
                            <div class="col-xl-12 mil-text-center">
                                <h2 class="mil-light mil-mb-30 mil-up">REVAAMP Solutions You Can Support</h2>
                                <div class="row">
                                    <div class="col-md-3 mil-mb-20">
                                        <p class="mil-text-s mil-light">✓ Joint Ownership Solution</p>
                                    </div>
                                    <div class="col-md-3 mil-mb-20">
                                        <p class="mil-text-s mil-light">✓ Project Management Solution</p>
                                    </div>
                                    <div class="col-md-3 mil-mb-20">
                                        <p class="mil-text-s mil-light">✓ Equity Release Scheme</p>
                                    </div>
                                    <div class="col-md-3 mil-mb-20">
                                        <p class="mil-text-s mil-light">✓ Mortgage Scheme</p>
                                    </div>
                                    <div class="col-md-3 mil-mb-20">
                                        <p class="mil-text-s mil-light">✓ Land Swap Scheme</p>
                                    </div>
                                    <div class="col-md-3 mil-mb-20">
                                        <p class="mil-text-s mil-light">✓ Students Housing Scheme</p>
                                    </div>
                                    <div class="col-md-3 mil-mb-20">
                                        <p class="mil-text-s mil-light">✓ Staff Housing Scheme</p>
                                    </div>
                                    <div class="col-md-3 mil-mb-20">
                                        <p class="mil-text-s mil-light">✓ Food Court Scheme</p>
                                    </div>
                                </div>
                                <div class="mil-up mil-mt-30">
                                    <a href="/solicitor/initiate" class="mil-btn mil-md mil-light">Initiate a Transaction</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-4 col-md-6 mil-mb-30">
                            <div class="mil-price-card mil-up mil-text-center" style="height: 100%;">
                                <i class="fa fa-users" style="font-size: 50px; color: #03A6A6; margin-bottom: 15px;"></i>
                                <h4>Onboard Promoters</h4>
                                <p class="mil-text-s mil-soft mil-mb-30">Invite real estate agents and marketers to join REVAAMP</p>
                                <a href="/solicitor/onboard-promoter" class="mil-link mil-accent">Get Referral Link →</a>
                            </div>
                        </div>
                        <div class="col-xl-4 col-md-6 mil-mb-30">
                            <div class="mil-price-card mil-up mil-text-center" style="height: 100%;">
                                <i class="fa fa-leaf" style="font-size: 50px; color: #03A6A6; margin-bottom: 15px;"></i>
                                <h4>Establish Cooperative</h4>
                                <p class="mil-text-s mil-soft mil-mb-30">Set up Hectare by Hectare Premium Cooperative Societies</p>
                                <a href="/solicitor/establish-cooperative" class="mil-link mil-accent">Learn More →</a>
                            </div>
                        </div>
                        <div class="col-xl-4 col-md-6 mil-mb-30">
                            <div class="mil-price-card mil-up mil-text-center" style="height: 100%;">
                                <i class="fa fa-graduation-cap" style="font-size: 50px; color: #03A6A6; margin-bottom: 15px;"></i>
                                <h4>Train Other Solicitors</h4>
                                <p class="mil-text-s mil-soft mil-mb-30">Onboard and train solicitors for cooperative establishment</p>
                                <a href="/solicitor/train-solicitors" class="mil-link mil-accent">Get Started →</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <footer class="mil-p-80-0">
                <div class="container">
                    <div class="mil-footer-bottom">
                        <div class="row">
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-soft">© 2024 RevaampAPA. All rights reserved.</p>
                            </div>
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-text-right mil-sm-text-left mil-soft">REVAAMP Partner Solicitor Dashboard</p>
                            </div>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/plugins/swiper.min.js"></script>
    <script src="/js/plugins/gsap.min.js"></script>
    <script src="/js/plugins/ScrollSmoother.min.js"></script>
    <script src="/js/plugins/ScrollTrigger.min.js"></script>
    <script src="/js/plugins/ScrollTo.min.js"></script>
    <script src="/js/plugins/magnific-popup.js"></script>
    <script src="/js/main.js"></script>

    <script>
        // Sample earnings chart data
        const ctx = document.getElementById('earningsChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                datasets: [{
                    label: 'Legal Fees (₦)',
                    data: [0, 0, 0, 0, 0, 0],
                    borderColor: '#03A6A6',
                    backgroundColor: 'rgba(3, 166, 166, 0.1)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { position: 'top' },
                    tooltip: { callbacks: { label: function(context) { return `₦${context.raw.toLocaleString()}`; } } }
                },
                scales: { y: { beginAtZero: true, ticks: { callback: function(value) { return '₦' + value.toLocaleString(); } } } }
            }
        });

        // Load actual earnings data
        async function loadEarningsData() {
            try {
                const response = await fetch('/solicitor/api/earnings');
                const data = await response.json();
                if (data.success && data.monthlyData) {
                    const chart = Chart.getChart('earningsChart');
                    if (chart) {
                        chart.data.labels = data.monthlyData.map(item => item.month);
                        chart.data.datasets[0].data = data.monthlyData.map(item => item.earnings);
                        chart.update();
                    }
                }
            } catch (error) {
                console.error('Error loading earnings data:', error);
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            loadEarningsData();
        });
    </script>

    <style>
        .dropdown-menu { display: none; }
        .dropdown:hover .dropdown-menu { display: block; }
        .dropdown-menu li a:hover { background: #f8f9fa; padding-left: 25px; }
        .mil-table-responsive { overflow-x: auto; }
        .mil-table { width: 100%; }
        .mil-p-40 { padding: 40px; }
        .mil-flex-between { display: flex; justify-content: space-between; align-items: center; }
        .mil-mt-10 { margin-top: 10px; }
        .mil-mt-15 { margin-top: 15px; }
        .mil-mb-10 { margin-bottom: 10px; }
        .mil-mb-20 { margin-bottom: 20px; }
        .progress-bar { background: #e0e0e0; border-radius: 10px; height: 8px; overflow: hidden; }
        @media (max-width: 768px) {
            .mil-table th, .mil-table td { padding: 8px; font-size: 12px; }
        }
    </style>
</body>
</html>