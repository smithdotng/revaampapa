<!DOCTYPE html>
<html lang="en-US">
<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="HandheldFriendly" content="true">
    <meta name="author" content="RevaampAPA">
    <meta name="robots" content="index, follow">
    <meta name="language" content="English">
    <meta name="revisit-after" content="7 days">
    
    <!-- Primary Meta Tags -->
    <meta name="title" content="Hectare by Hectare Solicitor | Support Cooperative Societies | REVAAMP">
    <meta name="description" content="Join the Hectare by Hectare programme as a solicitor. Support premium cooperative societies in agriculture and real estate across Africa.">
    <meta name="keywords" content="Hectare by Hectare solicitor, cooperative society legal, agricultural law, real estate cooperative, Africa legal services">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://revaampapa.com/solicitor/hectare/register">
    <meta property="og:title" content="Hectare by Hectare Solicitor | Support Cooperative Societies">
    <meta property="og:description" content="Join the Hectare by Hectare programme as a solicitor. Support premium cooperative societies in agriculture and real estate across Africa.">
    <meta property="og:image" content="https://revaampapa.com/img/og-hectare-solicitor.jpg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:site_name" content="RevaampAPA">
    <meta property="og:locale" content="en_NG">
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="https://revaampapa.com/solicitor/hectare/register">
    <meta name="twitter:title" content="Hectare by Hectare Solicitor | Support Cooperative Societies">
    <meta name="twitter:description" content="Join the Hectare by Hectare programme as a solicitor. Support premium cooperative societies in agriculture and real estate across Africa.">
    <meta name="twitter:image" content="https://revaampapa.com/img/twitter-hectare-card.jpg">
    <meta name="twitter:site" content="@revaampap">
    <meta name="twitter:creator" content="@revaampap">
    
    <!-- Canonical URL -->
    <link rel="canonical" href="https://revaampapa.com/solicitor/hectare/register">
    
    <!-- Favicon -->
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    
    <!-- CSS Files -->
    <link rel="stylesheet" href="/fonts/css/switzer.css" type="text/css" media="all">
    <link rel="stylesheet" href="/fonts/css/font-awesome.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/bootstrap-grid.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/swiper.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/magnific-popup.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">
    
    <title>Hectare by Hectare Solicitor | Support Cooperative Societies | REVAAMP</title>
</head>
<body>

    <div id="smooth-wrapper" class="mil-wrapper">
        <div class="mil-preloader"><div class="mil-load"></div><p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p></div>
        <div class="mil-progress-track"><div class="mil-progress"></div></div>
        <div class="progress-wrap active-progress"></div>

        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo"><img src="/img/logo.png" alt="RevaampAPA" width="83" height="32"></a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/properties">Properties</a></li>
                        <li><a href="/about">About</a></li>
                        <li><a href="/contact">Contact</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <a href="/login" class="mil-btn mil-sm">Log in</a>
                    <a href="/register" class="mil-btn mil-sm mil-light">List Property</a>
                    <div class="mil-menu-btn"><span></span></div>
                </div>
            </div>
        </div>

        <% if (typeof error !== 'undefined' && error && error.length) { %>
            <div class="alert alert-danger alert-dismissible fade show m-3" style="position: fixed; top: 100px; right: 20px; z-index: 9999;">
                <i class="fas fa-exclamation-circle"></i> <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert">&times;</button>
            </div>
        <% } %>
        <% if (typeof success !== 'undefined' && success && success.length) { %>
            <div class="alert alert-success alert-dismissible fade show m-3" style="position: fixed; top: 100px; right: 20px; z-index: 9999;">
                <i class="fas fa-check-circle"></i> <%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert">&times;</button>
            </div>
        <% } %>

        <div id="smooth-content">
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-text-m mil-mb-20 mil-up">Join the Hectare by Hectare Programme</div>
                                <h1 class="mil-mb-60 mil-up">Hectare by Hectare Solicitor</h1>
                                <ul class="mil-breadcrumbs mil-center mil-up">
                                    <li><a href="/">Home</a></li>
                                    <li><a href="/solicitor/hectare/register">HbH Solicitor</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mil-cta mil-up mil-mt-30">
                <div class="container">
                    <div class="mil-out-frame mil-p-80-80" style="background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);">
                        <div class="row justify-content-between align-items-center">
                            <div class="col-xl-12 mil-text-center">
                                <h2 class="mil-light mil-mb-15 mil-up">🌱 Support Premium Cooperative Societies Across Africa 🌱</h2>
                                <p class="mil-text-m mil-light mil-mb-0 mil-up">Provide legal services | Corporate governance | Earn professional fees</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-xl-6">
                            <div class="mil-price-card">
                                <div class="mil-text-center mil-mb-30">
                                    <i class="fa fa-leaf" style="font-size: 60px; color: #27ae60;"></i>
                                    <h3 class="mil-mb-15 mil-mt-15">Register as HbH Solicitor</h3>
                                    <p class="mil-text-m mil-soft">Support premium cooperative societies in agriculture and real estate</p>
                                </div>
                                
                                <form action="/solicitor/hectare/register" method="POST" enctype="multipart/form-data">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="text" name="name" placeholder="Full name" required>
                                        </div>
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="email" name="email" placeholder="Email address" required>
                                        </div>
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="tel" name="phone" placeholder="Phone number" required>
                                        </div>
                                        
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="text" name="barNumber" placeholder="Enrolment Number" required>
                                        </div>
                                        
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="text" name="countryOfPractice" placeholder="Country of Practice" required>
                                        </div>
                                        
                                        <!-- Law Firm - NOT REQUIRED for HbH -->
                                        
                                        <!-- Experience - NOT REQUIRED for HbH -->
                                        
                                        <% if (!userData) { %>
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="password" name="password" placeholder="Password (min. 8 characters)" required>
                                        </div>
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-30" type="password" name="confirmPassword" placeholder="Confirm Password" required>
                                        </div>
                                        <% } else { %>
                                            <input type="hidden" name="existingUser" value="true">
                                            <div class="alert alert-info mil-mb-30">
                                                <i class="fa fa-info-circle"></i> You are already logged in as <%= userData.name %>. Your existing password will be used.
                                            </div>
                                        <% } %>
                                    </div>

                                    <h4 class="mil-mb-15 mil-up mil-mt-30">Upload Documents</h4>
                                    <div class="mil-divider mil-mb-30"></div>
                                    
                                  

                                    <div class="mil-checkbox-frame mil-up mil-mb-30">
                                        <div class="mil-checkbox">
                                            <input type="checkbox" id="mandate" name="mandate" required>
                                            <label for="mandate"></label>
                                        </div>
                                        <p class="mil-text-xs mil-soft">I accept the <a href="/solicitor/hectare/mandate" class="mil-accent">Terms for HbH Solicitor</a> and agree to support assigned cooperative societies</p>
                                    </div>

                                    <div class="mil-checkbox-frame mil-up mil-mb-30">
                                        <div class="mil-checkbox">
                                            <input type="checkbox" id="terms" name="terms" required>
                                            <label for="terms"></label>
                                        </div>
                                        <p class="mil-text-xs mil-soft">I agree to the <a href="/terms" class="mil-accent">Terms and Conditions</a> and <a href="/privacy" class="mil-accent">Privacy Policy</a></p>
                                    </div>

                                    <div class="mil-up">
                                        <button type="submit" class="mil-btn mil-md mil-fw" style="background: #27ae60;">Register as HbH Solicitor</button>
                                    </div>

                                    <div class="mil-text-center mil-mt-30">
                                        <p class="mil-text-s mil-soft">
                                            Want to join as REVAAMP Partner Solicitor? <a href="/solicitor/register" class="mil-accent">Register Here →</a>
                                        </p>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mil-features mil-p-80-80">
                <div class="container">
                    <div class="mil-text-center mil-mb-60">
                        <h2 class="mil-mb-30 mil-up">Role of a Hectare by Hectare Solicitor</h2>
                        <p class="mil-text-m mil-soft mil-up">Supporting premium cooperative societies across Africa</p>
                    </div>
                    <div class="row">
                        <div class="col-xl-4 col-md-6 mil-mb-30">
                            <div class="mil-price-card mil-up mil-mb-30 mil-text-center" style="height: 100%;">
                                <i class="fa fa-university" style="font-size: 50px; color: #27ae60; margin-bottom: 20px;"></i>
                                <h4 class="mil-mb-15">Legal Services to Cooperatives</h4>
                                <p class="mil-text-s mil-soft">Provide legal services and corporate governance to assigned premium cooperative societies</p>
                            </div>
                        </div>
                        <div class="col-xl-4 col-md-6 mil-mb-30">
                            <div class="mil-price-card mil-up mil-mb-30 mil-text-center" style="height: 100%;">
                                <i class="fa fa-leaf" style="font-size: 50px; color: #27ae60; margin-bottom: 20px;"></i>
                                <h4 class="mil-mb-15">Agricultural & Real Estate Focus</h4>
                                <p class="mil-text-s mil-soft">Specialize in agricultural financing and real estate cooperative transactions</p>
                            </div>
                        </div>
                        <div class="col-xl-4 col-md-6 mil-mb-30">
                            <div class="mil-price-card mil-up mil-mb-30 mil-text-center" style="height: 100%;">
                                <i class="fa fa-money" style="font-size: 50px; color: #27ae60; margin-bottom: 20px;"></i>
                                <h4 class="mil-mb-15">Professional Fees</h4>
                                <p class="mil-text-s mil-soft">Earn professional fees from project-based transactions and legal services</p>
                            </div>
                        </div>
                        <div class="col-xl-4 col-md-6 mil-mb-30">
                            <div class="mil-price-card mil-up mil-mb-30 mil-text-center" style="height: 100%;">
                                <i class="fa fa-gavel" style="font-size: 50px; color: #27ae60; margin-bottom: 20px;"></i>
                                <h4 class="mil-mb-15">Innovative Legal Mechanisms</h4>
                                <p class="mil-text-s mil-soft">Access innovative legal mechanisms for agriculture and real estate transactions</p>
                            </div>
                        </div>
                        <div class="col-xl-4 col-md-6 mil-mb-30">
                            <div class="mil-price-card mil-up mil-mb-30 mil-text-center" style="height: 100%;">
                                <i class="fa fa-globe" style="font-size: 50px; color: #27ae60; margin-bottom: 20px;"></i>
                                <h4 class="mil-mb-15">Pan-African Network</h4>
                                <p class="mil-text-s mil-soft">Connect with legal practitioners and stakeholders across Africa</p>
                            </div>
                        </div>
                        <div class="col-xl-4 col-md-6 mil-mb-30">
                            <div class="mil-price-card mil-up mil-mb-30 mil-text-center" style="height: 100%;">
                                <i class="fa fa-line-chart" style="font-size: 50px; color: #27ae60; margin-bottom: 20px;"></i>
                                <h4 class="mil-mb-15">Skill Development</h4>
                                <p class="mil-text-s mil-soft">Acquire new skills in cooperative governance and agricultural financing</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mil-faq mil-p-80-80">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-text-center">
                                <h2 class="mil-mb-30 mil-up">Frequently Asked Questions</h2>
                                <p class="mil-text-m mil-soft mil-mb-60 mil-up">About the Hectare by Hectare Solicitor Programme</p>
                            </div>
                            <div class="mil-accordion">
                                <div class="mil-accordion-group mil-up">
                                    <div class="mil-accordion-menu">
                                        <h5>What is the Hectare by Hectare programme?</h5>
                                        <div class="mil-accordion-icon"><i class="fas fa-chevron-up"></i></div>
                                    </div>
                                    <div class="mil-accordion-content">
                                        <p class="mil-text-m mil-soft">Hectare by Hectare is a programme that supports premium cooperative societies in agriculture and real estate across Africa, providing legal and governance support.</p>
                                    </div>
                                </div>
                                <div class="mil-accordion-group mil-up">
                                    <div class="mil-accordion-menu">
                                        <h5>Do I need law firm registration to join?</h5>
                                        <div class="mil-accordion-icon"><i class="fas fa-chevron-up"></i></div>
                                    </div>
                                    <div class="mil-accordion-content">
                                        <p class="mil-text-m mil-soft">No, law firm registration is not required for Hectare by Hectare Solicitors. You only need your enrolment number and country of practice.</p>
                                    </div>
                                </div>
                                <div class="mil-accordion-group mil-up">
                                    <div class="mil-accordion-menu">
                                        <h5>Is experience required?</h5>
                                        <div class="mil-accordion-icon"><i class="fas fa-chevron-up"></i></div>
                                    </div>
                                    <div class="mil-accordion-content">
                                        <p class="mil-text-m mil-soft">No specific experience is required to register as a Hectare by Hectare Solicitor. All qualified solicitors are welcome.</p>
                                    </div>
                                </div>
                                <div class="mil-accordion-group mil-up">
                                    <div class="mil-accordion-menu">
                                        <h5>Do I need to pay any registration fee?</h5>
                                        <div class="mil-accordion-icon"><i class="fas fa-chevron-up"></i></div>
                                    </div>
                                    <div class="mil-accordion-content">
                                        <p class="mil-text-m mil-soft">Registration is completely free. There is no upfront fee to become a Hectare by Hectare Solicitor.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mil-cta mil-up">
                <div class="container">
                    <div class="mil-out-frame mil-p-80-80" style="background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);">
                        <div class="row justify-content-between align-items-center">
                            <div class="col-xl-8 mil-sm-text-center">
                                <h2 class="mil-light mil-mb-30 mil-up">Ready to Support Cooperative Societies?</h2>
                                <p class="mil-text-m mil-mb-30 mil-dark-soft mil-up">Join the Hectare by Hectare programme and provide legal services to premium cooperative societies across Africa.</p>
                            </div>
                            <div class="col-xl-4 mil-sm-text-center">
                                <div class="mil-buttons-frame mil-up">
                                    <a href="#top" class="mil-btn mil-md mil-light">Register Now</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <footer class="mil-p-80-0">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-3">
                            <a href="/" class="mil-footer-logo mil-mb-60"><img src="/img/logo-2.png" alt="RevaampAPA" width="28" height="32"></a>
                        </div>
                        <div class="col-xl-3 mil-mb-60">
                            <h6 class="mil-mb-60">Useful Links</h6>
                            <ul class="mil-footer-list">
                                <li><a href="/">Home</a></li>
                                <li><a href="/about">About Us</a></li>
                                <li><a href="/contact">Contact Us</a></li>
                            </ul>
                        </div>
                        <div class="col-xl-3 mil-mb-60">
                            <h6 class="mil-mb-60">For Solicitors</h6>
                            <ul class="mil-footer-list">
                                <li><a href="/solicitor/register">REVAAMP Partner Solicitor</a></li>
                                <li><a href="/solicitor/hectare/register">HbH Solicitor</a></li>
                            </ul>
                        </div>
                        <div class="col-xl-3 mil-mb-80">
                            <h6 class="mil-mb-60">Newsletter</h6>
                            <form class="mil-subscripe-form-footer" id="footerNewsletterForm">
                                <input class="mil-input" type="email" placeholder="Email">
                                <button type="submit"><i class="far fa-envelope-open mil-dark"></i></button>
                            </form>
                        </div>
                    </div>
                    <div class="mil-footer-bottom">
                        <div class="row">
                            <div class="col-xl-6"><p class="mil-text-s mil-soft">© 2024 RevaampAPA. All rights reserved.</p></div>
                            <div class="col-xl-6"><p class="mil-text-s mil-text-right mil-sm-text-left mil-soft">Website by <a href="https://shedfactory.co" target="_blank">Shed Factory</a></p></div>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/plugins/swiper.min.js"></script>
    <script src="/js/plugins/gsap.min.js"></script>
    <script src="/js/plugins/ScrollSmoother.min.js"></script>
    <script src="/js/plugins/ScrollTrigger.min.js"></script>
    <script src="/js/plugins/ScrollTo.min.js"></script>
    <script src="/js/plugins/magnific-popup.js"></script>
    <script src="/js/main.js"></script>

    <script>
        setTimeout(function() {
            document.querySelectorAll('.alert').forEach(function(alert) {
                alert.style.opacity = '0';
                setTimeout(function() { if (alert.parentNode) alert.remove(); }, 300);
            });
        }, 5000);

        var footerForm = document.getElementById('footerNewsletterForm');
        if (footerForm) {
            footerForm.addEventListener('submit', function(e) {
                e.preventDefault();
                var email = footerForm.querySelector('input[type="email"]').value;
                fetch('/api/subscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: email })
                })
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    alert(data.success ? 'Successfully subscribed!' : 'Error subscribing.');
                    if (data.success) footerForm.reset();
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    alert('Error subscribing.');
                });
            });
        }
    </script>

    <style>
        .mil-fw { width: 100%; }
        .mil-mt-30 { margin-top: 30px; }
        .mil-mt-10 { margin-top: 10px; }
        .mil-mb-5 { margin-bottom: 5px; }
        .mil-mb-15 { margin-bottom: 15px; }
        .mil-mb-30 { margin-bottom: 30px; }
        .mil-input { width: 100%; padding: 12px 15px; border: 1px solid #e0e0e0; border-radius: 8px; }
        .mil-divider { height: 1px; background: #e0e0e0; margin: 15px 0; }
        label { display: block; margin-bottom: 5px; font-weight: 500; }
        .alert-info { background: #d1ecf1; color: #0c5460; padding: 12px; border-radius: 8px; margin-bottom: 20px; }
    </style>
</body>
</html>