    <!-- swiper css -->
    <link rel="stylesheet" href="/css/plugins/swiper.min.css" type="text/css" media="all">
    <!-- magnific popup -->
    <link rel="stylesheet" href="/css/plugins/magnific-popup.css" type="text/css" media="all">
    <!-- plax css -->
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <!-- custom css -->
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">

    <!-- Favicon -->
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>

<body>

    <!-- wrapper -->
    <div id="smooth-wrapper" class="mil-wrapper">

        <!-- preloader -->
        <div class="mil-preloader">
            <div class="mil-load"></div>
            <p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p>
        </div>
        <!-- preloader end -->

        <!-- scroll progress -->
        <div class="mil-progress-track">
            <div class="mil-progress"></div>
        </div>
        <!-- scroll progress end -->

        <!-- back to top -->
        <div class="progress-wrap active-progress"></div>

        <!-- top panel -->
        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo">
                    <img src="/img/logo.png" alt="RevaampAP" width="83" height="32">
                </a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/properties">Properties</a></li>
                        <li><a href="/about">About</a></li>
                        <li><a href="/contact">Contact</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <a href="/login" class="mil-btn mil-sm">Log in</a>
                    <a href="/register" class="mil-btn mil-sm mil-light">List Property</a>
                    <div class="mil-menu-btn">
                        <span></span>
                    </div>
                </div>
            </div>
        </div>
        <!-- top panel end -->

        <!-- Flash Messages -->
        <% if (typeof error !== 'undefined' && error && error.length) { %>
            <div class="alert alert-danger alert-dismissible fade show m-3" style="position: fixed; top: 100px; right: 20px; z-index: 9999; background: #f8d7da; color: #721c24; padding: 15px 20px; border-radius: 10px; border-left: 4px solid #dc3545;">
                <i class="fas fa-exclamation-circle"></i> <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" style="float: right; background: none; border: none; font-size: 20px; cursor: pointer;">&times;</button>
            </div>
        <% } %>
        <% if (typeof success !== 'undefined' && success && success.length) { %>
            <div class="alert alert-success alert-dismissible fade show m-3" style="position: fixed; top: 100px; right: 20px; z-index: 9999; background: #d4edda; color: #155724; padding: 15px 20px; border-radius: 10px; border-left: 4px solid #28a745;">
                <i class="fas fa-check-circle"></i> <%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" style="float: right; background: none; border: none; font-size: 20px; cursor: pointer;">&times;</button>
            </div>
        <% } %>

        <!-- content -->
        <div id="smooth-content">

            <!-- banner -->
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-text-m mil-mb-20 mil-up">FREE Registration</div>
                                <h1 class="mil-mb-60 mil-up">Become a Revaamp Promoter</h1>
                                <ul class="mil-breadcrumbs mil-pub-info mil-center mil-up">
                                    <li><a href="/">Home</a></li>
                                    <li><a href="/promoter/register">Become a Promoter</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- banner end -->

            <!-- commission highlight -->
            <div class="mil-cta mil-up mil-mt-30">
                <div class="container">
                    <div class="mil-out-frame mil-p-80-80" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%);">
                        <div class="row justify-content-between align-items-center">
                            <div class="col-xl-12 mil-text-center">
                                <h2 class="mil-light mil-mb-15 mil-up">✨ FREE Registration - Start Earning Today! ✨</h2>
                                <p class="mil-text-m mil-light mil-mb-0 mil-up">No investment required. Just share properties and earn up to 90% commission!</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- commission highlight end -->

            <!-- registration form -->
            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-xl-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <div class="mil-text-center mil-mb-30">
                                    <i class="fa fa-handshake" style="font-size: 60px; color: #03A6A6;"></i>
                                    <h3 class="mil-mb-15 mil-mt-15">Join Our Promoter Network</h3>
                                    <p class="mil-text-m mil-soft">Start earning by sharing properties on your social media - <strong style="color:#28a745;">FREE!</strong></p>
                                </div>
                                
                                <form action="/promoter/register" method="POST">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="text" name="name" placeholder="Full name" required>
                                        </div>
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="email" name="email" placeholder="Email address" required>
                                        </div>
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="tel" name="phone" placeholder="Phone number (e.g., 08012345678)" required>
                                        </div>
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="text" name="socialHandle" placeholder="Social media handle (Instagram/Twitter/Facebook)">
                                        </div>
                                        <div class="col-md-12">
                                            <textarea class="mil-input mil-up mil-mb-15" name="experience" rows="3" placeholder="Tell us about your sales/marketing experience (optional)"></textarea>
                                        </div>
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="password" name="password" placeholder="Password (min. 8 characters)" required>
                                        </div>
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-30" type="password" name="confirmPassword" placeholder="Confirm Password" required>
                                        </div>
                                    </div>

                                    <div class="mil-checkbox-frame mil-up mil-mb-30">
                                        <div class="mil-checkbox">
                                            <input type="checkbox" id="terms" name="terms" required>
                                            <label for="terms"></label>
                                        </div>
                                        <p class="mil-text-xs mil-soft">I agree to the <a href="/terms" class="mil-accent">Terms and Conditions</a> and <a href="/privacy" class="mil-accent">Privacy Policy</a></p>
                                    </div>

                                    <div class="mil-up">
                                        <button type="submit" class="mil-btn mil-md mil-fw">Register as Promoter (Free)</button>
                                    </div>

                                    <div class="mil-text-center mil-mt-30">
                                        <p class="mil-text-s mil-soft">
                                            Already have an account? <a href="/login" class="mil-accent">Login here</a>
                                        </p>
                                        <p class="mil-text-s mil-soft mil-mt-15">
                                            Want to list your property? <a href="/register" class="mil-accent">List as Property Owner →</a>
                                        </p>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- registration form end -->

            <!-- benefits section - Main Benefits -->
            <div class="mil-features mil-p-80-80">
                <div class="container">
                    <div class="mil-text-center mil-mb-60">
                        <h2 class="mil-mb-30 mil-up">Promoter Benefits</h2>
                        <p class="mil-text-m mil-soft mil-up">Earn commissions through multiple streams</p>
                    </div>
                    <div class="row">
                        <div class="col-xl-4 col-md-6 mil-mb-30">
                            <div class="mil-price-card mil-up mil-mb-30 mil-text-center" style="height: 100%;">
                                <div class="mil-icon-box mil-mb-20">
                                    <i class="fa fa-home" style="font-size: 50px; color: #03A6A6;"></i>
                                </div>
                                <h4 class="mil-mb-15">Introduce a Property for Sale</h4>
                                <p class="mil-text-s mil-soft">Earn <strong class="mil-accent">40% of Agency Fee</strong> when you introduce a property under the Revaamp Agency Scheme upon its sale.</p>
                                <div class="mil-mt-15">
                                    <span class="mil-badge" style="background: #28a745; color: white;">40% Commission</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-4 col-md-6 mil-mb-30">
                            <div class="mil-price-card mil-up mil-mb-30 mil-text-center" style="height: 100%;">
                                <div class="mil-icon-box mil-mb-20">
                                    <i class="fa fa-users" style="font-size: 50px; color: #03A6A6;"></i>
                                </div>
                                <h4 class="mil-mb-15">Introduce a Buyer</h4>
                                <p class="mil-text-s mil-soft">Earn <strong class="mil-accent">90% of Agency Fee</strong> from buyer AND <strong class="mil-accent">50% of Agency Fee</strong> from seller under the Revaamp Agency Scheme.</p>
                                <div class="mil-mt-15">
                                    <span class="mil-badge" style="background: #28a745; color: white;">Up to 90% Commission</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-4 col-md-6 mil-mb-30">
                            <div class="mil-price-card mil-up mil-mb-30 mil-text-center" style="height: 100%;">
                                <div class="mil-icon-box mil-mb-20">
                                    <i class="fa fa-users" style="font-size: 50px; color: #03A6A6;"></i>
                                </div>
                                <h4 class="mil-mb-15">Introduce a Promoter</h4>
                                <p class="mil-text-s mil-soft">Earn <strong class="mil-accent">70% of Administrative Fee</strong> each time your referred promoter earns agency fee under the Revaamp Agency Scheme.</p>
                                <div class="mil-mt-15">
                                    <span class="mil-badge" style="background: #17a2b8; color: white;">70% Residual Income</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- benefits end -->

            <!-- Additional Benefits Section -->
            <div class="mil-cta mil-up">
                <div class="container">
                    <div class="mil-out-frame mil-p-80-80" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                        <div class="mil-text-center mil-mb-40">
                            <h2 class="mil-light mil-mb-30 mil-up">Additional Benefits</h2>
                            <p class="mil-text-m mil-dark-soft mil-up">More ways to earn with RevaampAPA</p>
                        </div>
                        <div class="row">
                            <div class="col-xl-6 col-md-6 mil-mb-30">
                                <div class="mil-text-center mil-up">
                                    <i class="fa fa-hotel" style="font-size: 40px; color: white; margin-bottom: 15px;"></i>
                                    <h4 class="mil-light mil-mb-15">Partner Hotel Onboarding</h4>
                                    <p class="mil-text-s mil-dark-soft">Earn <strong class="mil-light">30% of any commission</strong> payable to Revacom by the hotel when you onboard a partner hotel under the Revaamp Room Voucher Scheme.</p>
                                </div>
                            </div>
                            <div class="col-xl-6 col-md-6 mil-mb-30">
                                <div class="mil-text-center mil-up">
                                    <i class="fa fa-ticket" style="font-size: 40px; color: white; margin-bottom: 15px;"></i>
                                    <h4 class="mil-light mil-mb-15">Room Voucher Subscriber</h4>
                                    <p class="mil-text-s mil-dark-soft">Earn <strong class="mil-light">50% of the subscription fee</strong> when you successfully onboard a Subscriber to the Revaamp Room Voucher Scheme.</p>
                                </div>
                            </div>
                            <div class="col-xl-6 col-md-6 mil-mb-30">
                                <div class="mil-text-center mil-up">
                                    <i class="fa fa-handshake-o" style="font-size: 40px; color: white; margin-bottom: 15px;"></i>
                                    <h4 class="mil-light mil-mb-15">Business Partner Referral</h4>
                                    <p class="mil-text-s mil-dark-soft">Earn <strong class="mil-light">₦10,000</strong> (Ten Thousand Naira) when a Business Partner registers through your referral link.</p>
                                </div>
                            </div>
                            <div class="col-xl-6 col-md-6 mil-mb-30">
                                <div class="mil-text-center mil-up">
                                    <i class="fa fa-sitemap" style="font-size: 40px; color: white; margin-bottom: 15px;"></i>
                                    <h4 class="mil-light mil-mb-15">Sub-Aggregator Referral</h4>
                                    <p class="mil-text-s mil-dark-soft">Earn <strong class="mil-light">₦25,000</strong> (Twenty Five Thousand Naira) when a Sub-Aggregator registers through your referral link.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Additional Benefits End -->

            <!-- Important Note -->
            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-price-card mil-up mil-text-center" style="background: #fff3cd; border-left: 4px solid #ffc107;">
                                <i class="fa fa-info-circle" style="font-size: 40px; color: #856404; margin-bottom: 15px;"></i>
                                <h4 class="mil-mb-15">Important Note</h4>
                                <p class="mil-text-s mil-soft">Every Agency fee due to you as a promoter shall be subject to deduction of <strong>10% administrative fee</strong>.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Important Note End -->

            <!-- how it works -->
            <div class="mil-cta mil-up">
                <div class="container">
                    <div class="mil-out-frame mil-p-80-80" style="background: #f8f9fa;">
                        <div class="mil-text-center mil-mb-60">
                            <h2 class="mil-mb-30 mil-up">How It Works</h2>
                            <p class="mil-text-m mil-soft mil-up">Get started in 3 simple steps</p>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mil-text-center mil-mb-30">
                                <div class="step-number" style="width: 60px; height: 60px; background: #03A6A6; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: bold; margin: 0 auto 20px;">1</div>
                                <h5 class="mil-mb-15">Register for Free</h5>
                                <p class="mil-text-s mil-soft">Sign up as a promoter - it's free and takes less than 2 minutes.</p>
                            </div>
                            <div class="col-md-4 mil-text-center mil-mb-30">
                                <div class="step-number" style="width: 60px; height: 60px; background: #03A6A6; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: bold; margin: 0 auto 20px;">2</div>
                                <h5 class="mil-mb-15">Share & Refer</h5>
                                <p class="mil-text-s mil-soft">Share properties, refer buyers, onboard hotels, or recruit new promoters.</p>
                            </div>
                            <div class="col-md-4 mil-text-center mil-mb-30">
                                <div class="step-number" style="width: 60px; height: 60px; background: #03A6A6; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: bold; margin: 0 auto 20px;">3</div>
                                <h5 class="mil-mb-15">Get Paid</h5>
                                <p class="mil-text-s mil-soft">Earn commissions when your referrals successfully transact.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- how it works end -->

            <!-- FAQ -->
            <div class="mil-faq mil-p-80-80">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-text-center">
                                <h2 class="mil-mb-30 mil-up">Frequently Asked Questions</h2>
                                <p class="mil-text-m mil-soft mil-mb-60 mil-up">Everything you need to know about being a promoter</p>
                            </div>
                            <div class="mil-accordion">
                                <div class="mil-accordion-group mil-up">
                                    <div class="mil-accordion-menu">
                                        <h5>Do I need to pay anything to become a promoter?</h5>
                                        <div class="mil-accordion-icon"><i class="fas fa-chevron-up"></i></div>
                                    </div>
                                    <div class="mil-accordion-content">
                                        <p class="mil-text-m mil-soft">No! Registration is completely FREE. There are no upfront costs or hidden fees. You only earn when you successfully refer a buyer, property, or other promoters.</p>
                                    </div>
                                </div>
                                <div class="mil-accordion-group mil-up">
                                    <div class="mil-accordion-menu">
                                        <h5>How much commission will I earn?</h5>
                                        <div class="mil-accordion-icon"><i class="fas fa-chevron-up"></i></div>
                                    </div>
                                    <div class="mil-accordion-content">
                                        <p class="mil-text-m mil-soft">You can earn up to 90% of agency fees depending on the transaction type. For introducing a buyer, you earn 90% from buyer AND 50% from seller. A 10% administrative fee applies to all agency fees.</p>
                                    </div>
                                </div>
                                <div class="mil-accordion-group mil-up">
                                    <div class="mil-accordion-menu">
                                        <h5>How do I get paid?</h5>
                                        <div class="mil-accordion-icon"><i class="fas fa-chevron-up"></i></div>
                                    </div>
                                    <div class="mil-accordion-content">
                                        <p class="mil-text-m mil-soft">We pay directly to your bank account weekly. Simply add your bank details in your promoter dashboard and request withdrawal when ready.</p>
                                    </div>
                                </div>
                                <div class="mil-accordion-group mil-up">
                                    <div class="mil-accordion-menu">
                                        <h5>What platforms can I share properties on?</h5>
                                        <div class="mil-accordion-icon"><i class="fas fa-chevron-up"></i></div>
                                    </div>
                                    <div class="mil-accordion-content">
                                        <p class="mil-text-m mil-soft">You can share on WhatsApp, Instagram, Facebook, Twitter, LinkedIn, TikTok, Telegram, email, or any other platform. You can also share offline using QR codes on flyers and business cards.</p>
                                    </div>
                                </div>
                                <div class="mil-accordion-group mil-up">
                                    <div class="mil-accordion-menu">
                                        <h5>What is the administrative fee?</h5>
                                        <div class="mil-accordion-icon"><i class="fas fa-chevron-up"></i></div>
                                    </div>
                                    <div class="mil-accordion-content">
                                        <p class="mil-text-m mil-soft">A 10% administrative fee is deducted from every agency fee earned by promoters to cover platform operational costs, support, and payment processing.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- FAQ end -->

            <!-- footer -->
            <footer class="mil-p-80-0">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-3">
                            <a href="/" class="mil-footer-logo mil-mb-60">
                                <img src="/img/logo-2.png" alt="RevaampAP" width="28" height="32">
                            </a>
                        </div>
                        <div class="col-xl-3 mil-mb-60">
                            <h6 class="mil-mb-60">Useful Links</h6>
                            <ul class="mil-footer-list">
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/">Home</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/about">About Us</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/contact">Contact Us</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/properties">Properties</a></li>
                            </ul>
                        </div>
                        <div class="col-xl-3 mil-mb-60">
                            <h6 class="mil-mb-60">For Promoters</h6>
                            <ul class="mil-footer-list">
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/promoter/register">Become a Promoter</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/how-it-works#promoter">How It Works</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/how-it-works#commission">Commission Structure</a></li>
                            </ul>
                        </div>
                        <div class="col-xl-3 mil-mb-80">
                            <h6 class="mil-mb-60">Newsletter</h6>
                            <p class="mil-text-xs mil-soft mil-mb-15">Get tips and updates for promoters</p>
