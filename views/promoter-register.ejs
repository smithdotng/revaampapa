    <script src="/js/main.js"></script>

    <script>
        // Auto-close flash messages
        setTimeout(function() {
            document.querySelectorAll('.alert').forEach(function(alert) {
                alert.style.opacity = '0';
                setTimeout(function() {
                    if (alert.parentNode) alert.remove();
                }, 300);
            });
        }, 5000);

        // Newsletter subscription
        var footerForm = document.getElementById('footerNewsletterForm');
        if (footerForm) {
            footerForm.addEventListener('submit', function(e) {
                e.preventDefault();
                var email = footerForm.querySelector('input[type="email"]').value;
                fetch('/api/subscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: email })
                })
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    alert(data.success ? 'Successfully subscribed!' : 'Error subscribing. Please try again.');
                    if (data.success) footerForm.reset();
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    alert('Error subscribing. Please try again.');
                });
            });
        }
    </script>

    <style>
        .mil-fw {
            width: 100%;
        }
        .mil-mt-30 {
            margin-top: 30px;
        }
        .mil-mt-15 {
            margin-top: 15px;
        }
        .mil-mb-20 {
            margin-bottom: 20px;
        }
        .mil-mb-40 {
            margin-bottom: 40px;
        }
        .step-number {
            transition: transform 0.3s ease;
        }
        .step-number:hover {
            transform: scale(1.1);
        }
        .mil-price-card {
            transition: transform 0.3s ease;
        }
        .mil-price-card:hover {
            transform: translateY(-5px);
        }
        .alert {
            animation: slideIn 0.3s ease;
        }
        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
        .btn-close {
            background: none;
            border: none;
            font-size: 20px;
            cursor: pointer;
        }
        .mil-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }
    </style>
