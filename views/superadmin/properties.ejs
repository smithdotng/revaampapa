<!DOCTYPE html>
<html lang="en-US">

<head>
    <title><%= title %></title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <link rel="stylesheet" href="/fonts/css/switzer.css" type="text/css" media="all">
    <link rel="stylesheet" href="/fonts/css/font-awesome.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/bootstrap-grid.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/swiper.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/magnific-popup.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    
    <style>
        .dropdown-menu { display: none; }
        .dropdown:hover .dropdown-menu,
        .dropdown .dropdown-menu.show { display: block; }
        .form-control { border: 1px solid #ddd; border-radius: 8px; padding: 10px; width: 100%; }
        .mil-pagination { display: flex; gap: 10px; justify-content: center; margin-top: 30px; flex-wrap: wrap; }
        .mil-pagination .mil-link { padding: 8px 12px; background: #f8f9fa; border-radius: 8px; text-decoration: none; color: #333; }
        .mil-pagination .mil-active { background: #03A6A6; color: white; }
        .status-badge { display: inline-block; padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
        .status-verified { background: #28a745; color: #fff; }
        .status-pending { background: #ffc107; color: #000; }
        .status-rejected { background: #dc3545; color: #fff; }
        .status-payment_confirmed { background: #17a2b8; color: #fff; }
        .featured-badge { background: #ffd700; color: #000; padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; margin-left: 5px; }
        .delete-btn { background: none; border: none; color: #dc3545; cursor: pointer; font-size: 14px; margin-left: 10px; }
        .delete-btn:hover { color: #c82333; text-decoration: underline; }
        .feature-btn { background: none; border: none; color: #ffc107; cursor: pointer; font-size: 14px; margin-left: 10px; }
        .feature-btn:hover { color: #ffd700; text-decoration: underline; }
        .feature-btn.active { color: #ffd700; }
        .property-image { width: 50px; height: 50px; object-fit: cover; border-radius: 4px; }
        .modal {
            display: none;
            position: fixed;
            z-index: 9999;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
        }
        .modal-content {
            background-color: white;
            margin: 15% auto;
            padding: 30px;
            border-radius: 12px;
            width: 90%;
            max-width: 500px;
            text-align: center;
        }
        .modal-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-top: 25px;
        }
        .modal-buttons button {
            padding: 10px 25px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
        }
        .confirm-delete { background: #dc3545; color: white; }
        .confirm-feature { background: #ffc107; color: #000; }
        .cancel-delete { background: #6c757d; color: white; }
        .toast-message {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #28a745;
            color: white;
            padding: 12px 24px;
            border-radius: 8px;
            z-index: 10000;
            display: none;
            animation: slideIn 0.3s ease;
        }
        .toast-message.error { background: #dc3545; }
        .toast-message.warning { background: #ffc107; color: #000; }
        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        .action-buttons {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
        }
    </style>
</head>

<body>

    <div id="smooth-wrapper" class="mil-wrapper">
        <div class="mil-preloader">
            <div class="mil-load"></div>
            <p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p>
        </div>

        <div class="mil-progress-track">
            <div class="mil-progress"></div>
        </div>

        <div class="progress-wrap active-progress"></div>

        <!-- top panel -->
        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo">
                    <img src="/img/logo.png" alt="RevaampAP" width="83" height="32">
                </a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/superadmin/dashboard" class="mil-active">Dashboard</a></li>
                        <li><a href="/superadmin/properties">Properties</a></li>
                        <li><a href="/superadmin/promoters">Promoters</a></li>
                        <li><a href="/superadmin/property-owners">Owners</a></li>
                        <li><a href="/superadmin/transactions">Transactions</a></li>
                        <li><a href="/superadmin/inquiries">Inquiries</a></li>
                        <li><a href="/superadmin/analytics">Analytics</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <div class="dropdown" style="position: relative;">
                        <a href="#" class="mil-btn mil-sm dropdown-toggle" data-bs-toggle="dropdown" style="display: flex; align-items: center; gap: 8px;">
                            <i class="fa fa-user-circle"></i> 
                            <span><%= user.name %></span>
                            <i class="fa fa-chevron-down"></i>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a href="/superadmin/profile"><i class="fa fa-user"></i> Profile</a></li>
                            <li><a href="/superadmin/settings"><i class="fa fa-cog"></i> Settings</a></li>
                            <li><hr></li>
                            <li><a href="/logout"><i class="fa fa-sign-out-alt"></i> Logout</a></li>
                        </ul>
                    </div>
                    <div class="mil-menu-btn">
                        <span></span>
                    </div>
                </div>
            </div>
        </div>

        <div id="smooth-content">
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <h1 class="mil-mb-60 mil-up">Property Management</h1>
                                <ul class="mil-breadcrumbs mil-pub-info mil-center mil-up">
                                    <li><a href="/">Home</a></li>
                                    <li><a href="/superadmin/dashboard">Dashboard</a></li>
                                    <li>Properties</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stats Cards -->
            <div class="mil-blog-list mil-p-0-80">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30" style="text-align: center;">
                                <h3><%= stats.total %></h3>
                                <p>Total Properties</p>
                            </div>
                        </div>
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30" style="text-align: center; border-left: 4px solid #ffc107;">
                                <h3><%= stats.pending %></h3>
                                <p>Pending Verification</p>
                                <a href="/superadmin/properties/pending" class="mil-link mil-accent">Review →</a>
                            </div>
                        </div>
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30" style="text-align: center;">
                                <h3><%= stats.verified %></h3>
                                <p>Verified</p>
                            </div>
                        </div>
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30" style="text-align: center;">
                                <h3><%= stats.rejected %></h3>
                                <p>Rejected</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Filters -->
            <div class="mil-blog-list mil-p-0-40">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-12">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <form method="GET" action="/superadmin/properties" class="row">
                                    <div class="col-md-3">
                                        <select name="status" class="form-control">
                                            <option value="all">All Status</option>
                                            <option value="pending_payment" <%= filters.status === 'pending_payment' ? 'selected' : '' %>>Pending Payment</option>
                                            <option value="payment_confirmed" <%= filters.status === 'payment_confirmed' ? 'selected' : '' %>>Payment Confirmed</option>
                                            <option value="verified" <%= filters.status === 'verified' ? 'selected' : '' %>>Verified</option>
                                            <option value="rejected" <%= filters.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <select name="type" class="form-control">
                                            <option value="all">All Types</option>
                                            <option value="residential" <%= filters.type === 'residential' ? 'selected' : '' %>>Residential</option>
                                            <option value="commercial" <%= filters.type === 'commercial' ? 'selected' : '' %>>Commercial</option>
                                            <option value="land" <%= filters.type === 'land' ? 'selected' : '' %>>Land</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <input type="text" name="search" placeholder="Search by title, city, or state" value="<%= filters.search || '' %>" class="form-control">
                                    </div>
                                    <div class="col-md-2">
                                        <button type="submit" class="mil-btn mil-sm" style="width: 100%;">Filter</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Properties Table -->
            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-12">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4 class="mil-mb-30">All Properties (<%= total %>)</h4>
                                
                                <% if (properties && properties.length > 0) { %>
                                    <div class="mil-table-responsive">
                                        <table class="mil-table">
                                            <thead>
                                                <tr>
                                                    <th>Image</th>
                                                    <th>Title</th>
                                                    <th>Owner</th>
                                                    <th>Price</th>
                                                    <th>Status</th>
                                                    <th>Featured</th>
                                                    <th>Created</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% properties.forEach(function(property) { %>
                                                    <tr id="property-row-<%= property._id %>">
                                                        <td>
                                                            <% if (property.images && property.images.length > 0) { %>
                                                                <img src="<%= property.images[0].url %>" class="property-image">
                                                            <% } else { %>
                                                                <div style="width: 50px; height: 50px; background: #f0f0f0; border-radius: 4px;"></div>
                                                            <% } %>
                                                         </td>
                                                         <td>
                                                            <%= property.title.substring(0, 40) %>
                                                            <% if (property.featured) { %>
                                                                <span class="featured-badge"><i class="fa fa-star"></i> Featured</span>
                                                            <% } %>
                                                         </td>
                                                         <td><%= property.owner ? property.owner.name : 'N/A' %></td>
                                                         <td>₦<%= property.price.toLocaleString() %></td>
                                                         <td>
                                                            <% if (property.verificationStatus === 'verified') { %>
                                                                <span class="status-badge status-verified">✓ Verified</span>
                                                            <% } else if (property.verificationStatus === 'payment_confirmed') { %>
                                                                <span class="status-badge status-payment_confirmed">⏳ Payment Confirmed</span>
                                                            <% } else if (property.verificationStatus === 'pending_payment') { %>
                                                                <span class="status-badge status-pending">⚠ Pending Payment</span>
                                                            <% } else { %>
                                                                <span class="status-badge"><%= property.verificationStatus %></span>
                                                            <% } %>
                                                         </td>
                                                         <td class="text-center">
                                                            <button onclick="toggleFeatured('<%= property._id %>', <%= property.featured %>)" 
                                                                    class="feature-btn <%= property.featured ? 'active' : '' %>"
                                                                    title="<%= property.featured ? 'Remove from Featured' : 'Make Featured' %>">
                                                                <i class="fa fa-star"></i> <%= property.featured ? 'Unfeature' : 'Feature' %>
                                                            </button>
                                                         </td>
                                                         <td><%= new Date(property.createdAt).toLocaleDateString() %></td>
                                                         <td>
                                                            <div class="action-buttons">
                                                                <a href="/superadmin/properties/<%= property._id %>" class="mil-link mil-accent">View</a>
                                                                <% if (property.verificationStatus === 'payment_confirmed') { %>
                                                                    <button onclick="verifyProperty('<%= property._id %>')" class="mil-link" style="color: #28a745;">Verify</button>
                                                                <% } %>
                                                                <button onclick="confirmDelete('<%= property._id %>', '<%= property.title.replace(/'/g, "\\'") %>')" class="delete-btn" title="Delete Property">
                                                                    <i class="fa fa-trash"></i> Delete
                                                                </button>
                                                            </div>
                                                         </td>
                                                     </tr>
                                                <% }); %>
                                            </tbody>
                                        </table>
                                    </div>
                                    
                                    <!-- Pagination -->
                                    <% if (totalPages > 1) { %>
                                        <div class="mil-pagination">
                                            <% for (var i = 1; i <= totalPages; i++) { %>
                                                <a href="?page=<%= i %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.type ? '&type=' + filters.type : '' %><%= filters.search ? '&search=' + filters.search : '' %>" 
                                                   class="mil-link <%= currentPage === i ? 'mil-active' : '' %>"><%= i %></a>
                                            <% } %>
                                        </div>
                                    <% } %>
                                <% } else { %>
                                    <p class="mil-text-m mil-soft mil-text-center">No properties found.</p>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <footer class="mil-p-80-0">
                <div class="container">
                    <div class="mil-footer-bottom">
                        <div class="row">
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-soft">© 2024 RevaampAP. All rights reserved.</p>
                            </div>
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-text-right mil-sm-text-left mil-soft">Superadmin Dashboard</p>
                            </div>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" class="modal">
        <div class="modal-content">
            <i class="fa fa-exclamation-triangle" style="font-size: 48px; color: #dc3545; margin-bottom: 20px;"></i>
            <h3>Confirm Delete</h3>
            <p id="deleteMessage" style="margin: 20px 0;">Are you sure you want to delete this property?</p>
            <p id="propertyTitle" style="color: #dc3545; font-weight: bold;"></p>
            <div class="modal-buttons">
                <button class="cancel-delete" onclick="closeDeleteModal()">Cancel</button>
                <button class="confirm-delete" onclick="deleteProperty()">Delete Permanently</button>
            </div>
        </div>
    </div>

    <!-- Toast Message -->
    <div id="toastMessage" class="toast-message">
        <i class="fa fa-check-circle"></i> <span id="toastText"></span>
    </div>

    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/plugins/swiper.min.js"></script>
    <script src="/js/plugins/gsap.min.js"></script>
    <script src="/js/plugins/ScrollSmoother.min.js"></script>
    <script src="/js/plugins/ScrollTrigger.min.js"></script>
    <script src="/js/plugins/ScrollTo.min.js"></script>
    <script src="/js/plugins/magnific-popup.js"></script>
    <script src="/js/main.js"></script>

    <script>
        let propertyToDelete = null;
        let propertyTitle = '';
        
        // Toggle featured property
        function toggleFeatured(propertyId, currentStatus) {
            const action = currentStatus ? 'remove from featured' : 'make featured';
            if (confirm(`Are you sure you want to ${action} this property?`)) {
                fetch(`/superadmin/properties/${propertyId}/feature`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        const message = data.featured ? 'Property marked as featured!' : 'Property removed from featured!';
                        showToast(message, 'success');
                        setTimeout(() => {
                            location.reload();
                        }, 1000);
                    } else {
                        showToast(data.error || 'Error updating featured status', 'error');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    showToast('Error updating featured status', 'error');
                });
            }
        }
        
        // Show delete confirmation modal
        function confirmDelete(propertyId, title) {
            propertyToDelete = propertyId;
            propertyTitle = title;
            document.getElementById('propertyTitle').innerText = title;
            document.getElementById('deleteModal').style.display = 'block';
        }
        
        // Close delete modal
        function closeDeleteModal() {
            document.getElementById('deleteModal').style.display = 'none';
            propertyToDelete = null;
            propertyTitle = '';
        }
        
        // Delete property
        function deleteProperty() {
            if (!propertyToDelete) return;
            
            fetch(`/superadmin/properties/${propertyToDelete}`, {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const row = document.getElementById(`property-row-${propertyToDelete}`);
                    if (row) {
                        row.remove();
                    }
                    showToast('Property deleted successfully!', 'success');
                    closeDeleteModal();
                    
                    setTimeout(() => {
                        location.reload();
                    }, 1000);
                } else {
                    showToast(data.error || 'Error deleting property', 'error');
                    closeDeleteModal();
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showToast('Error deleting property. Please try again.', 'error');
                closeDeleteModal();
            });
        }
        
        // Verify property
        function verifyProperty(propertyId) {
            if (confirm('Verify this property? It will become available to promoters.')) {
                fetch(`/superadmin/properties/${propertyId}/verify`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ feedback: 'Property verified by superadmin' })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showToast('Property verified successfully!', 'success');
                        setTimeout(() => {
                            location.reload();
                        }, 1000);
                    } else {
                        showToast('Error verifying property', 'error');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    showToast('Error verifying property', 'error');
                });
            }
        }
        
        // Show toast message
        function showToast(message, type) {
            const toast = document.getElementById('toastMessage');
            const toastText = document.getElementById('toastText');
            toastText.innerText = message;
            toast.className = 'toast-message';
            if (type === 'error') {
                toast.classList.add('error');
            } else if (type === 'warning') {
                toast.classList.add('warning');
            }
            toast.style.display = 'block';
            
            setTimeout(() => {
                toast.style.display = 'none';
            }, 3000);
        }
        
        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('deleteModal');
            if (event.target == modal) {
                closeDeleteModal();
            }
        }
    </script>
</body>

</html>