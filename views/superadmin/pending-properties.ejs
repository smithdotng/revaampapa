<!DOCTYPE html>
<html lang="en-US">

<head>
    <title><%= title %></title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <link rel="stylesheet" href="/fonts/css/switzer.css" type="text/css" media="all">
    <link rel="stylesheet" href="/fonts/css/font-awesome.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/bootstrap-grid.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/swiper.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/magnific-popup.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
</head>

<body>
    <div id="smooth-wrapper" class="mil-wrapper">
        <div class="mil-preloader">
            <div class="mil-load"></div>
            <p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p>
        </div>

        <div class="mil-progress-track">
            <div class="mil-progress"></div>
        </div>

        <div class="progress-wrap active-progress"></div>

        <!-- top panel -->
        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo">
                    <img src="/img/logo.png" alt="RevaampAP" width="83" height="32">
                </a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/superadmin/dashboard" class="mil-active">Dashboard</a></li>
                        <li><a href="/superadmin/properties">Properties</a></li>
                        <li><a href="/superadmin/promoters">Promoters</a></li>
                        <li><a href="/superadmin/property-owners">Owners</a></li>
                        <li><a href="/superadmin/transactions">Transactions</a></li>
                        <li><a href="/superadmin/analytics">Analytics</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <div class="dropdown" style="position: relative;">
                        <a href="#" class="mil-btn mil-sm dropdown-toggle" data-bs-toggle="dropdown" style="display: flex; align-items: center; gap: 8px;">
                            <i class="fa fa-user-circle"></i> 
                            <span><%= user.name %></span>
                            <i class="fa fa-chevron-down"></i>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a href="/superadmin/profile"><i class="fa fa-user"></i> Profile</a></li>
                            <li><a href="/superadmin/settings"><i class="fa fa-cog"></i> Settings</a></li>
                            <li><hr></li>
                            <li><a href="/logout"><i class="fa fa-sign-out-alt"></i> Logout</a></li>
                        </ul>
                    </div>
                    <div class="mil-menu-btn">
                        <span></span>
                    </div>
                </div>
            </div>
        </div>

        <div id="smooth-content">
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <h1 class="mil-mb-60 mil-up">Pending Property Approvals</h1>
                                <ul class="mil-breadcrumbs mil-pub-info mil-center mil-up">
                                    <li><a href="/">Home</a></li>
                                    <li><a href="/superadmin/dashboard">Dashboard</a></li>
                                    <li><a href="/superadmin/properties">Properties</a></li>
                                    <li>Pending Approvals</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-12">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4 class="mil-mb-30">Properties Awaiting Verification (<%= properties.length %>)</h4>
                                
                                <% if (properties && properties.length > 0) { %>
                                    <div class="row">
                                        <% properties.forEach(function(property) { %>
                                            <div class="col-xl-6 col-lg-6 mil-mb-30">
                                                <div class="mil-price-card mil-up" style="padding: 20px;">
                                                    <div class="row">
                                                        <div class="col-md-4">
                                                            <% if (property.images && property.images.length > 0) { %>
                                                                <img src="<%= property.images[0] %>" alt="<%= property.title %>" style="width: 100%; height: 150px; object-fit: cover; border-radius: 8px;">
                                                            <% } else { %>
                                                                <div style="width: 100%; height: 150px; background: #f0f0f0; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                                    <i class="fa fa-building" style="font-size: 48px; color: #ccc;"></i>
                                                                </div>
                                                            <% } %>
                                                        </div>
                                                        <div class="col-md-8">
                                                            <h5><%= property.title %></h5>
                                                            <p class="mil-text-s mil-soft mil-mb-10">
                                                                <i class="fa fa-map-marker"></i> <%= property.location.city %>, <%= property.location.state %>
                                                            </p>
                                                            <p class="mil-text-m mil-accent mil-mb-10">
                                                                ₦<%= property.price.toLocaleString() %>
                                                            </p>
                                                            <p class="mil-text-s mil-soft">
                                                                <strong>Owner:</strong> <%= property.owner ? property.owner.name : 'N/A' %><br>
                                                                <strong>Email:</strong> <%= property.owner ? property.owner.email : 'N/A' %><br>
                                                                <strong>Phone:</strong> <%= property.owner ? property.owner.phone : 'N/A' %>
                                                            </p>
                                                            <div class="mil-mt-20">
                                                                <button onclick="approveProperty('<%= property._id %>')" class="mil-btn mil-sm" style="background: #28a745; margin-right: 10px;">
                                                                    <i class="fa fa-check"></i> Approve
                                                                </button>
                                                                <button onclick="rejectProperty('<%= property._id %>')" class="mil-btn mil-sm" style="background: #dc3545;">
                                                                    <i class="fa fa-times"></i> Reject
                                                                </button>
                                                                <a href="/superadmin/properties/<%= property._id %>" class="mil-link mil-accent mil-ml-20">View Details →</a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        <% }); %>
                                    </div>
                                <% } else { %>
                                    <div class="mil-text-center mil-p-60">
                                        <i class="fa fa-check-circle" style="font-size: 64px; color: #28a745;"></i>
                                        <h4 class="mil-mt-30">No Pending Properties</h4>
                                        <p class="mil-text-m mil-soft">All properties have been verified.</p>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <footer class="mil-p-80-0">
                <div class="container">
                    <div class="mil-footer-bottom">
                        <div class="row">
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-soft">© 2024 RevaampAP. All rights reserved.</p>
                            </div>
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-text-right mil-sm-text-left mil-soft">Superadmin Dashboard</p>
                            </div>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/plugins/swiper.min.js"></script>
    <script src="/js/plugins/gsap.min.js"></script>
    <script src="/js/plugins/ScrollSmoother.min.js"></script>
    <script src="/js/plugins/ScrollTrigger.min.js"></script>
    <script src="/js/plugins/ScrollTo.min.js"></script>
    <script src="/js/plugins/magnific-popup.js"></script>
    <script src="/js/main.js"></script>

    <style>
        .dropdown-menu { display: none; }
        .dropdown:hover .dropdown-menu,
        .dropdown .dropdown-menu.show { display: block; }
        .mil-ml-20 { margin-left: 20px; }
        .mil-p-60 { padding: 60px; }
    </style>

    <script>
        function approveProperty(propertyId) {
            if (confirm('Are you sure you want to approve this property? It will become visible to all users.')) {
                fetch(`/superadmin/properties/${propertyId}/verify`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ feedback: 'Property approved by superadmin' })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Property approved successfully!');
                        location.reload();
                    } else {
                        alert('Error approving property');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error approving property');
                });
            }
        }

        function rejectProperty(propertyId) {
            const reason = prompt('Please provide a reason for rejection:');
            if (reason) {
                fetch(`/superadmin/properties/${propertyId}/reject`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ reason: reason })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Property rejected successfully!');
                        location.reload();
                    } else {
                        alert('Error rejecting property');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error rejecting property');
                });
            }
        }
    </script>
</body>

</html>