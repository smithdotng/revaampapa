<!DOCTYPE html>
<html lang="en-US">

<head>
    <title><%= title %></title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <link rel="stylesheet" href="/fonts/css/switzer.css" type="text/css" media="all">
    <link rel="stylesheet" href="/fonts/css/font-awesome.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/bootstrap-grid.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">
</head>

<body>
    <div id="smooth-wrapper" class="mil-wrapper">
        <div class="mil-preloader"><div class="mil-load"></div><p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p></div>
        <div class="mil-progress-track"><div class="mil-progress"></div></div>
        <div class="progress-wrap active-progress"></div>

        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo"><img src="/img/logo.png" alt="RevaampAP" width="83" height="32"></a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/superadmin/dashboard">Dashboard</a></li>
                        <li><a href="/superadmin/properties">Properties</a></li>
                        <li><a href="/superadmin/promoters">Promoters</a></li>
                        <li><a href="/superadmin/transactions">Transactions</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <div class="dropdown" style="position: relative;">
                        <a href="#" class="mil-btn mil-sm dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="fa fa-user-circle"></i> <%= user.name %> <i class="fa fa-chevron-down"></i>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a href="/superadmin/profile"><i class="fa fa-user"></i> Profile</a></li>
                            <li><a href="/superadmin/settings"><i class="fa fa-cog"></i> Settings</a></li>
                            <li><hr></li>
                            <li><a href="/logout"><i class="fa fa-sign-out-alt"></i> Logout</a></li>
                        </ul>
                    </div>
                    <div class="mil-menu-btn"><span></span></div>
                </div>
            </div>
        </div>

        <div id="smooth-content">
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-text-m mil-mb-20 mil-up">My Profile</div>
                                <h1 class="mil-mb-60 mil-up">Admin Profile</h1>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mil-blog-list mil-p-0-80">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-xl-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4 class="mil-mb-30">Profile Information</h4>
                                <form action="/superadmin/update-profile" method="POST">
                                    <input class="mil-input mil-up mil-mb-15" type="text" name="name" value="<%= user.name %>" placeholder="Full Name" required>
                                    <input class="mil-input mil-up mil-mb-15" type="email" value="<%= user.email %>" disabled placeholder="Email">
                                    <input class="mil-input mil-up mil-mb-15" type="tel" name="phone" value="<%= user.phone || '' %>" placeholder="Phone Number">
                                    <textarea class="mil-input mil-up mil-mb-30" name="bio" rows="4" placeholder="Bio / About"><%= user.bio || '' %></textarea>
                                    <button type="submit" class="mil-btn mil-md">Update Profile</button>
                                </form>
                            </div>

                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4 class="mil-mb-30">Change Password</h4>
                                <form action="/superadmin/change-password" method="POST">
                                    <input class="mil-input mil-up mil-mb-15" type="password" name="currentPassword" placeholder="Current Password" required>
                                    <input class="mil-input mil-up mil-mb-15" type="password" name="newPassword" placeholder="New Password" required>
                                    <input class="mil-input mil-up mil-mb-30" type="password" name="confirmPassword" placeholder="Confirm New Password" required>
                                    <button type="submit" class="mil-btn mil-md">Change Password</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <footer class="mil-p-80-0">
            <div class="container">
                <div class="mil-footer-bottom">
                    <p class="mil-text-s mil-soft">© 2024 RevaampAP. All rights reserved.</p>
                </div>
            </div>
        </footer>
    </div>

    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/main.js"></script>
    <style>
        .dropdown-menu { display: none; }
        .dropdown:hover .dropdown-menu { display: block; }
    </style>
</body>
</html>