<!DOCTYPE html>
<html lang="en-US">

<head>
    <title><%= title %></title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <link rel="stylesheet" href="/fonts/css/switzer.css" type="text/css" media="all">
    <link rel="stylesheet" href="/fonts/css/font-awesome.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/bootstrap-grid.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/swiper.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/magnific-popup.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
</head>

<body>

    <div id="smooth-wrapper" class="mil-wrapper">

        <div class="mil-preloader">
            <div class="mil-load"></div>
            <p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p>
        </div>

        <div class="mil-progress-track">
            <div class="mil-progress"></div>
        </div>

        <div class="progress-wrap active-progress"></div>

        <!-- top panel -->
        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo">
                    <img src="/img/logo.png" alt="RevaampAP" width="83" height="32">
                </a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/superadmin/dashboard" class="mil-active">Dashboard</a></li>
                        <li><a href="/superadmin/properties">Properties</a></li>
                        <li><a href="/superadmin/promoters">Promoters</a></li>
                        <li><a href="/superadmin/property-owners">Owners</a></li>
                        <li><a href="/superadmin/transactions">Transactions</a></li>
                        <li><a href="/superadmin/inquiries">Inquiries</a></li>
                        <li><a href="/superadmin/analytics">Analytics</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <div class="dropdown" style="position: relative;">
                        <a href="#" class="mil-btn mil-sm dropdown-toggle" data-bs-toggle="dropdown" style="display: flex; align-items: center; gap: 8px;">
                            <i class="fa fa-user-circle"></i> 
                            <span><%= user.name %></span>
                            <i class="fa fa-chevron-down"></i>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a href="/superadmin/profile"><i class="fa fa-user"></i> Profile</a></li>
                            <li><a href="/superadmin/settings"><i class="fa fa-cog"></i> Settings</a></li>
                            <li><hr></li>
                            <li><a href="/logout"><i class="fa fa-sign-out-alt"></i> Logout</a></li>
                        </ul>
                    </div>
                    <div class="mil-menu-btn">
                        <span></span>
                    </div>
                </div>
            </div>
        </div>

        <div id="smooth-content">

            <!-- banner -->
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-text-m mil-mb-20 mil-up">Inquiry Management</div>
                                <h1 class="mil-mb-60 mil-up">Platform Inquiries</h1>
                                <ul class="mil-breadcrumbs mil-pub-info mil-center mil-up">
                                    <li><a href="/">Home</a></li>
                                    <li><a href="/superadmin/dashboard">Dashboard</a></li>
                                    <li>Inquiries</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stats Cards -->
            <div class="mil-blog-list mil-p-0-80">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-2 col-md-4">
                            <div class="mil-price-card mil-up mil-mb-30" style="text-align: center;">
                                <h3><%= stats.total %></h3>
                                <p class="mil-text-s">Total</p>
                            </div>
                        </div>
                        <div class="col-xl-2 col-md-4">
                            <div class="mil-price-card mil-up mil-mb-30" style="text-align: center; border-left: 4px solid #ffc107;">
                                <h3><%= stats.new %></h3>
                                <p class="mil-text-s">New</p>
                            </div>
                        </div>
                        <div class="col-xl-2 col-md-4">
                            <div class="mil-price-card mil-up mil-mb-30" style="text-align: center;">
                                <h3><%= stats.read %></h3>
                                <p class="mil-text-s">Read</p>
                            </div>
                        </div>
                        <div class="col-xl-2 col-md-4">
                            <div class="mil-price-card mil-up mil-mb-30" style="text-align: center;">
                                <h3><%= stats.replied %></h3>
                                <p class="mil-text-s">Replied</p>
                            </div>
                        </div>
                        <div class="col-xl-2 col-md-4">
                            <div class="mil-price-card mil-up mil-mb-30" style="text-align: center;">
                                <h3><%= stats.archived %></h3>
                                <p class="mil-text-s">Archived</p>
                            </div>
                        </div>
                        <div class="col-xl-2 col-md-4">
                            <div class="mil-price-card mil-up mil-mb-30" style="text-align: center;">
                                <a href="/superadmin/inquiries/export/csv<%= filters.status ? '?status=' + filters.status : '' %>" class="mil-btn mil-sm" style="background: #28a745;">
                                    <i class="fa fa-download"></i> Export CSV
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Filters -->
            <div class="mil-blog-list mil-p-0-40">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-12">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <form method="GET" action="/superadmin/inquiries" class="row align-items-end">
                                    <div class="col-md-3">
                                        <label class="mil-text-s mil-soft">Status</label>
                                        <select name="status" class="form-control">
                                            <option value="all">All Status</option>
                                            <option value="new" <%= filters.status === 'new' ? 'selected' : '' %>>New</option>
                                            <option value="read" <%= filters.status === 'read' ? 'selected' : '' %>>Read</option>
                                            <option value="replied" <%= filters.status === 'replied' ? 'selected' : '' %>>Replied</option>
                                            <option value="archived" <%= filters.status === 'archived' ? 'selected' : '' %>>Archived</option>
                                            <option value="spam" <%= filters.status === 'spam' ? 'selected' : '' %>>Spam</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="mil-text-s mil-soft">Property</label>
                                        <select name="propertyId" class="form-control">
                                            <option value="">All Properties</option>
                                            <% if (properties) { %>
                                                <% properties.forEach(function(property) { %>
                                                    <option value="<%= property._id %>" <%= filters.propertyId === property._id.toString() ? 'selected' : '' %>>
                                                        <%= property.title.substring(0, 50) %>
                                                    </option>
                                                <% }); %>
                                            <% } %>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="mil-text-s mil-soft">Search</label>
                                        <input type="text" name="search" placeholder="Name, email, or message" class="form-control" value="<%= filters.search || '' %>">
                                    </div>
                                    <div class="col-md-2">
                                        <button type="submit" class="mil-btn mil-sm" style="width: 100%;">Filter</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bulk Actions -->
            <div class="mil-blog-list mil-p-0-40">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-12">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <div class="row align-items-center">
                                    <div class="col-md-6">
                                        <div class="checkbox-group">
                                            <input type="checkbox" id="selectAll" onchange="toggleSelectAll()">
                                            <label for="selectAll" class="mil-ml-10">Select All</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6 mil-text-right">
                                        <select id="bulkStatus" class="form-control" style="width: auto; display: inline-block; margin-right: 10px;">
                                            <option value="">Bulk Action</option>
                                            <option value="read">Mark as Read</option>
                                            <option value="replied">Mark as Replied</option>
                                            <option value="archived">Archive</option>
                                            <option value="spam">Mark as Spam</option>
                                        </select>
                                        <button onclick="bulkUpdate()" class="mil-btn mil-sm">Apply</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Inquiries Table -->
            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-12">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4 class="mil-mb-30">All Inquiries (<%= total %>)</h4>
                                
                                <% if (inquiries && inquiries.length > 0) { %>
                                    <div class="mil-table-responsive">
                                        <table class="mil-table">
                                            <thead>
                                                <tr>
                                                    <th style="width: 30px;"><input type="checkbox" class="row-selector" onchange="updateSelectAll()"></th>
                                                    <th>Property</th>
                                                    <th>Inquirer</th>
                                                    <th>Message</th>
                                                    <th>Status</th>
                                                    <th>Date</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% inquiries.forEach(function(inquiry) { %>
                                                    <tr class="<%= inquiry.status === 'new' ? 'inquiry-new' : '' %>">
                                                        <td><input type="checkbox" class="inquiry-checkbox" value="<%= inquiry._id %>"></td>
                                                        <td>
                                                            <a href="/superadmin/properties/<%= inquiry.property._id %>" class="mil-link">
                                                                <%= inquiry.property.title.substring(0, 30) %>
                                                            </a>
                                                            <br>
                                                            <small class="mil-soft">
                                                                ₦<%= inquiry.property.price.toLocaleString() %>
                                                            </small>
                                                        </td>
                                                        <td>
                                                            <strong><%= inquiry.name %></strong><br>
                                                            <small><i class="fa fa-envelope"></i> <%= inquiry.email %></small><br>
                                                            <% if (inquiry.phone) { %>
                                                                <small><i class="fa fa-phone"></i> <%= inquiry.phone %></small>
                                                            <% } %>
                                                        </td>
                                                        <td>
                                                            <div class="message-preview">
                                                                <%= inquiry.message.substring(0, 80) %>...
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <% if (inquiry.status === 'new') { %>
                                                                <span class="badge badge-new">New</span>
                                                            <% } else if (inquiry.status === 'read') { %>
                                                                <span class="badge badge-read">Read</span>
                                                            <% } else if (inquiry.status === 'replied') { %>
                                                                <span class="badge badge-replied">Replied</span>
                                                            <% } else if (inquiry.status === 'archived') { %>
                                                                <span class="badge badge-archived">Archived</span>
                                                            <% } else if (inquiry.status === 'spam') { %>
                                                                <span class="badge badge-spam">Spam</span>
                                                            <% } %>
                                                            <br>
                                                            <% if (inquiry.repliedAt) { %>
                                                                <small class="mil-soft">Replied: <%= new Date(inquiry.repliedAt).toLocaleDateString() %></small>
                                                            <% } %>
                                                        </td>
                                                        <td>
                                                            <%= new Date(inquiry.createdAt).toLocaleDateString() %><br>
                                                            <small class="mil-soft"><%= new Date(inquiry.createdAt).toLocaleTimeString() %></small>
                                                        </td>
                                                        <td>
                                                            <a href="/superadmin/inquiries/<%= inquiry._id %>" class="mil-link mil-accent">
                                                                <i class="fa fa-eye"></i> View
                                                            </a>
                                                            <button onclick="deleteInquiry('<%= inquiry._id %>')" class="mil-link" style="color: #dc3545; margin-left: 10px;">
                                                                <i class="fa fa-trash"></i> Delete
                                                            </button>
                                                        </td>
                                                    </tr>
                                                <% }); %>
                                            </tbody>
                                        </table>
                                    </div>
                                    
                                    <!-- Pagination -->
                                    <% if (totalPages > 1) { %>
                                        <div class="pagination">
                                            <a href="?page=1<%= filters.status ? '&status=' + filters.status : '' %><%= filters.propertyId ? '&propertyId=' + filters.propertyId : '' %><%= filters.search ? '&search=' + filters.search : '' %>" class="mil-link">First</a>
                                            <% if (currentPage > 1) { %>
                                                <a href="?page=<%= currentPage - 1 %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.propertyId ? '&propertyId=' + filters.propertyId : '' %><%= filters.search ? '&search=' + filters.search : '' %>" class="mil-link">Previous</a>
                                            <% } %>
                                            <% for (var i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                                                <a href="?page=<%= i %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.propertyId ? '&propertyId=' + filters.propertyId : '' %><%= filters.search ? '&search=' + filters.search : '' %>" class="mil-link <%= currentPage === i ? 'active' : '' %>"><%= i %></a>
                                            <% } %>
                                            <% if (currentPage < totalPages) { %>
                                                <a href="?page=<%= currentPage + 1 %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.propertyId ? '&propertyId=' + filters.propertyId : '' %><%= filters.search ? '&search=' + filters.search : '' %>" class="mil-link">Next</a>
                                            <% } %>
                                            <a href="?page=<%= totalPages %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.propertyId ? '&propertyId=' + filters.propertyId : '' %><%= filters.search ? '&search=' + filters.search : '' %>" class="mil-link">Last</a>
                                        </div>
                                    <% } %>
                                <% } else { %>
                                    <div class="mil-text-center mil-p-60">
                                        <i class="fa fa-inbox" style="font-size: 64px; color: #ccc;"></i>
                                        <h4 class="mil-mt-30">No Inquiries Found</h4>
                                        <p class="mil-text-m mil-soft">No inquiries match your filter criteria.</p>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <footer class="mil-p-80-0">
                <div class="container">
                    <div class="mil-footer-bottom">
                        <div class="row">
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-soft">© 2024 RevaampAP. All rights reserved.</p>
                            </div>
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-text-right mil-sm-text-left mil-soft">Superadmin Dashboard</p>
                            </div>
                        </div>
                    </div>
                </div>
            </footer>

        </div>
    </div>

    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/plugins/swiper.min.js"></script>
    <script src="/js/plugins/gsap.min.js"></script>
    <script src="/js/plugins/ScrollSmoother.min.js"></script>
    <script src="/js/plugins/ScrollTrigger.min.js"></script>
    <script src="/js/plugins/ScrollTo.min.js"></script>
    <script src="/js/plugins/magnific-popup.js"></script>
    <script src="/js/main.js"></script>

    <style>
        .dropdown-menu { display: none; }
        .dropdown:hover .dropdown-menu,
        .dropdown .dropdown-menu.show { display: block; }
        .form-control { width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 8px; }
        .pagination { display: flex; gap: 10px; justify-content: center; margin-top: 30px; flex-wrap: wrap; }
        .pagination a { padding: 8px 12px; background: #f8f9fa; border-radius: 8px; text-decoration: none; color: #333; }
        .pagination a.active { background: #03A6A6; color: white; }
        .pagination a:hover { background: #03A6A6; color: white; }
        .badge { display: inline-block; padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
        .badge-new { background: #ffc107; color: #000; }
        .badge-read { background: #17a2b8; color: #fff; }
        .badge-replied { background: #28a745; color: #fff; }
        .badge-archived { background: #6c757d; color: #fff; }
        .badge-spam { background: #dc3545; color: #fff; }
        .inquiry-new { background: #fffbf0; }
        .message-preview { max-width: 250px; font-size: 13px; color: #666; line-height: 1.4; }
        .checkbox-group { display: flex; align-items: center; }
        .mil-p-60 { padding: 60px; }
        .mil-mt-30 { margin-top: 30px; }
        .mil-mb-30 { margin-bottom: 30px; }
        .mil-ml-10 { margin-left: 10px; }
        .mil-table td { vertical-align: middle; }
        .mil-table th { background: #f8f9fa; }
    </style>

    <script>
        // Select All functionality
        function toggleSelectAll() {
            const selectAll = document.getElementById('selectAll');
            const checkboxes = document.querySelectorAll('.inquiry-checkbox');
            checkboxes.forEach(checkbox => {
                checkbox.checked = selectAll.checked;
            });
        }
        
        function updateSelectAll() {
            const selectAll = document.getElementById('selectAll');
            const checkboxes = document.querySelectorAll('.inquiry-checkbox');
            const allChecked = Array.from(checkboxes).every(cb => cb.checked);
            selectAll.checked = allChecked;
        }
        
        // Bulk update
        function bulkUpdate() {
            const bulkStatus = document.getElementById('bulkStatus').value;
            if (!bulkStatus) {
                alert('Please select an action');
                return;
            }
            
            const selectedIds = [];
            document.querySelectorAll('.inquiry-checkbox:checked').forEach(checkbox => {
                selectedIds.push(checkbox.value);
            });
            
            if (selectedIds.length === 0) {
                alert('Please select at least one inquiry');
                return;
            }
            
            if (confirm(`Are you sure you want to mark ${selectedIds.length} inquiries as ${bulkStatus}?`)) {
                fetch('/superadmin/inquiries/bulk-update', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        inquiryIds: selectedIds,
                        status: bulkStatus
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert(data.message);
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error updating inquiries');
                });
            }
        }
        
        // Delete single inquiry
        function deleteInquiry(inquiryId) {
            if (confirm('Are you sure you want to delete this inquiry? This action cannot be undone.')) {
                fetch(`/superadmin/inquiries/${inquiryId}`, {
                    method: 'DELETE'
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Inquiry deleted successfully');
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error deleting inquiry');
                });
            }
        }
        
        // Add event listeners to row checkboxes
        document.addEventListener('DOMContentLoaded', function() {
            const checkboxes = document.querySelectorAll('.inquiry-checkbox');
            checkboxes.forEach(checkbox => {
                checkbox.addEventListener('change', updateSelectAll);
            });
        });
    </script>
</body>

</html>