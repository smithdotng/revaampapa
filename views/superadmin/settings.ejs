<!DOCTYPE html>
<html lang="en-US">

<head>
    <title><%= title %></title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <link rel="stylesheet" href="/fonts/css/switzer.css" type="text/css" media="all">
    <link rel="stylesheet" href="/fonts/css/font-awesome.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/bootstrap-grid.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">
</head>

<body>
    <div id="smooth-wrapper" class="mil-wrapper">
        <div class="mil-preloader"><div class="mil-load"></div><p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p></div>
        <div class="mil-progress-track"><div class="mil-progress"></div></div>
        <div class="progress-wrap active-progress"></div>

        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo"><img src="/img/logo.png" alt="RevaampAP" width="83" height="32"></a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/superadmin/dashboard">Dashboard</a></li>
                        <li><a href="/superadmin/settings" class="mil-active">Settings</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <div class="dropdown" style="position: relative;">
                        <a href="#" class="mil-btn mil-sm dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="fa fa-user-circle"></i> <%= user.name %> <i class="fa fa-chevron-down"></i>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a href="/superadmin/profile"><i class="fa fa-user"></i> Profile</a></li>
                            <li><a href="/superadmin/settings"><i class="fa fa-cog"></i> Settings</a></li>
                            <li><hr></li>
                            <li><a href="/logout"><i class="fa fa-sign-out-alt"></i> Logout</a></li>
                        </ul>
                    </div>
                    <div class="mil-menu-btn"><span></span></div>
                </div>
            </div>
        </div>

        <div id="smooth-content">
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-text-m mil-mb-20 mil-up">Platform Configuration</div>
                                <h1 class="mil-mb-60 mil-up">System Settings</h1>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mil-blog-list mil-p-0-80">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4 class="mil-mb-30">Commission Settings</h4>
                                <form action="/superadmin/settings" method="POST">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label class="mil-text-s mil-soft mil-mb-10">Verification Fee (₦)</label>
                                            <input class="mil-input mil-up mil-mb-15" type="number" name="verificationFee" value="<%= settings.verificationFee %>" required>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="mil-text-s mil-soft mil-mb-10">Promoter Commission (%)</label>
                                            <input class="mil-input mil-up mil-mb-15" type="number" name="promoterCommission" value="<%= settings.promoterCommission %>" required>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="mil-text-s mil-soft mil-mb-10">Platform Commission (%)</label>
                                            <input class="mil-input mil-up mil-mb-15" type="number" name="platformCommission" value="<%= settings.platformCommission %>" required>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="mil-text-s mil-soft mil-mb-10">Owner Commission (%)</label>
                                            <input class="mil-input mil-up mil-mb-15" type="number" name="ownerCommission" value="<%= settings.ownerCommission %>" required>
                                        </div>
                                    </div>
                                    
                                    <h4 class="mil-mb-30 mil-mt-30">Site Information</h4>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label class="mil-text-s mil-soft mil-mb-10">Site Name</label>
                                            <input class="mil-input mil-up mil-mb-15" type="text" name="siteName" value="<%= settings.siteName %>" required>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="mil-text-s mil-soft mil-mb-10">Site Email</label>
                                            <input class="mil-input mil-up mil-mb-15" type="email" name="siteEmail" value="<%= settings.siteEmail %>" required>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="mil-text-s mil-soft mil-mb-10">Site Phone</label>
                                            <input class="mil-input mil-up mil-mb-15" type="text" name="sitePhone" value="<%= settings.sitePhone %>" required>
                                        </div>
                                        <div class="col-md-12">
                                            <label class="mil-text-s mil-soft mil-mb-10">Site Address</label>
                                            <input class="mil-input mil-up mil-mb-30" type="text" name="siteAddress" value="<%= settings.siteAddress %>" required>
                                        </div>
                                    </div>
                                    
                                    <button type="submit" class="mil-btn mil-md">Save Settings</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <footer class="mil-p-80-0">
            <div class="container">
                <div class="mil-footer-bottom">
                    <p class="mil-text-s mil-soft">© 2024 RevaampAP. All rights reserved.</p>
                </div>
            </div>
        </footer>
    </div>

    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/main.js"></script>
    <style>
        .dropdown-menu { display: none; }
        .dropdown:hover .dropdown-menu { display: block; }
        .mil-mt-30 { margin-top: 30px; }
    </style>
</body>
</html>