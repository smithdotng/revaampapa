    <script>
        // Load featured properties
        function loadFeaturedProperties() {
            fetch('/api/properties/featured')
                .then(response => response.json())
                .then(data => {
                    const container = document.getElementById('featuredPropertiesContainer');
                    if (data.properties && data.properties.length > 0) {
                        container.innerHTML = data.properties.map(property => `
                            <div class="swiper-slide">
                                <div class="mil-center">
                                    <div class="property-card-featured">
                                        <img src="${property.images && property.images[0] ? property.images[0].url : '/img/property-placeholder.jpg'}" alt="${property.title}" style="width: 100%; border-radius: 20px; margin-bottom: 20px;">
                                        <h5>${property.title.substring(0, 50)}${property.title.length > 50 ? '...' : ''}</h5>
                                        <p class="mil-text-m mil-soft">${property.location.city}, ${property.location.state}</p>
                                        <p class="h5 mil-accent">₦${property.price.toLocaleString()}</p>
                                        <a href="/properties/${property.slug}" class="mil-btn mil-sm mil-mt-30">View Details</a>
                                    </div>
                                </div>
                            </div>
                        `).join('');
                        
                        new Swiper('#featuredPropertiesSlider', {
                            slidesPerView: 1,
                            spaceBetween: 30,
                            loop: true,
                            navigation: { nextEl: '.mil-testi-next', prevEl: '.mil-testi-prev' },
                            pagination: { el: '.mil-testi-pagination', clickable: true },
                            breakpoints: { 768: { slidesPerView: 2 }, 1200: { slidesPerView: 3 } }
                        });
                    } else {
                        container.innerHTML = '<div class="swiper-slide"><div class="mil-center"><p>No featured properties at the moment. Check back soon!</p></div></div>';
                    }
                })
                .catch(error => {
                    console.error('Error loading properties:', error);
                    document.getElementById('featuredPropertiesContainer').innerHTML = '<div class="swiper-slide"><div class="mil-center"><p>Unable to load properties. Please try again later.</p></div></div>';
                });
        }

        // Newsletter subscription
        function initNewsletter() {
            const newsletterForm = document.getElementById('footerNewsletterForm');
            if (newsletterForm) {
                newsletterForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const email = newsletterForm.querySelector('input[type="email"]').value;
                    try {
                        const response = await fetch('/api/subscribe', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ email })
                        });
                        const data = await response.json();
                        alert(data.success ? 'Successfully subscribed to newsletter!' : 'Error subscribing. Please try again.');
                        if (data.success) newsletterForm.reset();
                    } catch (error) {
                        console.error('Newsletter error:', error);
                        alert('Error subscribing. Please try again.');
                    }
                });
            }
        }

        // Initialize all functions
        document.addEventListener('DOMContentLoaded', function() {
            loadFeaturedProperties();
            initNewsletter();
        });
    </script>

