<%- include('partials/header') %>

<!-- Page Top -->
<section>
    <div class="w-100 pt-180 pb-110 black-layer opc45 position-relative">
        <div class="fixed-bg" style="background-image: url(/assets/images/pg-tp-bg.jpg);"></div>
        <div class="container">
            <div class="pg-tp-wrp text-center w-100">
                <h1 class="mb-0">For Realtors</h1>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/" title="Home">Home</a></li>
                    <li class="breadcrumb-item active">For Realtors</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<!-- Realtor Hero -->
<section>
    <div class="w-100 pt-120 pb-90 position-relative">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h2>Grow Your Real Estate Business with Found Properties</h2>
                    <p class="lead">List unlimited properties for free and reach thousands of qualified buyers and tenants across Nigeria.</p>
                    <ul class="feature-list mt-4">
                        <li><i class="fas fa-check-circle text-success"></i> 100% free to list</li>
                        <li><i class="fas fa-check-circle text-success"></i> Unlimited property listings</li>
                        <li><i class="fas fa-check-circle text-success"></i> Verified leads</li>
                        <li><i class="fas fa-check-circle text-success"></i> Analytics dashboard</li>
                        <li><i class="fas fa-check-circle text-success"></i> Agent network access</li>
                        <li><i class="fas fa-check-circle text-success"></i> Featured opportunities</li>
                    </ul>
                    <a href="/register" class="thm-btn mt-4">Create Your Free Account</a>
                </div>
                <div class="col-lg-6">
                    <img src="/assets/images/realtor-hero.jpg" alt="For Realtors" class="img-fluid rounded">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Benefits Grid -->
<section class="gray-bg">
    <div class="w-100 pt-120 pb-90 position-relative">
        <div class="container">
            <div class="sec-title text-center w-100">
                <h2 class="mb-0">Why Realtors Choose Found Properties</h2>
            </div>

            <div class="row mt-5">
                <div class="col-lg-4">
                    <div class="benefit-card">
                        <div class="icon-circle">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <h4>Increased Visibility</h4>
                        <p>Your properties get exposed to thousands of potential buyers and tenants actively searching for properties.</p>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="benefit-card">
                        <div class="icon-circle">
                            <i class="fas fa-users"></i>
                        </div>
                        <h4>Qualified Leads</h4>
                        <p>Receive inquiries from serious buyers and tenants. All leads are verified and genuine.</p>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="benefit-card">
                        <div class="icon-circle">
                            <i class="fas fa-hand-holding-usd"></i>
                        </div>
                        <h4>Additional Income</h4>
                        <p>Earn 10% commission when agents refer buyers to your properties and complete transactions.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works for Realtors -->
<section>
    <div class="w-100 pt-120 pb-90 position-relative">
        <div class="container">
            <div class="sec-title text-center w-100">
                <span class="d-block thm-clr">Simple Process</span>
                <h2 class="mb-0">Get Started in 3 Easy Steps</h2>
            </div>

            <div class="row mt-5">
                <div class="col-md-4">
                    <div class="step-box">
                        <div class="step-number">1</div>
                        <h4>Create Account</h4>
                        <p>Register for free and verify your realtor status with your company documents.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="step-box">
                        <div class="step-number">2</div>
                        <h4>List Properties</h4>
                        <p>Add your properties with high-quality images, detailed descriptions, and pricing.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="step-box">
                        <div class="step-number">3</div>
                        <h4>Manage & Grow</h4>
                        <p>Track views, manage inquiries, and grow your business with our analytics tools.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="dark-layer2 opc9 position-relative">
    <div class="fixed-bg" style="background-image: url(/assets/images/cta-bg.jpg);"></div>
    <div class="w-100 pt-120 pb-120 text-center text-white">
        <div class="container">
            <h2 class="mb-4">Ready to Start Listing?</h2>
            <p class="lead mb-5">Join hundreds of successful realtors on Found Properties today.</p>
            <a href="/register" class="thm-btn mr-3">Create Free Account</a>
            <a href="/contact" class="thm-btn brd-btn">Contact Sales</a>
        </div>
    </div>
</section>

<style>
.feature-list {
    list-style: none;
    padding: 0;
}

.feature-list li {
    margin-bottom: 15px;
    font-size: 16px;
}

.feature-list li i {
    margin-right: 15px;
    font-size: 20px;
}

.benefit-card {
    background: white;
    padding: 40px 30px;
    border-radius: 10px;
    text-align: center;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    transition: all 0.3s ease;
    margin-bottom: 30px;
}

.benefit-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.1);
}

.benefit-card .icon-circle {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 25px;
}

.benefit-card .icon-circle i {
    font-size: 32px;
    color: white;
}

.benefit-card h4 {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 15px;
}

.benefit-card p {
    color: #666;
    margin: 0;
}

.step-box {
    text-align: center;
    padding: 40px 30px;
    background: white;
    border-radius: 10px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    position: relative;
    margin-bottom: 30px;
}

.step-number {
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    font-weight: bold;
    margin: 0 auto 20px;
}

.step-box h4 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 15px;
}

.step-box p {
    color: #666;
    margin: 0;
}
</style>

