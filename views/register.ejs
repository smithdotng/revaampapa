                                        <p class="mil-mb-5"><strong>Account Name:</strong> Revacom Ltd</p>
                                        <p class="mil-mb-5"><strong>Account Number:</strong> 5601419395</p>
                                    </div>
                                    <p class="mil-text-xs mil-soft">After payment, enter your transaction details below and upload proof of payment.</p>
                                </div>
                            </div>

                            <div class="mil-price-card">
                                <form action="/register" method="POST" enctype="multipart/form-data">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <input class="mil-input mil-up mil-mb-15" type="text" name="name" placeholder="Full name" required>
                                        </div>
