        .step-number {
            transition: transform 0.3s ease;
        }
        .step-number:hover {
            transform: scale(1.1);
        }
        .alert {
            animation: slideIn 0.3s ease;
        }
        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
        .btn-close {
