    <script>
        // Auto-close flash messages
        setTimeout(function() {
            document.querySelectorAll('.alert').forEach(function(alert) {
                alert.style.opacity = '0';
                setTimeout(function() {
                    if (alert.parentNode) alert.remove();
                }, 300);
            });
        }, 5000);

        // Newsletter subscription
        var footerForm = document.getElementById('footerNewsletterForm');
        if (footerForm) {
            footerForm.addEventListener('submit', function(e) {
                e.preventDefault();
                var email = footerForm.querySelector('input[type="email"]').value;
                fetch('/api/subscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: email })
                })
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    alert(data.success ? 'Successfully subscribed!' : 'Error subscribing. Please try again.');
                    if (data.success) footerForm.reset();
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    alert('Error subscribing. Please try again.');
                });
            });
        }
    </script>

