                            <!-- Inquiry Form -->
                            <div class="inquiry-form">
                                <h4 class="mil-mb-20">Interested in this property?</h4>
                                
                                <div id="successMessage" class="success-message">
                                    <i class="fa fa-check-circle"></i> Inquiry sent successfully! The property owner will contact you soon.
                                </div>
                                <div id="errorMessage" class="error-message">
                                    <i class="fa fa-exclamation-circle"></i> <span id="errorText"></span>
                                </div>
                                
