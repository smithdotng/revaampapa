                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-text-m mil-mb-20 mil-up">Property Details</div>
                                <h1 class="mil-mb-60 mil-up"><%= property.title %></h1>
                                <ul class="mil-breadcrumbs mil-pub-info mil-center mil-up">
                                    <li><a href="/">Home</a></li>
                                    <li><a href="/properties">Properties</a></li>
                                    <li><%= property.title.substring(0, 30) %></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-8">
                            <!-- Gallery -->
                            <div class="property-gallery mil-mb-30">
                                <% if (property.images && property.images.length > 0) { 
                                    var primaryImage = property.images.find(function(img) { return img.isPrimary; }) || property.images[0];
                                    var primaryImageUrl = primaryImage.url || primaryImage;
                                %>
                                    <img id="mainImage" src="<%= primaryImageUrl %>" alt="<%= property.title %>" class="main-image" onerror="this.src='/img/property-placeholder.jpg'">
                                    <div class="thumbnail-list">
                                        <% property.images.forEach(function(image, index) { 
                                            var thumbUrl = image.url || image;
                                        %>
                                            <img src="<%= thumbUrl %>" alt="Thumbnail" class="thumbnail <%= image.isPrimary ? 'active' : '' %>" onerror="this.src='/img/property-placeholder.jpg'" onclick="changeImage(this, '<%= thumbUrl %>')">
                                        <% }); %>
                                    </div>
                                <% } else { %>
                                    <div style="width: 100%; height: 500px; background: #f0f0f0; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                                        <i class="fa fa-building" style="font-size: 80px; color: #ccc;"></i>
                                    </div>
                                <% } %>
                            </div>

                            <!-- Price & Status -->
                            <div class="mil-mb-30">
                                <div class="row align-items-center">
                                    <div class="col-md-6">
                                        <span class="property-price">₦<%= property.price.toLocaleString() %></span>
                                        <% if (property.priceNegotiable) { %>
                                            <span class="mil-text-s mil-soft"> (Negotiable)</span>
                                        <% } %>
                                    </div>
                                    <div class="col-md-6 mil-text-right">
                                        <span class="status-badge status-<%= property.status === 'available' ? 'available' : (property.status === 'sold' ? 'sold' : 'rented') %>">
                                            <%= property.status.toUpperCase() %>
                                        </span>
                                    </div>
                                </div>
