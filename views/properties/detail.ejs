                            <!-- Property Type & Transaction Type -->
                            <div class="mil-mb-30">
                                <span class="mil-badge" style="background: #03A6A6; color: white; padding: 5px 12px; border-radius: 20px; margin-right: 10px;">
                                    <i class="fa fa-home"></i> <%= property.propertyType.replace('_', ' ').toUpperCase() %>
                                </span>
                                <span class="mil-badge" style="background: #6c757d; color: white; padding: 5px 12px; border-radius: 20px;">
                                    <i class="fa fa-tag"></i> <%= property.transactionType.toUpperCase() %>
                                </span>
                            </div>

                            <!-- Description with Rich Text -->
                            <div class="mil-mb-40">
                                <h3 class="mil-mb-20">Description</h3>
                                <div class="property-description">
                                    <%- property.description %>
                                </div>
                            </div>

                            <!-- Features -->
                            <div class="mil-mb-40">
                                <h3 class="mil-mb-20">Features & Amenities</h3>
                                <div class="property-features">
                                    <% if (property.features && property.features.bedrooms) { %>
                                        <div class="feature-item"><i class="fa fa-bed"></i><span><%= property.features.bedrooms %> Bedrooms</span></div>
                                    <% } %>
                                    <% if (property.features && property.features.bathrooms) { %>
                                        <div class="feature-item"><i class="fa fa-bath"></i><span><%= property.features.bathrooms %> Bathrooms</span></div>
                                    <% } %>
                                    <% if (property.features && property.features.toilets) { %>
                                        <div class="feature-item"><i class="fa fa-toilet"></i><span><%= property.features.toilets %> Toilets</span></div>
                                    <% } %>
                                    <% if (property.features && property.features.parkingSpaces) { %>
                                        <div class="feature-item"><i class="fa fa-car"></i><span><%= property.features.parkingSpaces %> Parking Spaces</span></div>
                                    <% } %>
                                    <% if (property.features && property.features.floorArea) { %>
                                        <div class="feature-item"><i class="fa fa-arrows-alt"></i><span><%= property.features.floorArea.toLocaleString() %> sq ft</span></div>
                                    <% } %>
                                    <% if (property.features && property.features.landArea) { %>
                                        <div class="feature-item"><i class="fa fa-map"></i><span><%= property.features.landArea.toLocaleString() %> sq ft Land</span></div>
                                    <% } %>
                                    <% if (property.features && property.features.furnished) { %>
                                        <div class="feature-item"><i class="fa fa-couch"></i><span>Furnished</span></div>
                                    <% } %>
                                    <% if (property.features && property.features.serviced) { %>
                                        <div class="feature-item"><i class="fa fa-concierge-bell"></i><span>Serviced</span></div>
                                    <% } %>
                                    <% if (property.features && property.features.security) { %>
                                        <div class="feature-item"><i class="fa fa-shield-alt"></i><span>24/7 Security</span></div>
                                    <% } %>
                                    <% if (property.features && property.features.powerSupply) { %>
                                        <div class="feature-item"><i class="fa fa-bolt"></i><span>Power Supply</span></div>
                                    <% } %>
                                    <% if (property.features && property.features.borehole) { %>
                                        <div class="feature-item"><i class="fa fa-tint"></i><span>Borehole</span></div>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Location -->
                            <div class="mil-mb-40">
                                <h3 class="mil-mb-20">Location</h3>
                                <p class="mil-text-m mil-soft">
                                    <i class="fa fa-map-marker"></i> 
                                    <%= property.location.address ? property.location.address + ', ' : '' %>
                                    <%= property.location.city ? property.location.city + ', ' : '' %>
                                    <%= property.location.state ? property.location.state : '' %>
                                    <%= property.location.lga ? ' (' + property.location.lga + ')' : '' %>
                                </p>
                                <% if (property.location.landmark) { %>
                                    <p class="mil-text-s mil-soft mil-mt-10">
                                        <i class="fa fa-flag"></i> Landmark: <%= property.location.landmark %>
                                    </p>
                                <% } %>
                            </div>
                        </div>

                        <!-- Right Column - Sidebar -->
                        <div class="col-xl-4">
                            <!-- Owner Information -->
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4 class="mil-mb-20">Property Owner</h4>
                                <div class="mil-mb-15">
                                    <p><strong><i class="fa fa-user"></i> <%= property.owner ? property.owner.name : 'N/A' %></strong></p>
                                   
                                </div>
                            </div>

                            <!-- Share Property Section -->
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4 class="mil-mb-20">Share this Property</h4>
                                <div class="social-share">
                                    <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent('https://' + (host || 'revaampap.com') + '/properties/' + property.slug) %>" target="_blank" class="social-facebook">
                                        <i class="fa fa-facebook"></i> Facebook
                                    </a>
                                    <a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent('https://' + (host || 'revaampap.com') + '/properties/' + property.slug) %>&text=<%= encodeURIComponent(property.title) %>" target="_blank" class="social-twitter">
                                        <i class="fa fa-twitter"></i> Twitter
                                    </a>
                                    <a href="https://wa.me/?text=<%= encodeURIComponent(property.title + ' - ₦' + property.price.toLocaleString() + ' - https://' + (host || 'revaampap.com') + '/properties/' + property.slug) %>" target="_blank" class="social-whatsapp">
                                        <i class="fa fa-whatsapp"></i> WhatsApp
                                    </a>
                                    <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= encodeURIComponent('https://' + (host || 'revaampap.com') + '/properties/' + property.slug) %>" target="_blank" class="social-linkedin">
                                        <i class="fa fa-linkedin"></i> LinkedIn
                                    </a>
                                    <a href="mailto:?subject=<%= encodeURIComponent(property.title) %>&body=<%= encodeURIComponent('Check out this property: https://' + (host || 'revaampap.com') + '/properties/' + property.slug) %>" class="social-email">
                                        <i class="fa fa-envelope"></i> Email
                                    </a>
