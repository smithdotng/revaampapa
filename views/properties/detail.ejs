                                    <input type="hidden" name="propertyId" value="<%= property._id %>">
                                    
                                    <div class="form-group">
                                        <input type="text" id="inquiryName" name="name" placeholder="Your Name *" required 
                                               value="<%= user ? user.name : '' %>">
                                    </div>
                                    
                                    <div class="form-group">
                                        <input type="email" id="inquiryEmail" name="email" placeholder="Your Email *" required 
                                               value="<%= user ? user.email : '' %>">
                                    </div>
                                    
                                    <div class="form-group">
                                        <input type="tel" id="inquiryPhone" name="phone" placeholder="Your Phone Number (Optional)"
                                               value="<%= user && user.phone ? user.phone : '' %>">
                                    </div>
                                    
                                    <div class="form-group">
                                        <textarea name="message" rows="4" placeholder="I'm interested in this property. Please contact me with more information." required></textarea>
                                    </div>
                                    
                                    <button type="submit" class="btn-primary" id="submitInquiryBtn">
                                        <i class="fa fa-paper-plane"></i> Send Inquiry
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <footer class="mil-p-80-0">
                <div class="container">
                    <div class="mil-footer-bottom">
                        <div class="row">
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-soft">© 2024 RevaampAP. All rights reserved.</p>
                            </div>
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-text-right mil-sm-text-left mil-soft">Find your dream property today</p>
                            </div>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/plugins/swiper.min.js"></script>
    <script src="/js/plugins/gsap.min.js"></script>
    <script src="/js/plugins/ScrollSmoother.min.js"></script>
    <script src="/js/plugins/ScrollTrigger.min.js"></script>
    <script src="/js/plugins/ScrollTo.min.js"></script>
    <script src="/js/plugins/magnific-popup.js"></script>
    <script src="/js/main.js"></script>

    <script>
        // Change gallery image
        function changeImage(thumbnail, imageUrl) {
            document.getElementById('mainImage').src = imageUrl;
            document.querySelectorAll('.thumbnail').forEach(function(thumb) {
                thumb.classList.remove('active');
            });
            thumbnail.classList.add('active');
        }
        
        // Get form elements
        const inquiryForm = document.getElementById('inquiryForm');
        const submitBtn = document.getElementById('submitInquiryBtn');
        const successMessageDiv = document.getElementById('successMessage');
        const errorMessageDiv = document.getElementById('errorMessage');
        const errorTextSpan = document.getElementById('errorText');
        
        // Hide messages initially
        if (successMessageDiv) successMessageDiv.style.display = 'none';
        if (errorMessageDiv) errorMessageDiv.style.display = 'none';
        
        // Handle inquiry form submission
        if (inquiryForm) {
            inquiryForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                const propertyId = document.querySelector('input[name="propertyId"]').value;
                const name = document.getElementById('inquiryName').value.trim();
                const email = document.getElementById('inquiryEmail').value.trim();
                const phone = document.getElementById('inquiryPhone').value.trim();
                const message = document.querySelector('textarea[name="message"]').value.trim();
                
                if (!name) { showError('Please enter your name'); return; }
                if (!email) { showError('Please enter your email address'); return; }
                if (!email.includes('@') || !email.includes('.')) { showError('Please enter a valid email address'); return; }
                if (!message) { showError('Please enter your message'); return; }
                
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Sending...';
                hideMessages();
                
                try {
                    const response = await fetch('/api/inquiries', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ propertyId, name, email, phone, message })
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        showSuccess();
                        inquiryForm.reset();
                        document.querySelector('input[name="propertyId"]').value = propertyId;
                    } else {
                        showError(result.message || 'Failed to send inquiry. Please try again.');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    showError('Network error. Please check your connection and try again.');
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fa fa-paper-plane"></i> Send Inquiry';
                }
            });
        }
        
        function showSuccess() {
            if (successMessageDiv) {
                successMessageDiv.style.display = 'block';
                if (errorMessageDiv) errorMessageDiv.style.display = 'none';
                setTimeout(function() {
                    if (successMessageDiv) successMessageDiv.style.display = 'none';
                }, 5000);
            } else {
                alert('Inquiry sent successfully! The property owner will contact you soon.');
            }
        }
        
        function showError(message) {
            if (errorMessageDiv && errorTextSpan) {
                errorTextSpan.innerText = message;
                errorMessageDiv.style.display = 'block';
                if (successMessageDiv) successMessageDiv.style.display = 'none';
                setTimeout(function() {
                    if (errorMessageDiv) errorMessageDiv.style.display = 'none';
                }, 5000);
            } else {
                alert('Error: ' + message);
            }
        }
        
        function hideMessages() {
            if (successMessageDiv) successMessageDiv.style.display = 'none';
            if (errorMessageDiv) errorMessageDiv.style.display = 'none';
        }
    </script>
</body>

</html>