            "@type": "Organization",
            "name": "RevaampAPA",
            "url": "https://revaampap.com",
            "logo": "https://revaampap.com/img/logo.png",
            "sameAs": [
                "https://www.facebook.com/revaampap",
                "https://www.twitter.com/revaampap",
                "https://www.instagram.com/revaampap",
                "https://www.linkedin.com/company/revaampap"
            ],
            "contactPoint": {
                "@type": "ContactPoint",
                "telephone": "+2348000000000",
                "contactType": "customer service",
                "availableLanguage": ["English"]
            },
            "address": {
                "@type": "PostalAddress",
                "streetAddress": "Suite 6, Block B, Ebitu Ukiwe Street, Jabi",
                "addressLocality": "Abuja",
                "addressCountry": "NG"
            },
            "description": "Africa's leading aggregation, promotions and agency platform for property and project management."
        }
        </script>

        <!-- Flash Messages -->
        <% if (typeof error !== 'undefined' && error && error.length) { %>
            <div class="alert alert-danger alert-dismissible fade show m-3" style="position: fixed; top: 100px; right: 20px; z-index: 9999; background: #f8d7da; color: #721c24; padding: 15px 20px; border-radius: 10px; border-left: 4px solid #dc3545;">
                <i class="fas fa-exclamation-circle"></i> <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" style="float: right; background: none; border: none; font-size: 20px; cursor: pointer;">&times;</button>
            </div>
        <% } %>
        <% if (typeof success !== 'undefined' && success && success.length) { %>
            <div class="alert alert-success alert-dismissible fade show m-3" style="position: fixed; top: 100px; right: 20px; z-index: 9999; background: #d4edda; color: #155724; padding: 15px 20px; border-radius: 10px; border-left: 4px solid #28a745;">
                <i class="fas fa-check-circle"></i> <%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" style="float: right; background: none; border: none; font-size: 20px; cursor: pointer;">&times;</button>
            </div>
        <% } %>

