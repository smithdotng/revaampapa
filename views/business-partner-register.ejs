<body>
    <div id="smooth-wrapper" class="mil-wrapper">
        

        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo"><img src="/img/logo.png" alt="RevaampAPA" width="83" height="32"></a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/properties">Properties</a></li>
                        <li><a href="/about">About</a></li>
                        <li><a href="/contact">Contact</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <a href="/login" class="mil-btn mil-sm">Log in</a>
                    <a href="/register" class="mil-btn mil-sm mil-light">List Property</a>
                    <div class="mil-menu-btn"><span></span></div>
                </div>
            </div>
        </div>

        <div id="smooth-content">
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-text-m mil-mb-20">Earn money from Premium Discount Forward and Supply contracts generated weekly under the programme</div>
                                <h1 class="mil-mb-60">Become a Business Partner</h1>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-xl-6">
                            <!-- Payment Instructions -->
                            <div class="mil-price-card mil-up mil-mb-30" style="background: #f0f9ff; border-left: 4px solid #03A6A6;">
                                <div class="mil-text-center">
                                    <i class="fa fa-bank" style="font-size: 40px; color: #03A6A6; margin-bottom: 15px;"></i>
                                    <h4 class="mil-mb-15">Payment Instructions</h4>
                                    <p class="mil-text-s mil-soft">Pay the partnership fee of <strong>₦20,000</strong> to:</p>
                                    <div style="background: white; padding: 15px; border-radius: 10px; margin: 15px 0;">
                                        <p class="mil-mb-5"><strong>Bank Name:</strong> Fidelity Bank</p>
                                        <p class="mil-mb-5"><strong>Account Name:</strong> Revacom Ltd</p>
                                        <p class="mil-mb-5"><strong>Account Number:</strong> 5601419395</p>
                                    </div>
                                    <p class="mil-text-xs mil-soft">After payment, enter your transaction details below and upload proof of payment.</p>
                                </div>
                            </div>

                            <div class="mil-price-card">
                                <div class="mil-text-center mil-mb-30">
                                    <i class="fa fa-handshake" style="font-size: 60px; color: #03A6A6;"></i>
                                    <h3 class="mil-mb-15">Join Our Partner Network</h3>
                                    <p>Start earning by promoting properties on your social media</p>
                                </div>
                                
                                <form action="/business-partner/register" method="POST" enctype="multipart/form-data">
                                    <input class="mil-input mil-mb-15" type="text" name="name" placeholder="Full name" required>
                                    <input class="mil-input mil-mb-15" type="email" name="email" placeholder="Email address" required>
                                    <input class="mil-input mil-mb-15" type="tel" name="phone" placeholder="Phone number (e.g., 08012345678)" required>
                                    <input class="mil-input mil-mb-15" type="text" name="socialHandle" placeholder="Social media handle (Instagram/Twitter/Facebook)">
                                    <textarea class="mil-input mil-mb-15" name="experience" rows="3" placeholder="Tell us about your sales/marketing experience (optional)"></textarea>
                                    <input class="mil-input mil-mb-15" type="password" name="password" placeholder="Password (min. 8 characters)" required>
                                    <input class="mil-input mil-mb-30" type="password" name="confirmPassword" placeholder="Confirm Password" required>

                                    <!-- Payment Details Section -->
                                    <h4 class="mil-mb-15 mil-mt-30">Payment Details</h4>
                                    <div class="mil-divider mil-mb-30"></div>
                                    
                                    <input class="mil-input mil-mb-15" type="text" name="paymentReference" placeholder="Transaction Reference / Receipt Number" required>
                                    <input class="mil-input mil-mb-15" type="number" name="paymentAmount" placeholder="Amount Paid (₦)" value="20000" readonly style="background: #f5f5f5;">
                                    <input class="mil-input mil-mb-15" type="date" name="paymentDate" placeholder="Payment Date" required>
                                    
                                    <div class="mil-mb-30">
                                        <label class="mil-text-s mil-soft">Upload Payment Proof (Screenshot/Receipt)</label>
                                        <input class="mil-input mil-mt-10" type="file" name="paymentProof" accept="image/*,.pdf" required>
                                        <p class="mil-text-xs mil-soft mil-mt-5">Upload clear screenshot or PDF of your payment confirmation</p>
                                    </div>

                                    <div class="mil-checkbox-frame mil-up mil-mb-30">
                                        <div class="mil-checkbox">
                                            <input type="checkbox" id="terms" name="terms" required>
                                            <label for="terms"></label>
                                        </div>
                                        <p class="mil-text-xs mil-soft">I agree to the <a href="/terms" class="mil-accent">Terms and Conditions</a> and <a href="/privacy" class="mil-accent">Privacy Policy</a></p>
                                    </div>

                                    <button type="submit" class="mil-btn mil-md mil-fw">Submit Registration & Payment Proof</button>

                                    <div class="mil-text-center mil-mt-30">
                                        <p>Already have an account? <a href="/login">Login here</a></p>
                                        <p>Want to list your property? <a href="/register">Register as Property Owner</a></p>
                                        <p>Want to earn as a free promoter? <a href="/promoter/register">Become a Promoter (Free)</a></p>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <footer class="mil-p-80-0">
            <div class="container">
                <div class="mil-footer-bottom">
                    <p class="mil-text-s mil-soft">© 2026 RevaampAPA. All rights reserved.</p>
