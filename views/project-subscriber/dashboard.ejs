<!DOCTYPE html>
<html lang="en-US">

<head>
    <title><%= title %></title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <link rel="stylesheet" href="/fonts/css/switzer.css" type="text/css" media="all">
    <link rel="stylesheet" href="/fonts/css/font-awesome.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/bootstrap-grid.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/swiper.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>

<body>
    <div id="smooth-wrapper" class="mil-wrapper">
        <div class="mil-preloader"><div class="mil-load"></div><p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p></div>
        <div class="mil-progress-track"><div class="mil-progress"></div></div>
        <div class="progress-wrap active-progress"></div>

        <!-- Top Panel -->
        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo"><img src="/img/logo.png" alt="RevaampAP" width="83" height="32"></a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li class="mil-active"><a href="/project-subscriber/dashboard">Dashboard</a></li>
                        <li><a href="/project-subscriber/projects">Projects</a></li>
                        <li><a href="/project-subscriber/bank-guarantee">Bank Guarantee</a></li>
                        <li><a href="/project-subscriber/subscription">Subscription</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <div class="dropdown" style="position: relative;">
                        <a href="#" class="mil-btn mil-sm dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="fa fa-user-circle"></i> <%= user.name %> <i class="fa fa-chevron-down"></i>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a href="/project-subscriber/dashboard"><i class="fa fa-tachometer"></i> Dashboard</a></li>
                            <li><a href="/project-subscriber/settings"><i class="fa fa-cog"></i> Settings</a></li>
                            <li><hr></li>
                            <li><a href="/logout"><i class="fa fa-sign-out-alt"></i> Logout</a></li>
                        </ul>
                    </div>
                    <div class="mil-menu-btn"><span></span></div>
                </div>
            </div>
        </div>

        <div id="smooth-content">
            <!-- Banner -->
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-text-m mil-mb-20">Welcome back, <%= user.name %>!</div>
                                <h1 class="mil-mb-60">Project Management Dashboard</h1>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stats Cards -->
            <div class="mil-blog-list mil-p-0-80">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <i class="fa fa-building" style="font-size: 40px; color: #03A6A6; margin-bottom: 15px;"></i>
                                <h4><%= stats.totalProjects %></h4>
                                <p class="mil-text-s mil-soft">Total Projects</p>
                            </div>
                        </div>
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <i class="fa fa-spinner" style="font-size: 40px; color: #ffc107; margin-bottom: 15px;"></i>
                                <h4><%= stats.inProgressProjects %></h4>
                                <p class="mil-text-s mil-soft">In Progress</p>
                            </div>
                        </div>
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <i class="fa fa-check-circle" style="font-size: 40px; color: #28a745; margin-bottom: 15px;"></i>
                                <h4><%= stats.completedProjects %></h4>
                                <p class="mil-text-s mil-soft">Completed</p>
                            </div>
                        </div>
                        <div class="col-xl-3 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <i class="fa fa-money" style="font-size: 40px; color: #03A6A6; margin-bottom: 15px;"></i>
                                <h4>₦<%= stats.totalProjectValue.toLocaleString() %></h4>
                                <p class="mil-text-s mil-soft">Total Project Value</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Status Cards -->
            <div class="mil-blog-list mil-p-0-80">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-6 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4>Bank Guarantee Status</h4>
                                <div class="mil-mt-15">
                                    <% if (stats.bankGuaranteeStatus === 'approved') { %>
                                        <span style="background: #28a745; color: white; padding: 5px 15px; border-radius: 20px;">✓ Approved</span>
                                        <p class="mil-text-s mil-soft mil-mt-15">Your bank guarantee has been verified.</p>
                                    <% } else if (stats.bankGuaranteeStatus === 'pending') { %>
                                        <span style="background: #ffc107; color: #856404; padding: 5px 15px; border-radius: 20px;">⏳ Pending Verification</span>
                                        <p class="mil-text-s mil-soft mil-mt-15">Your bank guarantee is being reviewed.</p>
                                    <% } else { %>
                                        <span style="background: #dc3545; color: white; padding: 5px 15px; border-radius: 20px;">❌ Not Submitted</span>
                                        <p class="mil-text-s mil-soft mil-mt-15">Please submit your bank guarantee to start projects.</p>
                                    <% } %>
                                </div>
                                <div class="mil-mt-15">
                                    <a href="/project-subscriber/bank-guarantee" class="mil-link mil-accent">Manage Bank Guarantee →</a>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-6 col-md-6">
                            <div class="mil-price-card mil-up mil-mb-30">
                                <h4>Subscription Status</h4>
                                <div class="mil-mt-15">
                                    <% if (stats.subscriptionStatus === 'active') { %>
                                        <span style="background: #28a745; color: white; padding: 5px 15px; border-radius: 20px;">✓ Active</span>
                                        <p class="mil-text-s mil-soft mil-mt-15">Your subscription is active.</p>
                                    <% } else { %>
                                        <span style="background: #dc3545; color: white; padding: 5px 15px; border-radius: 20px;">❌ Inactive</span>
                                        <p class="mil-text-s mil-soft mil-mt-15">Please subscribe to activate your account.</p>
                                    <% } %>
                                </div>
                                <div class="mil-mt-15">
                                    <a href="/project-subscriber/subscription" class="mil-link mil-accent">Manage Subscription →</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Projects -->
            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="mil-text-center">
                        <h2 class="mil-mb-30">Recent Projects</h2>
                        <p class="mil-text-m mil-soft mil-mb-60">Your latest project activities</p>
                    </div>
                    <div class="row">
                        <% if (projects && projects.length > 0) { %>
                            <% projects.forEach(function(project) { %>
                                <div class="col-xl-4 col-md-6">
                                    <div class="mil-price-card mil-up mil-mb-30">
                                        <div class="mil-mb-15">
                                            <h4><%= project.title %></h4>
                                            <p class="mil-text-s mil-soft"><i class="fa fa-map-marker"></i> <%= project.location.city %>, <%= project.location.state %></p>
                                        </div>
                                        <div class="mil-mb-15">
                                            <div class="progress-bar" style="background: #e0e0e0; border-radius: 10px; height: 8px;">
                                                <div style="width: <%= project.progress || 0 %>%; background: #03A6A6; border-radius: 10px; height: 8px;"></div>
                                            </div>
                                            <p class="mil-text-xs mil-soft mil-mt-10">Progress: <%= project.progress || 0 %>%</p>
                                        </div>
                                        <div class="mil-flex-between">
                                            <span class="mil-text-s mil-soft">₦<%= project.projectValue.toLocaleString() %></span>
                                            <span class="mil-badge" style="background: 
                                                <% if (project.status === 'completed') { %>#28a745<% } 
                                                else if (project.status === 'in_progress') { %>#ffc107<% } 
                                                else if (project.status === 'pending_approval') { %>#17a2b8<% } 
                                                else { %>#6c757d<% } %>; 
                                                color: white; padding: 4px 12px; border-radius: 20px; font-size: 12px;">
                                                <%= project.status.replace('_', ' ').toUpperCase() %>
                                            </span>
                                        </div>
                                        <div class="mil-mt-15">
                                            <a href="/project-subscriber/projects/<%= project.slug %>" class="mil-link mil-accent">View Details →</a>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="col-xl-12">
                                <div class="mil-price-card mil-up mil-mb-30 mil-text-center">
                                    <i class="fa fa-folder-open" style="font-size: 60px; opacity: 0.3; margin-bottom: 20px;"></i>
                                    <h4>No Projects Yet</h4>
                                    <p class="mil-text-m mil-soft mil-mb-30">Get started by creating your first project.</p>
                                    <a href="/project-subscriber/projects/create" class="mil-btn mil-md">Create Project</a>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- How It Works -->
            <div class="mil-cta mil-up">
                <div class="container">
                    <div class="mil-out-frame mil-p-80-80" style="background: #f8f9fa;">
                        <div class="mil-text-center">
                            <h2 class="mil-mb-30">How Our Project Management Works</h2>
                            <p class="mil-text-m mil-soft mil-mb-60">A secure, transparent process to execute your building projects</p>
                        </div>
                        <div class="row">
                            <div class="col-md-3 mil-text-center mil-mb-30">
                                <div class="step-circle" style="width: 60px; height: 60px; background: #03A6A6; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: bold; margin: 0 auto 20px;">1</div>
                                <h5>Submit Bank Guarantee</h5>
                                <p class="mil-text-s mil-soft">Provide a bank guarantee to secure your project</p>
                            </div>
                            <div class="col-md-3 mil-text-center mil-mb-30">
                                <div class="step-circle" style="width: 60px; height: 60px; background: #03A6A6; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: bold; margin: 0 auto 20px;">2</div>
                                <h5>Subscribe to a Plan</h5>
                                <p class="mil-text-s mil-soft">Choose Basic, Premium, or Enterprise plan</p>
                            </div>
                            <div class="col-md-3 mil-text-center mil-mb-30">
                                <div class="step-circle" style="width: 60px; height: 60px; background: #03A6A6; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: bold; margin: 0 auto 20px;">3</div>
                                <h5>Create Project</h5>
                                <p class="mil-text-s mil-soft">Submit your project details for approval</p>
                            </div>
                            <div class="col-md-3 mil-text-center mil-mb-30">
                                <div class="step-circle" style="width: 60px; height: 60px; background: #03A6A6; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: bold; margin: 0 auto 20px;">4</div>
                                <h5>Track Progress</h5>
                                <p class="mil-text-s mil-soft">Monitor project execution in real-time</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer class="mil-p-80-0">
            <div class="container">
                <div class="mil-footer-bottom">
                    <p class="mil-text-s mil-soft">© 2024 RevaampAP. All rights reserved.</p>
                </div>
            </div>
        </footer>
    </div>

    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/main.js"></script>

    <style>
        .dropdown-menu { display: none; }
        .dropdown:hover .dropdown-menu { display: block; }
        .step-circle { transition: transform 0.3s ease; }
        .step-circle:hover { transform: scale(1.1); }
        .mil-flex-between { display: flex; justify-content: space-between; align-items: center; }
        .mil-mt-10 { margin-top: 10px; }
        .mil-mt-15 { margin-top: 15px; }
    </style>
</body>
</html>