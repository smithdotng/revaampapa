<!DOCTYPE html>
<html lang="en-US">

<head>
    <title><%= title %></title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <link rel="stylesheet" href="/fonts/css/switzer.css" type="text/css" media="all">
    <link rel="stylesheet" href="/fonts/css/font-awesome.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/bootstrap-grid.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">

    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>

<body>
    <div id="smooth-wrapper" class="mil-wrapper">
        <div class="mil-preloader"><div class="mil-load"></div><p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p></div>
        <div class="mil-progress-track"><div class="mil-progress"></div></div>
        <div class="progress-wrap active-progress"></div>

        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo"><img src="/img/logo.png" alt="RevaampAP" width="83" height="32"></a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/project-subscriber/dashboard">Dashboard</a></li>
                        <li class="mil-active"><a href="/project-subscriber/bank-guarantee">Bank Guarantee</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <div class="dropdown">
                        <a href="#" class="mil-btn mil-sm dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="fa fa-user-circle"></i> <%= user.name %> <i class="fa fa-chevron-down"></i>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a href="/project-subscriber/dashboard"><i class="fa fa-tachometer"></i> Dashboard</a></li>
                            <li><a href="/project-subscriber/settings"><i class="fa fa-cog"></i> Settings</a></li>
                            <li><hr></li>
                            <li><a href="/logout"><i class="fa fa-sign-out-alt"></i> Logout</a></li>
                        </ul>
                    </div>
                    <div class="mil-menu-btn"><span></span></div>
                </div>
            </div>
        </div>

        <div id="smooth-content">
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-text-m mil-mb-20">Secure Your Project</div>
                                <h1 class="mil-mb-60">Bank Guarantee</h1>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mil-blog-list mil-p-80-80">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-xl-8">
                            <% if (bankGuarantee && bankGuarantee.status === 'approved') { %>
                                <div class="mil-price-card mil-up mil-mb-30" style="border-left: 4px solid #28a745;">
                                    <div class="mil-text-center">
                                        <i class="fa fa-check-circle" style="font-size: 60px; color: #28a745; margin-bottom: 20px;"></i>
                                        <h3 class="mil-mb-15">Bank Guarantee Approved ✓</h3>
                                        <p class="mil-text-m mil-soft">Your bank guarantee has been verified and approved.</p>
                                    </div>
                                    <div class="mil-mt-30">
                                        <table style="width: 100%;">
                                            <tr><td style="padding: 8px;"><strong>Bank Name:</strong></td><td><%= bankGuarantee.bankName %></td></tr>
                                            <tr><td style="padding: 8px;"><strong>Amount:</strong></td><td>₦<%= bankGuarantee.amount.toLocaleString() %></td></tr>
                                            <tr><td style="padding: 8px;"><strong>Reference Number:</strong></td><td><%= bankGuarantee.referenceNumber %></td></tr>
                                            <tr><td style="padding: 8px;"><strong>Issue Date:</strong></td><td><%= new Date(bankGuarantee.issueDate).toLocaleDateString() %></td></tr>
                                            <tr><td style="padding: 8px;"><strong>Expiry Date:</strong></td><td><%= new Date(bankGuarantee.expiryDate).toLocaleDateString() %></td></tr>
                                        </table>
                                    </div>
                                </div>
                            <% } else { %>
                                <div class="mil-price-card mil-up mil-mb-30">
                                    <div class="mil-text-center mil-mb-30">
                                        <i class="fa fa-shield" style="font-size: 60px; color: #03A6A6;"></i>
                                        <h3 class="mil-mb-15">Submit Your Bank Guarantee</h3>
                                        <p class="mil-text-s mil-soft">Provide a bank guarantee to secure your project execution</p>
                                    </div>
                                    
                                    <form action="/project-subscriber/bank-guarantee" method="POST" enctype="multipart/form-data">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <label class="mil-text-s mil-soft">Bank Name</label>
                                                <input class="mil-input mil-mb-15" type="text" name="bankName" placeholder="e.g., First Bank, GTBank" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="mil-text-s mil-soft">Guarantee Amount (₦)</label>
                                                <input class="mil-input mil-mb-15" type="number" name="guaranteeAmount" placeholder="Enter amount" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="mil-text-s mil-soft">Reference Number</label>
                                                <input class="mil-input mil-mb-15" type="text" name="referenceNumber" placeholder="Bank guarantee reference number" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="mil-text-s mil-soft">Issue Date</label>
                                                <input class="mil-input mil-mb-15" type="date" name="issueDate" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="mil-text-s mil-soft">Expiry Date</label>
                                                <input class="mil-input mil-mb-15" type="date" name="expiryDate" required>
                                            </div>
                                            <div class="col-md-12">
                                                <label class="mil-text-s mil-soft">Bank Guarantee Document</label>
                                                <input class="mil-input mil-mb-30" type="file" name="guaranteeDocument" accept=".pdf,.jpg,.jpeg,.png" required>
                                                <p class="mil-text-xs mil-soft">Upload PDF, JPG, or PNG (max 5MB)</p>
                                            </div>
                                        </div>
                                        
                                        <button type="submit" class="mil-btn mil-md mil-fw">Submit Bank Guarantee</button>
                                    </form>
                                </div>
                            <% } %>
                            
                            <div class="mil-price-card mil-up mil-mt-30">
                                <h4 class="mil-mb-15">What is a Bank Guarantee?</h4>
                                <p class="mil-text-s mil-soft">A bank guarantee is a promise from a bank that if a borrower defaults on a loan payment, the bank will cover the losses. For project execution, it ensures that funds are available to complete your project.</p>
                                <div class="mil-mt-15">
                                    <i class="fa fa-info-circle" style="color: #03A6A6;"></i>
                                    <span class="mil-text-s mil-soft">Your bank guarantee will be verified by our team within 2-3 business days.</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <footer class="mil-p-80-0">
            <div class="container">
                <div class="mil-footer-bottom">
                    <p class="mil-text-s mil-soft">© 2024 RevaampAP. All rights reserved.</p>
                </div>
            </div>
        </footer>
    </div>

    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/main.js"></script>
    <style>
        .dropdown-menu { display: none; }
        .dropdown:hover .dropdown-menu { display: block; }
        .mil-fw { width: 100%; }
        .mil-mt-30 { margin-top: 30px; }
        .mil-mb-15 { margin-bottom: 15px; }
        .mil-mb-30 { margin-bottom: 30px; }
        .mil-input { width: 100%; padding: 12px 15px; border: 1px solid #e0e0e0; border-radius: 8px; }
        label { display: block; margin-bottom: 5px; font-weight: 500; }
    </style>
</body>
</html>