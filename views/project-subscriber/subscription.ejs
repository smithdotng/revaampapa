<!DOCTYPE html>
<html lang="en-US">

<head>
    <title><%= title %></title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <link rel="stylesheet" href="/fonts/css/switzer.css" type="text/css" media="all">
    <link rel="stylesheet" href="/fonts/css/font-awesome.min.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/plugins/bootstrap-grid.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">

    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>

<body>
    <div id="smooth-wrapper" class="mil-wrapper">
        <div class="mil-preloader"><div class="mil-load"></div><p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p></div>
        <div class="mil-progress-track"><div class="mil-progress"></div></div>
        <div class="progress-wrap active-progress"></div>

        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo"><img src="/img/logo.png" alt="RevaampAP" width="83" height="32"></a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/project-subscriber/dashboard">Dashboard</a></li>
                        <li class="mil-active"><a href="/project-subscriber/subscription">Subscription</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <div class="dropdown">
                        <a href="#" class="mil-btn mil-sm dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="fa fa-user-circle"></i> <%= user.name %> <i class="fa fa-chevron-down"></i>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a href="/project-subscriber/dashboard"><i class="fa fa-tachometer"></i> Dashboard</a></li>
                            <li><a href="/project-subscriber/settings"><i class="fa fa-cog"></i> Settings</a></li>
                            <li><hr></li>
                            <li><a href="/logout"><i class="fa fa-sign-out-alt"></i> Logout</a></li>
                        </ul>
                    </div>
                    <div class="mil-menu-btn"><span></span></div>
                </div>
            </div>
        </div>

        <div id="smooth-content">
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-text-m mil-mb-20">Choose Your Plan</div>
                                <h1 class="mil-mb-60">Subscription Plans</h1>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mil-blog-list mil-p-0-80">
                <div class="container">
                    <div class="row">
                        <% plans.forEach(function(plan) { %>
                            <div class="col-xl-4 col-md-6">
                                <div class="mil-price-card mil-up mil-mb-30 <%= plan.recommended ? 'mil-featured' : '' %>">
                                    <h3 class="mil-mb-15"><%= plan.name %></h3>
                                    <h2 class="mil-mb-15">₦<%= plan.price.toLocaleString() %></h2>
                                    <p class="mil-text-s mil-soft mil-mb-30">per year</p>
                                    <ul class="mil-list-2 mil-text-s mil-soft mil-mb-30">
                                        <% plan.features.forEach(function(feature) { %>
                                            <li><i class="fa fa-check-circle" style="color: #28a745;"></i> <%= feature %></li>
                                        <% }); %>
                                    </ul>
                                    <% if (currentPlan === plan.name.toLowerCase() && subscriptionStatus === 'active') { %>
                                        <button class="mil-btn mil-md mil-fw" disabled style="background: #28a745;">✓ Current Plan</button>
                                    <% } else { %>
                                        <form action="/project-subscriber/subscription" method="POST">
                                            <input type="hidden" name="plan" value="<%= plan.name.toLowerCase() %>">
                                            <button type="submit" class="mil-btn mil-md mil-fw">Subscribe</button>
                                        </form>
                                    <% } %>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>
            </div>

            <div class="mil-cta mil-up">
                <div class="container">
                    <div class="mil-out-frame mil-p-80-80" style="background: #f8f9fa;">
                        <div class="mil-text-center">
                            <h2 class="mil-mb-30">Need a Custom Plan?</h2>
                            <p class="mil-text-m mil-soft mil-mb-30">Contact us for enterprise-level solutions tailored to your needs</p>
                            <a href="/contact" class="mil-btn mil-md">Contact Sales</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <footer class="mil-p-80-0">
            <div class="container">
                <div class="mil-footer-bottom">
                    <p class="mil-text-s mil-soft">© 2024 RevaampAP. All rights reserved.</p>
                </div>
            </div>
        </footer>
    </div>

    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/main.js"></script>
    <style>
        .dropdown-menu { display: none; }
        .dropdown:hover .dropdown-menu { display: block; }
        .mil-fw { width: 100%; }
        .mil-featured { border: 2px solid #ffd700; position: relative; }
        .mil-featured::before { content: "★ RECOMMENDED"; position: absolute; top: -12px; right: 20px; background: #ffd700; color: #333; padding: 2px 12px; border-radius: 20px; font-size: 12px; }
        .mil-list-2 { list-style: none; padding: 0; }
        .mil-list-2 li { margin-bottom: 10px; }
        .mil-list-2 i { margin-right: 10px; }
    </style>
</body>
</html>