<script>
// Preview image before upload
function previewImage(input) {
    const preview = document.getElementById('imagePreview');
    const previewImg = document.getElementById('previewImg');
    const fileLabel = document.querySelector('.custom-file-label');
    
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        
        reader.onload = function(e) {
            previewImg.src = e.target.result;
            preview.classList.remove('d-none');
            fileLabel.textContent = input.files[0].name;
        }
        
        reader.readAsDataURL(input.files[0]);
    }
}

// Character counter for excerpt
document.querySelector('textarea[name="excerpt"]')?.addEventListener('input', function() {
    const maxLength = 300;
    const currentLength = this.value.length;
    const remaining = maxLength - currentLength;
    
    let feedback = this.nextElementSibling;
    if (!feedback || !feedback.classList.contains('char-counter')) {
        feedback = document.createElement('small');
        feedback.className = 'char-counter text-muted float-right';
        this.parentNode.appendChild(feedback);
    }
    
    feedback.textContent = `${remaining} characters remaining`;
    
    if (remaining < 50) {
        feedback.style.color = '#ff6b6b';
    } else {
        feedback.style.color = '#6c757d';
    }
});

// Initialize TinyMCE
tinymce.init({
    selector: '#content',
    height: 500,
    menubar: true,
    plugins: [
        'advlist', 'autolink', 'lists', 'link', 'image', 'charmap', 'preview',
        'anchor', 'searchreplace', 'visualblocks', 'code', 'fullscreen',
        'insertdatetime', 'media', 'table', 'help', 'wordcount', 'emoticons'
    ],
    toolbar: 'undo redo | blocks | ' +
        'bold italic backcolor | alignleft aligncenter ' +
        'alignright alignjustify | bullist numlist outdent indent | ' +
        'removeformat | help | fullscreen',
    content_style: 'body { font-family:Helvetica,Arial,sans-serif; font-size:16px }',
    block_formats: 'Paragraph=p; Heading 1=h2; Heading 2=h3; Heading 3=h4; Preformatted=pre',
    branding: false,
    promotion: false,
    setup: function(editor) {
        editor.on('change', function() {
            editor.save(); // This updates the underlying textarea
            formChanged = true;
        });
    }
});

// Auto-save draft functionality
let autoSaveTimer;
const form = document.getElementById('blogForm');

form.addEventListener('input', function() {
    formChanged = true;
    clearTimeout(autoSaveTimer);
    autoSaveTimer = setTimeout(function() {
        // You could implement auto-save here via AJAX
        console.log('Auto-save triggered');
        
        // Example auto-save AJAX call (uncomment to implement)
        /*
        const content = tinymce.get('content').getContent();
        const title = document.getElementById('title').value;
        const excerpt = document.getElementById('excerpt').value;
        
        fetch('/admin/blogs/auto-save', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                title: title,
                excerpt: excerpt,
                content: content,
                blogId: '<%= blog ? blog._id : "" %>'
            })
        });
        */
    }, 30000); // Auto-save after 30 seconds of inactivity
});

// Confirm before leaving with unsaved changes
let formChanged = false;

window.addEventListener('beforeunload', function(e) {
    if (formChanged) {
        e.preventDefault();
        e.returnValue = 'You have unsaved changes. Are you sure you want to leave?';
    }
});

form.addEventListener('submit', function() {
    // Ensure TinyMCE content is saved to textarea before submit
    tinymce.triggerSave();
    formChanged = false;
});

// Live preview of formatting (optional)
function showPreview() {
    const content = tinymce.get('content').getContent();
    const previewWindow = window.open('', 'Preview', 'width=800,height=600');
    previewWindow.document.write(`
        <html>
            <head>
                <title>Post Preview</title>
                <link rel="stylesheet" href="/assets/css/bootstrap.min.css">
                <link rel="stylesheet" href="/assets/css/style.css">
                <style>
                    body { padding: 30px; }
                    .preview-content { max-width: 800px; margin: 0 auto; }
                    h1 { color: #333; margin-bottom: 20px; }
                    h2 { color: #444; margin: 25px 0 15px; }
                    h3 { color: #555; margin: 20px 0 10px; }
                    p { line-height: 1.8; margin-bottom: 20px; }
                    ul, ol { margin-bottom: 20px; }
                </style>
            </head>
            <body>
                <div class="preview-content">
                    <h1>${document.getElementById('title').value}</h1>
                    ${content}
                </div>
            </body>
        </html>
    `);
    previewWindow.document.close();
}

// Add preview button
const submitBtn = document.querySelector('.thm-btn[type="submit"]');
const previewBtn = document.createElement('button');
previewBtn.type = 'button';
previewBtn.className = 'thm-btn brd-btn ml-2';
previewBtn.innerHTML = '<i class="fas fa-eye"></i> Preview';
previewBtn.onclick = showPreview;
submitBtn.parentNode.insertBefore(previewBtn, submitBtn.nextSibling);
</script>

<%- include('../partials/footer') %>