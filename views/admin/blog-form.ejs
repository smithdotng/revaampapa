<%- include('../partials/header') %>

<%
// Ensure user object exists
if (typeof user === 'undefined') {
    var user = {
        name: 'Admin',
        profileImage: null,
        email: 'admin@foundproperties.ng'
    };
}

const categories = [
    'Market News', 'Buying Guide', 'Selling Tips', 'Renting Advice', 
    'Investment', 'Legal Guide', 'Agent Tips', 'Property Spotlight', 'Industry Insights'
];

// Helper function to check if category is selected
function isCategorySelected(category, blog) {
    if (!blog || !blog.categories) return false;
    return blog.categories.includes(category);
}
%>

<!-- Add TinyMCE CSS -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

<!-- Page Top -->
<section>
    <div class="w-100 pt-180 pb-110 black-layer opc45 position-relative">
        <div class="fixed-bg" style="background-image: url(/assets/images/pg-tp-bg.jpg);"></div>
        <div class="container">
            <div class="pg-tp-wrp text-center w-100">
                <h1 class="mb-0"><%= blog ? 'Edit' : 'Create' %> Blog Post</h1>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="/admin/blogs">Blogs</a></li>
                    <li class="breadcrumb-item active"><%= blog ? 'Edit' : 'Create' %></li>
                </ol>
            </div>
        </div>
    </div>
</section>

<!-- Blog Form Section -->
<section>
    <div class="w-100 pt-120 pb-90 position-relative">
        <div class="container">
            <div class="row">
                <!-- Sidebar -->
                <div class="col-md-3">
                    <div class="admin-sidebar">
                        <div class="admin-profile text-center mb-4">
                            <img src="<%= user.profileImage ? '/uploads/profiles/' + user.profileImage : '/assets/images/default-avatar.jpg' %>" 
                                 alt="<%= user.name %>" 
                                 class="rounded-circle img-fluid" style="width: 80px; height: 80px; object-fit: cover;">
                            <h6 class="mt-2"><%= user.name %></h6>
                            <p class="text-muted small">Administrator</p>
                        </div>
                        <ul class="list-unstyled">
                            <li><a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                            <li><a href="/admin/users"><i class="fas fa-users"></i> Users</a></li>
                            <li><a href="/admin/agents"><i class="fas fa-user-tie"></i> Agents</a></li>
                            <li><a href="/admin/properties"><i class="fas fa-building"></i> Properties</a></li>
                            <li class="active"><a href="/admin/blogs"><i class="fas fa-newspaper"></i> Blogs</a></li>
                            <li><a href="/admin/featured"><i class="fas fa-star"></i> Featured</a></li>
                            <li><a href="/admin/settings"><i class="fas fa-cog"></i> Settings</a></li>
                        </ul>
                    </div>
                </div>

                <!-- Main Content -->
                <div class="col-md-9">
                    <div class="admin-content">
                        <form action="<%= blog ? '/admin/blogs/' + blog._id + '?_method=PUT' : '/admin/blogs/create' %>" 
                              method="POST" 
                              enctype="multipart/form-data"
                              id="blogForm">
                            
                            <!-- Basic Information -->
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0">Basic Information</h5>
                                </div>
                                <div class="card-body">
                                    <div class="form-group">
                                        <label>Title <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" name="title" id="title" 
                                               value="<%= blog ? blog.title : '' %>" 
                                               placeholder="Enter blog post title" required>
                                        <small class="text-muted">This will automatically generate the URL slug</small>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label>Excerpt <span class="text-danger">*</span></label>
                                        <textarea class="form-control" name="excerpt" id="excerpt" rows="3" 
                                                  placeholder="Brief summary (max 300 characters)" 
                                                  maxlength="300" required><%= blog ? blog.excerpt : '' %></textarea>
                                        <small class="text-muted">This will appear in blog listings and search results</small>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label>Content <span class="text-danger">*</span></label>
                                        <textarea class="form-control" name="content" id="content" rows="15" 
                                                  placeholder="Write your blog post content here..."><%= blog ? blog.content : '' %></textarea>
                                        <small class="text-muted">
                                            <i class="fas fa-info-circle"></i> 
                                            Use the toolbar above to format text with headings, lists, bold, italic, and more.
                                        </small>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Media -->
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0">Media</h5>
                                </div>
                                <div class="card-body">
                                    <div class="form-group">
                                        <label>Featured Image <span class="text-danger">*</span></label>
                                        <div class="custom-file">
                                            <input type="file" class="custom-file-input" name="featuredImage" id="featuredImage" 
                                                   accept="image/*" onchange="previewImage(this)" <%= blog ? '' : 'required' %>>
                                            <label class="custom-file-label" for="featuredImage">Choose file...</label>
                                        </div>
                                        <small class="text-muted">This will also be used as the OG image for social sharing</small>
                                    </div>
                                    
                                    <div id="imagePreview" class="mt-3 <%= blog && blog.featuredImage ? '' : 'd-none' %>">
                                        <p>Preview:</p>
                                        <img src="<%= blog ? blog.featuredImage : '' %>" id="previewImg" 
                                             alt="Preview" style="max-width: 300px; max-height: 200px; border-radius: 5px;">
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Categories & Tags -->
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0">Categories & Tags</h5>
                                </div>
                                <div class="card-body">
                                    <div class="form-group">
                                        <label>Categories</label>
                                        <select class="form-control" name="categories" multiple size="5">
                                            <% categories.forEach(category => { %>
                                                <option value="<%= category %>" <%= isCategorySelected(category, blog) ? 'selected' : '' %>>
                                                    <%= category %>
                                                </option>
                                            <% }); %>
                                        </select>
                                        <small class="text-muted">Hold Ctrl/Cmd to select multiple categories</small>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label>Tags</label>
                                        <input type="text" class="form-control" name="tags" 
                                               value="<%= blog && blog.tags ? blog.tags.join(', ') : '' %>" 
                                               placeholder="Enter tags separated by commas">
                                        <small class="text-muted">Example: real estate, lagos property, buying guide</small>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- SEO Settings -->
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0">SEO Settings</h5>
                                </div>
                                <div class="card-body">
                                    <div class="form-group">
                                        <label>Meta Title</label>
                                        <input type="text" class="form-control" name="metaTitle" 
                                               value="<%= blog ? blog.metaTitle || '' : '' %>" 
                                               placeholder="Leave blank to use post title">
                                    </div>
                                    
                                    <div class="form-group">
                                        <label>Meta Description</label>
                                        <textarea class="form-control" name="metaDescription" rows="2" 
                                                  placeholder="Leave blank to use excerpt"><%= blog ? blog.metaDescription || '' : '' %></textarea>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label>Meta Keywords</label>
                                        <input type="text" class="form-control" name="metaKeywords" 
                                               value="<%= blog ? blog.metaKeywords || '' : '' %>" 
                                               placeholder="Enter keywords separated by commas">
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Publishing Options -->
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0">Publishing Options</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Status</label>
                                                <select class="form-control" name="status">
                                                    <option value="draft" <%= blog && blog.status === 'draft' ? 'selected' : '' %>>Draft</option>
                                                    <option value="published" <%= blog && blog.status === 'published' ? 'selected' : '' %>>Published</option>
                                                    <option value="archived" <%= blog && blog.status === 'archived' ? 'selected' : '' %>>Archived</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>&nbsp;</label>
                                                <div class="form-check mt-2">
                                                    <input type="checkbox" class="form-check-input" name="featured" id="featured" 
                                                           <%= blog && blog.featured ? 'checked' : '' %>>
                                                    <label class="form-check-label" for="featured">Feature this post</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Form Actions -->
                            <div class="text-center">
                                <button type="submit" class="thm-btn">
                                    <i class="fas fa-save"></i> <%= blog ? 'Update' : 'Publish' %> Blog Post
                                </button>
                                <a href="/admin/blogs" class="thm-btn brd-btn ml-2">
                                    <i class="fas fa-times"></i> Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Add TinyMCE Script -->

<script src="https://cdn.tiny.cloud/1/ol1n69jx2n02ml9t329v60ngyfhvuzc05utzy95pwmkd6kdu/tinymce/8/tinymce.min.js" referrerpolicy="origin" crossorigin="anonymous"></script>
<style>
