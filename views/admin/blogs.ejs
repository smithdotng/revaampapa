<%- include('../partials/header') %>

<%
// Ensure user object exists
if (typeof user === 'undefined') {
    var user = {
        name: 'Admin',
        profileImage: null,
        email: 'admin@foundproperties.ng'
    };
}

// Helper function to format date
function formatDate(date) {
    if (!date) return 'N/A';
    return new Date(date).toLocaleDateString('en-NG', {
        year: 'numeric',
        month: 'short',
        day: 'numeric'
    });
}

// Helper function to get status badge class
function getStatusBadge(status) {
    switch(status) {
        case 'published': return 'success';
        case 'draft': return 'warning';
        case 'archived': return 'secondary';
        default: return 'primary';
    }
}
%>

<!-- Page Top -->
<section>
    <div class="w-100 pt-180 pb-110 black-layer opc45 position-relative">
        <div class="fixed-bg" style="background-image: url(/assets/images/pg-tp-bg.jpg);"></div>
        <div class="container">
            <div class="pg-tp-wrp text-center w-100">
                <h1 class="mb-0">Blog Management</h1>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item active">Blogs</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<!-- Blogs Section -->
<section>
    <div class="w-100 pt-120 pb-90 position-relative">
        <div class="container">
            <div class="row">
                <!-- Sidebar -->
                <div class="col-md-3">
                    <div class="admin-sidebar">
                        <div class="admin-profile text-center mb-4">
                            <img src="<%= user.profileImage ? '/uploads/profiles/' + user.profileImage : '/assets/images/default-avatar.jpg' %>" 
                                 alt="<%= user.name %>" 
                                 class="rounded-circle img-fluid" style="width: 80px; height: 80px; object-fit: cover;">
                            <h6 class="mt-2"><%= user.name %></h6>
                            <p class="text-muted small">Administrator</p>
                        </div>
                        <ul class="list-unstyled">
                            <li><a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                            <li><a href="/admin/users"><i class="fas fa-users"></i> Users</a></li>
                            <li><a href="/admin/agents"><i class="fas fa-user-tie"></i> Agents</a></li>
                            <li><a href="/admin/properties"><i class="fas fa-building"></i> Properties</a></li>
                            <li class="active"><a href="/admin/blogs"><i class="fas fa-newspaper"></i> Blogs</a></li>
                            <li><a href="/admin/featured"><i class="fas fa-star"></i> Featured</a></li>
                            <li><a href="/admin/settings"><i class="fas fa-cog"></i> Settings</a></li>
                        </ul>
                    </div>
                </div>

                <!-- Main Content -->
                <div class="col-md-9">
                    <div class="admin-content">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2>Blog Posts</h2>
                            <a href="/admin/blogs/create" class="thm-btn">
                                <i class="fas fa-plus"></i> New Post
                            </a>
                        </div>

                        <!-- Filter Bar -->
                        <div class="filter-bar mb-4">
                            <form method="GET" action="/admin/blogs" id="filterForm">
                                <div class="row">
                                    <div class="col-md-3">
                                        <select class="form-control" name="status">
                                            <option value="all">All Status</option>
                                            <option value="published" <%= filters.status === 'published' ? 'selected' : '' %>>Published</option>
                                            <option value="draft" <%= filters.status === 'draft' ? 'selected' : '' %>>Draft</option>
                                            <option value="archived" <%= filters.status === 'archived' ? 'selected' : '' %>>Archived</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <input type="text" class="form-control" name="search" 
                                               placeholder="Search by title, author, or content..." 
                                               value="<%= filters.search || '' %>">
                                    </div>
                                    <div class="col-md-3">
                                        <button type="submit" class="btn btn-primary btn-block">
                                            <i class="fas fa-filter"></i> Filter
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>

                        <!-- Blogs Table -->
                        <% if (blogs && blogs.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Post</th>
                                            <th>Author</th>
                                            <th>Categories</th>
                                            <th>Status</th>
                                            <th>Views</th>
                                            <th>Date</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% blogs.forEach(blog => { %>
                                            <tr>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <img src="<%= blog.featuredImage || '/assets/images/default-blog.jpg' %>" 
                                                             class="rounded mr-2" style="width: 50px; height: 40px; object-fit: cover;">
                                                        <div>
                                                            <strong><%= blog.title.length > 40 ? blog.title.substring(0, 40) + '...' : blog.title %></strong><br>
                                                            <small class="text-muted">Slug: <%= blog.slug %></small>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td><%= blog.authorName %></td>
                                                <td>
                                                    <% if (blog.categories && blog.categories.length > 0) { %>
                                                        <% blog.categories.slice(0, 2).forEach(cat => { %>
                                                            <span class="badge badge-primary mr-1"><%= cat %></span>
                                                        <% }); %>
                                                        <% if (blog.categories.length > 2) { %>
                                                            <span class="badge badge-secondary">+<%= blog.categories.length - 2 %></span>
                                                        <% } %>
                                                    <% } %>
                                                </td>
                                                <td>
                                                    <span class="badge badge-<%= getStatusBadge(blog.status) %>">
                                                        <%= blog.status %>
                                                    </span>
                                                    <% if (blog.featured) { %>
                                                        <span class="badge badge-warning"><i class="fas fa-star"></i></span>
                                                    <% } %>
                                                </td>
                                                <td><%= blog.views || 0 %></td>
                                                <td>
                                                    <%= formatDate(blog.publishedAt || blog.createdAt) %><br>
                                                    <small class="text-muted"><%= blog.readingTime || 0 %> min read</small>
                                                </td>
                                                <td>
                                                    <a href="/blog/<%= blog.slug %>" class="btn btn-sm btn-info" target="_blank" title="View">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a href="/admin/blogs/<%= blog._id %>/edit" class="btn btn-sm btn-warning" title="Edit">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <button class="btn btn-sm btn-danger" onclick="deleteBlog('<%= blog._id %>')" title="Delete">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>

                            <!-- Pagination -->
                            <% if (totalPages > 1) { %>
                                <div class="pagination-wrap text-center mt-4">
                                    <ul class="pagination justify-content-center">
                                        <% if (currentPage > 1) { %>
                                            <li class="page-item">
                                                <a class="page-link" href="?page=<%= currentPage - 1 %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.search ? '&search=' + filters.search : '' %>">
                                                    <i class="fas fa-chevron-left"></i>
                                                </a>
                                            </li>
                                        <% } %>
                                        
                                        <% for (let i = 1; i <= totalPages; i++) { %>
                                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                                <a class="page-link" href="?page=<%= i %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.search ? '&search=' + filters.search : '' %>">
                                                    <%= i %>
                                                </a>
                                            </li>
                                        <% } %>
                                        
                                        <% if (currentPage < totalPages) { %>
                                            <li class="page-item">
                                                <a class="page-link" href="?page=<%= currentPage + 1 %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.search ? '&search=' + filters.search : '' %>">
                                                    <i class="fas fa-chevron-right"></i>
                                                </a>
                                            </li>
                                        <% } %>
                                    </ul>
                                </div>
                            <% } %>
                        <% } else { %>
                            <div class="text-center py-5">
                                <i class="fas fa-newspaper fa-4x text-muted mb-3"></i>
                                <h4>No Blog Posts Found</h4>
                                <p class="text-muted">Get started by creating your first blog post.</p>
                                <a href="/admin/blogs/create" class="thm-btn">
                                    <i class="fas fa-plus"></i> Create First Post
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Blog Post</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this blog post? This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDelete">Delete</button>
            </div>
        </div>
    </div>
</div>

<style>
.admin-sidebar {
    background: white;
    border-radius: 10px;
    padding: 30px 20px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
    position: sticky;
    top: 100px;
}

.admin-sidebar ul li {
    margin-bottom: 10px;
}

.admin-sidebar ul li a {
    display: block;
    padding: 12px 15px;
    border-radius: 5px;
    color: #333;
    transition: all 0.3s ease;
    text-decoration: none;
}

.admin-sidebar ul li a i {
    margin-right: 10px;
    width: 20px;
}

.admin-sidebar ul li a:hover {
    background: #f8f9fa;
}

.admin-sidebar ul li.active a {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.admin-content {
    background: white;
    border-radius: 10px;
    padding: 30px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
    min-height: 600px;
}

.filter-bar {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 10px;
}

.table th {
    border-top: none;
    font-weight: 600;
    color: #555;
    font-size: 13px;
    text-transform: uppercase;
}

.table td {
    vertical-align: middle;
}

.btn-sm {
    padding: 5px 8px;
    margin: 0 2px;
}

.pagination .page-link {
    color: #ff6b6b;
    border: none;
    margin: 0 3px;
    border-radius: 5px;
}

.pagination .page-item.active .page-link {
    background: #ff6b6b;
    color: white;
}

@media (max-width: 991px) {
    .admin-sidebar {
        position: relative;
        top: 0;
        margin-bottom: 30px;
    }
}
</style>

<script>
let blogToDelete = null;

function deleteBlog(id) {
    blogToDelete = id;
    $('#deleteModal').modal('show');
}

document.getElementById('confirmDelete').addEventListener('click', function() {
    if (blogToDelete) {
        fetch('/admin/blogs/' + blogToDelete, {
            method: 'DELETE',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                $('#deleteModal').modal('hide');
                location.reload();
            } else {
                alert('Error deleting blog post');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error deleting blog post');
        });
    }
});

// Auto-submit filter on change
document.querySelector('select[name="status"]').addEventListener('change', function() {
    document.getElementById('filterForm').submit();
});
</script>

<%- include('../partials/footer') %>