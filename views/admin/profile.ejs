<%- include('../partials/header') %>

<%
if (typeof user === 'undefined') {
    var user = {
        name: 'Admin',
        profileImage: null,
        email: 'admin@found.ng',
        phone: '',
        createdAt: new Date()
    };
}
%>

<!-- Page Top -->
<section>
    <div class="w-100 pt-180 pb-110 black-layer opc45 position-relative">
        <div class="fixed-bg" style="background-image: url(/assets/images/pg-tp-bg.jpg);"></div>
        <div class="container">
            <div class="pg-tp-wrp text-center w-100">
                <h1 class="mb-0">Admin Profile</h1>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item active">Profile</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<section>
    <div class="w-100 pt-120 pb-90 position-relative">
        <div class="container">
            <div class="row">
                <div class="col-md-3">
                    <div class="admin-sidebar">
                        <div class="admin-profile text-center mb-4">
                            <div class="profile-image-wrapper position-relative d-inline-block">
                                <img src="<%= user.profileImage ? '/uploads/profiles/' + user.profileImage : '/assets/images/default-avatar.jpg' %>" 
                                     alt="<%= user.name %>" 
                                     class="rounded-circle img-fluid" 
                                     style="width: 100px; height: 100px; object-fit: cover; border: 3px solid #ff6b6b;">
                                <button class="change-photo-btn" onclick="document.getElementById('profileImageInput').click();" 
                                        style="position: absolute; bottom: 5px; right: 5px; width: 30px; height: 30px; border-radius: 50%; background: #ff6b6b; border: none; color: white; cursor: pointer;">
                                    <i class="fas fa-camera fa-sm"></i>
                                </button>
                            </div>
                            <form id="profileImageForm" action="/admin/update-profile-image" method="POST" enctype="multipart/form-data" style="display: none;">
                                <input type="file" id="profileImageInput" name="profileImage" accept="image/*" onchange="this.form.submit();">
                            </form>
                            <h5 class="mt-3"><%= user.name %></h5>
                            <p class="text-muted small">Super Administrator</p>
                        </div>
                        <ul class="list-unstyled">
                            <li><a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                            <li><a href="/admin/users"><i class="fas fa-users"></i> Users</a></li>
                            <li><a href="/admin/agents"><i class="fas fa-user-tie"></i> Agents</a></li>
                            <li><a href="/admin/properties"><i class="fas fa-building"></i> Properties</a></li>
                            <li><a href="/admin/blogs"><i class="fas fa-newspaper"></i> Blogs</a></li>
                            <li><a href="/admin/projects"><i class="fas fa-city"></i> Projects</a></li>
                            <li class="active"><a href="/admin/profile"><i class="fas fa-user-circle"></i> Profile</a></li>
                            <li><a href="/admin/settings"><i class="fas fa-cog"></i> Settings</a></li>
                        </ul>
                    </div>
                </div>

                <div class="col-md-9">
                    <div class="admin-content">
                        <!-- Profile Picture Section -->
                        <div class="card mb-4">
                            <div class="card-header">
                                <h5 class="mb-0">Profile Picture</h5>
                            </div>
                            <div class="card-body text-center">
                                <div class="current-profile-picture mb-4">
                                    <img src="<%= user.profileImage ? '/uploads/profiles/' + user.profileImage : '/assets/images/default-avatar.jpg' %>" 
                                         alt="<%= user.name %>" 
                                         class="rounded-circle img-fluid" 
                                         style="width: 150px; height: 150px; object-fit: cover; border: 4px solid #ff6b6b;">
                                </div>
                                <div class="upload-buttons">
                                    <label class="btn btn-primary mr-2">
                                        <i class="fas fa-upload"></i> Upload New Photo
                                        <input type="file" id="directProfileUpload" accept="image/*" style="display: none;" onchange="uploadProfileImage(this)">
                                    </label>
                                    <% if (user.profileImage && user.profileImage !== 'default-avatar.jpg') { %>
                                        <button class="btn btn-danger" onclick="removeProfileImage()">
                                            <i class="fas fa-trash"></i> Remove Photo
                                        </button>
                                    <% } %>
                                </div>
                                <small class="text-muted d-block mt-3">Recommended: Square image, minimum 300x300px, max 2MB</small>
                            </div>
                        </div>

                        <!-- Profile Information -->
                        <div class="card mb-4">
                            <div class="card-header">
                                <h5 class="mb-0">Profile Information</h5>
                            </div>
                            <div class="card-body">
                                <form action="/admin/update-profile" method="POST">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Full Name</label>
                                                <input type="text" class="form-control" name="name" value="<%= user.name %>" required>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Email Address</label>
                                                <input type="email" class="form-control" value="<%= user.email %>" disabled>
                                                <small class="text-muted">Email cannot be changed</small>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Phone Number</label>
                                                <input type="tel" class="form-control" name="phone" value="<%= user.phone || '' %>">
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label>Bio (Optional)</label>
                                                <textarea class="form-control" name="bio" rows="3" placeholder="Tell us a little about yourself..."><%= user.bio || '' %></textarea>
                                            </div>
                                        </div>
                                    </div>
                                    <button type="submit" class="thm-btn">
                                        <i class="fas fa-save"></i> Update Profile
                                    </button>
                                </form>
                            </div>
                        </div>

                        <!-- Change Password -->
                        <div class="card">
                            <div class="card-header">
                                <h5 class="mb-0">Change Password</h5>
                            </div>
                            <div class="card-body">
                                <form action="/admin/change-password" method="POST">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label>Current Password</label>
                                                <input type="password" class="form-control" name="currentPassword" required>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>New Password</label>
                                                <input type="password" class="form-control" name="newPassword" required>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Confirm New Password</label>
                                                <input type="password" class="form-control" name="confirmPassword" required>
                                            </div>
                                        </div>
                                    </div>
                                    <button type="submit" class="btn btn-warning">
                                        <i class="fas fa-key"></i> Change Password
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.admin-sidebar {
    background: white;
    border-radius: 10px;
    padding: 30px 20px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
    position: sticky;
    top: 100px;
}

.admin-sidebar ul li {
    margin-bottom: 10px;
}

.admin-sidebar ul li a {
    display: block;
    padding: 12px 15px;
    border-radius: 5px;
    color: #333;
    transition: all 0.3s ease;
    text-decoration: none;
}

.admin-sidebar ul li a i {
    margin-right: 10px;
    width: 20px;
}

.admin-sidebar ul li a:hover {
    background: #f8f9fa;
}

.admin-sidebar ul li.active a {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.admin-content {
    background: white;
    border-radius: 10px;
    padding: 30px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
}

.card {
    border: 1px solid #f0f0f0;
    border-radius: 10px;
    margin-bottom: 20px;
}

.card-header {
    background: #f8f9fa;
    border-bottom: 1px solid #f0f0f0;
    padding: 15px 20px;
    font-weight: 600;
}

.card-body {
    padding: 20px;
}

.form-control {
    border: 1px solid #e0e0e0;
    border-radius: 5px;
    padding: 10px 15px;
}

.form-control:focus {
    border-color: #ff6b6b;
    box-shadow: none;
}

.thm-btn, .btn-primary, .btn-warning, .btn-danger {
    padding: 10px 20px;
    font-size: 14px;
    border-radius: 5px;
}

.btn-primary {
    background: #ff6b6b;
    border-color: #ff6b6b;
}

.btn-primary:hover {
    background: #ff5252;
    border-color: #ff5252;
}

.current-profile-picture {
    position: relative;
    display: inline-block;
}
</style>

<script>
// Upload profile image via AJAX
function uploadProfileImage(input) {
    if (input.files && input.files[0]) {
        var file = input.files[0];
        
        // Validate file type
        if (!file.type.match('image.*')) {
            alert('Please select an image file (jpg, png, gif)');
            return;
        }
        
        // Validate file size (max 2MB)
        if (file.size > 2 * 1024 * 1024) {
            alert('File size must be less than 2MB');
            return;
        }
        
        var formData = new FormData();
        formData.append('profileImage', file);
        
        // Show loading state
        var submitBtn = document.querySelector('#directProfileUpload').closest('.upload-buttons');
        var originalHtml = submitBtn.innerHTML;
        submitBtn.innerHTML = '<div class="spinner-border text-primary" role="status"><span class="sr-only">Uploading...</span></div>';
        
        fetch('/admin/update-profile-image', {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('Profile picture updated successfully!');
                location.reload();
            } else {
                alert('Error: ' + (data.error || 'Unknown error'));
                submitBtn.innerHTML = originalHtml;
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error uploading image');
            submitBtn.innerHTML = originalHtml;
        });
    }
}

// Remove profile image
function removeProfileImage() {
    if (confirm('Are you sure you want to remove your profile picture?')) {
        fetch('/admin/remove-profile-image', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('Profile picture removed');
                location.reload();
            } else {
                alert('Error removing profile picture');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error removing profile picture');
        });
    }
}

// Direct file input trigger
document.querySelector('label[for="directProfileUpload"]')?.addEventListener('click', function(e) {
    document.getElementById('directProfileUpload').click();
});
</script>

<%- include('../partials/footer') %>