<%- include('../partials/header') %>

<%
// Ensure user object exists
if (typeof user === 'undefined') {
    var user = {
        name: 'Admin',
        profileImage: null,
        email: 'admin@found.ng'
    };
}

// Ensure stats object exists
if (typeof stats === 'undefined') {
    var stats = {
        totalUsers: 0,
        totalRealtors: 0,
        totalAgents: 0,
        pendingAgents: 0,
        totalProperties: 0,
        pendingProperties: 0,
        featuredProperties: 0,
        totalPropertyValue: 0,
        totalTransactions: 0,
        completedTransactions: 0,
        totalRevenue: 0,
        monthlyRevenue: 0,
        pendingWithdrawals: 0,
        // Blog stats
        totalBlogs: 0,
        publishedBlogs: 0,
        draftBlogs: 0,
        totalBlogViews: 0
    };
}

// Ensure arrays exist
if (typeof recentUsers === 'undefined') {
    var recentUsers = [];
}
if (typeof recentProperties === 'undefined') {
    var recentProperties = [];
}
if (typeof recentTransactions === 'undefined') {
    var recentTransactions = [];
}
if (typeof recentBlogs === 'undefined') {
    var recentBlogs = [];
}
%>

<!-- Page Top -->
<section>
    <div class="w-100 pt-180 pb-110 black-layer opc45 position-relative">
        <div class="fixed-bg" style="background-image: url(/assets/images/pg-tp-bg.jpg);"></div>
        <div class="container">
            <div class="pg-tp-wrp text-center w-100">
                <h1 class="mb-0">Admin Dashboard</h1>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/" title="Home">Home</a></li>
                    <li class="breadcrumb-item active">Admin Dashboard</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<!-- Dashboard Section -->
<section>
    <div class="w-100 gray-bg position-relative">
        <div class="container">
            <div class="row">
                <!-- Sidebar -->
                <div class="col-md-3">
                    <div class="admin-sidebar">
                        <div class="admin-profile text-center mb-4">
                            <img src="<%= user.profileImage ? '/uploads/profiles/' + user.profileImage : '/assets/images/default-avatar.jpg' %>" 
                                 alt="<%= user.name %>" 
                                 class="rounded-circle img-fluid" style="width: 100px; height: 100px; object-fit: cover;">
                            <h5 class="mt-3"><%= user.name %></h5>
                            <p class="text-muted">Administrator</p>
                        </div>
                        
                        <ul class="nav nav-pills flex-column">
                            <li class="nav-item">
                                <a class="nav-link active" href="/admin/dashboard">
                                    <i class="fas fa-tachometer-alt"></i> Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/admin/users">
                                    <i class="fas fa-users"></i> Users
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/admin/agents">
                                    <i class="fas fa-user-tie"></i> All Agents
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/admin/agents/pending">
                                    <i class="fas fa-clock"></i> Pending Approvals
                                    <% if (stats.pendingAgents > 0) { %>
                                        <span class="badge badge-danger float-right"><%= stats.pendingAgents %></span>
                                    <% } %>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/admin/properties">
                                    <i class="fas fa-building"></i> Properties
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/admin/properties/pending">
                                    <i class="fas fa-hourglass-half"></i> Pending Properties
                                    <% if (stats.pendingProperties > 0) { %>
                                        <span class="badge badge-danger float-right"><%= stats.pendingProperties %></span>
                                    <% } %>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/admin/featured">
                                    <i class="fas fa-star"></i> Featured Properties
                                </a>
                            </li>
                            <!-- New Blog Management Section -->
                            <li class="nav-item">
                                <a class="nav-link" href="/admin/blogs">
                                    <i class="fas fa-newspaper"></i> Blog Posts
                                    <% if (stats.draftBlogs > 0) { %>
                                        <span class="badge badge-warning float-right"><%= stats.draftBlogs %></span>
                                    <% } %>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/admin/blogs/create">
                                    <i class="fas fa-plus-circle"></i> New Blog Post
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/admin/transactions">
                                    <i class="fas fa-credit-card"></i> Transactions
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/admin/withdrawals">
                                    <i class="fas fa-money-bill-wave"></i> Withdrawals
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/admin/analytics">
                                    <i class="fas fa-chart-line"></i> Analytics
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/admin/settings">
                                    <i class="fas fa-cog"></i> Settings
                                </a>
                            </li>
                        </ul>
                        
                        <div class="sidebar-footer mt-4">
                            <a href="/logout" class="btn btn-outline-danger btn-block">
                                <i class="fas fa-sign-out-alt"></i> Logout
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Main Content -->
                <div class="col-md-9">
                    <div class="admin-content">
                        <!-- Welcome Header -->
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div>
                                <h2>Welcome back, <%= user.name %>!</h2>
                                <p class="text-muted">Here's what's happening on Found Properties today.</p>
                            </div>
                            <div class="date-display">
                                <i class="fas fa-calendar-alt thm-clr"></i> 
                                <%= new Date().toLocaleDateString('en-NG', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
                            </div>
                        </div>

                        <!-- Statistics Cards - Added Blog Stats -->
                        <div class="row">
                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="stat-icon bg-primary">
                                        <i class="fas fa-users"></i>
                                    </div>
                                    <div class="stat-details">
                                        <h3><%= stats.totalUsers %></h3>
                                        <p>Total Users</p>
                                        <small class="text-muted">
                                            <%= stats.totalRealtors %> Realtors, <%= stats.totalAgents %> Agents
                                        </small>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="stat-icon bg-success">
                                        <i class="fas fa-building"></i>
                                    </div>
                                    <div class="stat-details">
                                        <h3><%= stats.totalProperties %></h3>
                                        <p>Total Properties</p>
                                        <small class="text-muted">
                                            Value: ₦<%= (stats.totalPropertyValue / 1000000).toFixed(0) %>M
                                        </small>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="stat-icon bg-info">
                                        <i class="fas fa-newspaper"></i>
                                    </div>
                                    <div class="stat-details">
                                        <h3><%= stats.totalBlogs %></h3>
                                        <p>Blog Posts</p>
                                        <small class="text-muted">
                                            <%= stats.publishedBlogs %> Published, <%= stats.draftBlogs %> Draft
                                        </small>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="stat-icon bg-warning">
                                        <i class="fas fa-eye"></i>
                                    </div>
                                    <div class="stat-details">
                                        <h3><%= stats.totalBlogViews %></h3>
                                        <p>Blog Views</p>
                                        <small class="text-muted">
                                            Content Engagement
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Second Row Stats -->
                        <div class="row">
                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="stat-icon bg-info">
                                        <i class="fas fa-credit-card"></i>
                                    </div>
                                    <div class="stat-details">
                                        <h3><%= stats.totalTransactions %></h3>
                                        <p>Transactions</p>
                                        <small class="text-muted">
                                            <%= stats.completedTransactions %> Completed
                                        </small>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="stat-icon bg-warning">
                                        <i class="fas fa-naira-sign"></i>
                                    </div>
                                    <div class="stat-details">
                                        <h3>₦<%= (stats.totalRevenue / 1000000).toFixed(1) %>M</h3>
                                        <p>Platform Revenue</p>
                                        <small class="text-muted">
                                            +₦<%= (stats.monthlyRevenue / 1000000).toFixed(1) %>M this month
                                        </small>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="stat-icon bg-primary">
                                        <i class="fas fa-star"></i>
                                    </div>
                                    <div class="stat-details">
                                        <h3><%= stats.featuredProperties || 0 %></h3>
                                        <p>Featured Properties</p>
                                        <small class="text-muted">
                                            Premium Listings
                                        </small>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="stat-icon bg-success">
                                        <i class="fas fa-clock"></i>
                                    </div>
                                    <div class="stat-details">
                                        <h3><%= stats.pendingAgents + stats.pendingProperties %></h3>
                                        <p>Total Pending</p>
                                        <small class="text-muted">
                                            <%= stats.pendingAgents %> Agents, <%= stats.pendingProperties %> Properties
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Pending Approvals Row - Updated with Blog Drafts -->
                        <div class="row mt-3">
                            <div class="col-md-3">
                                <div class="pending-card">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h5>Pending Agents</h5>
                                            <h2><%= stats.pendingAgents %></h2>
                                        </div>
                                        <i class="fas fa-user-clock fa-3x text-warning"></i>
                                    </div>
                                    <a href="/admin/agents/pending" class="btn btn-warning btn-sm mt-3 w-100">
                                        Review Applications <i class="fas fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                            
                            <div class="col-md-3">
                                <div class="pending-card">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h5>Pending Properties</h5>
                                            <h2><%= stats.pendingProperties %></h2>
                                        </div>
                                        <i class="fas fa-building fa-3x text-info"></i>
                                    </div>
                                    <a href="/admin/properties/pending" class="btn btn-info btn-sm mt-3 w-100">
                                        Review Properties <i class="fas fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                            
                            <div class="col-md-3">
                                <div class="pending-card">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h5>Blog Drafts</h5>
                                            <h2><%= stats.draftBlogs %></h2>
                                        </div>
                                        <i class="fas fa-pen-square fa-3x text-primary"></i>
                                    </div>
                                    <a href="/admin/blogs?status=draft" class="btn btn-primary btn-sm mt-3 w-100">
                                        Edit Drafts <i class="fas fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                            
                            <div class="col-md-3">
                                <div class="pending-card">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h5>Withdrawals</h5>
                                            <h2><%= stats.pendingWithdrawals || 0 %></h2>
                                        </div>
                                        <i class="fas fa-money-bill-wave fa-3x text-success"></i>
                                    </div>
                                    <a href="/admin/withdrawals" class="btn btn-success btn-sm mt-3 w-100">
                                        Process Payments <i class="fas fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Charts Row -->
                        <div class="row mt-4">
                            <div class="col-md-8">
                                <div class="chart-card">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <h5 class="mb-0">Revenue Overview</h5>
                                        <select class="form-control form-control-sm w-auto" id="revenuePeriod" onchange="loadRevenueChart()">
                                            <option value="week">Last 7 Days</option>
                                            <option value="month" selected>This Month</option>
                                            <option value="year">This Year</option>
                                        </select>
                                    </div>
                                    <div class="card-body">
                                        <canvas id="revenueChart" height="250"></canvas>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-md-4">
                                <div class="chart-card">
                                    <div class="card-header">
                                        <h5 class="mb-0">Content Distribution</h5>
                                    </div>
                                    <div class="card-body">
                                        <canvas id="contentChart" height="250"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Recent Activities Row - Added Recent Blogs -->
                        <div class="row mt-4">
                            <div class="col-md-6">
                                <div class="activity-card">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <h5 class="mb-0">Recent Users</h5>
                                        <a href="/admin/users" class="btn btn-sm btn-primary">View All</a>
                                    </div>
                                    <div class="card-body">
                                        <div class="table-responsive">
                                            <table class="table table-hover">
                                                <thead>
                                                    <tr>
                                                        <th>User</th>
                                                        <th>Type</th>
                                                        <th>Date</th>
                                                        <th>Status</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% if (recentUsers && recentUsers.length > 0) { %>
                                                        <% recentUsers.slice(0, 5).forEach(user => { %>
                                                            <tr>
                                                                <td>
                                                                    <div class="d-flex align-items-center">
                                                                        <img src="<%= user.profileImage ? '/uploads/profiles/' + user.profileImage : '/assets/images/default-avatar.jpg' %>" 
                                                                             class="rounded-circle mr-2" style="width: 30px; height: 30px; object-fit: cover;">
                                                                        <div>
                                                                            <strong><%= user.name %></strong><br>
                                                                            <small class="text-muted"><%= user.email %></small>
                                                                        </div>
                                                                    </div>
                                                                </td>
                                                                <td><span class="badge badge-<%= user.userType === 'agent' ? 'info' : (user.userType === 'admin' ? 'danger' : 'primary') %>">
                                                                    <%= user.userType %>
                                                                </span></td>
                                                                <td><%= new Date(user.createdAt).toLocaleDateString() %></td>
                                                                <td>
                                                                    <% if (user.userType === 'agent' && !user.agentProfile?.isApproved) { %>
                                                                        <span class="badge badge-warning">Pending</span>
                                                                    <% } else { %>
                                                                        <span class="badge badge-success">Active</span>
                                                                    <% } %>
                                                                </td>
                                                            </tr>
                                                        <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="4" class="text-center">No recent users</td>
                                                        </tr>
                                                    <% } %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="activity-card">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <h5 class="mb-0">Recent Blog Posts</h5>
                                        <a href="/admin/blogs" class="btn btn-sm btn-primary">View All</a>
                                    </div>
                                    <div class="card-body">
                                        <div class="table-responsive">
                                            <table class="table table-hover">
                                                <thead>
                                                    <tr>
                                                        <th>Post</th>
                                                        <th>Author</th>
                                                        <th>Status</th>
                                                        <th>Views</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% if (recentBlogs && recentBlogs.length > 0) { %>
                                                        <% recentBlogs.slice(0, 5).forEach(blog => { %>
                                                            <tr>
                                                                <td>
                                                                    <div class="d-flex align-items-center">
                                                                        <img src="<%= blog.featuredImage || '/assets/images/default-blog.jpg' %>" 
                                                                             class="rounded mr-2" style="width: 40px; height: 30px; object-fit: cover;">
                                                                        <div>
                                                                            <strong><%= blog.title.length > 25 ? blog.title.substring(0, 25) + '...' : blog.title %></strong><br>
                                                                            <small class="text-muted"><%= new Date(blog.createdAt).toLocaleDateString() %></small>
                                                                        </div>
                                                                    </div>
                                                                </td>
                                                                <td><%= blog.authorName %></td>
                                                                <td>
                                                                    <% if (blog.status === 'published') { %>
                                                                        <span class="badge badge-success">Published</span>
                                                                    <% } else if (blog.status === 'draft') { %>
                                                                        <span class="badge badge-warning">Draft</span>
                                                                    <% } else { %>
                                                                        <span class="badge badge-secondary">Archived</span>
                                                                    <% } %>
                                                                </td>
                                                                <td><%= blog.views || 0 %></td>
                                                            </tr>
                                                        <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="4" class="text-center">No recent blog posts</td>
                                                        </tr>
                                                    <% } %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Recent Properties and Transactions Row -->
                        <div class="row mt-4">
                            <div class="col-md-6">
                                <div class="activity-card">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <h5 class="mb-0">Recent Properties</h5>
                                        <a href="/admin/properties" class="btn btn-sm btn-primary">View All</a>
                                    </div>
                                    <div class="card-body">
                                        <div class="table-responsive">
                                            <table class="table table-hover">
                                                <thead>
                                                    <tr>
                                                        <th>Property</th>
                                                        <th>Owner</th>
                                                        <th>Price</th>
                                                        <th>Status</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% if (recentProperties && recentProperties.length > 0) { %>
                                                        <% recentProperties.slice(0, 5).forEach(property => { %>
                                                            <tr>
                                                                <td>
                                                                    <div class="d-flex align-items-center">
                                                                        <img src="<%= property.images && property.images[0] ? property.images[0].url : '/assets/images/default-property.jpg' %>" 
                                                                             class="rounded mr-2" style="width: 40px; height: 30px; object-fit: cover;">
                                                                        <div>
                                                                            <strong><%= property.title.substring(0, 20) %>...</strong><br>
                                                                            <small class="text-muted"><%= property.location.city %></small>
                                                                        </div>
                                                                    </div>
                                                                </td>
                                                                <td><%= property.owner?.name || 'N/A' %></td>
                                                                <td>₦<%= (property.price / 1000000).toFixed(1) %>M</td>
                                                                <td>
                                                                    <% if (property.status === 'available') { %>
                                                                        <span class="badge badge-success">Available</span>
                                                                    <% } else if (property.status === 'pending') { %>
                                                                        <span class="badge badge-warning">Pending</span>
                                                                    <% } else { %>
                                                                        <span class="badge badge-secondary"><%= property.status %></span>
                                                                    <% } %>
                                                                </td>
                                                            </tr>
                                                        <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="4" class="text-center">No recent properties</td>
                                                        </tr>
                                                    <% } %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="activity-card">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <h5 class="mb-0">Recent Transactions</h5>
                                        <a href="/admin/transactions" class="btn btn-sm btn-primary">View All</a>
                                    </div>
                                    <div class="card-body">
                                        <div class="table-responsive">
                                            <table class="table table-hover">
                                                <thead>
                                                    <tr>
                                                        <th>Date</th>
                                                        <th>Property</th>
                                                        <th>Agent</th>
                                                        <th>Amount</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% if (recentTransactions && recentTransactions.length > 0) { %>
                                                        <% recentTransactions.slice(0, 5).forEach(transaction => { %>
                                                            <tr>
                                                                <td><%= new Date(transaction.transactionDate).toLocaleDateString() %></td>
                                                                <td><%= transaction.property?.title?.substring(0, 15) || 'N/A' %>...</td>
                                                                <td><%= transaction.agent?.name || 'N/A' %></td>
                                                                <td>₦<%= (transaction.amount / 1000000).toFixed(1) %>M</td>
                                                            </tr>
                                                        <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="4" class="text-center">No recent transactions</td>
                                                        </tr>
                                                    <% } %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Quick Actions - Updated with Blog Actions -->
                        <div class="row mt-4">
                            <div class="col-md-12">
                                <div class="quick-actions-card">
                                    <div class="card-header">
                                        <h5 class="mb-0">Quick Actions</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-2">
                                                <a href="/admin/featured/add" class="btn btn-outline-primary btn-block mb-2">
                                                    <i class="fas fa-star"></i> Add Featured
                                                </a>
                                            </div>
                                            <div class="col-md-2">
                                                <a href="/admin/blogs/create" class="btn btn-outline-success btn-block mb-2">
                                                    <i class="fas fa-pen"></i> Write Blog
                                                </a>
                                            </div>
                                            <div class="col-md-2">
                                                <a href="/admin/blogs" class="btn btn-outline-info btn-block mb-2">
                                                    <i class="fas fa-newspaper"></i> Manage Blogs
                                                </a>
                                            </div>
                                            <div class="col-md-2">
                                                <a href="/admin/settings" class="btn btn-outline-warning btn-block mb-2">
                                                    <i class="fas fa-cog"></i> Settings
                                                </a>
                                            </div>
                                            <div class="col-md-2">
                                                <a href="/admin/agents/pending" class="btn btn-outline-danger btn-block mb-2">
                                                    <i class="fas fa-user-check"></i> Review Agents
                                                </a>
                                            </div>
                                            <div class="col-md-2">
                                                <a href="/admin/properties/pending" class="btn btn-outline-secondary btn-block mb-2">
                                                    <i class="fas fa-building"></i> Review Properties
                                                </a>
                                            </div>
                                        </div>
