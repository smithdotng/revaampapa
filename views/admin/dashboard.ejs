<!-- JavaScript -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
let revenueChart, contentChart;

// Load revenue chart
function loadRevenueChart() {
    const period = $('#revenuePeriod').val();
    
    $.get('/api/admin/revenue-data?period=' + period, function(data) {
        if (revenueChart) revenueChart.destroy();
        
        const ctx = document.getElementById('revenueChart').getContext('2d');
        revenueChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: data.labels,
                datasets: [{
                    label: 'Revenue (₦)',
                    data: data.values,
                    borderColor: '#28a745',
                    backgroundColor: 'rgba(40, 167, 69, 0.1)',
                    tension: 0.4,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return '₦' + (value / 1000).toFixed(0) + 'k';
                            }
                        }
                    }
                }
            }
        });
    });
}

// Load content distribution chart (Properties vs Blog Posts)
function loadContentChart() {
    $.get('/api/admin/content-distribution', function(data) {
        if (contentChart) contentChart.destroy();
        
        const ctx = document.getElementById('contentChart').getContext('2d');
        contentChart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Properties', 'Blog Posts', 'Users', 'Agents'],
                datasets: [{
                    data: [<%= stats.totalProperties %>, <%= stats.totalBlogs %>, <%= stats.totalUsers %>, <%= stats.totalAgents %>],
                    backgroundColor: ['#28a745', '#ffc107', '#667eea', '#17a2b8']
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });
    });
}

// Initialize charts on page load
$(document).ready(function() {
    loadRevenueChart();
    loadContentChart();
    
    // Auto-refresh data every 5 minutes
    setInterval(function() {
        loadRevenueChart();
        loadContentChart();
    }, 300000);
});

// Handle period change
$('#revenuePeriod').change(loadRevenueChart);
</script>

