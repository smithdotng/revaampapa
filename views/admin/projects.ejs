<%- include('../partials/header') %>

<%
// Ensure user object exists
if (typeof user === 'undefined') {
    var user = {
        name: 'Admin',
        profileImage: null,
        email: 'admin@found.ng'
    };
}

function formatDate(date) {
    if (!date) return 'N/A';
    return new Date(date).toLocaleDateString('en-NG');
}
%>

<!-- Page Top -->
<section>
    <div class="w-100 pt-180 pb-110 black-layer opc45 position-relative">
        <div class="fixed-bg" style="background-image: url(/assets/images/pg-tp-bg.jpg);"></div>
        <div class="container">
            <div class="pg-tp-wrp text-center w-100">
                <h1 class="mb-0">Project Management</h1>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item active">Projects</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<section>
    <div class="w-100 pt-120 pb-90 position-relative">
        <div class="container">
            <div class="row">
                <div class="col-md-3">
                    <div class="admin-sidebar">
                        <div class="admin-profile text-center mb-4">
                            <img src="<%= user.profileImage ? '/uploads/profiles/' + user.profileImage : '/assets/images/default-avatar.jpg' %>" 
                                 alt="<%= user.name %>" 
                                 class="rounded-circle img-fluid" style="width: 80px; height: 80px; object-fit: cover;">
                            <h6 class="mt-2"><%= user.name %></h6>
                            <p class="text-muted small">Administrator</p>
                        </div>
                        <ul class="list-unstyled">
                            <li><a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                            <li><a href="/admin/users"><i class="fas fa-users"></i> Users</a></li>
                            <li><a href="/admin/agents"><i class="fas fa-user-tie"></i> Agents</a></li>
                            <li><a href="/admin/properties"><i class="fas fa-building"></i> Properties</a></li>
                            <li><a href="/admin/blogs"><i class="fas fa-newspaper"></i> Blogs</a></li>
                            <li class="active"><a href="/admin/projects"><i class="fas fa-city"></i> Projects</a></li>
                            <li><a href="/admin/settings"><i class="fas fa-cog"></i> Settings</a></li>
                        </ul>
                    </div>
                </div>

                <div class="col-md-9">
                    <div class="admin-content">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2>Projects</h2>
                            <a href="/admin/projects/create" class="thm-btn">
                                <i class="fas fa-plus"></i> Add New Project
                            </a>
                        </div>

                        <div class="filter-bar mb-4">
                            <form method="GET" action="/admin/projects" id="filterForm">
                                <div class="row">
                                    <div class="col-md-3">
                                        <select class="form-control" name="status">
                                            <option value="all">All Status</option>
                                            <option value="published" <%= filters.status === 'published' ? 'selected' : '' %>>Published</option>
                                            <option value="draft" <%= filters.status === 'draft' ? 'selected' : '' %>>Draft</option>
                                            <option value="archived" <%= filters.status === 'archived' ? 'selected' : '' %>>Archived</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <input type="text" class="form-control" name="search" placeholder="Search projects..." value="<%= filters.search || '' %>">
                                    </div>
                                    <div class="col-md-3">
                                        <button type="submit" class="btn btn-primary btn-block">Filter</button>
                                    </div>
                                </div>
                            </form>
                        </div>

                        <% if (projects && projects.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Project</th>
                                            <th>Developer</th>
                                            <th>Status</th>
                                            <th>Featured</th>
                                            <th>Created</th>
                                            <th>Actions</th>
                                        </thead>
                                        <tbody>
                                            <% projects.forEach(project => { %>
                                                 <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <img src="<%= project.media.featuredImage || '/assets/images/default-project.jpg' %>" 
                                                                 class="rounded mr-2" style="width: 50px; height: 40px; object-fit: cover;">
                                                            <div>
                                                                <strong><%= project.name.length > 30 ? project.name.substring(0, 30) + '...' : project.name %></strong><br>
                                                                <small class="text-muted"><%= project.location.city %></small>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td><%= project.developer.name %></td>
                                                    <td>
                                                        <% if (project.status === 'published') { %>
                                                            <span class="badge badge-success">Published</span>
                                                        <% } else if (project.status === 'draft') { %>
                                                            <span class="badge badge-warning">Draft</span>
                                                        <% } else { %>
                                                            <span class="badge badge-secondary">Archived</span>
                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <% if (project.featured) { %>
                                                            <span class="badge badge-warning"><i class="fas fa-star"></i> Featured</span>
                                                        <% } else { %>
                                                            <span class="badge badge-light">No</span>
                                                        <% } %>
                                                    </td>
                                                    <td><%= formatDate(project.createdAt) %></td>
                                                    <td>
                                                        <a href="/projects/<%= project.slug %>" class="btn btn-sm btn-info" target="_blank" title="View">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                        <a href="/admin/projects/<%= project._id %>/edit" class="btn btn-sm btn-warning" title="Edit">
                                                            <i class="fas fa-edit"></i>
                                                        </a>
                                                        <button class="btn btn-sm btn-danger" onclick="deleteProject('<%= project._id %>')" title="Delete">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>

                                <% if (totalPages > 1) { %>
                                    <div class="pagination-wrap mt-4">
                                        <ul class="pagination justify-content-center">
                                            <% for (let i = 1; i <= totalPages; i++) { %>
                                                <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                                    <a class="page-link" href="?page=<%= i %><%= filters.status && filters.status !== 'all' ? '&status=' + filters.status : '' %><%= filters.search ? '&search=' + filters.search : '' %>">
                                                        <%= i %>
                                                    </a>
                                                </li>
                                            <% } %>
                                        </ul>
                                    </div>
                                <% } %>
                            <% } else { %>
                                <div class="text-center py-5">
                                    <i class="fas fa-city fa-4x text-muted mb-3"></i>
                                    <h4>No Projects Found</h4>
                                    <p>Get started by creating your first project.</p>
                                    <a href="/admin/projects/create" class="thm-btn">Create Project</a>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Project</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this project? This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDelete">Delete</button>
            </div>
        </div>
    </div>
</div>

<style>
.admin-sidebar {
    background: white;
    border-radius: 10px;
    padding: 30px 20px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
    position: sticky;
    top: 100px;
}

.admin-sidebar ul li {
    margin-bottom: 10px;
}

.admin-sidebar ul li a {
    display: block;
    padding: 12px 15px;
    border-radius: 5px;
    color: #333;
    transition: all 0.3s ease;
    text-decoration: none;
}

.admin-sidebar ul li a i {
    margin-right: 10px;
    width: 20px;
}

.admin-sidebar ul li a:hover {
    background: #f8f9fa;
}

.admin-sidebar ul li.active a {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.admin-content {
    background: white;
    border-radius: 10px;
    padding: 30px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
    min-height: 500px;
}

.filter-bar {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 10px;
}

.table th {
    border-top: none;
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
}

.btn-sm {
    padding: 5px 8px;
    margin: 0 2px;
}
</style>

<script>
let projectToDelete = null;

function deleteProject(id) {
    projectToDelete = id;
    $('#deleteModal').modal('show');
}

document.getElementById('confirmDelete').addEventListener('click', function() {
    if (projectToDelete) {
        fetch('/admin/projects/' + projectToDelete, {
            method: 'DELETE',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert('Error deleting project');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error deleting project');
        });
    }
});
</script>

<%- include('../partials/footer') %>