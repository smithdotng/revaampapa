<%- include('../partials/header') %>

<%
// Ensure user object exists
if (typeof user === 'undefined') {
    var user = {
        name: 'Admin',
        profileImage: null,
        email: 'admin@found.ng'
    };
}

// Ensure settings object exists
if (typeof settings === 'undefined') {
    var settings = {
        agentRegistrationFee: 5000,
        agentCommission: 70,
        promoterCommission: 10,
        platformCommission: 20,
        siteName: 'Found Properties',
        siteEmail: 'info@found.ng',
        sitePhone: '+234 800 000 0000',
        siteAddress: 'Suite 5 Gwandal Centre, 1015 Frai Close, Wuse 2, Abuja',
        siteDescription: 'Nigeria\'s premier property listing platform connecting buyers with verified realtors and agents.',
        facebook: 'https://facebook.com/founddotng',
        instagram: 'https://instagram.com/founddotng',
        twitter: '',
        linkedin: ''
    };
}
%>

<!-- Page Top -->
<section>
    <div class="w-100 pt-180 pb-110 black-layer opc45 position-relative">
        <div class="fixed-bg" style="background-image: url(/assets/images/pg-tp-bg.jpg);"></div>
        <div class="container">
            <div class="pg-tp-wrp text-center w-100">
                <h1 class="mb-0">Platform Settings</h1>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/dashboard" title="Admin Dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item active">Settings</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<!-- Settings Section -->
<section>
    <div class="w-100 pt-120 pb-90 position-relative">
        <div class="container">
            <div class="row">
                <!-- Sidebar -->
                <div class="col-md-3">
                    <div class="admin-sidebar">
                        <div class="admin-profile text-center mb-4">
                            <img src="<%= user.profileImage ? '/uploads/profiles/' + user.profileImage : '/assets/images/default-avatar.jpg' %>" 
                                 alt="<%= user.name %>" 
                                 class="rounded-circle img-fluid" style="width: 80px; height: 80px; object-fit: cover;">
                            <h6 class="mt-2"><%= user.name %></h6>
                            <p class="text-muted small">Administrator</p>
                        </div>
                        <ul class="list-unstyled">
                            <li><a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                            <li><a href="/admin/users"><i class="fas fa-users"></i> Users</a></li>
                            <li><a href="/admin/agents"><i class="fas fa-user-tie"></i> Agents</a></li>
                            <li><a href="/admin/properties"><i class="fas fa-building"></i> Properties</a></li>
                            <li><a href="/admin/blogs"><i class="fas fa-newspaper"></i> Blogs</a></li>
                            <li><a href="/admin/projects"><i class="fas fa-city"></i> Projects</a></li>
                            <li><a href="/admin/inquiries"><i class="fas fa-envelope"></i> Inquiries</a></li>
                            <li class="active"><a href="/admin/settings"><i class="fas fa-cog"></i> Settings</a></li>
                        </ul>
                    </div>
                </div>

                <!-- Main Content -->
                <div class="col-md-9">
                    <div class="admin-content">
                        <form action="/admin/settings" method="POST" id="settingsForm">
                            <!-- General Settings -->
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0">General Settings</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Site Name</label>
                                                <input type="text" class="form-control" name="siteName" 
                                                       value="<%= settings.siteName %>" required>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Site Email</label>
                                                <input type="email" class="form-control" name="siteEmail" 
                                                       value="<%= settings.siteEmail %>" required>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Site Phone</label>
                                                <input type="tel" class="form-control" name="sitePhone" 
                                                       value="<%= settings.sitePhone %>">
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label>Site Description</label>
                                                <textarea class="form-control" name="siteDescription" rows="3"><%= settings.siteDescription %></textarea>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label>Site Address</label>
                                                <input type="text" class="form-control" name="siteAddress" 
                                                       value="<%= settings.siteAddress %>">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Commission Settings -->
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0">Commission Settings</h5>
                                </div>
                                <div class="card-body">
                                    <div class="alert alert-info mb-4">
                                        <i class="fas fa-info-circle"></i> 
                                        These settings determine how commissions are split between agents, property owners, and the platform.
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Agent Registration Fee (₦)</label>
                                                <input type="number" class="form-control" name="agentRegistrationFee" 
                                                       value="<%= settings.agentRegistrationFee %>" required>
                                                <small class="text-muted">One-time fee for agents to join the platform</small>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Agent Commission (%)</label>
                                                <input type="number" class="form-control" name="agentCommission" 
                                                       value="<%= settings.agentCommission %>" step="1" min="0" max="100" required>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Promoter Commission (%)</label>
                                                <input type="number" class="form-control" name="promoterCommission" 
                                                       value="<%= settings.promoterCommission %>" step="1" min="0" max="100" required>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Platform Commission (%)</label>
                                                <input type="number" class="form-control" name="platformCommission" 
                                                       value="<%= settings.platformCommission %>" step="1" min="0" max="100" required>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="alert alert-secondary mt-3">
                                        <strong>Example Calculation:</strong><br>
                                        Agency Fee: ₦100,000<br>
                                        Agent: ₦<%= (100000 * settings.agentCommission / 100).toLocaleString() %> (<%= settings.agentCommission %>%)
                                        | Promoter: ₦<%= (100000 * settings.promoterCommission / 100).toLocaleString() %> (<%= settings.promoterCommission %>%)
                                        | Platform: ₦<%= (100000 * settings.platformCommission / 100).toLocaleString() %> (<%= settings.platformCommission %>%)
                                    </div>
                                </div>
                            </div>

                            <!-- Social Media Settings -->
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0">Social Media Links</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label><i class="fab fa-facebook-f text-primary"></i> Facebook</label>
                                                <input type="url" class="form-control" name="facebook" 
                                                       value="<%= settings.facebook %>" placeholder="https://facebook.com/yourpage">
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label><i class="fab fa-instagram text-danger"></i> Instagram</label>
                                                <input type="url" class="form-control" name="instagram" 
                                                       value="<%= settings.instagram %>" placeholder="https://instagram.com/yourpage">
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label><i class="fab fa-twitter text-info"></i> Twitter</label>
                                                <input type="url" class="form-control" name="twitter" 
                                                       value="<%= settings.twitter %>" placeholder="https://twitter.com/yourpage">
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label><i class="fab fa-linkedin-in text-primary"></i> LinkedIn</label>
                                                <input type="url" class="form-control" name="linkedin" 
                                                       value="<%= settings.linkedin %>" placeholder="https://linkedin.com/company/yourpage">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Email Settings -->
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0">Email Notifications</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="emailNewUser" id="emailNewUser" checked>
                                                <label class="form-check-label" for="emailNewUser">
                                                    Notify on new user registration
                                                </label>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="emailNewProperty" id="emailNewProperty" checked>
                                                <label class="form-check-label" for="emailNewProperty">
                                                    Notify on new property listing
                                                </label>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="emailNewInquiry" id="emailNewInquiry" checked>
                                                <label class="form-check-label" for="emailNewInquiry">
                                                    Notify on new inquiry
                                                </label>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="emailAgentApproval" id="emailAgentApproval" checked>
                                                <label class="form-check-label" for="emailAgentApproval">
                                                    Notify on agent approval
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Maintenance Mode -->
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0">Maintenance Mode</h5>
                                </div>
                                <div class="card-body">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="maintenanceMode" id="maintenanceMode">
                                        <label class="form-check-label" for="maintenanceMode">
                                            Enable maintenance mode
                                        </label>
                                    </div>
                                    <div class="form-group mt-3" id="maintenanceMessageGroup" style="display: none;">
                                        <label>Maintenance Message</label>
                                        <textarea class="form-control" name="maintenanceMessage" rows="3" placeholder="We'll be back soon! Our site is currently under maintenance."></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- Save Button -->
                            <div class="text-center">
                                <button type="submit" class="thm-btn">
                                    <i class="fas fa-save"></i> Save Settings
                                </button>
                                <a href="/admin/dashboard" class="thm-btn brd-btn ml-2">
                                    <i class="fas fa-times"></i> Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.admin-sidebar {
    background: white;
    border-radius: 10px;
    padding: 30px 20px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
    position: sticky;
    top: 100px;
}

.admin-sidebar ul li {
    margin-bottom: 10px;
}

.admin-sidebar ul li a {
    display: block;
    padding: 12px 15px;
    border-radius: 5px;
    color: #333;
    transition: all 0.3s ease;
    text-decoration: none;
}

.admin-sidebar ul li a i {
    margin-right: 10px;
    width: 20px;
}

.admin-sidebar ul li a:hover {
    background: #f8f9fa;
}

.admin-sidebar ul li.active a {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.admin-content {
    background: white;
    border-radius: 10px;
    padding: 30px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
}

.card {
    border: 1px solid #f0f0f0;
    border-radius: 10px;
    margin-bottom: 20px;
}

.card-header {
    background: #f8f9fa;
    border-bottom: 1px solid #f0f0f0;
    padding: 15px 20px;
    font-weight: 600;
}

.card-body {
    padding: 20px;
}

.form-group {
    margin-bottom: 20px;
}

.form-control {
    border: 1px solid #e0e0e0;
    border-radius: 5px;
    padding: 10px 15px;
    font-size: 14px;
}

.form-control:focus {
    border-color: #ff6b6b;
    box-shadow: none;
}

.form-check {
    margin-bottom: 10px;
}

.form-check-input {
    margin-top: 0.3rem;
}

.alert {
    border-radius: 8px;
    padding: 15px;
}

.thm-btn {
    padding: 12px 30px;
    font-size: 16px;
}

@media (max-width: 991px) {
    .admin-sidebar {
        position: relative;
        top: 0;
        margin-bottom: 30px;
    }
}
</style>

<script>
// Show/hide maintenance message field
document.getElementById('maintenanceMode').addEventListener('change', function() {
    var messageGroup = document.getElementById('maintenanceMessageGroup');
    if (this.checked) {
        messageGroup.style.display = 'block';
    } else {
        messageGroup.style.display = 'none';
    }
});

// Commission validation
document.querySelector('form').addEventListener('submit', function(e) {
    var agentComm = parseFloat(document.querySelector('input[name="agentCommission"]').value);
    var promoterComm = parseFloat(document.querySelector('input[name="promoterCommission"]').value);
    var platformComm = parseFloat(document.querySelector('input[name="platformCommission"]').value);
    
    var total = agentComm + promoterComm + platformComm;
    
    if (total !== 100) {
        e.preventDefault();
        alert('Commission percentages must add up to 100%. Current total: ' + total + '%');
        return false;
    }
    
    if (agentComm < 0 || promoterComm < 0 || platformComm < 0) {
        e.preventDefault();
        alert('Commission percentages cannot be negative');
        return false;
    }
    
    if (confirm('Are you sure you want to save these settings? This will affect all future transactions.')) {
        return true;
    }
    e.preventDefault();
    return false;
});

// Phone number formatting
document.querySelector('input[name="sitePhone"]').addEventListener('input', function(e) {
    var phone = this.value.replace(/\D/g, '');
    if (phone.length > 11 && !this.value.startsWith('+234')) {
        phone = phone.substr(0, 11);
    } else if (this.value.startsWith('+234') && phone.length > 13) {
        phone = phone.substr(0, 13);
    }
    this.value = phone;
});

// Check if maintenance mode was previously enabled
if (document.getElementById('maintenanceMode').checked) {
    document.getElementById('maintenanceMessageGroup').style.display = 'block';
}
</script>

<%- include('../partials/footer') %>