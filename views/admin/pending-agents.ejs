

<%- include('../partials/header') %>

<%
// Ensure user object exists
if (typeof user === 'undefined') {
    var user = {
        name: 'Admin',
        profileImage: null,
        email: 'admin@foundproperties.ng'
    };
}

// Ensure agents array exists
if (typeof agents === 'undefined') {
    var agents = [];
}

// Helper function to format date
function formatDate(date) {
    if (!date) return 'N/A';
    return new Date(date).toLocaleDateString('en-NG', {
        year: 'numeric',
        month: 'short',
        day: 'numeric'
    });
}
%>

<!-- Rest of your pending-agents.ejs content continues here... -->

<!-- Page Top -->
<section>
    <div class="w-100 pt-180 pb-110 black-layer opc45 position-relative">
        <div class="fixed-bg" style="background-image: url(/assets/images/pg-tp-bg.jpg);"></div>
        <div class="container">
            <div class="pg-tp-wrp text-center w-100">
                <h1 class="mb-0">Pending Agent Approvals</h1>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/dashboard" title="Admin Dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item active">Pending Agents</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<!-- Pending Agents Section -->
<section>
    <div class="w-100 pt-120 pb-90 position-relative">
        <div class="container">
            <div class="row">
                <!-- Sidebar -->
                <div class="col-md-3">
                    <div class="admin-sidebar">
                        <ul class="list-unstyled">
                            <li><a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                            <li><a href="/admin/users"><i class="fas fa-users"></i> Users</a></li>
                            <li><a href="/admin/agents"><i class="fas fa-user-tie"></i> All Agents</a></li>
                            <li class="active"><a href="/admin/agents/pending"><i class="fas fa-clock"></i> Pending Approvals</a></li>
                            <li><a href="/admin/properties"><i class="fas fa-building"></i> Properties</a></li>
                            <li><a href="/admin/transactions"><i class="fas fa-credit-card"></i> Transactions</a></li>
                            <li><a href="/admin/withdrawals"><i class="fas fa-money-bill-wave"></i> Withdrawals</a></li>
                            <li><a href="/admin/settings"><i class="fas fa-cog"></i> Settings</a></li>
                        </ul>
                    </div>
                </div>

                <!-- Main Content -->
                <div class="col-md-9">
                    <div class="admin-content">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2>Pending Agent Applications</h2>
                            <span class="badge badge-warning p-2"><%= agents ? agents.length : 0 %> Pending</span>
                        </div>

                        <% if (agents && agents.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Agent Details</th>
                                            <th>Contact</th>
                                            <th>Payment</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% agents.forEach(agent => { %>
                                            <tr>
                                                <td><%= new Date(agent.createdAt).toLocaleDateString() %></td>
                                                <td>
                                                    <strong><%= agent.name %></strong><br>
                                                    <small class="text-muted">
                                                        <%= agent.agentProfile?.socialHandle || 'No social handle' %><br>
                                                        Exp: <%= agent.agentProfile?.experience || 'Not specified' %>
                                                    </small>
                                                </td>
                                                <td>
                                                    <i class="fas fa-phone"></i> <%= agent.phone %><br>
                                                    <i class="fas fa-envelope"></i> <%= agent.email %>
                                                </td>
                                                <td>
                                                    <span class="badge badge-success">Paid</span><br>
                                                    <small>Ref: <%= agent.agentProfile?.paymentReference?.substring(0, 10) %>...</small>
                                                </td>
                                                <td>
                                                    <button class="btn btn-sm btn-success mb-1" onclick="approveAgent('<%= agent._id %>')">
                                                        <i class="fas fa-check"></i> Approve
                                                    </button>
                                                    <button class="btn btn-sm btn-danger mb-1" onclick="rejectAgent('<%= agent._id %>')">
                                                        <i class="fas fa-times"></i> Reject
                                                    </button>
                                                    <button class="btn btn-sm btn-info" onclick="viewAgent('<%= agent._id %>')">
                                                        <i class="fas fa-eye"></i> View
                                                    </button>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <div class="text-center py-5">
                                <i class="fas fa-check-circle fa-4x text-success mb-3"></i>
                                <h4>No Pending Applications</h4>
                                <p class="text-muted">All agent applications have been processed.</p>
                                <a href="/admin/agents" class="thm-btn">View All Agents</a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Agent Details Modal -->
<div class="modal fade" id="agentModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Agent Details</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body" id="agentModalBody">
                <!-- Will be populated via AJAX -->
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="sr-only">Loading...</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-success" onclick="approveFromModal()">Approve</button>
                <button type="button" class="btn btn-danger" onclick="rejectFromModal()">Reject</button>
            </div>
        </div>
    </div>
</div>

<style>
.admin-sidebar {
    background: white;
    border-radius: 10px;
    padding: 30px 20px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
    position: sticky;
    top: 100px;
}

.admin-sidebar ul li {
    margin-bottom: 10px;
}

.admin-sidebar ul li a {
    display: block;
    padding: 12px 15px;
    border-radius: 5px;
    color: #333;
    transition: all 0.3s ease;
}

.admin-sidebar ul li a i {
    margin-right: 10px;
    width: 20px;
}

.admin-sidebar ul li a:hover {
    background: #f8f9fa;
}

.admin-sidebar ul li.active a {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.admin-content {
    background: white;
    border-radius: 10px;
    padding: 30px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
}

.table th {
    border-top: none;
    font-weight: 600;
    color: #555;
}

.table td {
    vertical-align: middle;
}

.badge-success {
    background: #28a745;
    color: white;
}

.badge-warning {
    background: #ffc107;
    color: #333;
}
</style>

<script>
// View agent details
function viewAgent(id) {
    $('#agentModal').modal('show');
    $('#agentModalBody').html('<div class="text-center py-4"><div class="spinner-border text-primary" role="status"><span class="sr-only">Loading...</span></div></div>');
    
    $.get('/admin/agents/' + id, function(data) {
        let html = `
            <div class="row">
                <div class="col-md-4 text-center">
                    <img src="${data.profileImage ? '/uploads/profiles/' + data.profileImage : '/assets/images/default-avatar.jpg'}" 
                         class="rounded-circle img-fluid mb-3" style="width: 150px; height: 150px; object-fit: cover;">
                    <h5>${data.name}</h5>
                    <p class="text-muted">${data.email}</p>
                </div>
                <div class="col-md-8">
                    <table class="table table-borderless">
                        <tr>
                            <th>Phone:</th>
                            <td>${data.phone}</td>
                        </tr>
                        <tr>
                            <th>Social Handle:</th>
                            <td>${data.agentProfile?.socialHandle || 'Not provided'}</td>
                        </tr>
                        <tr>
                            <th>Experience:</th>
                            <td>${data.agentProfile?.experience || 'Not specified'}</td>
                        </tr>
                        <tr>
                            <th>Registration Date:</th>
                            <td>${new Date(data.createdAt).toLocaleString()}</td>
                        </tr>
                        <tr>
                            <th>Payment Reference:</th>
                            <td>${data.agentProfile?.paymentReference || 'N/A'}</td>
                        </tr>
                        <tr>
                            <th>Payment Status:</th>
                            <td><span class="badge badge-success">Paid</span></td>
                        </tr>
                        <tr>
                            <th>Unique Link:</th>
                            <td><code>${data.agentProfile?.uniqueLink || 'Not generated'}</code></td>
                        </tr>
                    </table>
                </div>
            </div>
        `;
        $('#agentModalBody').html(html);
        window.currentAgentId = id;
    }).fail(function() {
        $('#agentModalBody').html('<p class="text-center text-danger">Error loading agent details</p>');
    });
}

// Approve agent
function approveAgent(id) {
    if (confirm('Are you sure you want to approve this agent? They will be able to access the agent dashboard and earn commissions.')) {
        $.post('/admin/agents/' + id + '/approve', function(data) {
            if (data.success) {
                alert('Agent approved successfully!');
                location.reload();
            } else {
                alert('Error approving agent');
            }
        }).fail(function() {
            alert('Error approving agent');
        });
    }
}

// Reject agent
function rejectAgent(id) {
    if (confirm('Are you sure you want to reject this agent? This action cannot be undone.')) {
        $.post('/admin/agents/' + id + '/reject', function(data) {
            if (data.success) {
                alert('Agent application rejected');
                location.reload();
            } else {
                alert('Error rejecting agent');
            }
        }).fail(function() {
            alert('Error rejecting agent');
        });
    }
}

// Approve from modal
function approveFromModal() {
    if (window.currentAgentId) {
        approveAgent(window.currentAgentId);
    }
}

// Reject from modal
function rejectFromModal() {
    if (window.currentAgentId) {
        rejectAgent(window.currentAgentId);
    }
}
</script>

<%- include('../partials/footer') %>