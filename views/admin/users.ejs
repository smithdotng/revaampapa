<%- include('../partials/header') %>

<%
// Ensure user object exists
if (typeof user === 'undefined') {
    var user = {
        name: 'Admin',
        profileImage: null,
        email: 'admin@found.ng'
    };
}

// Ensure users array exists
if (typeof users === 'undefined') {
    var users = [];
}

// Helper function to format date
function formatDate(date) {
    if (!date) return 'N/A';
    return new Date(date).toLocaleDateString('en-NG', {
        year: 'numeric',
        month: 'short',
        day: 'numeric'
    });
}

// Helper function to get user type badge class
function getUserTypeBadge(type) {
    switch(type) {
        case 'admin': return 'danger';
        case 'agent': return 'info';
        case 'realtor': return 'success';
        default: return 'secondary';
    }
}
%>

<!-- Page Top -->
<section>
    <div class="w-100 pt-180 pb-110 black-layer opc45 position-relative">
        <div class="fixed-bg" style="background-image: url(/assets/images/pg-tp-bg.jpg);"></div>
        <div class="container">
            <div class="pg-tp-wrp text-center w-100">
                <h1 class="mb-0">User Management</h1>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/dashboard" title="Admin Dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item active">Users</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<!-- Users Section -->
<section>
    <div class="w-100 pt-120 pb-90 position-relative">
        <div class="container">
            <div class="row">
                <!-- Sidebar -->
                <div class="col-md-3">
                    <div class="admin-sidebar">
                        <div class="admin-profile text-center mb-4">
                            <img src="<%= user.profileImage ? '/uploads/profiles/' + user.profileImage : '/assets/images/default-avatar.jpg' %>" 
                                 alt="<%= user.name %>" 
                                 class="rounded-circle img-fluid" style="width: 80px; height: 80px; object-fit: cover;">
                            <h6 class="mt-2"><%= user.name %></h6>
                            <p class="text-muted small">Administrator</p>
                        </div>
                        <ul class="list-unstyled">
                            <li><a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                            <li class="active"><a href="/admin/users"><i class="fas fa-users"></i> Users</a></li>
                            <li><a href="/admin/agents"><i class="fas fa-user-tie"></i> Agents</a></li>
                            <li><a href="/admin/properties"><i class="fas fa-building"></i> Properties</a></li>
                            <li><a href="/admin/blogs"><i class="fas fa-newspaper"></i> Blogs</a></li>
                            <li><a href="/admin/projects"><i class="fas fa-city"></i> Projects</a></li>
                            <li><a href="/admin/inquiries"><i class="fas fa-envelope"></i> Inquiries</a></li>
                            <li><a href="/admin/settings"><i class="fas fa-cog"></i> Settings</a></li>
                        </ul>
                    </div>
                </div>

                <!-- Main Content -->
                <div class="col-md-9">
                    <div class="admin-content">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2>User Management</h2>
                            <span class="badge badge-primary p-2">Total: <%= total %></span>
                        </div>

                        <!-- Filter Bar -->
                        <div class="filter-bar mb-4">
                            <form method="GET" action="/admin/users" id="filterForm">
                                <div class="row">
                                    <div class="col-md-3">
                                        <select class="form-control" name="type">
                                            <option value="all">All Users</option>
                                            <option value="realtor" <%= filters.type === 'realtor' ? 'selected' : '' %>>Realtors</option>
                                            <option value="agent" <%= filters.type === 'agent' ? 'selected' : '' %>>Agents</option>
                                            <option value="admin" <%= filters.type === 'admin' ? 'selected' : '' %>>Admins</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <input type="text" class="form-control" name="search" 
                                               placeholder="Search by name, email, or phone..." 
                                               value="<%= filters.search || '' %>">
                                    </div>
                                    <div class="col-md-3">
                                        <button type="submit" class="btn btn-primary btn-block">
                                            <i class="fas fa-search"></i> Search
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>

                        <!-- Users Table -->
                        <% if (users && users.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>User</th>
                                            <th>Contact</th>
                                            <th>Type</th>
                                            <th>Joined</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </thead>
                                        <tbody>
                                            <% users.forEach(userItem => { %>
                                                 <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <img src="<%= userItem.profileImage ? '/uploads/profiles/' + userItem.profileImage : '/assets/images/default-avatar.jpg' %>" 
                                                                 class="rounded-circle mr-2" style="width: 40px; height: 40px; object-fit: cover;">
                                                            <div>
                                                                <strong><%= userItem.name %></strong><br>
                                                                <small class="text-muted">ID: <%= userItem._id.toString().slice(-6).toUpperCase() %></small>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <small>
                                                            <i class="fas fa-envelope"></i> <%= userItem.email %><br>
                                                            <i class="fas fa-phone"></i> <%= userItem.phone || 'N/A' %>
                                                        </small>
                                                    </td>
                                                    <td>
                                                        <span class="badge badge-<%= getUserTypeBadge(userItem.userType) %>">
                                                            <%= userItem.userType %>
                                                        </span>
                                                    </td>
                                                    <td><%= formatDate(userItem.createdAt) %></td>
                                                    <td>
                                                        <% if (userItem.isSuspended) { %>
                                                            <span class="badge badge-danger">Suspended</span>
                                                        <% } else { %>
                                                            <span class="badge badge-success">Active</span>
                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <a href="/admin/users/<%= userItem._id %>" class="btn btn-sm btn-info" title="View Details">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                        <% if (userItem.userType === 'realtor' && !userItem.realtorProfile?.verified) { %>
                                                            <button class="btn btn-sm btn-success" onclick="verifyUser('<%= userItem._id %>')" title="Verify Realtor">
                                                                <i class="fas fa-check-circle"></i>
                                                            </button>
                                                        <% } %>
                                                        <% if (userItem._id.toString() !== user._id.toString()) { %>
                                                            <button class="btn btn-sm btn-<%= userItem.isSuspended ? 'success' : 'warning' %>" 
                                                                    onclick="suspendUser('<%= userItem._id %>', <%= userItem.isSuspended %>)" 
                                                                    title="<%= userItem.isSuspended ? 'Unsuspend' : 'Suspend' %>">
                                                                <i class="fas fa-<%= userItem.isSuspended ? 'play' : 'pause' %>"></i>
                                                            </button>
                                                            <button class="btn btn-sm btn-danger" onclick="deleteUser('<%= userItem._id %>')" title="Delete">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        <% } %>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>

                                <!-- Pagination -->
                                <% if (totalPages > 1) { %>
                                    <div class="pagination-wrap text-center mt-4">
                                        <ul class="pagination justify-content-center">
                                            <% if (currentPage > 1) { %>
                                                <li class="page-item">
                                                    <a class="page-link" href="?page=<%= currentPage - 1 %><%= filters.type && filters.type !== 'all' ? '&type=' + filters.type : '' %><%= filters.search ? '&search=' + filters.search : '' %>">
                                                        <i class="fas fa-chevron-left"></i>
                                                    </a>
                                                </li>
                                            <% } %>
                                            
                                            <% for (let i = 1; i <= totalPages; i++) { %>
                                                <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                                    <a class="page-link" href="?page=<%= i %><%= filters.type && filters.type !== 'all' ? '&type=' + filters.type : '' %><%= filters.search ? '&search=' + filters.search : '' %>">
                                                        <%= i %>
                                                    </a>
                                                </li>
                                            <% } %>
                                            
                                            <% if (currentPage < totalPages) { %>
                                                <li class="page-item">
                                                    <a class="page-link" href="?page=<%= currentPage + 1 %><%= filters.type && filters.type !== 'all' ? '&type=' + filters.type : '' %><%= filters.search ? '&search=' + filters.search : '' %>">
                                                        <i class="fas fa-chevron-right"></i>
                                                    </a>
                                                </li>
                                            <% } %>
                                        </ul>
                                    </div>
                                <% } %>
                            <% } else { %>
                                <div class="text-center py-5">
                                    <i class="fas fa-users fa-4x text-muted mb-3"></i>
                                    <h4>No Users Found</h4>
                                    <p class="text-muted">Try adjusting your search or filter criteria.</p>
                                    <a href="/admin/users" class="thm-btn">Clear Filters</a>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete User</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this user? This action cannot be undone.</p>
                <p class="text-danger"><strong>Warning:</strong> This will also delete all associated properties and data.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDelete">Delete User</button>
            </div>
        </div>
    </div>
</div>

<!-- Suspend Confirmation Modal -->
<div class="modal fade" id="suspendModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="suspendModalTitle">Suspend User</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p id="suspendModalMessage">Are you sure you want to suspend this user?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning" id="confirmSuspend">Confirm</button>
            </div>
        </div>
    </div>
</div>

<style>
.admin-sidebar {
    background: white;
    border-radius: 10px;
    padding: 30px 20px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
    position: sticky;
    top: 100px;
}

.admin-sidebar ul li {
    margin-bottom: 10px;
}

.admin-sidebar ul li a {
    display: block;
    padding: 12px 15px;
    border-radius: 5px;
    color: #333;
    transition: all 0.3s ease;
    text-decoration: none;
}

.admin-sidebar ul li a i {
    margin-right: 10px;
    width: 20px;
}

.admin-sidebar ul li a:hover {
    background: #f8f9fa;
}

.admin-sidebar ul li.active a {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.admin-content {
    background: white;
    border-radius: 10px;
    padding: 30px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
}

.filter-bar {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 10px;
}

.table th {
    border-top: none;
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    color: #555;
}

.table td {
    vertical-align: middle;
}

.btn-sm {
    padding: 5px 8px;
    margin: 0 2px;
}

.badge {
    padding: 5px 10px;
    font-weight: 500;
}

.pagination .page-link {
    color: #ff6b6b;
    border: none;
    margin: 0 3px;
    border-radius: 5px;
}

.pagination .page-item.active .page-link {
    background: #ff6b6b;
    color: white;
}

@media (max-width: 991px) {
    .admin-sidebar {
        position: relative;
        top: 0;
        margin-bottom: 30px;
    }
    
    .table-responsive {
        font-size: 14px;
    }
}
</style>

<script>
let userIdToAction = null;
let userActionType = null;

// Verify user (realtor)
function verifyUser(id) {
    if (confirm('Verify this realtor? They will receive a verified badge.')) {
        $.post('/admin/users/' + id + '/verify', function(data) {
            if (data.success) {
                alert('Realtor verified successfully');
                location.reload();
            } else {
                alert('Error verifying user');
            }
        }).fail(function(xhr) {
            alert('Error: ' + (xhr.responseJSON?.error || 'Unknown error'));
        });
    }
}

// Suspend/Unsuspend user
function suspendUser(id, isCurrentlySuspended) {
    userIdToAction = id;
    userActionType = isCurrentlySuspended ? 'unsuspend' : 'suspend';
    
    if (isCurrentlySuspended) {
        $('#suspendModalTitle').text('Unsuspend User');
        $('#suspendModalMessage').text('Are you sure you want to unsuspend this user? They will regain access to the platform.');
    } else {
        $('#suspendModalTitle').text('Suspend User');
        $('#suspendModalMessage').text('Are you sure you want to suspend this user? They will lose access to the platform.');
    }
    
    $('#suspendModal').modal('show');
}

// Confirm suspend/unsuspend
document.getElementById('confirmSuspend').addEventListener('click', function() {
    if (userIdToAction) {
        $.post('/admin/users/' + userIdToAction + '/suspend', function(data) {
            if (data.success) {
                alert('User ' + (userActionType === 'suspend' ? 'suspended' : 'unsuspended') + ' successfully');
                location.reload();
            } else {
                alert('Error updating user status');
            }
        }).fail(function(xhr) {
            alert('Error: ' + (xhr.responseJSON?.error || 'Unknown error'));
        });
    }
    $('#suspendModal').modal('hide');
});

// Delete user
function deleteUser(id) {
    userIdToAction = id;
    $('#deleteModal').modal('show');
}

// Confirm delete
document.getElementById('confirmDelete').addEventListener('click', function() {
    if (userIdToAction) {
        $.ajax({
            url: '/admin/users/' + userIdToAction,
            type: 'DELETE',
            success: function(data) {
                if (data.success) {
                    alert('User deleted successfully');
                    location.reload();
                } else {
                    alert('Error deleting user');
                }
            },
            error: function(xhr) {
                alert('Error: ' + (xhr.responseJSON?.error || 'Unknown error'));
            }
        });
    }
    $('#deleteModal').modal('hide');
});

// Auto-submit filter on select change
document.querySelector('select[name="type"]').addEventListener('change', function() {
    document.getElementById('filterForm').submit();
});

// Search on Enter key
document.querySelector('input[name="search"]').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
        document.getElementById('filterForm').submit();
    }
});
</script>

<%- include('../partials/footer') %>