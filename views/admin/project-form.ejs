}

.card-header {
    background: #f8f9fa;
    border-bottom: 1px solid #f0f0f0;
    padding: 15px 20px;
    font-weight: 600;
}

.card-body {
    padding: 20px;
}

.form-control {
    border: 1px solid #e0e0e0;
    border-radius: 5px;
    padding: 10px 15px;
    font-size: 14px;
}

