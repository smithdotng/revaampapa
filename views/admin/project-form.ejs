    padding: 12px 30px;
    font-size: 16px;
}

@media (max-width: 991px) {
    .admin-sidebar {
        position: relative;
        top: 0;
        margin-bottom: 30px;
    }
}
</style>

<script>
// Dynamic feature fields
let featureCount = <%= project && project.features ? project.features.length : 1 %>;

function addFeatureField() {
    const container = document.getElementById('features-container');
    const newIndex = featureCount;
    
    const featureHtml = `
        <div class="feature-item mb-3 p-3 border rounded" data-index="${newIndex}">
            <div class="row">
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Icon Class</label>
                        <input type="text" class="form-control" name="features[${newIndex}][icon]" 
                               value="fas fa-check-circle" placeholder="fas fa-building">
                        <small class="text-muted">Font Awesome icon class</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label>Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="features[${newIndex}][title]" required>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label>Description <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="features[${newIndex}][description]" required>
                    </div>
                </div>
                <div class="col-md-1">
                    <div class="form-group">
                        <label>&nbsp;</label>
                        <button type="button" class="btn btn-danger btn-block" onclick="removeFeature(this)">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    `;
    
    container.insertAdjacentHTML('beforeend', featureHtml);
    featureCount++;
}

function removeFeature(button) {
    button.closest('.feature-item').remove();
}

// Form validation and preview
const form = document.getElementById('projectForm');
let formChanged = false;

form.addEventListener('input', function() {
    formChanged = true;
});

window.addEventListener('beforeunload', function(e) {
    if (formChanged) {
        e.preventDefault();
        e.returnValue = 'You have unsaved changes. Are you sure you want to leave?';
    }
});

form.addEventListener('submit', function() {
    formChanged = false;
});

// JSON validation for gallery and paymentPlan
function validateJSON(textareaId, errorMessage) {
    const textarea = document.getElementById(textareaId);
    if (textarea && textarea.value.trim()) {
        try {
            JSON.parse(textarea.value);
            textarea.classList.remove('is-invalid');
            return true;
        } catch(e) {
            textarea.classList.add('is-invalid');
            if (!textarea.nextElementSibling || !textarea.nextElementSibling.classList.contains('invalid-feedback')) {
                const feedback = document.createElement('div');
                feedback.className = 'invalid-feedback';
                feedback.textContent = errorMessage;
                textarea.parentNode.appendChild(feedback);
            }
            return false;
        }
    }
    return true;
}

// Add JSON validation listeners
document.querySelector('textarea[name="gallery"]')?.addEventListener('blur', function() {
    validateJSON('gallery', 'Invalid JSON format');
});

document.querySelector('textarea[name="paymentPlan"]')?.addEventListener('blur', function() {
    validateJSON('paymentPlan', 'Invalid JSON format');
});
</script>

