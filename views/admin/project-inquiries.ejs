<%- include('../partials/header') %>

<%
if (typeof user === 'undefined') {
    var user = {
        name: 'Admin',
        profileImage: null,
        email: 'admin@found.ng'
    };
}

function formatDate(date) {
    if (!date) return 'N/A';
    return new Date(date).toLocaleDateString('en-NG', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
    });
}

function getStatusBadge(status) {
    switch(status) {
        case 'new': return 'danger';
        case 'read': return 'warning';
        case 'replied': return 'success';
        case 'archived': return 'secondary';
        default: return 'primary';
    }
}
%>

<!-- Page Top -->
<section>
    <div class="w-100 pt-180 pb-110 black-layer opc45 position-relative">
        <div class="fixed-bg" style="background-image: url(/assets/images/pg-tp-bg.jpg);"></div>
        <div class="container">
            <div class="pg-tp-wrp text-center w-100">
                <h1 class="mb-0">Project Inquiries</h1>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item active">Inquiries</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<section>
    <div class="w-100 pt-120 pb-90 position-relative">
        <div class="container">
            <div class="row">
                <div class="col-md-3">
                    <div class="admin-sidebar">
                        <div class="admin-profile text-center mb-4">
                            <img src="<%= user.profileImage ? '/uploads/profiles/' + user.profileImage : '/assets/images/default-avatar.jpg' %>" 
                                 alt="<%= user.name %>" 
                                 class="rounded-circle img-fluid" style="width: 80px; height: 80px; object-fit: cover;">
                            <h6 class="mt-2"><%= user.name %></h6>
                            <p class="text-muted small">Administrator</p>
                        </div>
                        <ul class="list-unstyled">
                            <li><a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                            <li><a href="/admin/users"><i class="fas fa-users"></i> Users</a></li>
                            <li><a href="/admin/agents"><i class="fas fa-user-tie"></i> Agents</a></li>
                            <li><a href="/admin/properties"><i class="fas fa-building"></i> Properties</a></li>
                            <li><a href="/admin/blogs"><i class="fas fa-newspaper"></i> Blogs</a></li>
                            <li><a href="/admin/projects"><i class="fas fa-city"></i> Projects</a></li>
                            <li class="active"><a href="/admin/inquiries"><i class="fas fa-envelope"></i> Inquiries</a></li>
                            <li><a href="/admin/settings"><i class="fas fa-cog"></i> Settings</a></li>
                        </ul>
                    </div>
                </div>

                <div class="col-md-9">
                    <div class="admin-content">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2>Project Inquiries</h2>
                            <span class="badge badge-primary p-2">Total: <%= total %></span>
                        </div>

                        <div class="filter-bar mb-4">
                            <form method="GET" action="/admin/inquiries" id="filterForm">
                                <div class="row">
                                    <div class="col-md-4">
                                        <select class="form-control" name="status">
                                            <option value="all">All Status</option>
                                            <option value="new" <%= filters.status === 'new' ? 'selected' : '' %>>New</option>
                                            <option value="read" <%= filters.status === 'read' ? 'selected' : '' %>>Read</option>
                                            <option value="replied" <%= filters.status === 'replied' ? 'selected' : '' %>>Replied</option>
                                            <option value="archived" <%= filters.status === 'archived' ? 'selected' : '' %>>Archived</option>
                                        </select>
                                    </div>
                                    <div class="col-md-5">
                                        <select class="form-control" name="projectId">
                                            <option value="">All Projects</option>
                                            <% projects.forEach(project => { %>
                                                <option value="<%= project._id %>" <%= filters.projectId === project._id ? 'selected' : '' %>><%= project.name %></option>
                                            <% }); %>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <button type="submit" class="btn btn-primary btn-block">Filter</button>
                                    </div>
                                </div>
                            </form>
                        </div>

                        <% if (inquiries && inquiries.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Inquirer</th>
                                            <th>Project</th>
                                            <th>Message</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </thead>
                                        <tbody>
                                            <% inquiries.forEach(inquiry => { %>
                                                 <tr>
                                                    <td><%= formatDate(inquiry.createdAt) %></td>
                                                    <td>
                                                        <strong><%= inquiry.name %></strong><br>
                                                        <small class="text-muted"><%= inquiry.email %></small><br>
                                                        <% if (inquiry.phone) { %>
                                                            <small><%= inquiry.phone %></small>
                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <a href="/projects/<%= inquiry.project?.slug %>" target="_blank">
                                                            <%= inquiry.projectName %>
                                                        </a>
                                                    </td>
                                                    <td><%= inquiry.message.substring(0, 60) %>...</td>
                                                    <td>
                                                        <span class="badge badge-<%= getStatusBadge(inquiry.status) %>">
                                                            <%= inquiry.status.toUpperCase() %>
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <a href="/admin/inquiries/<%= inquiry._id %>" class="btn btn-sm btn-info" title="View">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                        <button class="btn btn-sm btn-danger" onclick="deleteInquiry('<%= inquiry._id %>')" title="Delete">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>

                                <% if (totalPages > 1) { %>
                                    <div class="pagination-wrap mt-4">
                                        <ul class="pagination justify-content-center">
                                            <% for (let i = 1; i <= totalPages; i++) { %>
                                                <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                                    <a class="page-link" href="?page=<%= i %><%= filters.status && filters.status !== 'all' ? '&status=' + filters.status : '' %><%= filters.projectId ? '&projectId=' + filters.projectId : '' %>">
                                                        <%= i %>
                                                    </a>
                                                </li>
                                            <% } %>
                                        </ul>
                                    </div>
                                <% } %>
                            <% } else { %>
                                <div class="text-center py-5">
                                    <i class="fas fa-envelope fa-4x text-muted mb-3"></i>
                                    <h4>No Inquiries Found</h4>
                                    <p>No project inquiries have been submitted yet.</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Inquiry</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this inquiry? This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDelete">Delete</button>
            </div>
        </div>
    </div>
</div>

<style>
.admin-sidebar {
    background: white;
    border-radius: 10px;
    padding: 30px 20px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
    position: sticky;
    top: 100px;
}

.admin-sidebar ul li {
    margin-bottom: 10px;
}

.admin-sidebar ul li a {
    display: block;
    padding: 12px 15px;
    border-radius: 5px;
    color: #333;
    transition: all 0.3s ease;
    text-decoration: none;
}

.admin-sidebar ul li a i {
    margin-right: 10px;
    width: 20px;
}

.admin-sidebar ul li a:hover {
    background: #f8f9fa;
}

.admin-sidebar ul li.active a {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.admin-content {
    background: white;
    border-radius: 10px;
    padding: 30px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
}

.filter-bar {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 10px;
}

.table th {
    border-top: none;
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
}

.btn-sm {
    padding: 5px 8px;
    margin: 0 2px;
}

.badge {
    padding: 5px 10px;
}
</style>

<script>
let inquiryToDelete = null;

function deleteInquiry(id) {
    inquiryToDelete = id;
    $('#deleteModal').modal('show');
}

document.getElementById('confirmDelete').addEventListener('click', function() {
    if (inquiryToDelete) {
        fetch('/admin/inquiries/' + inquiryToDelete, {
            method: 'DELETE',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert('Error deleting inquiry');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error deleting inquiry');
        });
    }
});
</script>

<%- include('../partials/footer') %>