<%- include('../partials/header') %>

<%
if (typeof user === 'undefined') {
    var user = {
        name: 'Admin',
        profileImage: null,
        email: 'admin@found.ng'
    };
}

function formatDate(date) {
    if (!date) return 'N/A';
    return new Date(date).toLocaleDateString('en-NG', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
    });
}
%>

<!-- Page Top -->
<section>
    <div class="w-100 pt-180 pb-110 black-layer opc45 position-relative">
        <div class="fixed-bg" style="background-image: url(/assets/images/pg-tp-bg.jpg);"></div>
        <div class="container">
            <div class="pg-tp-wrp text-center w-100">
                <h1 class="mb-0">Inquiry Details</h1>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="/admin/inquiries">Inquiries</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<section>
    <div class="w-100 pt-120 pb-90 position-relative">
        <div class="container">
            <div class="row">
                <div class="col-md-3">
                    <div class="admin-sidebar">
                        <div class="admin-profile text-center mb-4">
                            <img src="<%= user.profileImage ? '/uploads/profiles/' + user.profileImage : '/assets/images/default-avatar.jpg' %>" 
                                 alt="<%= user.name %>" 
                                 class="rounded-circle img-fluid" style="width: 80px; height: 80px; object-fit: cover;">
                            <h6 class="mt-2"><%= user.name %></h6>
                            <p class="text-muted small">Administrator</p>
                        </div>
                        <ul class="list-unstyled">
                            <li><a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                            <li><a href="/admin/users"><i class="fas fa-users"></i> Users</a></li>
                            <li><a href="/admin/agents"><i class="fas fa-user-tie"></i> Agents</a></li>
                            <li><a href="/admin/properties"><i class="fas fa-building"></i> Properties</a></li>
                            <li><a href="/admin/blogs"><i class="fas fa-newspaper"></i> Blogs</a></li>
                            <li><a href="/admin/projects"><i class="fas fa-city"></i> Projects</a></li>
                            <li class="active"><a href="/admin/inquiries"><i class="fas fa-envelope"></i> Inquiries</a></li>
                            <li><a href="/admin/settings"><i class="fas fa-cog"></i> Settings</a></li>
                        </ul>
                    </div>
                </div>

                <div class="col-md-9">
                    <div class="admin-content">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2>Inquiry Details</h2>
                            <a href="/admin/inquiries" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Back to Inquiries
                            </a>
                        </div>

                        <div class="card mb-4">
                            <div class="card-header">
                                <h5 class="mb-0">Inquiry Information</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <p><strong>Date:</strong> <%= formatDate(inquiry.createdAt) %></p>
                                        <p><strong>Name:</strong> <%= inquiry.name %></p>
                                        <p><strong>Email:</strong> <a href="mailto:<%= inquiry.email %>"><%= inquiry.email %></a></p>
                                        <p><strong>Phone:</strong> <%= inquiry.phone || 'Not provided' %></p>
                                    </div>
                                    <div class="col-md-6">
                                        <p><strong>Project:</strong> 
                                            <a href="/projects/<%= inquiry.project?.slug %>" target="_blank">
                                                <%= inquiry.projectName %>
                                            </a>
                                        </p>
                                        <p><strong>Status:</strong> 
                                            <span class="badge badge-<%= inquiry.status === 'new' ? 'danger' : (inquiry.status === 'read' ? 'warning' : 'success') %>">
                                                <%= inquiry.status.toUpperCase() %>
                                            </span>
                                        </p>
                                        <% if (inquiry.readAt) { %>
                                            <p><strong>Read at:</strong> <%= formatDate(inquiry.readAt) %></p>
                                        <% } %>
                                        <% if (inquiry.repliedAt) { %>
                                            <p><strong>Replied at:</strong> <%= formatDate(inquiry.repliedAt) %></p>
                                        <% } %>
                                    </div>
                                </div>
                                <hr>
                                <h6>Message:</h6>
                                <div class="bg-light p-3 rounded">
                                    <p class="mb-0"><%= inquiry.message %></p>
                                </div>
                            </div>
                        </div>

                        <% if (!inquiry.replyMessage) { %>
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="mb-0">Reply to Inquiry</h5>
                                </div>
                                <div class="card-body">
                                    <form action="/admin/inquiries/<%= inquiry._id %>/reply" method="POST">
                                        <div class="form-group">
                                            <label>Your Reply</label>
                                            <textarea class="form-control" name="replyMessage" rows="6" required placeholder="Type your reply here..."></textarea>
                                        </div>
                                        <button type="submit" class="thm-btn">
                                            <i class="fas fa-paper-plane"></i> Send Reply
                                        </button>
                                    </form>
                                </div>
                            </div>
                        <% } else { %>
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="mb-0">Reply Sent</h5>
                                </div>
                                <div class="card-body">
                                    <p><strong>Sent at:</strong> <%= formatDate(inquiry.repliedAt) %></p>
                                    <h6>Reply Message:</h6>
                                    <div class="bg-light p-3 rounded">
                                        <p class="mb-0"><%= inquiry.replyMessage %></p>
                                    </div>
                                </div>
                            </div>
                        <% } %>

                        <div class="text-center mt-4">
                            <button class="btn btn-danger" onclick="deleteInquiry('<%= inquiry._id %>')">
                                <i class="fas fa-trash"></i> Delete Inquiry
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Inquiry</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this inquiry? This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDelete">Delete</button>
            </div>
        </div>
    </div>
</div>

<style>
.admin-sidebar {
    background: white;
    border-radius: 10px;
    padding: 30px 20px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
    position: sticky;
    top: 100px;
}

.admin-sidebar ul li {
    margin-bottom: 10px;
}

.admin-sidebar ul li a {
    display: block;
    padding: 12px 15px;
    border-radius: 5px;
    color: #333;
    transition: all 0.3s ease;
    text-decoration: none;
}

.admin-sidebar ul li a i {
    margin-right: 10px;
    width: 20px;
}

.admin-sidebar ul li a:hover {
    background: #f8f9fa;
}

.admin-sidebar ul li.active a {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.admin-content {
    background: white;
    border-radius: 10px;
    padding: 30px;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
}

.card {
    border: 1px solid #f0f0f0;
    border-radius: 10px;
    margin-bottom: 20px;
}

.card-header {
    background: #f8f9fa;
    border-bottom: 1px solid #f0f0f0;
    padding: 15px 20px;
    font-weight: 600;
}

.card-body {
    padding: 20px;
}

.form-control {
    border: 1px solid #e0e0e0;
    border-radius: 5px;
    padding: 10px 15px;
}

.form-control:focus {
    border-color: #ff6b6b;
    box-shadow: none;
}

.thm-btn {
    padding: 12px 30px;
}
</style>

<script>
let inquiryToDelete = '<%= inquiry._id %>';

function deleteInquiry(id) {
    $('#deleteModal').modal('show');
}

document.getElementById('confirmDelete').addEventListener('click', function() {
    if (inquiryToDelete) {
        fetch('/admin/inquiries/' + inquiryToDelete, {
            method: 'DELETE',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                window.location.href = '/admin/inquiries';
            } else {
                alert('Error deleting inquiry');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error deleting inquiry');
        });
    }
});
</script>

<%- include('../partials/footer') %>