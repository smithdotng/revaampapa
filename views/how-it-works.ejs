                <!-- Buyers & Tenants -->
                <div class="tab-pane fade show active" id="buyer" role="tabpanel">
                    <div class="how-work-wrap res-row text-center w-100">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="how-work-box v2 w-100">
                                    <span class="rounded-circle d-inline-block">
                                        <img class="img-fluid" src="/assets/images/icons/search-icon.png" alt="Search">
                                    </span>
                                    <div class="how-work-inner w-100">
                                        <h3 class="mb-0">1. Search Properties</h3>
                                        <p class="mb-0">Browse thousands of verified properties across Nigeria. Filter by type, location, price, and more.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="how-work-box v2 w-100">
                                    <span class="rounded-circle d-inline-block">
                                        <img class="img-fluid" src="/assets/images/icons/view-icon.png" alt="View">
                                    </span>
                                    <div class="how-work-inner w-100">
                                        <h3 class="mb-0">2. View & Compare</h3>
                                        <p class="mb-0">View detailed property information, high-quality images, and compare multiple options side by side.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="how-work-box v2 w-100">
                                    <span class="rounded-circle d-inline-block">
                                        <img class="img-fluid" src="/assets/images/icons/contact-icon.png" alt="Contact">
                                    </span>
                                    <div class="how-work-inner w-100">
                                        <h3 class="mb-0">3. Connect & Close</h3>
                                        <p class="mb-0">Contact the realtor directly or work with an agent to schedule viewings and complete your transaction.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Buyer Features -->
                    <div class="features-grid mt-5">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="feature-card p-4">
                                    <i class="fas fa-check-circle text-success fa-2x mb-3"></i>
                                    <h4>Verified Properties</h4>
                                    <p>All properties on our platform are verified by our team to ensure authenticity and accuracy.</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="feature-card p-4">
                                    <i class="fas fa-shield-alt text-success fa-2x mb-3"></i>
                                    <h4>Secure Transactions</h4>
                                    <p>Your payments and personal information are protected with industry-standard security.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Realtors -->
                <div class="tab-pane fade" id="realtor" role="tabpanel">
                    <div class="how-work-wrap res-row text-center w-100">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="how-work-box v2 w-100">
                                    <span class="rounded-circle d-inline-block">
                                        <img class="img-fluid" src="/assets/images/icons/register-icon.png" alt="Register">
                                    </span>
                                    <div class="how-work-inner w-100">
                                        <h3 class="mb-0">1. Create Account</h3>
                                        <p class="mb-0">Register as a realtor for free. Provide your company details and get verified by our team.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="how-work-box v2 w-100">
                                    <span class="rounded-circle d-inline-block">
                                        <img class="img-fluid" src="/assets/images/icons/list-icon.png" alt="List">
                                    </span>
                                    <div class="how-work-inner w-100">
                                        <h3 class="mb-0">2. List Properties</h3>
                                        <p class="mb-0">Add unlimited properties with detailed information, high-quality images, and videos.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="how-work-box v2 w-100">
                                    <span class="rounded-circle d-inline-block">
                                        <img class="img-fluid" src="/assets/images/icons/lead-icon.png" alt="Leads">
                                    </span>
                                    <div class="how-work-inner w-100">
                                        <h3 class="mb-0">3. Get Leads</h3>
                                        <p class="mb-0">Receive inquiries from potential buyers and tenants. Track views and engagement.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Realtor Benefits -->
                    <div class="benefits-box mt-5 p-5">
                        <h3 class="text-center mb-4">Why List with Found Properties?</h3>
                        <div class="row">
                            <div class="col-md-4">
                                <ul class="list-unstyled">
                                    <li><i class="fas fa-check text-success mr-2"></i> Free to list</li>
                                    <li><i class="fas fa-check text-success mr-2"></i> Unlimited properties</li>
                                    <li><i class="fas fa-check text-success mr-2"></i> Verified leads</li>
                                </ul>
                            </div>
                            <div class="col-md-4">
                                <ul class="list-unstyled">
                                    <li><i class="fas fa-check text-success mr-2"></i> Analytics dashboard</li>
                                    <li><i class="fas fa-check text-success mr-2"></i> Agent network access</li>
                                    <li><i class="fas fa-check text-success mr-2"></i> Featured opportunities</li>
                                </ul>
                            </div>
                            <div class="col-md-4">
                                <ul class="list-unstyled">
                                    <li><i class="fas fa-check text-success mr-2"></i> 24/7 support</li>
                                    <li><i class="fas fa-check text-success mr-2"></i> Marketing tools</li>
                                    <li><i class="fas fa-check text-success mr-2"></i> Performance insights</li>
                                </ul>
                            </div>
                        </div>
                        <div class="text-center mt-4">
                            <a href="/register" class="thm-btn">Start Listing Today</a>
                        </div>
                    </div>
                </div>

                <!-- Agents -->
                <div class="tab-pane fade" id="agent" role="tabpanel">
                    <div class="how-work-wrap res-row text-center w-100">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="how-work-box v2 w-100">
                                    <span class="rounded-circle d-inline-block">
                                        <img class="img-fluid" src="/assets/images/icons/agent-register-icon.png" alt="Register">
                                    </span>
                                    <div class="how-work-inner w-100">
                                        <h3 class="mb-0">1. Register & Pay Fee</h3>
                                        <p class="mb-0">Pay a one-time registration fee of ₦5,000 to become a verified agent.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="how-work-box v2 w-100">
                                    <span class="rounded-circle d-inline-block">
                                        <img class="img-fluid" src="/assets/images/icons/referral-icon.png" alt="Referral">
                                    </span>
                                    <div class="how-work-inner w-100">
                                        <h3 class="mb-0">2. Get Unique Links</h3>
                                        <p class="mb-0">Receive unique referral links for each property to share on social media.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="how-work-box v2 w-100">
                                    <span class="rounded-circle d-inline-block">
                                        <img class="img-fluid" src="/assets/images/icons/earn-icon.png" alt="Earn">
                                    </span>
                                    <div class="how-work-inner w-100">
                                        <h3 class="mb-0">3. Earn 70% Commission</h3>
                                        <p class="mb-0">Earn 70% of the agency fee on every successful transaction from your referrals.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Commission Structure -->
                    <div class="commission-card mt-5 p-5 text-white text-center">
                        <h3 class="mb-4">Commission Structure</h3>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="commission-item">
                                    <h2 class="text-warning">70%</h2>
                                    <p>Agent Commission</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="commission-item">
                                    <h2 class="text-info">10%</h2>
                                    <p>Promoter (Realtor)</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="commission-item">
                                    <h2 class="text-light">20%</h2>
                                    <p>Found Platform</p>
                                </div>
                            </div>
                        </div>
                        <p class="mt-4 mb-0">Example: On a ₦100,000 agency fee, you earn ₦70,000!</p>
                    </div>

                    <div class="text-center mt-5">
                        <a href="/agent/register" class="thm-btn">Become an Agent Today</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FAQ Section -->
<section class="gray-bg">
    <div class="w-100 pt-120 pb-120 position-relative">
        <div class="container">
            <div class="sec-title text-center w-100">
                <span class="d-block thm-clr">Got Questions?</span>
                <h2 class="mb-0">Frequently Asked Questions</h2>
            </div>

            <div class="row mt-5">
                <div class="col-lg-8 offset-lg-2">
                    <div class="accordion" id="faqAccordion">
                        <div class="card">
                            <div class="card-header" id="faq1">
                                <h5 class="mb-0">
                                    <button class="btn btn-link" type="button" data-toggle="collapse" data-target="#collapse1">
                                        Is it really free for realtors to list properties?
                                    </button>
                                </h5>
                            </div>
                            <div id="collapse1" class="collapse show" data-parent="#faqAccordion">
                                <div class="card-body">
                                    Yes! Realtors can create an account and list properties completely free. There are no listing fees or hidden charges.
                                </div>
                            </div>
                        </div>

                        <div class="card">
                            <div class="card-header" id="faq2">
                                <h5 class="mb-0">
                                    <button class="btn btn-link collapsed" type="button" data-toggle="collapse" data-target="#collapse2">
                                        How do agents earn commissions?
                                    </button>
                                </h5>
                            </div>
                            <div id="collapse2" class="collapse" data-parent="#faqAccordion">
                                <div class="card-body">
                                    Agents get unique referral links for each property. When someone clicks your link and completes a transaction, you earn 70% of the agency fee. The payment is automatically processed and added to your wallet.
                                </div>
                            </div>
                        </div>

                        <div class="card">
                            <div class="card-header" id="faq3">
                                <h5 class="mb-0">
                                    <button class="btn btn-link collapsed" type="button" data-toggle="collapse" data-target="#collapse3">
                                        What is the agent registration fee?
                                    </button>
                                </h5>
                            </div>
                            <div id="collapse3" class="collapse" data-parent="#faqAccordion">
                                <div class="card-body">
                                    The one-time registration fee is ₦5,000. This fee is fully refundable if your application is not approved. It covers account setup, verification, and access to our agent network.
                                </div>
                            </div>
                        </div>

                        <div class="card">
                            <div class="card-header" id="faq4">
                                <h5 class="mb-0">
                                    <button class="btn btn-link collapsed" type="button" data-toggle="collapse" data-target="#collapse4">
                                        How are properties verified?
                                    </button>
                                </h5>
                            </div>
                            <div id="collapse4" class="collapse" data-parent="#faqAccordion">
                                <div class="card-body">
                                    Our team manually reviews each property listing to ensure accuracy and authenticity. We verify ownership documents, property details, and images before publishing.
                                </div>
                            </div>
                        </div>

                        <div class="card">
                            <div class="card-header" id="faq5">
                                <h5 class="mb-0">
                                    <button class="btn btn-link collapsed" type="button" data-toggle="collapse" data-target="#collapse5">
                                        Can I be both a realtor and an agent?
                                    </button>
                                </h5>
                            </div>
                            <div id="collapse5" class="collapse" data-parent="#faqAccordion">
                                <div class="card-body">
                                    Yes! You can have both accounts, but they must be separate. You can list your own properties as a realtor and also promote other properties as an agent to earn additional commissions.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section>
    <div class="w-100 pt-120 pb-120 dark-layer2 opc9 position-relative">
        <div class="fixed-bg" style="background-image: url(/assets/images/cta-bg.jpg);"></div>
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8 offset-lg-2 text-center text-white">
                    <h2 class="mb-4">Ready to Get Started?</h2>
                    <p class="lead mb-5">Join thousands of Nigerians finding their dream properties and earning commissions daily.</p>
                    <div class="cta-buttons">
                        <a href="/register" class="thm-btn mr-3">List a Property</a>
                        <a href="/agent/register" class="thm-btn brd-btn">Become an Agent</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.role-tabs .nav-pills .nav-link {
    padding: 15px 30px;
    margin: 0 5px;
    border-radius: 50px;
    color: #333;
    background: #f8f9fa;
    font-weight: 600;
}

.role-tabs .nav-pills .nav-link i {
    margin-right: 10px;
}

.role-tabs .nav-pills .nav-link.active {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.how-work-box {
    padding: 30px;
    background: white;
    border-radius: 10px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    transition: all 0.3s ease;
    margin-bottom: 30px;
}

.how-work-box:hover {
    transform: translateY(-10px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.1);
}

.how-work-box span {
    width: 100px;
    height: 100px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 25px;
}

.how-work-box span img {
    width: 50px;
    height: 50px;
    filter: brightness(0) invert(1);
}

.how-work-inner h3 {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 15px;
}

.feature-card {
    background: white;
    border-radius: 10px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    height: 100%;
}

.benefits-box {
    background: white;
    border-radius: 10px;
    box-shadow: 0 5px 30px rgba(0,0,0,0.1);
}

.commission-card {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 10px;
}

.commission-item h2 {
    font-size: 48px;
    font-weight: bold;
    margin-bottom: 10px;
}

.accordion .card {
    border: none;
    margin-bottom: 15px;
    border-radius: 10px !important;
    box-shadow: 0 3px 10px rgba(0,0,0,0.05);
}

.accordion .card-header {
    background: white;
    border: none;
    padding: 0;
    border-radius: 10px !important;
}

.accordion .btn-link {
    width: 100%;
    text-align: left;
    padding: 20px;
    color: #333;
    font-weight: 600;
    text-decoration: none;
}

.accordion .btn-link:hover {
    text-decoration: none;
}

.accordion .btn-link.collapsed:after {
    content: '\f067';
    font-family: 'Font Awesome 5 Free';
    font-weight: 900;
    float: right;
}

.accordion .btn-link:after {
    content: '\f068';
    font-family: 'Font Awesome 5 Free';
    font-weight: 900;
    float: right;
}

.accordion .card-body {
    padding: 0 20px 20px 20px;
    color: #666;
}

@media (max-width: 768px) {
    .role-tabs .nav-pills .nav-link {
        display: block;
        margin: 10px 0;
    }
    
    .how-work-box {
        margin-bottom: 20px;
    }
}
</style>

