<!DOCTYPE html>
<html lang="en-US">

<head>
    <title>Projects | RevaampAPA - Construction & Development Projects</title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="HandheldFriendly" content="true">
    <meta name="author" content="RevaampAPA" />
    <meta name="description" content="Explore RevaampAPA's featured construction and development projects across Nigeria." />

    <!-- switzer font css -->
    <link rel="stylesheet" href="/fonts/css/switzer.css" type="text/css" media="all">
    <!-- font awesome css -->
    <link rel="stylesheet" href="/fonts/css/font-awesome.min.css" type="text/css" media="all">
    <!-- bootstrap grid css -->
    <link rel="stylesheet" href="/css/plugins/bootstrap-grid.css" type="text/css" media="all">
    <!-- swiper css -->
    <link rel="stylesheet" href="/css/plugins/swiper.min.css" type="text/css" media="all">
    <!-- magnific popup -->
    <link rel="stylesheet" href="/css/plugins/magnific-popup.css" type="text/css" media="all">
    <!-- plax css -->
    <link rel="stylesheet" href="/css/style.css" type="text/css" media="all">
    <!-- custom css -->
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all">

    <!-- Favicon -->
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>

<body>

    <!-- wrapper -->
    <div id="smooth-wrapper" class="mil-wrapper">

        <!-- preloader -->
        <div class="mil-preloader">
            <div class="mil-load"></div>
            <p class="h2 mil-mb-30"><span class="mil-light mil-counter" data-number="100">100</span><span class="mil-light">%</span></p>
        </div>
        <!-- preloader end -->

        <!-- scroll progress -->
        <div class="mil-progress-track">
            <div class="mil-progress"></div>
        </div>
        <!-- scroll progress end -->

        <!-- back to top -->
        <div class="progress-wrap active-progress"></div>

        <!-- top panel -->
        <div class="mil-top-panel">
            <div class="container">
                <a href="/" class="mil-logo">
                    <img src="/img/logo.png" alt="RevaampAPA" width="83" height="32">
                </a>
                <nav class="mil-top-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/properties">Properties</a></li>
                        <li class="mil-active"><a href="/projects">Projects</a></li>
                        <li><a href="/about">About</a></li>
                        <li><a href="/contact">Contact</a></li>
                    </ul>
                </nav>
                <div class="mil-menu-buttons">
                    <% if (typeof user !== 'undefined' && user) { %>
                        <div class="dropdown" style="position: relative;">
                            <a href="#" class="mil-btn mil-sm dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="fa fa-user-circle"></i> <%= user.name %>
                                <i class="fa fa-chevron-down" style="margin-left: 8px; font-size: 12px;"></i>
                            </a>
                            <ul class="dropdown-menu">
                                <li><a href="/dashboard"><i class="fa fa-tachometer"></i> Dashboard</a></li>
                                <li><a href="/dashboard/settings"><i class="fa fa-cog"></i> Settings</a></li>
                                <li><hr></li>
                                <li><a href="/logout"><i class="fa fa-sign-out-alt"></i> Logout</a></li>
                            </ul>
                        </div>
                    <% } else { %>
                        <a href="/login" class="mil-btn mil-sm">Log in</a>
                        <a href="/register" class="mil-btn mil-sm mil-light">Get Started</a>
                    <% } %>
                    <div class="mil-menu-btn">
                        <span></span>
                    </div>
                </div>
            </div>
        </div>
        <!-- top panel end -->

        <!-- content -->
        <div id="smooth-content">

            <!-- banner -->
            <div class="mil-banner mil-banner-inner mil-dissolve">
                <div class="container">
                    <div class="row align-items-center justify-content-center">
                        <div class="col-xl-8">
                            <div class="mil-banner-text mil-text-center">
                                <div class="mil-text-m mil-mb-20 mil-up">Our Portfolio</div>
                                <h1 class="mil-mb-60 mil-up">Featured Projects</h1>
                                <ul class="mil-breadcrumbs mil-center mil-up">
                                    <li><a href="/">Home</a></li>
                                    <li><a href="/projects">Projects</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- banner end -->

            <!-- projects filter -->
            <div class="mil-blog-list mil-p-0-80">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-xl-10">
                            <div class="mil-filter-frame mil-up">
                                <div class="mil-filter-buttons">
                                    <button class="mil-filter-btn mil-active" data-filter="*">All Projects</button>
                                    <button class="mil-filter-btn" data-filter=".residential">Residential</button>
                                    <button class="mil-filter-btn" data-filter=".commercial">Commercial</button>
                                    <button class="mil-filter-btn" data-filter=".infrastructure">Infrastructure</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- projects filter end -->

            <!-- projects grid -->
            <div class="mil-blog-list mil-p-0-80">
                <div class="container">
                    <div class="row mil-grid" id="projectsGrid">
                        <% if (typeof projects !== 'undefined' && projects && projects.length > 0) { %>
                            <% for(var i = 0; i < projects.length; i++) { %>
                                <% var project = projects[i]; %>
                                <div class="col-xl-4 col-md-6 mil-grid-item <%= project.projectType || 'residential' %>">
                                    <div class="mil-price-card mil-up mil-mb-30">
                                        <div class="mil-project-img" style="position: relative; overflow: hidden; border-radius: 15px; margin-bottom: 20px;">
                                            <% if(project.images && project.images.length > 0) { %>
                                                <img src="<%= project.images[0].url %>" alt="<%= project.title %>" style="width: 100%; height: 250px; object-fit: cover; transition: transform 0.3s ease;">
                                            <% } else { %>
                                                <img src="/img/projects/placeholder.jpg" alt="<%= project.title %>" style="width: 100%; height: 250px; object-fit: cover; transition: transform 0.3s ease;">
                                            <% } %>
                                            <div class="mil-project-overlay" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s ease;">
                                                <a href="/projects/<%= project.slug || project._id %>" class="mil-btn mil-sm mil-light">View Details</a>
                                            </div>
                                        </div>
                                        <div class="mil-project-content">
                                            <div class="mil-flex-between mil-mb-15">
                                                <span class="mil-badge" style="background: 
                                                    <% if(project.status === 'completed') { %>#28a745<% } 
                                                    else if(project.status === 'in_progress') { %>#17a2b8<% } 
                                                    else if(project.status === 'planning') { %>#ffc107<% } 
                                                    else { %>#6c757d<% } %>; 
                                                    color: white; padding: 4px 12px; border-radius: 20px; font-size: 12px;">
                                                    <%= project.status ? project.status.replace('_', ' ').toUpperCase() : 'PLANNING' %>
                                                </span>
                                                <span class="mil-text-xs mil-soft"><%= project.completionYear || 'TBD' %></span>
                                            </div>
                                            <h4 class="mil-mb-15"><%= project.title %></h4>
                                            <p class="mil-text-s mil-soft mil-mb-15"><i class="fa fa-map-marker"></i> <%= project.location ? project.location.city + ', ' + project.location.state : 'Location TBD' %></p>
                                            <p class="mil-text-s mil-soft"><%= project.description ? project.description.substring(0, 100) + (project.description.length > 100 ? '...' : '') : 'No description available.' %></p>
                                            <div class="mil-mt-30">
                                                <a href="/projects/<%= project.slug || project._id %>" class="mil-link mil-accent">View Project →</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% } %>
                        <% } else { %>
                            <div class="col-xl-12">
                                <div class="mil-price-card mil-up mil-mb-30 mil-text-center">
                                    <i class="fa fa-folder-open" style="font-size: 60px; opacity: 0.3; margin-bottom: 20px;"></i>
                                    <h4>No Projects Yet</h4>
                                    <p class="mil-text-m mil-soft mil-mb-30">Check back soon for our featured projects.</p>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
            <!-- projects grid end -->

            <!-- call to action -->
            <div class="mil-cta mil-up">
                <div class="container">
                    <div class="mil-out-frame mil-p-80-80" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                        <div class="row justify-content-between align-items-center">
                            <div class="col-xl-8 mil-sm-text-center">
                                <h2 class="mil-light mil-mb-30 mil-up">Have a Project in Mind?</h2>
                                <p class="mil-text-m mil-mb-30 mil-dark-soft mil-up">Let's bring your vision to life. Contact us to discuss your project.</p>
                            </div>
                            <div class="col-xl-4 mil-sm-text-center">
                                <div class="mil-buttons-frame mil-up">
                                    <a href="/contact" class="mil-btn mil-md mil-light">Start Your Project</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- call to action end -->

            <!-- footer -->
            <footer class="mil-p-80-0">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-3">
                            <a href="/" class="mil-footer-logo mil-mb-60">
                                <img src="/img/logo-2.png" alt="RevaampAPA" width="28" height="32">
                            </a>
                        </div>
                        <div class="col-xl-3 mil-mb-60">
                            <h6 class="mil-mb-60">Useful Links</h6>
                            <ul class="mil-footer-list">
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/">Home</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/about">About Us</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/contact">Contact Us</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/properties">Properties</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/projects">Projects</a></li>
                            </ul>
                        </div>
                        <div class="col-xl-3 mil-mb-60">
                            <h6 class="mil-mb-60">For Partners</h6>
                            <ul class="mil-footer-list">
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/business-partner/register">Become a Partner</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/partner/benefits">Partner Benefits</a></li>
                                <li class="mil-text-m mil-soft mil-mb-15"><a href="/partner/resources">Resources</a></li>
                            </ul>
                        </div>
                        <div class="col-xl-3 mil-mb-80">
                            <h6 class="mil-mb-60">Newsletter</h6>
                            <p class="mil-text-xs mil-soft mil-mb-15">Subscribe to get the latest updates</p>
                            <form class="mil-subscripe-form-footer" id="footerNewsletterForm">
                                <input class="mil-input" type="email" placeholder="Email">
                                <button type="submit"><i class="far fa-envelope-open mil-dark"></i></button>
                            </form>
                        </div>
                    </div>
                    <div class="mil-footer-bottom">
                        <div class="row">
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-soft">© 2024 RevaampAPA. All rights reserved.</p>
                            </div>
                            <div class="col-xl-6">
                                <p class="mil-text-s mil-text-right mil-sm-text-left mil-soft">Website Design & Development by <a href="https://shedfactory.co" target="_blank" style="color: #667eea; text-decoration: none;">Shed Factory</a></p>
                            </div>
                        </div>
                    </div>
                </div>
            </footer>
            <!-- footer end -->

        </div>
        <!-- content end -->
    </div>
    <!-- wrapper end -->

    <!-- jquery js -->
    <script src="/js/plugins/jquery.min.js"></script>
    <script src="/js/plugins/swiper.min.js"></script>
    <script src="/js/plugins/gsap.min.js"></script>
    <script src="/js/plugins/ScrollSmoother.min.js"></script>
    <script src="/js/plugins/ScrollTrigger.min.js"></script>
    <script src="/js/plugins/ScrollTo.min.js"></script>
    <script src="/js/plugins/magnific-popup.js"></script>
    <script src="/js/plugins/isotope.pkgd.min.js"></script>
    <script src="/js/main.js"></script>

    <script>
        // Initialize Isotope filter
        $(document).ready(function() {
            var $grid = $('.mil-grid').isotope({
                itemSelector: '.mil-grid-item',
                layoutMode: 'fitRows'
            });

            $('.mil-filter-btn').on('click', function() {
                var filterValue = $(this).attr('data-filter');
                $grid.isotope({ filter: filterValue });
                
                $('.mil-filter-btn').removeClass('mil-active');
                $(this).addClass('mil-active');
            });
        });

        // Newsletter subscription
        function initNewsletter() {
            const newsletterForm = document.getElementById('footerNewsletterForm');
            if (newsletterForm) {
                newsletterForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const email = newsletterForm.querySelector('input[type="email"]').value;
                    try {
                        const response = await fetch('/api/subscribe', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ email })
                        });
                        const data = await response.json();
                        alert(data.success ? 'Successfully subscribed to newsletter!' : 'Error subscribing. Please try again.');
                        if (data.success) newsletterForm.reset();
                    } catch (error) {
                        console.error('Newsletter error:', error);
                        alert('Error subscribing. Please try again.');
                    }
                });
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            initNewsletter();
        });

        // Project image hover effect
        document.querySelectorAll('.mil-project-img').forEach(function(imgContainer) {
            imgContainer.addEventListener('mouseenter', function() {
                var overlay = this.querySelector('.mil-project-overlay');
                var img = this.querySelector('img');
                if (overlay) overlay.style.opacity = '1';
                if (img) img.style.transform = 'scale(1.1)';
            });
            imgContainer.addEventListener('mouseleave', function() {
                var overlay = this.querySelector('.mil-project-overlay');
                var img = this.querySelector('img');
                if (overlay) overlay.style.opacity = '0';
                if (img) img.style.transform = 'scale(1)';
            });
        });
    </script>

    <style>
        .dropdown-menu { display: none; }
        .dropdown:hover .dropdown-menu { display: block; }
        .mil-filter-buttons {
            display: flex;
            justify-content: center;
            gap: 15px;
            flex-wrap: wrap;
            margin-bottom: 40px;
        }
        .mil-filter-btn {
            padding: 8px 24px;
            border: none;
            background: #f0f0f0;
            border-radius: 30px;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .mil-filter-btn:hover,
        .mil-filter-btn.mil-active {
            background: #03A6A6;
            color: white;
        }
        .mil-flex-between {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .mil-mb-15 {
            margin-bottom: 15px;
        }
        .mil-mt-30 {
            margin-top: 30px;
        }
        .mil-project-img {
            cursor: pointer;
        }
        .mil-project-img img {
            transition: transform 0.3s ease;
        }
    </style>
</body>
</html>