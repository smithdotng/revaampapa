<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick-theme.min.css" />

<script>
$(document).ready(function() {
    var $slider = $('#project-slider');
    var slideCount = $slider.find('.feat-item').length;
    
    console.log('Slide count:', slideCount);
    
    // If only one slide, just show it without slider functionality
    if (slideCount <= 1) {
        $slider.css('opacity', '1');
        return;
    }
    
    // Initialize slider
    function initSlider() {
        if ($slider.hasClass('slick-initialized')) {
            $slider.slick('unslick');
        }
        
        $slider.slick({
            dots: true,
            arrows: true,
            infinite: true,
            speed: 500,
            fade: true,
            autoplay: true,
            autoplaySpeed: 5000,
            slidesToShow: 1,
            slidesToScroll: 1,
            prevArrow: '<button type="button" class="slick-prev"><i class="fas fa-chevron-left"></i></button>',
            nextArrow: '<button type="button" class="slick-next"><i class="fas fa-chevron-right"></i></button>'
        });
        
        $slider.slick('slickGoTo', 0, true);
    }
    
    // Check if all images are loaded
    var imagesLoaded = 0;
    var totalImages = slideCount;
    
    $slider.find('.feat-img').each(function() {
        var imgUrl = $(this).css('background-image');
        imgUrl = imgUrl.replace(/^url\(["']?/, '').replace(/["']?\)$/, '');
        
        var img = new Image();
        img.onload = function() {
            imagesLoaded++;
            if (imagesLoaded === totalImages) {
                initSlider();
            }
        };
        img.onerror = function() {
            imagesLoaded++;
            if (imagesLoaded === totalImages) {
                initSlider();
            }
        };
        img.src = imgUrl;
    });
    
    // Fallback initialization
    setTimeout(function() {
        if (!$slider.hasClass('slick-initialized')) {
            initSlider();
        }
    }, 3000);
    
    // Initialize fancybox gallery
    $('[data-fancybox="gallery"]').fancybox({
        loop: true,
        thumbs: {
            autoStart: true
        },
        toolbar: true
    });
    
    // Smooth scroll for anchor links
    $('a[href*="#"]').on('click', function(e) {
        if (this.hash !== '' && $(this.hash).length) {
            e.preventDefault();
            var hash = this.hash;
            $('html, body').animate({
                scrollTop: $(hash).offset().top - 100
            }, 800, function() {
                window.location.hash = hash;
            });
        }
    });
    
    // Highlight active tab on scroll
    $(window).on('scroll', function() {
        var scrollPos = $(window).scrollTop() + 120;
        $('.place-layout-detail-inner2').each(function() {
            var currLink = $(this);
            var refElement = $(currLink.attr('id'));
            if (refElement.length) {
                var refTop = refElement.offset().top;
                if (refTop <= scrollPos && refTop + refElement.height() > scrollPos) {
                    $('.reviewer-review-links a').removeClass('active');
                    $('.reviewer-review-links a[href="#' + currLink.attr('id') + '"]').addClass('active');
                }
            }
        });
    });
    
    $(window).trigger('scroll');
    
    $(window).on('resize', function() {
        if ($slider.hasClass('slick-initialized')) {
            $slider.slick('refresh');
        }
    });
});

// Initialize map if coordinates exist
<% if (project.location.coordinates.lat && project.location.coordinates.lng) { %>
    function initMap() {
        var location = { lat: <%= project.location.coordinates.lat %>, lng: <%= project.location.coordinates.lng %> };
        var map = new google.maps.Map(document.getElementById('listing-loc-map'), {
            zoom: 15,
            center: location,
            styles: [
                {
                    featureType: "all",
                    elementType: "geometry",
                    stylers: [{ color: "#f5f5f5" }]
                },
                {
                    featureType: "water",
                    elementType: "geometry",
                    stylers: [{ color: "#c9c9c9" }]
                }
            ]
        });
        var marker = new google.maps.Marker({
            position: location,
            map: map,
            title: '<%= project.name %>'
        });
    }
<% } else { %>
    function initMap() {
        var location = { lat: 9.0819, lng: 7.4679 };
        var map = new google.maps.Map(document.getElementById('listing-loc-map'), {
            zoom: 12,
            center: location
        });
    }
<% } %>
</script>

<script async defer src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCYc537bQom7ajFpWE5sQaVyz1SQa9_tuY&callback=initMap"></script>

